// leek-strict: false
function simulateFight() { var moves = [] for (var turn = 0; turn < 64; turn++) { push(moves, [randInt(0, 10), randInt(0, 10)]) } return randInt(0, 2) } var winners = [] for (var i = 0; i < 16; i++) { var winner = simulateFight() push(winners, winner) } return count(winners)
