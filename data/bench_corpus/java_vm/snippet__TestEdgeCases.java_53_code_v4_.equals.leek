// leek-version: 4
// leek-strict: false
function minimax2(val, depth, isMax) { if (depth == 0) return val var scores = [] for (var i = -1; i <= 1; i++) push(scores, minimax2(val + i, depth - 1, !isMax)) if (isMax) return arrayMax(scores) else return arrayMin(scores) } return minimax2(0, 3, true) >= -3
