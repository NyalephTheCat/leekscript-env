// leeklang: version=v4
// Inspired by turn logic that merges per-cell weights from nested loops (no game APIs).
var full = [:];
for (var a in [1, 2, 3]) {
    for (var b in [10, 20]) {
        var k = a * 100 + b;
        if (full[k] == null) {
            full[k] = 0;
        }
        full[k] = full[k] + 1;
    }
}
var n = 0;
for (k : v in full) {
    n = n + 1;
}
return n;
