function getBlue(integer|real color) => integer;

/**
 * @brief पैरामीटर के रूप में प्रदान किए गए रंग (लाल, हरा, नीला) के अनुरूप पूर्णांक लौटाता है।
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red 0 और 255 के बीच लाल मान।
 * @param[in] green 0 और 255 के बीच हरा मान।
 * @param[in] blue नीला मान 0 और 255 के बीच।
