/**
 * @brief इकाई निकाय के ब्रीडर का देश लौटाता है।
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (वैकल्पिक) उस इकाई की आईडी जिसके ब्रीडर का देश लौटाया जाएगा।
 * @return country निकाय इकाई के ब्रीडर का देश, या "?" यदि इंगित नहीं किया गया है।
 */
function getFarmerCountry(integer|real entity) => string;
function getFarmerCountry() => string;

/**
 * @brief इकाई निकाय की ब्रीडर आईडी लौटाता है।
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (वैकल्पिक) उस इकाई का आईडी जिसकी ब्रीडर आईडी लौटाई जाएगी।
