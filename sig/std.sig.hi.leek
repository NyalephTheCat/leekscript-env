 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief 0 और 255 के बीच, रंग रंग में हरे रंग की मात्रा लौटाता है। उदाहरण के लिए,…
 *
 * getGreen(@ref COLOR_GREEN) = 255 और getGreen(@ref COLOR_RED) = 0।
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color वह रंग जिसका हरा रेट लौटाया जाएगा।
 * @return green रंग रंग में हरे रंग की दर
 */
function getGreen(integer|real color) => integer;

/**
 * @brief 0 और 255 के बीच, रंग रंग में लाल रंग की मात्रा लौटाता है। उदाहरण के लिए,…
 *
 * getRed(@ref COLOR_RED) = 255 और getRed(@ref COLOR_BLUE) = 0।
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color वह रंग जिसका लाल रेट लौटाया जाएगा।
 * @return red रंग में लाल रंग की दर
 */
function getRed(integer|real color) => integer;

