 *
 * @param[in] message वह संदेश जिसका प्रकार लौटाया जाएगा (@ref MESSAGE_HEAL, @ref MESSAGE_ATTACK, आदि के बीच)।
 * @return type संदेश प्रकार संदेश।
 */
function getMessageType(Array message) => integer;

/**
 * @brief निकाय इकाई संदेश सरणी लौटाता है।
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (वैकल्पिक) वह निकाय जिसके संदेश लौटाए जाएंगे.
 * @return messages आपके संदेशों की तालिका। संदेश स्वयं एक के रूप में प्रस्तुत किया जाता है फ़ॉर्म की
 *     श्रेणी: [लेखक, प्रकार, पैरामीटर] विभिन्न प्रकार के संदेशों को स्थिरांक द्वारा दर्शाया
 *     जाता है: @ref MESSAGE_HEAL: देखभाल के लिए अनुरोध @ref MESSAGE_ATTACK: हमला करने का अनुरोध
 *     @ref MESSAGE_BUFF_FORCE: फोर्स बूस्ट रिक्वेस्ट ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

