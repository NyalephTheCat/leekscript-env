 *
 * @param[in] entity उस इकाई की आईडी जिसे संदेश भेजा जाएगा।
 * @param[in] type भेजने के लिए संदेश का प्रकार (MESSAGE_* स्थिरांक देखें)।
 * @param[in] params संदेश पैरामीटर, जो कोई भी मान हो सकता है।
 * @return sent true यदि प्रेषण सफल रहा, false यदि कोई त्रुटि हुई।
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

