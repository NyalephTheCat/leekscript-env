 * @brief चिप के प्रभाव प्रकार का क्षेत्र लौटाता है।
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip वह चिप जिसका ज़ोन प्रकार लौटाया जाएगा।
 * @return area क्षेत्र_* स्थिरांक के बीच चिप का क्षेत्र प्रकार चिप: @ref AREA_POINT: एकल वर्ग क्षेत्र
 *     @ref AREA_LASER_LINE: लेज़र की रेखा @ref AREA_CIRCLE_1: गोलाकार क्षेत्रफल 3 वर्ग व्यास
 *     @ref AREA_CIRCLE_2: गोलाकार क्षेत्रफल 5 वर्ग व्यास में @ref AREA_CIRCLE_3: गोलाकार क्षेत्रफल 7
 *     वर्ग व्यास में
 */
function getChipArea(integer|real chip) => integer;

/**
 * @brief बाज़ार से लिया गया चिप चिप पुनर्प्राप्ति समय लौटाता है।
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip वह चिप जिसका कोल्डाउन लौटाया जाएगा।
 * @return cooldown चिप कूलडाउन।
 */
function getChipCooldown(integer|real chip) => integer;

/**
 * @brief चिप चिप की TP में लागत लौटाता है।
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip जिस चिप की कीमत चुकानी होगी वह वापस कर दी जाएगी।
 * @return cost चिप की कीमत।
 */
function getChipCost(integer|real chip) => integer;

/**
 * @brief उन सेल की सूची लौटाता है जो प्रभावित होंगे यदि चिप चिप का उपयोग सेल सेल पर से सेल से किया जाता है।
 *
 * @category chip
 * @cost 78 ops
 *
 * @param[in] chip चिप का परीक्षण किया जाना है।
 * @param[in] cell लक्ष्य सेल।
 * @param[in] from (वैकल्पिक) वह सेल जिससे चिप का उपयोग किया जाता है।
 * @return cells प्रभावित होने वाले सभी सेल की आईडी वाली सरणी।
 */
function getChipEffectiveArea(integer|real chip, integer|real cell, integer|real from) => Array<integer>;
function getChipEffectiveArea(integer|real chip, integer|real cell) => Array<integer>;

/**
 * @brief चिप चिप के प्रभाव लौटाता है।
 *
 * @category chip
 * @cost 125 ops
 *
 * @param[in] chip वह चिप जिसका प्रभाव लौटाया जाएगा।
 * @return effects चिप चिप के प्रभाव। @ref getWeaponEffects फ़ंक्शन के समान वापसी मान।
 */
function getChipEffects(integer|real chip) => Array<Array>;

/**
 * @brief चिप चिप की विफलता का प्रतिशत जोखिम लौटाता है।
 *
 * @deprecated यह समारोह बहिष्कृत है।
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip वह चिप जिसका विफलता प्रतिशत लौटाया जाएगा।
 * @return failure चिप चिप विफलता प्रतिशत, 0 और 100 के बीच एक पूर्णांक।
 */
function getChipFailure(integer|real chip) => integer;

/**
 * @brief LAUNCH_TYPE_* स्थिरांकों के बीच, चिप चिप का लॉन्च मोड लौटाता है।
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip चिप की आईडी जिसका फेंकने वाला मोड लौटाया जाएगा।
 * @return launchType चिप चिप का फेंकने का तरीका।
 */
function getChipLaunchType(integer|real chip) => integer;

/**
 * @brief चिप चिप की अधिकतम रेंज लौटाता है।
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip वह चिप जिसकी अधिकतम सीमा लौटाई जाएगी।
 * @return maxRange चिप की अधिकतम सीमा।
 */
function getChipMaxRange(integer|real chip) => integer;

/**
 * @brief चिप चिप की अधिकतम रेंज लौटाता है।
 *
 * @deprecated यह समारोह बहिष्कृत है। इसे @ref getChipMaxRange से बदल दिया गया है।
 * @sa getChipMaxRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip वह चिप जिसकी अधिकतम सीमा लौटाई जाएगी।
 * @return maxScope चिप की अधिकतम सीमा।
 */
function getChipMaxScope(integer|real chip) => integer;

/**
 * @brief (No `func_getChipMaxUses` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip
 * @return maxUses
 */
function getChipMaxUses(integer chip) => integer;

/**
 * @brief चिप चिप की न्यूनतम सीमा लौटाता है।
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip वह चिप जिसकी न्यूनतम सीमा लौटा दी जाएगी।
 * @return minRange चिप की न्यूनतम सीमा।
 */
function getChipMinRange(integer|real chip) => integer;

/**
 * @brief चिप चिप की न्यूनतम सीमा लौटाता है।
 *
 * @deprecated यह समारोह बहिष्कृत है। इसे @ref getChipMinRange से बदल दिया गया है।
 * @sa getChipMinRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip वह चिप जिसकी न्यूनतम सीमा लौटा दी जाएगी।
 * @return minScope चिप की न्यूनतम सीमा।
 */
function getChipMinScope(integer|real chip) => integer;

/**
 * @brief चिप चिप का नाम लौटाता है।
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip वह चिप जिसका नाम लौटाया जाएगा।
 * @return name चिप चिप का नाम।
 */
function getChipName(integer|real chip) => string;

/**
 * @brief निकाय इकाई का वर्तमान चिप कूलडाउन लौटाता है।
 *
 * @category chip
 * @cost 30 ops
 *
 * @param[in] chip वह चिप जिसका वर्तमान कोल्डाउन लौटाया जाएगा।
 * @param[in] entity (वैकल्पिक) वह इकाई जिसका कूलडाउन लौटाया जाएगा।
 * @return cooldown चिप चिप का वर्तमान कोल्डाउन, यह चिप के उपयोग योग्य बनने से पहले घुमावों की संख्या है,
 *     0 यदि यह वर्तमान में उपयोग करने योग्य है।
 */
function getCooldown(integer|real chip, integer|real entity) => integer;
function getCooldown(integer|real chip) => integer;

/**
 * @brief निर्धारित करता है कि कोई मान एक चिप का प्रतिनिधित्व करने वाला एक स्थिरांक है या नहीं।
 *
 * isChip(CHIP_RAGE) = true;
 * isChip(WEAPON_PISTOL) = false।
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] value संख्या निर्धारित की जानी है।
 * @return chip true यदि मान एक चिप स्थिरांक है।
 */
function isChip(integer|real value) => boolean;

/**
 * @brief निर्धारित करता है कि चिप का उपयोग केवल ऑनलाइन किया जा सकता है या नहीं।
 *
 * @deprecated यह समारोह बहिष्कृत है। इसे @ref getChipLaunchType से बदल दिया गया है।
 * @sa getChipLaunchType
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip परीक्षण की जाने वाली चिप की आईडी।
 * @return isInline सही यदि चिप केवल-ऑनलाइन है, अन्यथा गलत।
 */
function isInlineChip(integer|real chip) => boolean;

/**
 * @brief सेल सेल पर आईडी इकाई के साथ एक मृत इकाई को पुनर्जीवित करने के लिए CHIP_RESURRECTION चिप का उपयोग करता है।
 *
 * @category chip
 * @cost 500 ops
 *
 * @param[in] entity पुनर्जीवित करने के लिए इकाई की आईडी।
 * @param[in] cell वह सेल जिस पर इकाई प्रतिक्रिया देगी।
 * @return result स्थिरांक USE_* के बीच चिप को लॉन्च करने का परिणाम।
 */
function resurrect(integer|real entity, integer|real cell) => integer;

/**
 * @brief IA के लिए फ़ंक्शन ai वाले सेल सेल पर चिप चिप द्वारा निर्धारित इकाई को आमंत्रित करता है।
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip तलब करने के लिए इस्तेमाल की जाने वाली चिप। चिप एक समन प्रकार की चिप होनी चाहिए और उस
 *     इकाई से सुसज्जित होनी चाहिए जो समन फ़ंक्शन का उपयोग करती है।
 * @param[in] cell सेल या सम्मन प्रकट होना चाहिए।
 * @param[in] ai मंगलाचरण एआई, एक समारोह के रूप में।
 * @param[in] name (वैकल्पिक)
 * @return return सम्मन फ़ंक्शन में @ref useChip फ़ंक्शन के समान रिटर्न होता है।
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief इकाई निकाय पर चिप चिप का उपयोग करें।
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip उपयोग करने के लिए चिप।
 * @param[in] entity (वैकल्पिक) लक्ष्य निकाय।
 * @return result UseChip के वापसी मूल्य हैं: @ref USE_CRITICAL, गंभीर हिट पर @ref USE_SUCCESS, सफल होने पर
 *     @ref USE_FAILED, विफल होने पर @ref USE_INVALID_TARGET, यदि लक्ष्य मौजूद नहीं है
 *     @ref USE_NOT_ENOUGH_TP, यदि आपकी इकाई के पास पर्याप्त TP नहीं है @ref USE_INVALID_COOLDOWN,
 *     यदि चिप अभी तक प्रयोग करने योग्य नहीं है @ref USE_INVALID_POSITION, यदि सीमा खराब है या
 *     दृष्टि रेखा स्पष्ट नहीं है
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief सेल सेल पर चिप चिप का प्रयोग करें।
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip उपयोग करने के लिए चिप।
 * @param[in] cell लक्ष्य कोशिका।
 * @return result यदि हमला शुरू किया गया था तो 0 से अधिक मान।
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief आईडी सेल वाले सेल की सामग्री लौटाता है।
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell सेल की आईडी जिसकी सामग्री लौटाई जाएगी।
 * @return content सेल सेल की सामग्री: एक खाली सेल के लिए @ref CELL_EMPTY, एक इकाई के लिए @ref CELL_ENTITY, एक
 *     बाधा के लिए @ref CELL_OBSTACLE।
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief दो सेल सेल1 और सेल2 के बीच की दूरी लौटाता है।
 *
 * लौटाई गई दूरी कोशिकाओं की संख्या में व्यक्त की जाती है, और दो कोशिकाओं के बीच विभिन्न
 * बाधाओं को ध्यान में नहीं रखा जाता है।
 * कौए के उड़ते समय दूरी पाने के लिए, @ref getDistance देखें और बाधाओं से बचने वाली दो कोशिकाओं
 * के बीच पथ की दूरी पाने के लिए, @ref getPathLength देखें।
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 प्रारंभिक सेल की आईडी।
 * @param[in] cell2 आगमन सेल की आईडी।
 * @return distance दो सेल सेल1 और सेल2 के बीच की दूरी।
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief स्थिति (x, y) पर सेल की आईडी लौटाता है।
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x सेल की एक्स-स्थिति।
 * @param[in] y सेल की वाई-स्थिति।
 * @return cell स्थिति में सेल आईडी (x, y), शून्य यदि सेल मौजूद नहीं है।
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief सेल सेल के X में स्थिति निर्धारित करता है।
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell वह सेल जिसकी X में स्थिति निर्धारित की जाएगी।
 * @return x सेल की एक्स स्थिति।
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief सेल सेल की Y स्थिति निर्धारित करता है।
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell वह सेल जिसकी Y में स्थिति निर्धारित की जाएगी।
 * @return y सेल की Y स्थिति।
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief दूरी की गणना करता है क्योंकि कौआ दो कोशिकाओं सेल1 और सेल2 के बीच उड़ता है।
 *
 * कोशिकाओं की संख्या में दूरी प्राप्त करने के लिए, @ref getCellDistance देखें, और विभिन्न बाधाओं
 * से बचते हुए दो कक्षों के बीच पथ की लंबाई प्राप्त करने के लिए, @ref getPathLength देखें।
 *
 * @deprecated यह समारोह बहिष्कृत है। इसे @ref getCellDistance से बदल दिया गया है।
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 प्रारंभिक सेल।
 * @param[in] cell2 आगमन प्रकोष्ठ।
 * @return distance दो कोठरियों के बीच कौआ जितनी दूरी से उड़ता है।
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief वह इकाई लौटाता है जो सेल सेल पर है।
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell वह सेल जिसकी इकाई को हम पुनः प्राप्त करना चाहते हैं।
 * @return entity सेल पर इकाई की आईडी, या -1 अगर सेल में कोई इकाई नहीं है।
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief वह इकाई लौटाता है जो सेल सेल पर है।
 *
 * @deprecated यह समारोह बहिष्कृत है। इसे @ref getEntityOnCell से बदल दिया गया है।
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell वह सेल जिसकी इकाई को हम पुनः प्राप्त करना चाहते हैं।
 * @return entity सेल पर इकाई की आईडी, या -1 अगर सेल में कोई इकाई नहीं है।
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief स्थिरांक @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER और @ref MAP_BEACH के…
 *
 * बीच उस प्रकार के इलाके को लौटाता है, जिस पर लड़ाई होती है (कारखाना, रेगिस्तान, जंगल आदि)।
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType भूभाग का प्रकार।
 */
function getMapType() => integer;

/**
 * @brief इलाके में बाधा स्थानों की सूची लौटाता है।
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles बाधा सेल आईडी वाली सरणी।
 */
function getObstacles() => Array<integer>;

/**
 * @brief दो सेल सेल1 और सेल2 के बीच बाधाओं से बचने का रास्ता लौटाता है, अगर यह मौजूद है, तो सरणी…
 *
 * अनदेखा किया गया में मौजूद सेल को अनदेखा कर देता है। अगर कोई खिलाड़ी उपेक्षित सेल पर है, तो
 * पथ उनके ऊपर से गुजर सकता है।
 * प्रारंभिक सेल cell1 कभी भी परिणामी पथ का हिस्सा नहीं होता है। सेल सेल2 परिणामी पथ का
 * हिस्सा है अगर और केवल अगर यह खाली है या अनदेखा किया गया द्वारा अनदेखा किया गया है।
 * यदि दो सेल के बीच कोई पथ मौजूद नहीं है, तो getPath रिटर्न null देता है।
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start प्रारंभिक सेल।
 * @param[in] end आगमन प्रकोष्ठ।
 * @param[in] ignoredCells (वैकल्पिक) अनदेखा करने के लिए सेल की सरणी।
 * @return path कोशिकाओं से युक्त सरणी दो कोशिकाओं के बीच पथ बनाती है।
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
