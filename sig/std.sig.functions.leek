// leeklang: version=v4 experimental-templates=true experimental-fn-optional-params=true

// --- Functions ---
// === math ===
/**
 * @brief Absolute value of a number.
 * @param[in] a The number to get the absolute value of.
 * @return The absolute value of the number.
 * @cost 2 ops
 */
function abs(integer|real a) => integer|real;

/**
 * @brief Computes the arc cosine of a number.
 * @param[in] a The number to compute the arc cosine of.
 * @return The arc cosine of the number.
 * @cost 12 ops
 */
function acos(integer|real a) => real;

/**
 * @brief Computes the arc sine of a number.
 * @param[in] a The number to compute the arc sine of.
 * @return The arc sine of the number.
 * @cost 12 ops
 */
function asin(integer|real a) => real;

/**
 * @brief Computes the arc tangent of argument, in the interval [0, PI].
 * @param[in] a The number to compute the arc tangent of.
 * @return The arc tangent of the number.
 * @cost 25 ops
 */
function atan(integer|real a) => real;

/**
 * @brief Converts Cartesian coordinates to polar coordinates, returning the angle between -PI and PI using the signs of the arguments.
 * @param[in] a The x-coordinate.
 * @param[in] b The y-coordinate.
 * @return The angle between -PI and PI, using the signs of the arguments.
 * @cost 35 ops
 */
function atan2(integer|real a, integer|real b) => real;

/**
 * @brief Returns a string containing the number in binary (base 2) notation.
 * @param[in] a The number to convert to binary.
 * @return A string containing the number in binary (base 2) notation.
 * @cost 10 ops
 */
function binary(integer a) => string;

/**
 * @brief Returns the number of bits at 1 in the number.
 * @param[in] a The number to count the bits at 1 of.
 * @return The number of bits at 1 in the number.
 * @cost 1 op
 */
function bitCount(integer a) => integer;

/**
 * @brief Reverses all the bits in the number from left to right.
 * @param[in] a The number to reverse the bits of.
 * @return The number with all the bits reversed from left to right.
 * @cost 1 op
 */
function bitReverse(integer a) => integer;

/**
 * @brief Converts the bits of an integer to a floating-point number.
 * @param[in] a The integer to convert to a floating-point number.
 * @return The floating-point number corresponding to the bits of the integer.
 * @cost 1 op
 */
function bitsToReal(integer a) => real;

/**
 * @brief Reverses the byte (8 bits) order in the number.
 * @param[in] a The number to reverse the byte order of.
 * @return The number with the byte order reversed.
 * @cost 1 op
 */
function byteReverse(integer a) => integer;

/**
 * @brief Computes the cube root of a number.
 * @param[in] a The number to compute the cube root of.
 * @return The cube root of the number.
 * @cost 62 ops
 */
function cbrt(integer|real a) => real;

/**
 * @brief Rounds up a number to the nearest integer.
 * @param[in] a The number to round up to the nearest integer.
 * @return The nearest integer to the number.
 * @cost 2 ops
 *
 * @see floor
 * @see round
 */
function ceil(integer|real a) => integer;

/**
 * @brief Calculates the cosine of an angle.
 * @param[in] a The angle to calculate the cosine of.
 * @return The cosine of the angle.
 * @cost 30 ops
 */
function cos(integer|real a) => real;

/**
 * @brief Raises Euler's number to the number's power.
 * @param[in] a The number to raise Euler's number to the power of.
 * @return Euler's number raised to the number's power.
 * @cost 40 ops
 */
function exp(integer|real a) => real;

/**
 * @brief Rounds a number down to the nearest integer.
 * @param[in] a The number to round down to the nearest integer.
 * @return The nearest integer to the number.
 * @cost 2 ops
 *
 * @see ceil
 * @see round
 */
function floor(integer|real a) => integer;

/**
 * @brief Returns a character string containing the hexadecimal representation of the number.
 * @param[in] a The number to convert to a hexadecimal string.
 * @return A character string containing the hexadecimal representation of the number.
 * @cost 10 ops
 */
function hexString(integer a) => string;

/**
 * @brief Returns the hypotenuse of the right triangle with legs of length a and b.
 * @param[in] a The length of the first leg of the right triangle.
 * @param[in] b The length of the second leg of the right triangle.
 * @return The hypotenuse of the right triangle with legs of length a and b.
 * @cost 187 ops
 *
 * @note This function is equivalent to `sqrt(a**2 + b**2)`.
 */
function hypot(integer|real a, integer|real b) => real;

/**
 * @brief Returns true if the number is finite, false otherwise.
 * @param[in] a The number to check if it is finite.
 * @return True if the number is finite, false otherwise.
 * @cost 1 op
 */
function isFinite(real a) => boolean;

/**
 * @brief Returns true if the number is infinite, false otherwise.
 * @param[in] a The number to check if it is infinite.
 * @return True if the number is infinite, false otherwise.
 * @cost 1 op
 */
function isInfinite(real a) => boolean;

/**
 * @brief Returns true if the number is NaN, false otherwise.
 * @param[in] a The number to check if it is NaN.
 * @return True if the number is NaN, false otherwise.
 * @cost 1 op
 */
function isNaN(real a) => boolean;

/**
 * @brief Returns true if a and b are digit permutations of each other in base 10, false otherwise.
 * @param[in] a The first number.
 * @param[in] b The second number.
 * @return True if a and b are digit permutations of each other in base 10, false otherwise.
 * @cost 50 ops
 */
function isPermutation(integer a, integer b) => boolean;

/**
 * @brief Returns the number of bits at 0 at the beginning of the number.
 * @param[in] a The number to count the bits at 0 at the beginning of.
 * @return The number of bits at 0 at the beginning of the number.
 * @cost 1 op
 */
function leadingZeros(integer a) => integer;

/**
 * @brief Calculates the natural logarithm of a number.
 * @param[in] a The number to calculate the natural logarithm of.
 * @return The natural logarithm of the number.
 * @cost 39 ops
 */
function log(integer|real a) => real;

/**
 * @brief Calculates the base-10 logarithm of a number.
 * @param[in] a The number to calculate the base-10 logarithm of.
 * @return The base-10 logarithm of the number.
 * @cost 23 ops
 */
function log10(integer|real a) => real;

/**
 * @brief Calculates the base-2 logarithm of a number.
 * @param[in] a The number in the range of ]0;+inf[ to calculate the base-2 logarithm of.
 * @return The base-2 logarithm of the number.
 * @cost 1 op
 */
function log2(integer|real a) => real;

/**
 * @brief Returns the maximum of two numbers.
 * @param[in] a The first number to compare.
 * @param[in] b The second number to compare.
 * @return The maximum of the two numbers.
 * @cost 2 ops
 */
function max(integer|real a, integer|real b) => integer|real;

/**
 * @brief Returns the minimum of two numbers.
 * @param[in] a The first number to compare.
 * @param[in] b The second number to compare.
 * @return The minimum of the two numbers.
 * @cost 2 ops
 */
function min(integer|real a, integer|real b) => integer|real;

/**
 * @brief Converts a value to a number. If the value is a string, it is converted to a number. If the value is a number, it is returned as is.
 * @param[in] a The value to convert to a number.
 * @return The number corresponding to the value.
 * @cost 20 ops
 */
function number(string|integer|real a) => integer|real;

/**
 * @brief Raises the number base to the exponent power.
 * @param[in] base The base to raise to the exponent power.
 * @param[in] exponent The exponent to raise the base to.
 * @return The base raised to the exponent power.
 * @cost 140 ops
 */
function pow(integer|real base, integer|real exponent) => integer|real;

/**
 * @brief Returns a random real number uniformly distributed in the half-open interval [0, 1).
 * @return A random real number in [0, 1).
 * @cost 30 ops
 */
function rand() => real;

/**
 * @brief Returns a random real number in the half-open interval [a, b).
 * @param[in] a The minimum value (inclusive).
 * @param[in] b The maximum value (exclusive).
 * @return A random real number in [a, b).
 * @cost 30 ops
 *
 * @deprecated Use `randReal(a, b)` instead.
 */
function randFloat(real a, real b) => real;

/**
 * @brief Returns a random integer in the half-open interval [a, b).
 * @param[in] a The minimum value (inclusive).
 * @param[in] b The maximum value (exclusive).
 * @return A random integer in [a, b).
 * @cost 30 ops
 */
function randInt(integer a, integer b) => integer;

/**
 * @brief Returns a random real number in the half-open interval [a, b).
 * @param[in] a The minimum value (inclusive).
 * @param[in] b The maximum value (exclusive).
 * @return A random real number in [a, b).
 * @cost 30 ops
 */
function randReal(real a, real b) => real;

/**
 * @brief Returns the raw bits of the number in an integer.
 * @param[in] a The number to get the raw bits of.
 * @return The raw bits of the number in an integer.
 * @cost 1 op
 */
function rawBits(real a) => integer;

/**
 * @brief Returns a new number with the bits of a shifted to the left by b (resets the bits from the right).
 * @param[in] a The number to shift the bits of.
 * @param[in] b The number of bits to shift the bits of.
 * @return A new number with the bits of a shifted to the left by b (resets the bits from the right).
 * @cost 1 op
 */
function rotateLeft(integer a, integer b) => integer;

/**
 * @brief Returns a new number with the bits of a shifted to the right by b (resets the bits from the left).
 * @param[in] a The number to shift the bits of.
 * @param[in] b The number of bits to shift the bits of.
 * @return A new number with the bits of a shifted to the right by b (resets the bits from the left).
 * @cost 1 op
 */
function rotateRight(integer a, integer b) => integer;

/**
 * @brief Rounds a number to the nearest integer.
 * @param[in] a The number to round to the nearest integer.
 * @return The nearest integer to the number.
 * @cost 2 ops
 *
 * @see ceil
 * @see floor
 */
function round(real a) => integer;

/**
 * @brief Returns the sign of the number.
 * @param[in] a The number to get the sign of.
 * @return 1 if the number is positive, 0 if the number is zero, -1 if the number is negative.
 * @cost 2 ops
 */
function sign(integer|real a) => integer;

/**
 * @brief Returns the sine of an angle.
 * @param[in] a The angle to calculate the sine of.
 * @return The sine of the angle.
 * @cost 30 ops
 */
function sin(integer|real a) => real;

/**
 * @brief Returns the square root of a number.
 * @param[in] a The number to calculate the square root of.
 * @return The square root of the number.
 * @cost 8 ops
 */
function sqrt(integer|real a) => real;

/**
 * @brief Returns the tangent of an angle in radians.
 * @param[in] a The angle in radians to calculate the tangent of.
 * @return The tangent of the angle.
 * @cost 30 ops
 */
function tan(integer|real a) => real;

/**
 * @brief Converts an angle from radians to degrees.
 * @param[in] a The angle in radians to convert to degrees.
 * @return The angle in degrees.
 * @cost 1 op
 */
function toDegrees(real a) => real;

/**
 * @brief Converts an angle from degrees to radians.
 * @param[in] a The angle in degrees to convert to radians.
 * @return The angle in radians.
 * @cost 31 ops
 */
function toRadians(real a) => real;

/**
 * @brief Returns the number of bits to 0 at the end of the number.
 * @param[in] a The number to count the bits to 0 at the end of.
 * @return The number of bits to 0 at the end of the number.
 * @cost 1 op
 */
function trailingZeros(integer a) => integer;

/**
 * @brief Returns the character at index i in the string.
 * @param[in] str The string.
 * @param[in] i The index.
 * @return The character at index i.
 * @cost 8 ops
 */
function charAt(string str, integer i) => string;

/**
 * @brief Returns the Unicode code point of the character at index i.
 * @param[in] str The string.
 * @param[in] i The index.
 * @return The Unicode code point at index i.
 * @cost 5 ops
 */
function codePointAt(string str, integer i) => integer;

/**
 * @brief Returns true if search is found in str, false otherwise.
 * @param[in] str The string to search in.
 * @param[in] search The string to search for.
 * @return True if search is found in str, false otherwise.
 * @cost O(n)
 */
function contains(string str, string search) => boolean;

/**
 * @brief Returns true if str ends with suffix, false otherwise.
 * @param[in] str The string to check if it ends with suffix.
 * @param[in] suffix The string to check if it ends with.
 * @return True if str ends with suffix, false otherwise.
 * @cost O(n)
 */
function endsWith(string str, string suffix) => boolean;

/**
 * @brief Returns the index of the first occurrence of search in str, -1 if not found.
 * @param[in] str The string to search in.
 * @param[in] search The string to search for.
 * @return The index of the first occurrence of search in str, -1 if not found.
 * @cost O(n)
 */
function indexOf(string str, string search) => integer;

/**
 * @brief Returns the length of the string.
 * @param[in] str The string to get the length of.
 * @return The length of the string.
 * @cost 15 ops
 */
function length(string str) => integer;

/**
 * @brief Replaces all occurrences of oldChar with newChar in str.
 * @param[in] str The string to replace characters in.
 * @param[in] oldChar The character or substring to replace.
 * @param[in] newChar The replacement character or substring.
 * @return The string with all occurrences of oldChar replaced by newChar.
 * @cost O(n)
 */
function replace(string str, string oldChar, string newChar) => string;

/**
 * @brief Splits str into an array of strings, using the separator.
 * @param[in] str The string to split.
 * @param[in] sep The separator to split the string by.
 * @return An array of strings, split by the separator.
 * @cost O(n)
 */
function split(string str, string sep) => Array<string>;

/**
 * @brief Returns true if str starts with prefix, false otherwise.
 * @param[in] str The string to check if it starts with prefix.
 * @param[in] prefix The string to check if it starts with.
 * @return True if str starts with prefix, false otherwise.
 * @cost O(n)
 */
function startsWith(string str, string prefix) => boolean;

/**
 * @brief Converts value to a string.
 *
 * - If the value is null, returns "null".
 * - If the value is a boolean, "true" and "false" are returned accordingly.
 * - If the value is already a string, it is returned as is.
 * - If the value is a number x, the string representation of x is returned.
 * - If the value is an array, a string of the form "[value1, value2, ...]" is returned.
 * - If the value is an object, a string of the form "{key1: value1, key2: value2, ...}" is returned.
 * - If the value is a function, returns "#AnonymousFunction", "Function" or similar accordingly.
 * - If the value is an instance of a class, returns the result of `.string()`, or "ClassName { field1: value1, field2: value2, ... }" accordingly.
 *
 * @param[in] value The value to convert to a string.
 * @return The string representation of the value.
 * @cost 8 ops
 */
function string(any value) => string;

/**
 * @brief Returns the substring of str from the character at the index start and of size length.
 * @param[in] str The string to get the substring of.
 * @param[in] start The start index of the substring.
 * @param[in] length The length of the substring.
 * @return The substring of str from the character at the index start and of size length.
 * @cost O(n)
 */
function substring(string str, integer start, integer length) => string;

/**
 * @brief Returns the substring of str from start through the end of the string.
 * @param[in] str The string.
 * @param[in] start The start index.
 * @return The substring from start to the end.
 * @cost O(n)
 */
function subString(string str, integer start) => string;

/**
 * @brief Converts the string to lowercase.
 * @param[in] str The string to convert.
 * @return The string in lowercase.
 * @cost O(n)
 */
function toLowerCase(string str) => string;

/**
 * @brief Converts the string to uppercase.
 * @param[in] str The string to convert.
 * @return The string in uppercase.
 * @cost O(n)
 */
function toUpperCase(string str) => string;

/**
 * @brief Splits the array into sub-arrays of at most chunkSize elements.
 * @param[in] array The array to split.
 * @param[in] chunkSize The size of the chunks.
 * @return An array of arrays, split by the chunk size.
 * @cost O(n)
 */
function arrayChunk<T>(Array<T> array, integer chunkSize) => Array<Array<T>>;

/**
 * @brief Returns a new array containing all elements of array1 followed by all elements of array2.
 * @param[in] array1 The first array.
 * @param[in] array2 The second array.
 * @return A new array with the concatenated elements.
 * @cost O(n)
 *
 * @note This function is equivalent to `array1 + array2`.
 */
function arrayConcat<T>(Array<T> array1, Array<T> array2) => Array<T>;

/**
 * @brief Removes all elements from the array.
 * @param[in,out] array The array to clear.
 * @cost 2 ops
 */
function arrayClear<T>(Array<T> array) => void;

/**
 * @brief Returns true if the predicate is true for all elements of the array, false otherwise.
 * @param[in] array The array to check if the predicate is true for all elements.
 * @param[in] predicate The predicate to check if it is true for all elements of the array.
 * @return True if the predicate is true for all elements of the array, false otherwise.
 * @cost O(n)
 */
function arrayEvery<T>(Array<T> array, Function<T => boolean> predicate) => boolean;

/**
 * @brief Returns a new list containing all values of the array that satisfy the predicate.
 * @param[in] array The array to filter.
 * @param[in] predicate The predicate to filter the array.
 * @return A new list containing all values of the array that satisfy the predicate.
 * @cost O(n)
 */
function arrayFilter<T>(Array<T> array, Function<T => boolean> predicate) => Array<T>;

/**
 * @brief Returns a new array containing all the elements of the source array. All elements contained in a sub-array are extracted into the new array.
 * @param[in] array The array to flatten.
 * @param[in] depth (optional) The depth of the flattening.
 * @return A new array containing all the elements of the source array. All elements contained in a sub-array are extracted into the new array.
 * @cost O(n)
 */
function arrayFlatten<T>(Array<T> array, integer depth = 1) => Array<T>;

/**
 * @brief Reduces the list to a single value by applying, from the left, the function to each element and the accumulator.
 * @param[in] array The array to reduce.
 * @param[in] accumulator The accumulator to reduce the array.
 * @param[in] function The function to apply to each element and the accumulator.
 * @return The reduced value.
 * @cost O(n)
 */
function arrayFoldLeft<T, U>(Array<T> array, Function<T, U => U>|Function<T, U, integer => U>|Function<T, U, integer, Array<T> => U> function, U accumulator) => T;

/**
 * @brief Reduces the list to a single value by applying, from the right, the function to each element and the accumulator.
 * @param[in] array The array to reduce.
 * @param[in] accumulator The accumulator to reduce the array.
 * @param[in] function The function to apply to each element and the accumulator.
 * @return The reduced value.
 * @cost O(n)
 */
function arrayFoldRight<T, U>(Array<T> array, Function<T, U => U>|Function<T, U, integer => U>|Function<T, U, integer, Array<T> => U> function, U accumulator) => T;

/**
 * @brief Returns a map from each distinct element to its occurrence count.
 * @param[in] array The array to count.
 * @return A map associating each unique element with its quantity.
 * @cost O(n)
 */
function arrayFrequencies<T>(Array<T> array) => Map<T, integer>;

/**
 * @brief Returns the element of the array at the index i, defaulting to defaultValue if the index is out of bounds.
 * @param[in] array The array to get the element of.
 * @param[in] i The index to get the element of.
 * @param[in] defaultValue The value to return if the index is out of bounds.
 * @return The element of the array at the index i, defaulting to defaultValue if the index is out of bounds.
 * @cost 1 op
 */
function arrayGet<T>(Array<T> array, integer i, T defaultValue) => T;

/**
 * @brief Returns the element at index i, or null if the index is out of bounds.
 * @param[in] array The array.
 * @param[in] i The index.
 * @return The element at i, or null if out of bounds.
 * @cost 1 op
 */
function arrayGetOrElse<T>(Array<T> array, integer i) => T?;

/**
 * @brief Calls callback for each element of the array.
 * @param[in] array The array to iterate over.
 * @param[in] callback The callback to call for each element of the array.
 * @return The array.
 * @cost O(n)
 */
function arrayIter<T>(Array<T> array, Function<T => void>|Function<T, integer => void>|Function<T, integer, Array<T> => void> callback) => Array<T>;

/**
 * @brief Returns a new array containing, for each value of the original array, the result of the callback.
 * @param[in] array The array to map.
 * @param[in] callback The callback to map the array.
 * @return A new array containing, for each value of the original array, the result of the callback.
 * @cost O(n)
 */
function arrayMap<T, U>(Array<T> array, Function<T => U>|Function<T, integer => U>|Function<T, integer, Array<T> => U> callback) => Array<U>;

/**
 * @brief Returns the greatest value in the array.
 * @param[in] array The array to get the greatest value of.
 * @return The greatest value of the array.
 * @cost O(n)
 *
 * @see arrayMin
 * @see sort
 */
function arrayMax<T>(Array<T> array) => T;

/**
 * @brief Returns the smallest value in the array.
 * @param[in] array The array to get the smallest value of.
 * @return The smallest value of the array.
 * @cost O(n)
 *
 * @see arrayMax
 * @see sort
 */
function arrayMin<T>(Array<T> array) => T;

/**
 * @brief Returns a two element array, the first containing the array for which the predicate is true, the second containing the array for which the predicate is false.
 * @param[in] array The array to partition.
 * @param[in] predicate The predicate to partition the array.
 * @return A two element array, the first containing the array for which the predicate is true, the second containing the array for which the predicate is false.
 * @cost O(n)
 */
function arrayPartition<T>(Array<T> array, Function<T => boolean>|Function<T, integer => boolean>|Function<T, integer, Array<T> => boolean> predicate) => Array<Array<T>>;

/**
 * @brief Returns an array of n unique elements randomly chosen from the array.
 * @param[in] array The array to choose the elements from.
 * @param[in] n The number of unique elements to choose.
 * @return An array of n unique elements randomly chosen from the array.
 * @cost O(n)
 */
function arrayRandom<T>(Array<T> array, integer n) => Array<T>;

/**
 * @brief Removes all elements from the array equal to the value.
 * @param[in,out] array The array to remove the elements from.
 * @param[in] value The value to remove from the array.
 * @return The array.
 * @cost O(n)
 */
function arrayRemove<T>(Array<T> array, T value) => Array<T>;

/**
 * @brief Returns a sublist of array containing all elements between start and end, with a step of step.
 * @param[in] array The array to get the sublist of.
 * @param[in] start The start index of the sublist.
 * @param[in] end (optional) The end index of the sublist.
 * @param[in] step (optional) The step of the sublist.
 * @return A sublist of array containing all elements between start and end, with a step of step.
 * @cost O(n)
 */
function arraySlice<T>(Array<T> array, integer start, integer end = count(array), integer step = 1) => Array<T>;

/**
 * @brief Returns true if predicate is true for at least one element of the array, false otherwise.
 * @param[in] array The array to check if the predicate is true for at least one element.
 * @param[in] predicate The predicate to check if it is true for at least one element of the array.
 * @return True if predicate is true for at least one element of the array, false otherwise.
 * @cost O(n)
 */
function arraySome<T>(Array<T> array, Function<T => boolean>|Function<T, integer => boolean>|Function<T, integer, Array<T> => boolean> predicate) => boolean;

/**
 * @brief Sorts the elements of the array according to the comparator.
 * @param[in] array The array to sort.
 * @param[in] comparator (optional) The comparator to sort the array.
 * @return The array.
 * @cost O(n log n)
 */
function arraySort<T>(Array<T> array, Function<T, T => integer>|Function<T, T, integer => integer>|Function<T, T, integer, Array<T> => integer> comparator) => Array<T>;

/**
 * @brief Returns a set containing all unique elements of the array.
 * @param[in] array The array to get the unique elements of.
 * @return A set containing all unique elements of the array.
 * @cost O(n)
 */
function arrayToSet<T>(Array<T> array) => Set<T>;

/**
 * @brief Returns an array containing all the elements of the original array, eliminating duplicates.
 * @param[in] array The array to get the unique elements of.
 * @return An array containing all the elements of the original array, eliminating duplicates.
 * @cost O(n)
 */
function arrayUnique<T>(Array<T> array) => Array<T>;

/**
 * @brief Calculates the average of the elements of the array.
 * @param[in] array The array to calculate the average of.
 * @return The average of the elements of the array.
 * @cost O(n)
 */
function average(Array<integer|real> array) => real;

/**
 * @brief Returns the length of the array.
 * @param[in] array The array to get the length of.
 * @return The length of the array.
 * @cost 1 op
 */
function count(Array<any> array) => integer;

/**
 * @brief Checks whether the element is inside the array.
 * @param[in] array The array to check if the element is inside.
 * @param[in] element The element to check if it is inside the array.
 * @return True if the element is inside the array, false otherwise.
 * @cost O(n)
 *
 * @note This function is equivalent to `element in array`
 */
function inArray<T>(Array<T> array, T element) => boolean;

/**
 * @brief Checks whether the array is empty.
 * @param[in] array The array to check if it is empty.
 * @return True if the array is empty, false otherwise.
 * @cost 2 ops
 *
 * @note This function is equivalent to `count(array) == 0`
 */
function isEmpty(Array<any> array) => boolean;

/**
 * @brief Creates a single string containing all elements of a given array, separated by the separator.
 * @param[in] array The array to join.
 * @param[in] separator The separator to join the elements of the array.
 * @return A single string containing all elements of a given array, separated by the separator.
 * @cost O(n)
 */
function join(Array array, string separator) => string;

/**
 * @brief Removes and returns the last element of the array.
 * @param[in,out] array The array to remove the last element from.
 * @return The last element of the array.
 * @cost 5 ops
 */
function pop<T>(Array<T> array) => T;

/**
 * @brief Removes and returns the element at the index i.
 * @param[in,out] array The array to remove the element from.
 * @param[in] i The index to remove the element from.
 * @return The element at the index i.
 * @cost O(n)
 */
function remove<T>(Array<T> array, integer i) => T;

/**
 * @brief Finds the index of the element in the array, starting at start.
 * @param[in] array The array to find the element in.
 * @param[in] element The element to find in the array.
 * @param[in] start (optional) The index to start the search at.
 * @return The index of the element in the array, -1 if not found.
 * @cost O(n)
 */
function indexOf<T>(Array<T> array, T element, integer start = 0) => integer;

/**
 * @brief Removes the first element of the array and returns it.
 * @param[in,out] array The array to remove the first element from.
 * @return The first element of the array.
 * @cost O(n)
 */
function shift<T>(Array<T> array) => T;

/**
 * @brief Returns a subarray of array, starting at the index start and ending at the index end.
 * @param[in] array The array to get the subarray of.
 * @param[in] start The start index of the subarray.
 * @param[in] end The end index of the subarray.
 * @return A subarray of array, starting at the index start and ending at the index end.
 * @cost O(n)
 */
function subArray<T>(Array<T> array, integer start, integer end) => Array<T>;

/**
 * @brief Returns the sum of all elements within a given array.
 * @param[in] array The array to calculate the sum of.
 * @return The sum of all elements within a given array.
 * @cost O(n)
 */
function sum(Array<integer> array) => integer;
function sum(Array<integer|real> array) => real;

/**
 * @brief Resizes array to a given size and fills it with the value.
 * @param[in,out] array The array to resize.
 * @param[in] value The value to fill the array with.
 * @param[in] size (optional) The new size of the array.
 * @return The array.
 * @cost O(n)
 */
function resize<T>(Array<T> array, T value, integer size = count(array)) => Array<T>;

/**
 * @brief Adds the element to the end of the array.
 * @param[in,out] array The array to add the element to.
 * @param[in] element The element to add to the array.
 * @cost 2 ops
 */
function push<T>(Array<T> array, T element) => Array<T>;

/**
 * @brief Removes the first occurrence of value from the array.
 * @param[in,out] array The array to remove the value from.
 * @param[in] value The value to remove from the array.
 * @return The array.
 * @cost O(n)
 */
function remove<T>(Array<T> array, T value) => Array<T>;

/**
 * @brief Reverses the elements of the array.
 * @param[in,out] array The array to reverse.
 * @return The array.
 * @cost O(n)
 */
function reverse<T>(Array<T> array) => Array<T>;

/**
 * @brief Randomly shuffles the elements of the array in place.
 * @param[in,out] array The array to shuffle.
 * @cost O(n)
 */
function shuffle<T>(Array<T> array) => void;

/**
 * @brief Sorts the array using a built-in ordering of values.
 *
 * Kind order: booleans (false, then true), numbers (ascending), strings (lexicographic), then null.
 * @param[in,out] array The array to sort.
 * @param[in] order (optional) Direction: `SORT_ASC` for ascending, `SORT_DESC` for descending.
 * @return The array.
 * @cost O(n log n)
 */
function sort<T>(Array<T> array, integer order = 0) => Array<T>;

/**
 * @brief Adds the given element at the start of the array.
 * @param[in,out] array The array to add the element to.
 * @param[in] element The element to add to the array.
 * @cost O(n)
 */
function unshift<T>(Array<T> array, T element) => void;

/**
 * @brief Returns the average of all value in the Map, if the table is empty, returns 0.
 * @param[in] map The map to calculate the average of.
 * @return The average of all value in the Map, if the table is empty, returns 0.
 * @cost O(n)
 */
function mapAverage<K>(Map<K, integer|real> map) => real;

/**
 * @brief Returns true if the map contains the given value, false otherwise.
 * @param[in] map The map to check if it contains the value.
 * @param[in] value The value to check if it is in the map.
 * @return True if the map contains the given value, false otherwise.
 * @cost O(n)
 *
 * @note This function is equivalent to `value in map`
 */
function mapContains<K, V>(Map<K, V> map, V value) => boolean;

/**
 * @brief Returns true if the map contains the given key, false otherwise.
 * @param[in] map The map to check if it contains the key.
 * @param[in] key The key to check if it is in the map.
 * @return True if the map contains the given key, false otherwise.
 * @cost 2 ops
 *
 * @note This function is equivalent to `map[key] != null`
 */
function mapContainsKey<K, V>(Map<K, V> map, K key) => boolean;

/**
 * @returns Returns true if the predicate is true for every element in the map, false otherwise.
 * @param[in] map The map to check if the predicate is true for every element.
 * @param[in] predicate The predicate to check if it is true for every element in the map.
 * @return True if the predicate is true for every element in the map, false otherwise.
 * @cost O(n)
 *
 * @note This function is equivalent to `all(map.values(), predicate)`
 */
function mapEvery<K, V>(Map<K, V> map, Function<V => boolean>|Function<V, K => boolean>|Function<V, K, Map<K, V> => boolean> predicate) => boolean;

/**
 * @brief Returns a new map containing all values from the table for which the applied predicate is true.
 * @param[in] map The map to filter.
 * @param[in] predicate The predicate to apply to the values of the map.
 * @return A new map containing all values from the table for which the applied predicate is true.
 * @cost O(n)
 *
 * @note This function is equivalent to `filter(map, predicate)`
 */
function mapFilter<K, V>(Map<K, V> map, Function<V => boolean>|Function<V, K => boolean>|Function<V, K, Map<K, V> => boolean> predicate) => Map<K, V>;

/**
 * @brief Reduces the map to a single value by applying the reducer function to each key-value pair and the accumulator.
 * @param[in] map The map to reduce.
 * @param[in] reducer The reducer function to apply to each key-value pair and the accumulator.
 * @param[in] accumulator The accumulator to reduce the map.
 * @return The reduced value.
 * @cost O(n)
 */
function mapFold<K, V, U>(Map<K, V> map, Function<U, V => U>|Function<U, V, K => U>|Function<U, V, K, Map<K, V> => U> reducer, U accumulator) => U;

/**
 * @brief Returns the value assotiated with the given key, or defaultValue if the key is not found.
 * @param[in] map The map to get the value from.
 * @param[in] key The key to get the value from.
 * @param[in] defaultValue The value to return if the key is not found.
 * @return The value associated with the given key, or defaultValue if the key is not found.
 * @cost 2
 */
function mapGet<K, V>(Map<K, V> map, K key, V defaultValue) => V;

/**
 * @brief Returns true if the map is empty, false otherwise.
 * @param[in] map The map to check if it is empty.
 * @return True if the map is empty, false otherwise.
 * @cost 2 ops
 *
 * @note This function is equivalent to `count(map) == 0`
 */
function mapIsEmpty<K, V>(Map<K, V> map) => boolean;

/**
 * @brief Returns the keys of the map.
 * @param[in] map The map to get the keys from.
 * @return The keys of the map.
 * @cost O(n)
 */
function mapKeys<K, V>(Map<K, V> map) => Array<K>;

/**
 * @brief Returns a new table containing the values returned by the callback function.
 * @param[in] map The map to map.
 * @param[in] callback The callback function to apply to the values of the map.
 * @return A new table containing the values returned by the callback function.
 * @cost O(n)
 */
function mapMap<K, V, U>(Map<K, V> map, Function<V => U>|Function<V, K => U>|Function<V, K, Map<K, V> => U> callback) => Map<K, U>;

/**
 * @brief Returns the maximum value in the map.
 * @param[in] map The map to get the maximum value from.
 * @return The maximum value in the map.
 * @cost O(n)
 */
function mapMax<T, U>(Map<T, U> map) => U?;

/**
 * @brief Returns a table containing all values from the two maps.
 * @param[in] map1 The first map.
 * @param[in] map2 The second map.
 * @return A table containing all values from the two maps.
 * @cost O(n)
 */
function mapMerge<T, U>(Map<T, U> map1, Map<T, U> map2) => Map<T, U>;

/**
 * @brief Returns the minimum value in the map.
 * @param[in] map The map to get the minimum value from.
 * @return The minimum value in the map.
 * @cost O(n)
 */
function mapMin<T, U>(Map<T, U> map) => U?;

/**
 * @brief Adds or replaces the value associated with the given key.
 * @param[in,out] map The map to add or replace the value in.
 * @param[in] key The key to add or replace the value for.
 * @param[in] value The value to add or replace.
 * @return The map.
 * @cost 3 ops
 */
function mapSet<T, U>(Map<T, U> map, T key, U value) => Map<T, U>;

/**
 * @brief Deletes the value associated with the given key.
 * @param[in,out] map The map to delete the value from.
 * @param[in] key The key to delete the value for.
 * @return The value associated with the given key.
 * @cost 2 ops
 */
function mapRemove<T, U>(Map<T, U> map, T key) => U;

/**
 * @brief Replaces the value associated with the given key.
 * @param[in,out] map The map to replace the value in.
 * @param[in] key The key to replace the value for.
 * @param[in] value The value to replace.
 * @return The previous value assotiated with the given key.
 * @cost 3 ops
 */
function mapReplace<T, U>(Map<T, U> map, T key, U value) => U?;

/**
 * @brief Replaces all values from the first map with the values from the second map.
 * @param[in,out] map The map to replace the values in.
 * @param[in] map2 The map to replace the values from.
 * @return The map.
 * @cost O(n)
 */
function mapReplaceAll<T, U>(Map<T, U> map, Map<T, U> map2) => Map<T, U>;

/**
 * @brief Returns the key assotiated with the given value, or null if the value is not found.
 * @param[in] map The map to get the key from.
 * @param[in] value The value to get the key from.
 * @return The key associated with the given value, or null if the value is not found.
 * @cost O(n)
 */
function mapKeyOf<T, U>(Map<T, U> map, U value) => T?;

/**
 * @brief Returns the size of the map.
 * @param[in] map The map to get the size of.
 * @return The size of the map.
 * @cost 1 op
 */
function mapSize<T, U>(Map<T, U> map) => integer;

/**
 * @brief Returns true if the predicate is true for at least one element in the map, false otherwise.
 * @param[in] map The map to check if the predicate is true for at least one element.
 * @param[in] predicate The predicate to check if it is true for at least one element in the map.
 * @return True if the predicate is true for at least one element in the map, false otherwise.
 * @cost O(n)
 *
 * @note This function is equivalent to `any(map.values(), predicate)`
 */
function mapSome<K, V>(Map<K, V> map, Function<V => boolean>|Function<V, K => boolean>|Function<V, K, Map<K, V> => boolean> predicate) => boolean;

/**
 * @brief Returns the sum of all values in the map.
 * @param[in] map The map to get the sum of.
 * @return The sum of all values in the map.
 * @cost O(n)
 */
function mapSum<T>(Map<T, integer> map) => integer;
function mapSum<T>(Map<T, integer|real> map) => real;

/**
 * @brief Returns the an array of all values in the map.
 * @param[in] map The map to get the values from.
 * @return An array of all values in the map.
 * @cost O(n)
 */
function mapValues<T, U>(Map<T, U> map) => Array<U>;

/**
 * @brief Empties the map of all its elements.
 * @param[in,out] map The map to empty.
 * @cost 1 op
 *
 * @note This function is equivalent to `map = [:]`
 */
function mapClear<T, U>(Map<T, U> map) => void;

/**
 * @brief Replaces all values of the map with the given value.
 * @param[in,out] map The map to replace the values in.
 * @param[in] value The value to replace the values with.
 * @cost O(n)
 */
function mapFill<T, U>(Map<T, U> map, U value) => void;

/**
 * @brief Applies the callback function to each key-value pair in the map.
 * @param[in] map The map to apply the callback function to.
 * @param[in] callback The callback function to apply to each key-value pair in the map.
 * @return The map.
 * @cost O(n)
 */
function mapIter<T, U>(Map<T, U> map, Function<U => void>|Function<T, U => void>|Function<T, U, Map<T, U> => void> callback) => void;

/**
 * @brief Adds or replaces all value from the first map with the values from the second map.
 * @param[in,out] map The map to add or replace the values in.
 * @param[in] map2 The map to add or replace the values from.
 * @return The map.
 * @cost O(n)
 */
function mapReplaceAll<T, U>(Map<T, U> map, Map<T, U> map2) => Map<T, U>;

/**
 * @brief Removes all values equal to value in the map table.
 * @param[in,out] map The map to remove the values from.
 * @param[in] value The value to remove from the map.
 * @return The map.
 * @cost O(n)
 */
function mapRemoveAll<T, U>(Map<T, U> map, U value) => Map<T, U>;

/**
 * @brief Returns the given entity's absolute shield.
 * @param[in] entity (optional) The entity to get the absolute shield of.
 * @return The given entity's absolute shield.
 * @cost 15 ops
 */
function getAbsoluteShield(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given's entity agility.
 * @param[in] entity (optional) The entity to get the agility of.
 * @return The given entity's agility.
 * @cost 15 ops
 */
function getAgility(integer entity = getEntity()) => integer;

/**
 * @brief Returns the id of the given entity's ai.
 * @param[in] entity (optional) The entity to get the ai id of.
 * @return The id of the given entity's ai.
 * @cost 15 ops
 */
function getAIId(integer entity = getEntity()) => integer;

/**
 * @brief Returns the name of the given entity's ai.
 * @param[in] entity (optional) The entity to get the ai name of.
 * @return The name of the given entity's ai.
 * @cost 15 ops
 */
function getAIName(integer entity = getEntity()) => string;

/**
 * @brief Returns the turn during which the given entity has appreared.
 * @param[in] entity (optional) The entity to get the birth turn of.
 * @return The turn during which the given entity has appreared.
 * @cost 15 ops
 *
 * @note For a leek, it will always return 1.
 */
function getBirthTurn(integer entity = getEntity()) => integer;

/**
 * @brief Returns the cell where the given entity is located.
 * @param[in] entity (optional) The entity to get the cell of.
 * @return The cell where the given entity is located.
 * @cost 5 ops
 */
function getCell(integer entity = getEntity()) => integer;

/**
 * @brief Lists the given entity's chips.
 * @param[in] entity (optional) The entity to get the chips of.
 * @return An array of the given entity's chips.
 * @cost 40 ops
 *
 * @see getWeapons
 * @note The chips ids and weapon ids do not collide.
 */
function getChips(integer entity = getEntity()) => Array<integer>;

/**
 * @brief Returns the given entity's number of cores.
 * @param[in] entity (optional) The entity to get the number of cores of.
 * @return The given entity's number of cores.
 * @cost 15 ops
 */
function getCores(integer entity = getEntity()) => integer;

/**
 * @brief Returns the entity's damage return ratio, in percentage.
 * @param[in] entity (optional) The entity to get the damage return ratio of.
 * @return The entity's damage return ratio, in percentage.
 * @cost 15 ops
 */
function getDamageReturn(integer entity = getEntity()) => integer;

/**
 * @brief Returns the effects currently affecting the given entity.
 * @param[in] entity (optional) The entity to get the effects of.
 * @return An array of the effects currently affecting the given entity.
 * @cost 25 ops
 *
 * @note The effects are given in an array of array. In the inner array, the elements are formatted as such:
 * - Type: The type of the effect, equal to an EFFECT_* constant.
 * - Value: The value of the effect
 * - CasterId: The id of the entity that caused the effect
 * - Turns: The number of turns remaining for the effect
 * - Critical: True if the effect is a critical hit, false otherwise
 * - ItemId: The id of the item that caused the effect, this can be a weapon or a chip.
 * - TargetId: The id of the entity that is affected by the effect.
 * - Modifiers: The modifiers of the effect, equal to bitmask of EFFECT_MODIFIER_* constants.
 *
 * @see EFFECT_* constants
 * @see EFFECT_MODIFIER_* constants
 * @see getWeaponEffects
 * @see getChipEffects
 * @set getWeaponPassiveEffects
 * @see getLaunchedEffects
 */
function getEffects(integer entity = getEntity()) => Array<Array<integer|boolean>>;

/**
 * @brief Returns the id of your entity.
 * @return The id of your entity.
 * @cost 5 ops
 */
function getEntity() => integer;

/**
 * @brief Indicates the position of the entity in the acting order, between 1 and the amount of entities in the game.
 * @param[in] entity (optional) The entity to get the position of.
 * @return The position of the entity in the acting order, between 1 and the amount of entities in the game.
 * @cost 30 ops
 *
 * @note The position is not the same as the entity id and may change whenever an entity is summoned, killed or resurrected.
 */
function getEntityTurnOrder(integer entity = getEntity()) => integer;

/**
 * @brief Returns the country of the given entity's farmer.
 * @param[in] entity (optional) The entity to get the country of.
 * @return The country of the given entity's farmer, ? if not specified
 * @cost 15 ops
 */
function getFarmerCountry(integer entity = getEntity()) => string;

/**
 * @brief Returns the id of the given entity's farmer.
 * @param[in] entity (optional) The entity to get the farmer id of.
 * @return The id of the given entity's farmer.
 * @cost 15 ops
 */
function getFarmerId(integer entity = getEntity()) => integer;

/**
 * @brief Returns the name of the given entity's farmer.
 * @param[in] entity (optional) The entity to get the farmer name of.
 * @return The name of the given entity's farmer.
 * @cost 15 ops
 */
function getFarmerName(integer entity = getEntity()) => string;

/**
 * @brief Returns the given entity's strength.
 * @deprecated Use `getStrength` instead.
 * @param[in] entity (optional) The entity to get the strength of.
 * @return The given entity's strength.
 * @cost 15 ops
 */
function getForce(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's frequency.
 * @param[in] entity (optional) The entity to get the frequency of.
 * @return The given entity's frequency.
 * @cost 15 ops
 */
function getFrequency(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given item's maximum amount of uses.
 * @param[in] item The item to get the maximum amount of uses of.
 * @return The given item's maximum amount of uses.
 * @cost 15 ops
 */
function getItemMaxUses(integer item) => integer;

/**
 * @brief Returns the list of effects launched by the given entity.
 * @param[in] entity (optional) The entity to get the effects launched by.
 * @return An array of the effects launched by the given entity.
 * @cost 25 ops
 *
 * @note The effects are given in an array of array. In the inner array, the elements are formatted as such:
 * - Type: The type of the effect, equal to an EFFECT_* constant.
 * - Value: The value of the effect
 * - CasterId: The id of the entity that caused the effect
 * - Turns: The number of turns remaining for the effect
 * - Critical: True if the effect is a critical hit, false otherwise
 * - ItemId: The id of the item that caused the effect, this can be a weapon or a chip.
 * - TargetId: The id of the entity that is affected by the effect.
 * - Modifiers: The modifiers of the effect, equal to bitmask of EFFECT_MODIFIER_* constants.
 *
 * @see EFFECT_* constants
 * @see EFFECT_MODIFIER_* constants
 * @see getWeaponEffects
 * @see getChipEffects
 * @set getWeaponPassiveEffects
 */
function getLaunchedEffects(integer entity = getEntity()) => Array<Array<integer|boolean>>;

/**
 * @brief Returns your entity's id.
 * @deprecated Use `getEntity` instead.
 * @return Your entity's id.
 * @cost 5 ops
 */
function getLeek() => integer;

/**
 * @brief Returns the given leek's absolute id.
 * @param[in] leek (optional) The leek to get the absolute id of.
 * @return The given leek's absolute id.
 * @cost 15 ops
 */
function getLeekID(integer entity = getEntity()) => integer?;

/**
 * @brief Returns the given entity's level.
 * @param[in] entity (optional) The entity to get the level of.
 * @return The given entity's level.
 * @cost 15 ops
 */
function getLevel(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's life.
 * @param[in] entity (optional) The entity to get the life of.
 * @return The given entity's life.
 * @cost 15 ops
 */
function getLife(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's magic.
 * @param[in] entity (optional) The entity to get the magic of.
 * @return The given entity's magic.
 * @cost 15 ops
 */
function getMagic(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's move points.
 * @param[in] entity (optional) The entity to get the move points of.
 * @return The given entity's move points.
 * @cost 15 ops
 */
function getMP(integer entity = getEntity()) => integer;

/**
 * @brief Returns the mob type of the entity. If the entity is not a mob, it will return -1.
 * @param[in] entity (optional) The entity to get the mob type of.
 * @return The mob type of the entity. If the entity is not a mob, it will return -1.
 * @cost 15 ops
 *
 * @see MOB_* constants
 * @see ENTITY_MOB
 * @see getType
 */
function getMobType(integer entity = getEntity()) => integer;

/**
 * @brief Returns the name of the given entity.
 * @param[in] entity (optional) The entity to get the name of.
 * @return The name of the given entity.
 * @cost 15 ops
 */
function getName(integer entity = getEntity()) => string;

/**
 * @brief Returns the array of passive effects for the given entity.
 * @param[in] entity (optional) The entity to get the passive effects of.
 * @return An array of the passive effects for the given entity.
 * @cost 125 ops
 *
 * @note The passive effects are given in an array of array. In the inner array, the elements are formatted as such:
 * - Type: The type of the passive effect, equal to an EFFECT_* constant.
 * - Value: The value of the passive effect
 * - CasterId: The id of the entity that caused the passive effect
 * - Turns: The number of turns remaining for the passive effect
 * - Critical: True if the passive effect is a critical hit, false otherwise
 * - ItemId: The id of the item that caused the passive effect, this can be a weapon or a chip.
 * - TargetId: The id of the entity that is affected by the passive effect.
 * - Modifiers: The modifiers of the passive effect, equal to bitmask of EFFECT_MODIFIER_* constants.
 *
 * @see EFFECT_* constants
 * @see EFFECT_MODIFIER_* constants
 * @see getWeaponPassiveEffects
 * @see getChipPassiveEffects
 */
function getPassiveEffects(integer entity = getEntity()) => Array<Array<integer|boolean>>;

/**
 * @brief Returns the given entity's power.
 * @param[in] entity (optional) The entity to get the power of.
 * @return The given entity's power.
 * @cost 15 ops
 */
function getPower(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's RAM.
 * @param[in] entity (optional) The entity to get the RAM of.
 * @return The given entity's RAM.
 * @cost 1 op
 */
function getRAM(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's relative shield.
 * @param[in] entity (optional) The entity to get the relative shield of.
 * @return The given entity's relative shield.
 * @cost 15 ops
 */
function getRelativeShield(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's resistance.
 * @param[in] entity (optional) The entity to get the resistance of.
 * @return The given entity's resistance.
 * @cost 15 ops
 */
function getResistance(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's science.
 * @param[in] entity (optional) The entity to get the science of.
 * @return The given entity's science.
 * @cost 15 ops
 */
function getScience(integer entity = getEntity()) => integer;

/**
 * @brief Returns the team number of the entity during the fight.
 * @param[in] entity (optional) The entity to get the team number of.
 * @return The team number of the entity during the fight.
 * @cost 5 ops
 *
 * @see getAllies
 * @see getEnemies
 * @see getTeamID
 */
function getSide(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's states.
 * @param[in] entity (optional) The entity to get the states of.
 * @return A set of the given entity's states that are currently affecting it.
 * @cost 5 ops
 *
 * @see STATE_* constants
 */
function getStates(integer entity = getEntity()) => Set<integer>;

/**
 * @brief Returns the given entity's stat.
 * @param[in] entity (optional) The entity to get the stat of.
 * @param[in] stat The stat to get the value of.
 * @return The given entity's stat value.
 * @cost 15 ops
 *
 * @see STAT_* constants
 */
function getStat(integer entity = getEntity(), integer stat) => integer;

/**
 * @brief Returns the given entity's strength.
 * @param[in] entity (optional) The entity to get the strength of.
 * @return The given entity's strength.
 * @cost 15 ops
 */
function getStrength(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's summoner.
 * @param[in] entity (optional) The entity to get the summoner of.
 * @return The given entity's summoner.
 * @cost 15 ops
 *
 * @note Returns -1 if the entity was not summoned (has no summoner).
 */
function getSummoner(integer entity = getEntity()) => integer?;

/**
 * @brief Returns the given entity's alive summons.
 * @param[in] entity (optional) The entity to get the summons of.
 * @return An array of the given entity's alive summons.
 * @cost 15 ops
 *
 * @see getSummoner
 */
function getSummons(integer entity = getEntity()) => Array<integer>;

/**
 * @brief Returns the given entity's team ID.
 * @param[in] entity (optional) The entity to get the team ID of.
 * @return The given entity's team ID.
 * @cost 15 ops
 *
 * @see getSide
 */
function getTeamID(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's team name.
 * @param[in] entity (optional) The entity to get the team name of.
 * @return The given entity's team name.
 * @cost 15 ops
 *
 * @see getTeamID
 */
function getTeamName(integer entity = getEntity()) => string;

/**
 * @brief Returns the given entity's maximum life.
 * @param[in] entity (optional) The entity to get the maximum life of.
 * @return The given entity's maximum life.
 * @cost 15 ops
 *
 * @see getLife
 */
function getTotalLife(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's total move points.
 * @param[in] entity (optional) The entity to get the total move points of.
 * @return The given entity's total move points.
 * @cost 15 ops
 *
 * @see getMP
 */
function getTotalMP(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's total turn points.
 * @param[in] entity (optional) The entity to get the total turn points of.
 * @return The given entity's total turn points.
 * @cost 15 ops
 *
 * @see getTP
 */
function getTotalTP(integer entity = getEntity()) => integer;

/**
 * @brief Returns the given entity's turn points.
 * @param[in] entity (optional) The entity to get the turn points of.
 * @return The given entity's turn points.
 * @cost 15 ops
 *
 * @see getTotalTP
 */
function getTP(integer entity = getEntity()) => integer;

/**
 * @brief Returns the entity's type.
 * @param[in] entity (optional) The entity to get the type of.
 * @return The entity's type.
 * @cost 15 ops
 *
 * @see ENTITY_* constants
 */
function getType(integer entity = getEntity()) => integer;

/**
 * @brief Returns the currently equipped weapon of the given entity.
 * @param[in] entity (optional) The entity to get the currently equipped weapon of.
 * @return The currently equipped weapon of the given entity.
 * @cost 15 ops
 *
 * @see getWeapons
 */
function getWeapon(integer entity = getEntity()) => integer?;

/**
 * @brief Returns the list of weapons for the given entity.
 * @param[in] entity (optional) The entity to get the weapons of.
 * @return An array of the weapons for the given entity.
 * @cost 50 ops
 *
 * @see getWeapon
 */
function getWeapons(integer entity = getEntity()) => Array<integer>;

/**
 * @brief Returns the given entity's wisdom.
 * @param[in] entity (optional) The entity to get the wisdom of.
 * @return The given entity's wisdom.
 * @cost 15 ops
 */
function getWisdom(integer entity = getEntity()) => integer;

/**
 * @brief Checks whether the given entity is alive.
 * @param[in] entity (optional) The entity to check if it is alive.
 * @return True if the given entity is alive, false otherwise.
 * @cost 15 ops
 *
 * @note This is equivalent to `getLife(entity) > 0`.
 * @see getLife
 */
function isAlive(integer entity = getEntity()) => boolean;

/**
 * @brief Checks whether the given entity is your ally.
 * @param[in] entity (optional) The entity to check if it is your ally.
 * @return True if the given entity is your ally, false otherwise.
 * @cost 15 ops
 *
 * @note This is equivalent to `getSide(entity) == getSide()`.
 * @see getSide
 */
function isAlly(integer entity = getEntity()) => boolean;

/**
 * @brief Checks whether the given entity is dead.
 * @param[in] entity (optional) The entity to check if it is dead.
 * @return True if the given entity is dead, false otherwise.
 * @cost 15 ops
 *
 * @note This is equivalent to `getLife(entity) <= 0`.
 * @see getLife
 */
function isDead(integer entity = getEntity()) => boolean;

/**
 * @brief Checks whether the given entity is static or not.
 * @param[in] entity (optional) The entity to check if it is static.
 * @return True if the given entity is static, false otherwise.
 * @cost 15 ops
 *
 * @note A static entity cannot move or be moved; this is especially the case for turrets.
 *
 * @see getCell
 * @see ENTITY_TURRET
 * @see getType
 */
function isStatic(integer entity = getEntity()) => boolean;

/**
 * @brief Checks whether the given entity is a summoned entity or not.
 * @param[in] entity (optional) The entity to check if it is a summoned entity.
 * @return True if the given entity is a summoned entity, false otherwise.
 * @cost 10 ops
 *
 * @see getSummoner
 */
function isSummon(integer entity = getEntity()) => boolean;

/**
 * @brief Returns an array of messages from say() performed by the previous entities, as [entity_id, message].
 * @return An array of messages from say() performed by the previous entities, as [entity_id, message].
 * @cost 78 ops
 *
 * @see say
 */
function listen() => Array<Array<integer|string>>;

/**
 * @brief Say a message, available to all entities. Costs 1 TP.
 * @param[in] message The message to say.
 * @cost 30 ops
 *
 * @note The length of a message is limited to 100 chars, the remaining characters are discarded.
 * @note To limit chatter overload, a limit of 2 say() per turn is in place.
 * @see listen
 */
function say(string message) => void;

/**
 * @brief Equips the given weapon. Costs 1 TP.
 * @param[in] weapon The weapon to equip.
 * @cost 15 ops
 *
 * @see getWeapon
 * @see getWeapons
 */
function setWeapon(integer weapon) => void;

/**
 * @brief Returns true if your entity can currently shoot the target entity with the weapon.
 *
 * This function checks the following conditions:
 * - Range: The distance between you and the target is within the weapon's range.
 * - Line of sight between the two positions if needed
 *
 * The function does not check if you have sufficient TP or if the weapon is equipped.
 *
 * @param[in] target The target entity to check if it can be shot with the weapon.
 * @return True if your entity can currently shoot the target entity with the weapon, false otherwise.
 * @cost 15 ops
 *
 * @see canUseWeaponOnCell
 * @see canUseChip
 */
function canUseWeapon(integer weapon = getWeapon(), integer target) => boolean;

/**
 * @brief Returns true if your entity can currently shoot the target cell with the weapon.
 *
 * This function checks the following conditions:
 * - Range: The distance between you and the target cell is within the weapon's range.
 * - Line of sight between the two positions if needed
 *
 * The function does not check if you have sufficient TP or if the weapon is equipped.
 *
 * @param[in] target The target cell to check if it can be shot with the weapon.
 * @return True if your entity can currently shoot the target cell with the weapon, false otherwise.
 * @cost 15 ops
 *
 * @see canUseWeapon
 * @see canUseChip
 */
function canUseWeaponOnCell(integer weapon = getWeapon(), integer target) => boolean;

/**
 * @brief Returns the list of all weapons in the game.
 * @return An array of all weapons in the game.
 * @cost 200 ops
 *
 * @see getWeapon
 * @see getWeapons
 */
function getAllWeapons() => Array<integer>;

/**
 * @brief Returns the area of effect shape for the weapon.
 * @param[in] weapon The weapon to get the area of effect shape of.
 * @return The area of effect shape for the weapon.
 * @cost 15 ops
 *
 * @see AREA_* constants
 */
function getWeaponArea(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns the cost of a weapon, in TP.
 * @param[in] weapon The weapon to get the cost of.
 * @return The cost of the weapon, in TP.
 * @cost 15 ops
 *
 * @note This doesn't count the equip cost if it isn't equipped.
 */
function getWeaponCost(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns a list of cells that will be affected by the weapon if used on the given cell from a given cell.
 * @param[in] weapon The weapon to get the affected cells of.
 * @param[in] targetCell The cell to get the affected cells of.
 * @param[in] fromCell The cell to get the affected cells from.
 * @return A list of cells that will be affected by the weapon if used on the given cell from a given cell.
 * @cost 78 ops
 *
 * @see getWeaponArea
 * @see AREA_* constants
 */
function getWeaponEffectiveArea(integer targetCell, integer fromCell) => Array<integer>;
function getWeaponEffectiveArea(integer weapon, integer targetCell, integer fromCell = getCell()) => Array<integer>;

/**
 * @brief Returns the weapon's effects.
 * @param[in] weapon The weapon to get the effects of.
 * @return The weapon's effects.
 * @cost 125 ops
 *
 * @note The effects are given in an array of array. In the inner array, the elements are formatted as such:
 * - Type: The type of the effect, equal to an EFFECT_* constant.
 * - Min: The minimum value of the effect
 * - Max: The maximum value of the effect
 * - Turns: The number of turns remaining for the effect
 * - Targets: A bitmask of EFFECT_TARGET_* constants, representing which entities are affected by the effect.
 * - Modifiers: A bitmask of EFFECT_MODIFIER_* constants, representing the modifiers of the effect.
 *
 * @see getChipEffects
 * @see getWeaponPassiveEffects
 * @see EFFECT_* constants
 * @see EFFECT_MODIFIER_* constants
 * @see EFFECT_TARGET_* constants
 */
function getWeaponEffects(integer weapon = getWeapon()) => Array<Array<integer|boolean>>;

/**
 * @brief Returns the weapons's failure rate.
 * @deprecated Weapons no longer have failure rates.
 * @param[in] weapon The weapon to get the failure rate of.
 * @return The weapon's failure rate.
 * @cost 15 ops
 */
function getWeaponFailureRate(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns the weapon's launch shape.
 * @param[in] weapon The weapon to get the launch shape of.
 * @return The weapon's launch shape.
 * @cost 15 ops
 *
 * @see LAUNCH_TYPE* constants
 */
function getWeaponLaunchType(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns the weapon's max range.
 * @param[in] weapon The weapon to get the max range of.
 * @return The weapon's max range.
 * @cost 15 ops
 */
function getWeaponMaxRange(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns the weapon's max range.
 * @deprecated Use `getWeaponMaxRange` instead.
 * @param[in] weapon The weapon to get the max range of.
 * @return The weapon's max range.
 * @cost 15 ops
 */
function getWeaponMaxScope(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns the weapon's max uses.
 * @param[in] weapon The weapon to get the max uses of.
 * @return The weapon's max uses.
 * @cost 15 ops
 */
function getWeaponMaxUses(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns the weapon's min range.
 * @param[in] weapon The weapon to get the min range of.
 * @return The weapon's min range.
 * @cost 15 ops
 */
function getWeaponMinRange(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns the weapon's min range.
 * @deprecated Use `getWeaponMinRange` instead.
 * @param[in] weapon The weapon to get the min range of.
 * @return The weapon's min range.
 * @cost 15 ops
 */
function getWeaponMinScope(integer weapon = getWeapon()) => integer;

/**
 * @brief Returns a weapon's name.
 * @param[in] weapon The weapon to get the name of.
 * @return The weapon's name.
 * @cost 15 ops
 */
function getWeaponName(integer weapon = getWeapon()) => string;

/**
 * @brief Returns a weapon's passive effects.
 * @param[in] weapon The weapon to get the passive effects of.
 * @return The weapon's passive effects.
 * @cost 125 ops
 *
 * @note The effects are given in an array of array. In the inner array, the elements are formatted as such:
 * - Type: The type of the effect, equal to an EFFECT_* constant.
 * - Min: The minimum value of the effect
 * - Max: The maximum value of the effect
 * - Turns: The number of turns remaining for the effect
 * - Targets: A bitmask of EFFECT_TARGET_* constants, representing which entities are affected by the effect.
 * - Modifiers: A bitmask of EFFECT_MODIFIER_* constants, representing the modifiers of the effect.
 *
 * @see getWeaponEffects
 * @see EFFECT_* constants
 * @see EFFECT_MODIFIER_* constants
 * @see EFFECT_TARGET_* constants
 */
function getWeaponPassiveEffects(integer weapon = getWeapon()) => Array<Array<integer|boolean>>;

/**
 * @brief Returns true if the weapon is only usable in a line of sight.
 * @deprecated Use `getWeaponLaunchType` instead.
 * @param[in] weapon The weapon to check if it is only usable in a line of sight.
 * @return True if the weapon is only usable in a line of sight, false otherwise.
 * @cost 15 ops
 *
 * @see getWeaponLaunchType
 * @see LAUNCH_TYPE* constants
 */
function isInlineWeapon(integer weapon = getWeapon()) => boolean;

/**
 * @brief Returns true if the value is a constant representing a weapon.
 * @param[in] value The value to check if it is a constant representing a weapon.
 * @return True if the value is a constant representing a weapon, false otherwise.
 * @cost 15 ops
 *
 * @see WEAPON_* constants
 */
function isWeapon(any value) => boolean;

/**
 * @brief Uses the selected weapon on the target entity.
 * @param[in] target The target entity to use the weapon on.
 * @return The result of the weapon use.
 * @cost 3000 ops
 *
 * @see canUseWeapon
 * @see useWeaponOnCell
 * @see useChip
 * @see USE_* constants
 */
function useWeapon(integer target) => integer;

/**
 * @brief Uses the selected weapon on the target cell.
 * @param[in] target The target cell to use the weapon on.
 * @return The result of the weapon use.
 * @cost 3000 ops
 *
 * @see canUseWeaponOnCell
 * @see useWeapon
 * @see useChipOnCell
 * @see USE_* constants
 */
function useWeaponOnCell(integer target) => integer;

/**
 * @brief Returns true if the weapon requires line of sight to be used.
 * @param[in] weapon The weapon to check if it requires line of sight to be used.
 * @return True if the weapon requires line of sight to be used, false otherwise.
 * @cost 10 ops
 *
 * @see getWeaponLaunchType
 * @see LAUNCH_TYPE* constants
 */
function weaponNeedLos(integer weapon = getWeapon()) => boolean;

/**
 * @brief Returns true if your entity can use the given chip on the given entity from its current position.
 *
 * This function checks the following conditions:
 * - Range: The distance between you and the target is within the chip's range.
 * - Line of sight between the two positions if needed
 *
 * The function does not check if you have sufficient TP or if the chip is not in recovery.
 *
 * @param[in] target The target entity to check if it can be used with the chip.
 * @return True if your entity can use the given chip on the given entity from its current position, false otherwise.
 * @cost 45 ops
 *
 * @see canUseChip
 * @see canUseChipOnCell
 * @see useChip
 * @see USE_* constants
 */
function canUseChip(integer chip, integer target) => boolean;

/**
 * @brief Returns true if your entity can use the given chip on the given cell from its current position.
 *
 * This function checks the following conditions:
 * - Range: The distance between you and the target is within the chip's range.
 * - Line of sight between the two positions if needed
 *
 * The function does not check if you have sufficient TP or if the chip is not in recovery.
 *
 * @param[in] target The target cell to check if it can be used with the chip.
 * @return True if your entity can use the given chip on the given cell from its current position, false otherwise.
 * @cost 45 ops
 *
 * @see canUseChip
 * @see canUseChipOnCell
 * @see useChipOnCell
 * @see USE_* constants
 */
function canUseChipOnCell(integer chip, integer target) => boolean;

/**
 * @brief Returns true if the given chip requires line of sight to be used.
 * @param[in] chip The chip to check if it requires line of sight to be used.
 * @return True if the given chip requires line of sight to be used, false otherwise.
 * @cost 10 ops
 *
 * @see getChipLaunchType
 * @see LAUNCH_TYPE* constants
 */
function chipNeedLos(integer chip) => boolean;

/**
 * @brief Returns a list of all chips in the game.
 * @return A list of all chips in the game.
 * @cost 200 ops
 *
 * @see getChip
 * @see getChips
 */
function getAllChips() => Array<integer>;

/**
 * @brief Returns the area of effect shape for the chip.
 * @param[in] chip The chip to get the area of effect shape of.
 * @return The area of effect shape for the chip.
 * @cost 15 ops
 *
 * @see AREA_* constants
 */
function getChipArea(integer chip) => integer;

/**
 * @brief Returns the cooldown of a chip, in turns.
 * @param[in] chip The chip to get the cooldown of.
 * @return The cooldown of the chip, in turns.
 * @cost 15 ops
 *
 * @see getChip
 * @see getChips
 */
function getChipCooldown(integer chip) => integer;

/**
 * @brief Returns the cost of a chip, in TP.
 * @param[in] chip The chip to get the cost of.
 * @return The cost of the chip, in TP.
 * @cost 15 ops
 *
 * @see getChip
 * @see getChips
 */
function getChipCost(integer chip) => integer;

/**
 * @brief Returns a list of cells that will be affected by the chip if used on the given cell from a given cell.
 * @param[in] chip The chip to get the effective area of.
 * @param[in] targetCell The cell to get the effective area of.
 * @param[in] fromCell The cell to get the effective area from.
 * @return A list of cells that will be affected by the chip if used on the given cell from a given cell.
 * @cost 78 ops
 *
 * @see getChipArea
 * @see AREA_* constants
 */
function getChipEffectiveArea(integer chip, integer targetCell, integer fromCell = getCell()) => Array<integer>;

/**
 * @brief Returns the chip's effects.
 * @param[in] chip The chip to get the effects of.
 * @return The chip's effects.
 * @cost 125 ops
 *
 * @note The effects are given in an array of array. In the inner array, the elements are formatted as such:
 * - Type: The type of the effect, equal to an EFFECT_* constant.
 * - Min: The minimum value of the effect
 * - Max: The maximum value of the effect
 * - Turns: The number of turns remaining for the effect
 * - Targets: A bitmask of EFFECT_TARGET_* constants, representing which entities are affected by the effect.
 * - Modifiers: A bitmask of EFFECT_MODIFIER_* constants, representing the modifiers of the effect.
 *
 * @see getWeaponEffects
 * @see getWeaponPassiveEffects
 * @see EFFECT_* constants
 * @see EFFECT_MODIFIER_* constants
 * @see EFFECT_TARGET_* constants
 */
function getChipEffects(integer chip) => Array<Array<integer|boolean>>;

/**
 * @brief Returns a chip's failure rate.
 * @deprecated Chips no longer have failure rates.
 * @param[in] chip The chip to get the failure rate of.
 * @return The chip's failure rate.
 * @cost 15 ops
 *
 * @see getChip
 * @see getChips
 */
function getChipFailureRate(integer chip) => integer;

/**
 * @brief Returns the chip's launch shape.
 * @param[in] chip The chip to get the launch shape of.
 * @return The chip's launch shape.
 * @cost 15 ops
 *
 * @see LAUNCH_TYPE* constants
 */
function getChipLaunchType(integer chip) => integer;

/**
 * @brief Returns the chip's max range.
 * @param[in] chip The chip to get the max range of.
 * @return The chip's max range.
 * @cost 15 ops
 *
 * @see getChip
 * @see getChips
 */
function getChipMaxRange(integer chip) => integer;

/**
 * @brief Returns the chip's max range.
 * @deprecated Use `getChipMaxRange` instead.
 * @param[in] chip The chip to get the max range of.
 * @return The chip's max range.
 * @cost 15 ops
 */
function getChipMaxScope(integer chip) => integer;

/**
 * @brief Returns the chip's max uses.
 * @param[in] chip The chip to get the max uses of.
 * @return The chip's max uses.
 * @cost 15 ops
 */
function getChipMaxUses(integer chip) => integer;

/**
 * @brief Returns the chip's min range.
 * @param[in] chip The chip to get the min range of.
 * @return The chip's min range.
 * @cost 15 ops
 */
function getChipMinRange(integer chip) => integer;

/**
 * @brief Returns the chip's min range.
 * @deprecated Use `getChipMinRange` instead.
 * @param[in] chip The chip to get the min range of.
 * @return The chip's min range.
 * @cost 15 ops
 */
function getChipMinScope(integer chip) => integer;

/**
 * @brief Returns a chip's name.
 * @param[in] chip The chip to get the name of.
 * @return The chip's name.
 * @cost 15 ops
 */
function getChipName(integer chip) => string;

/**
 * @brief Returns a chip current cooldown for the given entity.
 * @param[in] entity The entity to get the current cooldown of.
 * @return The chip's current cooldown for the given entity.
 * @cost 30 ops
 *
 * @see getChip
 * @see getChips
 * @see getChipCooldown
 */
function getCooldown(integer chip, integer entity = getEntity()) => integer;

/**
 * @brief Return true if the value represents a chip.
 * @param[in] value The value to check if it represents a chip.
 * @return True if the value represents a chip, false otherwise.
 * @cost 10 ops
 */
function isChip(any value) => boolean;

/**
 * @brief Returns true if the chip is inline.
 * @deprecated Use `getChipLaunchType` instead.
 * @param[in] chip The chip to check if it is inline.
 * @return True if the chip is inline, false otherwise.
 * @cost 10 ops
 *
 * @see getChipLaunchType
 * @see LAUNCH_TYPE* constants
 */
function isInlineChip(integer chip) => boolean;

/**
 * @brief Uses CHIP_RESURRECTION to resurect an entity on the given cell.
 * @param[in] cell The cell to resurect the entity on.
 * @return The result of the chip use.
 * @cost 500 ops
 *
 * @see canUseChip
 * @see canUseChipOnCell
 * @see useChip
 * @see USE_* constants
 */
function resurrect(integer entity, integer cell) => integer;

/**
 * @brief Uses the given chip to summon the corresponding entity on the given cell. The AI of the entity will be the callback function.
 * @param[in] chip The chip to use to summon the entity.
 * @param[in] cell The cell to summon the entity on.
 * @param[in] callback The callback function to use as the AI of the entity.
 * @param[in] name (optional) The name of the entity to summon.
 * @return The result of the chip use.
 * @cost 1750 ops
 *
 * @see canUseChip
 * @see canUseChipOnCell
 * @see useChip
 * @see USE_* constants
 */
function summon(integer chip, integer cell, Function<void> callback, string? name) => integer;

/**
 * @brief Uses the given chip on the entity, or yourself if no entity is given.
 * @param[in] chip The chip to use.
 * @param[in] target (optional) The target entity to use the chip on.
 * @return The result of the chip use.
 * @cost 3000 ops
 *
 * @see canUseChip
 * @see canUseChipOnCell
 * @see useChip
 * @see USE_* constants
 */
function useChip(integer chip, integer target = getEntity()) => integer;

/**
 * @brief Uses the given chip on the cell.
 * @param[in] chip The chip to use.
 * @param[in] cell The cell to use the chip on.
 * @return The result of the chip use.
 * @cost 3000 ops
 *
 * @see canUseChip
 * @see canUseChipOnCell
 * @see useChip
 * @see USE_* constants
 */
function useChipOnCell(integer chip, integer cell) => integer;

/**
 * @brief Returns the content of a given cell.
 * @param[in] cell The cell to get the content of.
 * @return The content of the cell.
 * @cost 6 ops
 *
 * @see CELL_* constants
 * @see isObstacle
 */
function getCellContent(integer cell) => integer;

/**
 * @brief Returns the distance between cellA, and cellB.
 *
 * The distance is expressed in number of cells and does not take into account the various obstacles between two cells
 * To get the distance as the crow flies, see `getDistance`, and for the path distance between the two cells avoiding obstacles, see `getPathDistance`.
 *
 * @param[in] cellA The first cell.
 * @param[in] cellB The second cell.
 * @return The distance between cellA and cellB.
 * @cost 15 ops
 *
 * @see getCell
 * @see getDistance
 * @see getPathDistance
 */
function getCellDistance(integer cellA, integer cellB) => integer;

/**
 * @brief Returns the id of the cell at coordinates (x, y). Returns null if the coordinates are out of bounds.
 * @param[in] x The x coordinate.
 * @param[in] y The y coordinate.
 * @return The id of the cell at coordinates (x, y). Returns null if the coordinates are out of bounds.
 * @cost 5 ops
 *
 * @note This is a safer equivalent to `x * 18 + y * 17`
 * @see getCell
 * @see getCells
 */
function getCellFromXY(integer x, integer y) => integer;

/**
 * @brief Returns the x-coordinate of a given cell.
 * @param[in] cell The cell to get the x-coordinate of.
 * @return The x-coordinate of the cell.
 * @cost 5 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellX(integer cell) => integer;

/**
 * @brief Returns the y-coordinate of a given cell.
 * @param[in] cell The cell to get the y-coordinate of.
 * @return The y-coordinate of the cell.
 * @cost 5 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellY(integer cell) => integer;

/**
 * @brief Returns the distance as the crow flies between cellA, and cellB.
 * @deprecated Use `getCellDistance` instead.
 * @param[in] cellA The first cell.
 * @param[in] cellB The second cell.
 * @return The distance as the crow flies between cellA and cellB.
 * @cost 15 ops
 *
 * @see getCellDistance
 * @see getPathDistance
 */
function getDistance(integer cellA, integer cellB) => integer;

/**
 * @brief Returns the entity that is on cell, -1 if there is no entity.
 * @param[in] cell The cell to get the entity from.
 * @return The entity that is on cell, -1 if there is no entity.
 * @cost 15 ops
 */
function getEntityOnCell(integer cell) => integer;

/**
 * @brief Returns the entity that is on cell, -1 if there is no entity.
 * @deprecated Use `getEntityOnCell` instead.
 * @param[in] cell The cell to get the entity from.
 * @return The entity that is on cell, -1 if there is no entity.
 * @cost 15 ops
 *
 * @see getEntityOnCell
 * @see getCells
 */
function getLeekOnCell(integer cell) => integer;

/**
 * @brief Returns the map type on which the fight takes place.
 * @return The map type on which the fight takes place.
 * @cost 5 ops
 *
 * @see MAP_* constants
 */
function getMapType() => integer;

/**
 * @brief Returns a list of all cells occupied by obstacles.
 * @return A list of all cells occupied by obstacles.
 * @cost 200 ops
 *
 * @see getCell
 * @see getCells
 */
function getObstacles() => Array<integer>;

/**
 * @brief Returns a path avoiding obstacles between cellA and cellB, if it exists, ignoring the cells contained in ignoredCells.
 * @param[in] cellA The first cell.
 * @param[in] cellB The second cell.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return A path avoiding obstacles between cellA and cellB, if it exists, ignoring the cells contained in ignoredCells.
 * @cost O(n**2)
 *
 * @note The starting cell is not included in the path, and the ending cell is only included if it is empty.
 * @note It is possible that `getPath(a, b) != getPath(b, a)`.
 * @see getCell
 * @see getCells
 */
function getPath(integer cellA, integer cellB, Array<integer> ignoredCells = []) => Array<integer>?;

/**
 * @brief Returns the length of a path between cellA and cellB, if it exists, ignoring the cells contained in ignoredCells.
 * @param[in] cellA The first cell.
 * @param[in] cellB The second cell.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return The length of a path between cellA and cellB, if it exists, ignoring the cells contained in ignoredCells.
 * @cost O(n**2)
 *
 * @note The starting cell is not included in the path, and the ending cell is only included if it is empty.
 * @note It is possible that `getPathLength(a, b) != getPathLength(b, a)`.
 * @see getCell
 * @see getCells
 */
function getPathLength(integer cellA, integer cellB, Array<integer> ignoredCells = []) => integer;

/**
 * @brief Returns true if the given cell is empty.
 * @param[in] cell The cell to check if it is empty.
 * @return True if the given cell is empty, false otherwise.
 * @cost 10 ops
 *
 * @see CELL_* constants
 */
function isEmptyCell(integer cell) => boolean;

/**
 * @brief Returns true if the content of the cell is an entity.
 * @param[in] cell The cell to check if it contains an entity.
 * @return True if the content of the cell is an entity, false otherwise.
 * @cost 10 ops
 *
 * @see CELL_* constants
 */
function isEntity(integer cell) => boolean;

/**
 * @brief Returns true if the content of the cell is an entity.
 * @deprecated Use `isEntity` instead.
 * @param[in] cell The cell to check if it contains an entity.
 * @return True if the content of the cell is an entity, false otherwise.
 * @cost 10 ops
 *
 * @see isEntity
 * @see CELL_* constants
 */
function isLeek(integer cell) => boolean;

/**
 * @brief Returns true if the content of the cell is an obstacle.
 * @param[in] cell The cell to check if it contains an obstacle.
 * @return True if the content of the cell is an obstacle, false otherwise.
 * @cost 10 ops
 *
 * @see CELL_* constants
 */
function isObstacle(integer cell) => boolean;

/**
 * @brief Returns true if cellA and cellB are on the same line.
 * @param[in] cellA The first cell.
 * @param[in] cellB The second cell.
 * @return True if cellA and cellB are on the same line, false otherwise.
 * @cost 15 ops
 */
function isOnSameLine(integer cellA, integer cellB) => boolean;

/**
 * @brief Returns an array containing all of your alive allies in a fight.
 * @return An array containing all of your alive allies in a fight.
 * @cost 100 ops
 *
 * @see getEntity
 * @see getEntities
 */
function getAliveAllies() => Array<integer>;

/**
 * @brief Returns the amount of alive allies remaining in a fight.
 * @return The amount of alive allies remaining in a fight.
 * @cost 25 ops
 *
 * @see getAliveAllies
 */
function getAliveAlliesCount() => integer;

/**
 * @brief Returns an array containing all of your alive enemies in a fight.
 * @return An array containing all of your alive enemies in a fight.
 * @cost 100 ops
 *
 * @see getEntity
 * @see getEntities
 */
function getAliveEnemies() => Array<integer>;

/**
 * @brief Returns the amount of alive enemies remaining in a fight.
 * @return The amount of alive enemies remaining in a fight.
 * @cost 25 ops
 *
 * @see getAliveEnemies
 */
function getAliveEnemiesCount() => integer;

/**
 * @brief Returns an array containing all of the effects in the game.
 * @return An array containing all of the effects in the game.
 * @cost 200 ops
 *
 * @see getEffect
 * @see getEffects
 */
function getEffects() => Array<integer>;

/**
 * @brief Returns, if it exists, your team's turret id.
 * @return The turret id of your team, or null if there is no turret.
 * @cost 15 ops
 */
function getAlliedTurret() => integer?;

/**
 * @brief Returns all of your allies in a fight, alive or dead.
 * @return All of your allies in a fight, alive or dead.
 * @cost 100 ops
 *
 * @see getEntity
 * @see getEntities
 */
function getAllies() => Array<integer>;

/**
 * @brief Returns the amount of allies in a fight, alive or dead.
 * @return The amount of allies in a fight, alive or dead.
 * @cost 25 ops
 *
 * @see getAllies
 */
function getAlliesCount() => integer;

/**
 * @brief Returns the sum of all of your allies's HP.
 * @return The sum of all of your allies's HP.
 * @cost 50 ops
 *
 * @see getEntity
 * @see getEntities
 */
function getAlliesLife() => integer;

/**
 * @brief Returns the min and max market characteristics for a bulb invoked by the chipId.
 * @param[in] chipId The chip id to get the market characteristics of.
 * @return A map indexed by STAT_* constants with each value being [min, max] array.
 * @cost 40 ops
 *
 * @see STAT_* constants
 */
function getBulbStats(integer chipId) => Map<integer, Array<integer>>;

/**
 * @brief Returns the min and max market characteristics for a bulb invoked by the chipId.
 * @deprecated Use `getBulbStats` instead.
 * @param[in] chipId The chip id to get the market characteristics of.
 * @return A map indexed by STAT_* constants with each value being [min, max] array.
 * @cost 40 ops
 *
 * @see STAT_* constants
 */
function getBulbCharacteristics(integer chipId) => Map<integer, Array<integer>>;

/**
 * @brief Returns the list of chips that will be equipped on a bulb invoked by the chipId.
 * @param[in] chipId The chip id to get the list of chips of.
 * @return A list of chips that will be equipped on a bulb invoked by the chipId.
 * @cost 40 ops
 *
 * @see getChip
 * @see getChips
 */
function getBulbChips(integer chipId) => Array<integer>;

/**
 * @brief Returns the type of bulb of the given entity.
 * @param[in] entity The entity to get the type of bulb of.
 * @return The type of bulb of the given entity.
 * @cost 15 ops
 *
 * @see BULB_* constants
 */
function getBulbType(integer entity) => integer;

/**
 * @brief Returns the cells that allow your entity to use a given chip, targetting a given entity.
 * @param[in] chip The chip to get the cells of.
 * @param[in] target The target entity to get the cells of.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return A list of cells that allow your entity to use a given chip, targetting a given entity.
 * @cost 25834 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellsToUseChip(integer chip, integer target, Array<integer> ignoredCells = []) => Array<integer>;

/**
 * @brief Returns the cells that allow your entity to use a given chip, targetting a given cell.
 * @param[in] chip The chip to get the cells of.
 * @param[in] target The target cell to get the cells of.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return A list of cells that allow your entity to use a given chip, targetting a given cell.
 * @cost 25834 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellsToUseChipOnCell(integer chip, integer cell, Array<integer> ignoredCells = []) => Array<integer>;

/**
 * @brief Returns the list of cells that allow your entity to use a given weapon, targetting a given entity.
 * @param[in] weapon (optional) The weapon to get the cell of.
 * @param[in] target The target entity to get the cell of.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return The list of cells that allow your entity to use a given weapon, targetting a given entity.
 * @cost 25834 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellsToUseWeapon(integer target) => integer;
function getCellsToUseWeapon(integer weapon, integer target, Array<integer> ignoredCells = []) => Array<integer>;

/**
 * @brief Returns the list of cells that allow your entity to use a given weapon, targetting a given cell.
 * @param[in] weapon (optional) The weapon to get the cell of.
 * @param[in] target The target cell to get the cell of.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return The list of cells that allow your entity to use a given weapon, targetting a given cell.
 * @cost 25834 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellsToUseWeaponOnCell(integer target) => Array<integer>;
function getCellsToUseWeaponOnCell(integer weapon, integer cell, Array<integer> ignoredCells = []) => Array<integer>;

/**
 * @brief Returns a cell where your entity can use the given chip on the given entity.
 * @param[in] chip The chip to get the cell of.
 * @param[in] target The target entity to get the cell of.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return A cell where your entity can use the given chip on the given entity.
 * @cost 38080 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellToUseChip(integer chip, integer target, Array<integer> ignoredCells = []) => integer;

/**
 * @brief Returns a cell where your entity can use the given chip on the given cell.
 * @param[in] chip The chip to get the cell of.
 * @param[in] target The target cell to get the cell of.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return A cell where your entity can use the given chip on the given cell.
 * @cost 38080 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellToUseChipOnCell(integer chip, integer cell, Array<integer> ignoredCells = []) => integer;

/**
 * @brief Returns a cell where your entity can use the given weapon on the given entity.
 * @param[in] weapon (optional) The weapon to get the cell of.
 * @param[in] target The target entity to get the cell of.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return A cell where your entity can use the given weapon on the given entity.
 * @cost 38080 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellToUseWeapon(integer target) => integer;
function getCellToUseWeapon(integer weapon, integer target, Array<integer> ignoredCells = []) => integer;

/**
 * @brief Returns a cell where your entity can use the given weapon on the given cell.
 * @param[in] weapon (optional) The weapon to get the cell of.
 * @param[in] target The target cell to get the cell of.
 * @param[in] ignoredCells (optional) A list of cells to ignore.
 * @return A cell where your entity can use the given weapon on the given cell.
 * @cost 38080 ops
 *
 * @see getCell
 * @see getCells
 */
function getCellToUseWeaponOnCell(integer target) => integer;

/**
 * @brief Returns a list of all entities that will be affected if the given chip is used on the given cell.
 * @param[in] chip The chip to get the entities of.
 * @param[in] target The target cell to get the entities of.
 * @return A list of all entities that will be affected if the given chip is used on the given cell.
 * @cost 40 ops
 */
function getChipTargets(integer chip, integer cell) => Array<integer>;

/**
 * @brief Returns and array containing all dead allies.
 * @return An array containing all dead allies.
 * @cost 100 ops
 */
function getDeadAllies() => Array<integer>;

/**
 * @brief Returns the amount of dead allies.
 * @return The amount of dead allies.
 * @cost 25 ops
 *
 * @see getDeadAllies
 */
function getDeadAlliesCount() => integer;

/**
 * @brief Returns and array containing all dead enemies.
 * @return An array containing all dead enemies.
 * @cost 100 ops
 */
function getDeadEnemies() => Array<integer>;

/**
 * @brief Returns the amount of dead enemies.
 * @return The amount of dead enemies.
 * @cost 25 ops
 *
 * @see getDeadEnemies
 */
function getDeadEnemiesCount() => integer;

/**
 * @brief Returns the sum of all of your enemies's life.
 * @return The sum of all of your enemies's life.
 * @cost 50 ops
 *
 * @see getEntity
 * @see getEntities
 */
function getEnemiesLife() => integer;

/**
 * @brief Returns, if it exists, your enemy's turret id.
 * @return The turret id of your enemy, or null if there is no turret.
 * @cost 15 ops
 *
 * @see getEntity
 * @see getEntities
 */
function getEnemyTurret() => integer?;

/**
 * @brief Returns your furthest ally.
 * @return Your furthest ally.
 * @cost 31 ops
 *
 * @see getEntity
 * @see getEntities
 */
function getFarthestAlly() => integer;

/**
 * @brief Returns your furthest enemy.
 * @return Your furthest enemy.
 * @cost 31 ops
 *
 * @see getEntity
 * @see getEntities
 */
function getFarthestAlly() => integer;

/**
 * @brief Returns, if it exists, the boss of the fight.
 * @return The boss type of the fight, or 0 if the fight isn't a boss fight.
 * @cost 10 ops
 *
 * @see BOSS_* constants
 * @see getFightType
 */
function getFightBoss() => integer;

/**
 * @brief Returns the context of the current fight.
 * @return The context of the current fight.
 * @cost 10 ops
 *
 * @see FIGHT_CONTEXT_* constants
 */
function getFightContext() => integer;

/**
 * @brief Returns the id of the current fight.
 * @return The id of the current fight.
 * @cost 5 ops
 */
function getFightId() => integer;

/**
 * @brief Returns the current fight's type.
 * @return The current fight's type.
 * @cost 5 ops
 *
 * @see FIGHT_TYPE_* constants
 */
function getFightType() => integer;

/**
 * @brief Returns the nearest ally.
 * @return The nearest ally, -1 if there is no nearest ally.
 * @cost 25 ops
 */
function getNearestAlly() => integer;

/**
 * @brief Returns the nearest ally to an entity.
 * @param[in] entity The entity to get the nearest ally to.
 * @return The nearest ally to the entity, -1 if there is no nearest ally.
 * @cost 35 ops
 */
function getNearestAllyTo(integer entity) => integer;

/**
 * @brief Returns the nearest ally to a cell.
 * @param[in] cell The cell to get the nearest ally to.
 * @return The nearest ally to the cell, -1 if there is no nearest ally.
 * @cost 35 ops
 */
function getNearestAllyToCell(integer cell) => integer;

/**
 * @brief Returns the nearest enemy.
 * @return The nearest enemy, -1 if there is no nearest enemy.
 * @cost 25 ops
 */
function getNearestEnemy() => integer;

/**
 * @brief Returns the nearest enemy to an entity.
 * @param[in] entity The entity to get the nearest enemy to.
 * @return The nearest enemy to the entity, -1 if there is no nearest enemy.
 * @cost 35 ops
 */
function getNearestEnemyTo(integer entity) => integer;

/**
 * @brief Returns the nearest enemy to a cell.
 * @param[in] cell The cell to get the nearest enemy to.
 * @return The nearest enemy to the cell, -1 if there is no nearest enemy.
 * @cost 35 ops
 */
function getNearestEnemyToCell(integer cell) => integer;

/**
 * @brief Returns the id of the entity that will play after the given entity.
 * @param[in] entity (optional) The entity to get the next entity to play after.
 * @return The id of the entity that will play after the given entity.
 * @cost 20 ops
 */
function getNextPlayer(integer entity) => integer;

/**
 * @brief Returns the id of the entity that will play before the given entity.
 * @param[in] entity (optional) The entity to get the previous entity to play before.
 * @return The id of the entity that will play before the given entity.
 * @cost 20 ops
 */
function getPreviousPlayer(integer entity) => integer;

/**
 * @brief Returns the current turn number in the fight.
 * @return The current turn number in the fight. The first turn is 1.
 * @cost 15 ops
 */
function getTurn() => integer;

/**
 * @brief Returns the entities that will be affected if the given weapon is used on the given cell.
 * @param[in] weapon (optional) The weapon to get the entities of.
 * @param[in] cell The cell to get the entities of.
 * @return The entities that will be affected if the given weapon is used on the given cell.
 * @cost 40 ops
 */
function getWeaponTargets(integer weapon = getWeapon(), integer cell) => Array<integer>;

/**
 * Returns true if there is line of sight between start and end, ignoring the entities in entitiesToIgnore.
 * @param[in] start The start cell.
 * @param[in] end The end cell.
 * @param[in] entitiesToIgnore (optional) A list of entities to ignore.
 * @return True if there is line of sight between start and end, ignoring the entities in entitiesToIgnore.
 * @cost 31 ops
 */
function lineOfSight(integer start, integer end, Array<integer> entitiesToIgnore = []) => boolean;

/**
 * @brief Moves your entity away from the given entity, using at most mp moves.
 * @param[in] entity The entity to move away from.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveAwayFrom(integer entity, integer mp = getMP()) => integer;

/**
 * @brief Moves your entity away from the given cell, using at most mp moves.
 * @param[in] cell The cell to move away from.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveAwayFromCell(integer cell, integer mp = getMP()) => integer;

/**
 * @brief Moves your entity away from a given array of cells, using at most mp moves.
 * @param[in] cells The cells to move away from.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveAwayFromCells(Array<integer> cells, integer mp = getMP()) => integer;

/**
 * @brief Moves your entity away from a given array of entities, using at most mp moves.
 * @param[in] entities The entities to move away from.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveAwayFromEntities(Array<integer> entities, integer mp = getMP()) => integer;

/**
 * @brief Moves your entity away from a given array of entities, using at most mp moves.
 * @deprecated Use `moveAwayFromEntities` instead.
 * @param[in] entities The entities to move away from.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveAwayFromLeeks(Array<integer> entities, integer mp = getMP()) => integer;

/**
 * @brief Moves you entity away from a line defined by cellA and cellB, using at most mp moves.
 * @param[in] cellA The first cell of the line.
 * @param[in] cellB The second cell of the line.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveAwayFromLine(integer cellA, integer cellB, integer mp = getMP()) => integer;

/**
 * @brief Moves you entity towards another entity, using at most mp moves.
 * @param[in] entity The entity to move towards.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveToward(integer entity, integer mp = getMP()) => integer;

/**
 * @brief Moves you entity towards another cell, using at most mp moves.
 * @param[in] cell The cell to move towards.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveTowardCell(integer cell, integer mp = getMP()) => integer;

/**
 * @brief Moves you entity towards a given array of cells, using at most mp moves.
 * @param[in] cells The cells to move towards.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveTowardCells(Array<integer> cells, integer mp = getMP()) => integer;

/**
 * @brief Moves you entity towards a given array of entities, using at most mp moves.
 * @param[in] entities The entities to move towards.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveTowardEntities(Array<integer> entities, integer mp = getMP()) => integer;

/**
 * @brief Moves you entity towards a given array of entities, using at most mp moves.
 * @deprecated Use `moveTowardsEntities` instead.
 * @param[in] entities The entities to move towards.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500 ops
 */
function moveTowardLeeks(Array<integer> entities, integer mp = getMP()) => integer;

/**
 * @brief Moves you entity towards a line defined by cellA and cellB, using at most mp moves.
 * @param[in] cellA The first cell of the line.
 * @param[in] cellB The second cell of the line.
 * @param[in] mp (optional) The maximum number of moves to use.
 * @return the amount of moves used.
 * @cost 500
 */
function moveTowardLine(integer cellA, integer cellB, integer mp = getMP()) => integer;

/**
 * @brief Clears all marks done by mark() and markText() on the terrain.
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Clones the value up to the given level of recursion.
 * @param[in] value The value to clone.
 * @param[in] level (optional) The level of recursion to clone.
 * @return The cloned value.
 * @cost O(n)
 */
function clone<T>(T value) => T;
function clone<T>(T value, integer level) => T;

/**
 * @brief Logs a message to the console.
 *
 * The limit of debug() per fight is 500k characters.
 *
 * @param[in] message The message to log to the console.
 * @cost 100 ops
 */
function debug(any message) => void;

/**
 * @brief Logs a message to the console with the given color.
 *
 * The limit of debug() per fight is 500k characters.
 *
 * @param[in] message The message to log to the console.
 * @param[in] color The color to log the message in.
 * @cost 100 ops
 */
function debugC(any message, integer color) => void;

/**
 * @brief Logs a message as an error to the console.
 *
 * The limit of debug() per fight is 500k characters.
 *
 * @param[in] message The message to log as an error to the console.
 * @cost 100 ops
 */
function debugE(any message) => void;

/**
 * @brief Logs a message as a warning to the console.
 *
 * The limit of debug() per fight is 500k characters.
 *
 * @param[in] message The message to log as a warning to the console.
 * @cost 100 ops
 */
function debugW(any message) => void;

/**
 * @brief Deletes the register assotiated to the given key if it exists.
 * @param[in] key The key to delete the register from.
 * @cost 16 ops
 */
function deleteRegister(string key) => void;

/**
 * @brief Returns the date of the fight, using the dd/MM/yyyy format.
 * @return The date of the fight, using the dd/MM/yyyy format.
 * @cost 50 ops
 */
function getDate() => string;

/**
 * @brief Returns the amount of operations currently used for the turn.
 * @return The amount of operations currently used for the turn.
 * @cost 1 op
 */
function getOperations() => integer;

/**
 * @brief Returns the amount of operations currently used for the turn.
 * @deprecated Use `getOperations` instead.
 * @return The amount of operations currently used for the turn.
 * @cost 15 ops
 */
function getInstructionCount() => integer;

/**
 * @brief Returns the maximum amount of operations allowed for the turn.
 * @return The maximum amount of operations allowed for the turn.
 * @cost 1 op
 */
function getMaxOperations() => integer;

/**
 * @brief Returns the content of the register assotiated with the given key, or null if it doesn't exist.
 * @param[in] key The key to get the content of the register from.
 * @return The content of the register assotiated with the given key, or null if it doesn't exist.
 * @cost 15 ops
 */
function getRegister(string key) => string?;

/**
 * @brief Returns a map of all registers.
 * @return A map of all registers.
 * @cost 15 ops
 */
function getRegisters() => Map<string, string>;

/**
 * @brief Returns the time at which the fight was run, formatted as HH:mm:ss.
 * @return The time at which the fight was run, formatted as HH:mm:ss.
 * @cost 50 ops
 */
function getTime() => string;

/**
 * @brief Returns the timestamp of the fight.
 * @return The timestamp of the fight.
 * @cost 5 ops
 */
function getTimestamp() => integer;

/**
 * @brief Returns the amount of RAM currently used by your AI.
 * @return The amount of RAM currently used by your AI.
 * @cost 1 op
 */
function getRam() => integer;

/**
 * @brief Includes the AI located in the given path relative to the current AI.
 * @param[in] path The path to the AI to include.
 * @cost 1 op
 */
function include(string path) => void;

/**
 * @brief Decodes the string into a leekscript object.
 * @param[in] str The string to decode.
 * @return The decoded leekscript object.
 * @cost O(n)
 *
 * @note The function can only return integer, real, boolean, string, array, and object values.
 */
function jsonDecode(string str) => any;

/**
 * @brief Encodes the given value into a string.
 * @param[in] value The value to encode.
 * @return The encoded string.
 * @cost O(n)
 */
function jsonEncode(any value) => string;

/**
 * @brief Marks one or more cells of the given color for a given amount of turn. This is only visible by the player that marked the cells.
 * @param[in] cells The cells to mark.
 * @param[in] color The color to mark the cells with.
 * @param[in] turns The amount of turns to mark the cells for.
 * @return True if the cells were marked successfully, false otherwise.
 * @cost 164 ops
 */
function mark(Array<integer>|integer cells, integer color = 0, integer turns = 0) => boolean;

/**
 * @brief Writes text on each given cell, with a given color and for a given amount of time.
 * @param[in] cells The cells to write the text on.
 * @param[in] text The text to write on the cells.
 * @param[in] color The color to write the text with.
 * @param[in] time The amount of time to write the text for.
 * @return True if the text was written successfully, false otherwise.
 * @cost 164 ops
 */
function markText(Array<integer>|integer cells, string text, integer color = 0, integer time = 0) => boolean;

/**
 * @brief Pauses the fight, only for the user that uses the function.
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Stores the given value in the register assotiated with the given key.
 * @param[in] key The key to store the value in. Must be at most 100 characters long.
 * @param[in] value The value to store in the register. Must be at most 500 characters long.
 * @return True if the value was stored successfully, false otherwise.
 * @cost 50 ops
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Points to all players one cell, of a given color for 1 turn. This function costs 1 TP.
 * @param[in] cell The cell to point to.
 * @param[in] color (optional) The color to point to the cell with.
 * @cost 8 ops
 *
 * @note The maximum amount of show() is 5 per turn.
 */
function show(integer cell, integer color = 0) => boolean;

/**
 * @brief Returns the type of a value.
 * @param[in] value The value to get the type of.
 * @return The type of the value.
 * @cost 8 ops
 *
 * @see TYPE_* constants
 */
function type(any value) => integer;

/**
 * @brief Returns the author of a message.
 * @param[in] message The message to get the author of.
 * @return The author of the message.
 * @cost 5 ops
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Returns the parameters of a message.
 * @param[in] message The message to get the parameters of.
 * @return The parameters of the message.
 * @cost 5 ops
 */
function getMessageParams(Array message) => any;

/**
 * @brief Returns the messages from the given entity.
 * @param[in] entity (optional) The entity to get the messages from.
 * @return The messages from the given entity, formatted as: [author, type, params]
 * @cost O(n)
 */
function getMessages(integer entity = getEntity()) => Array<Array<any>>;

/**
 * @brief Returns the type of a message.
 * @param[in] message The message to get the type of.
 * @return The type of the message.
 * @cost 5 ops
 */
function getMessageType(Array message) => integer;

/**
 * @brief Sends a message to all of your team.
 * @param[in] type The type of message.
 * @param[in] params The parameters of the message.
 * @cost 40 ops
 */
function sendAll(integer type, any params) => void;

/**
 * @brief Sends a message to a specific entity.
 * @param[in] entity The entity to send the message to.
 * @param[in] type The type of message.
 * @param[in] params The parameters of the message.
 * @cost 15 ops
 */
function sendTo(integer entity, integer type, any params) => void;

/**
 * @brief Returns the amount of blue in a given color, between 0 and 255.
 * @param[in] color The color to get the blue amount of.
 * @return The amount of blue in the given color, between 0 and 255.
 * @cost 10 op
 */
function getBlue(integer color) => integer;

/**
 * @brief Returns the amount of green in a given color, between 0 and 255.
 * @param[in] color The color to get the green amount of.
 * @return The amount of green in the given color, between 0 and 255.
 * @cost 10 op
 */
function getGreen(integer color) => integer;

/**
 * @brief Returns the amount of red in a given color, between 0 and 255.
 * @param[in] color The color to get the red amount of.
 * @return The amount of red in the given color, between 0 and 255.
 * @cost 10 op
 */
function getRed(integer color) => integer;

/**
 * @brief Returns a color from the given amount of blue, green and red.
 * @param[in] blue The amount of blue in the color.
 * @param[in] green The amount of green in the color.
 * @param[in] red The amount of red in the color.
 * @return The color from the given amount of blue, green and red.
 * @cost 15 op
 */
function getColor(integer blue, integer green, integer red) => integer;

/**
 * @brief Empties the given set.
 * @param[in,out] set The set to empty.
 * @cost 1 op
 */
function setClear(Set<any> set) => void;

/**
 * @brief Returns true if the given set contains the given value.
 * @param[in] set The set to check if it contains the value.
 * @param[in] value The value to check if it is in the set.
 * @return True if the given set contains the given value, false otherwise.
 * @cost 2 op
 *
 * @note This function is equivalent to `value in set`
 */
function setContains<T>(Set<T> set, T value) => boolean;

/**
 * @brief Returns the difference between setA and setB.
 * @param[in] setA The first set.
 * @param[in] setB The second set.
 * @return The difference between setA and setB.
 * @cost O(n)
 */
function setDifference<T>(Set<T> setA, Set<T> setB) => Set<T>;

/**
 * @brief Returns the disjunction of setA and setB.
 * @param[in] setA The first set.
 * @param[in] setB The second set.
 * @return The disjunction of setA and setB.
 * @cost O(n)
 */
function setDisjunction<T>(Set<T> setA, Set<T> setB) => Set<T>;

/**
 * @brief Returns the intersection of setA and setB.
 * @param[in] setA The first set.
 * @param[in] setB The second set.
 * @return The intersection of setA and setB.
 * @cost O(n)
 */
function setIntersection<T>(Set<T> setA, Set<T> setB) => Set<T>;

/**
 * @brief Returns true if the set is empty.
 * @param[in] set The set to check if it is empty.
 * @return True if the set is empty, false otherwise.
 * @cost 2 ops
 *
 * @note This function is equivalent to `count(set) == 0`
 */
function setIsEmpty<T>(Set<T> set) => boolean;

/**
 * @brief Returns true if setA is a subset of setB.
 * @param[in] setA The first set.
 * @param[in] setB The second set.
 * @return True if setA is a subset of setB, false otherwise.
 * @cost O(n)
 */
function setIsSubsetOf<T>(Set<T> setA, Set<T> setB) => boolean;

/**
 * @brief Inserts the given value into the set.
 * @param[in,out] set The set to insert the value into.
 * @param[in] value The value to insert into the set.
 * @return True if the value was inserted successfully, false otherwise.
 * @cost 3 op
 */
function setInsert<T>(Set<T> set, T value) => boolean;

/**
 * @brief Removes the given value from the set.
 * @param[in,out] set The set to remove the value from.
 * @param[in] value The value to remove from the set.
 * @return True if the element existed, false otherwise.
 * @cost 2 op
 */
function setRemove<T>(Set<T> set, T value) => boolean;

/**
 * @brief Returns the size of the set.
 * @param[in] set The set to get the size of.
 * @return The size of the set.
 * @cost 1 op
 */
function setSize<T>(Set<T> set) => integer;

/**
 * @brief Inserts the given value into the set, if it doesn't exist.
 * @param[in,out] set The set to insert the value into.
 * @param[in] value The value to insert into the set.
 * @return True if the value was inserted successfully, false otherwise.
 * @cost 3 op
 */
function setPut<T>(Set<T> set, T value) => boolean;

/**
 * @brief Returns an array containing all elements of the set.
 * @param[in] set The set to get the elements from.
 * @return An array containing all elements of the set.
 * @cost O(n)
 *
 * @note The order of the elements is not guaranteed.
 */
function setToArray<T>(Set<T> set) => Array<T>;

/**
 * @brief Returns the union of setA and setB.
 * @param[in] setA The first set.
 * @param[in] setB The second set.
 * @return The union of setA and setB.
 * @cost O(n)
 */
function setUnion<T>(Set<T> setA, Set<T> setB) => Set<T>;

/**
 * @brief Returns the average of the interval.
 * @param[in] interval The interval to calculate the average of.
 * @return The average of the interval.
 * @cost 3 op
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Combines two intervals.
 * @param[in] intervalA The first interval.
 * @param[in] intervalB The second interval.
 * @return The combined interval.
 * @cost 3 op
 */
function intervalCombine<T>(Interval<T> intervalA, Interval<T> intervalB) => Interval<T>;

/**
 * @brief Returns the intersection of two intervals.
 * @param[in] intervalA The first interval.
 * @param[in] intervalB The second interval.
 * @return The intersection of two intervals.
 * @cost 3 op
 */
function intervalIntersection<T>(Interval<T> intervalA, Interval<T> intervalB) => Interval<T>;

/**
 * @brief Returns True if the interval is bounded on both sides.
 * @param[in] interval The interval to check if it is bounded on both sides.
 * @return True if the interval is bounded on both sides, false otherwise.
 * @cost 1 op
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Returns True if the interval is closed on both sides.
 * @param[in] interval The interval to check if it is closed on both sides.
 * @return True if the interval is closed on both sides, false otherwise.
 * @cost 1 op
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Returns True if the interval is empty.
 * @param[in] interval The interval to check if it is empty.
 * @return True if the interval is empty, false otherwise.
 * @cost 1 op
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Returns True if the interval is left bounded.
 * @param[in] interval The interval to check if it is left bounded.
 * @return True if the interval is left bounded, false otherwise.
 * @cost 1 op
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Returns True if the interval is right bounded.
 * @param[in] interval The interval to check if it is right bounded.
 * @return True if the interval is right bounded, false otherwise.
 * @cost 1 op
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Returns True if the interval is left closed.
 * @param[in] interval The interval to check if it is left closed.
 * @return True if the interval is left closed, false otherwise.
 * @cost 1 op
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Returns True if the interval is right closed.
 * @param[in] interval The interval to check if it is right closed.
 * @return True if the interval is right closed, false otherwise.
 * @cost 1 op
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Returns the upper bound of the interval.
 * @param[in] interval The interval to get the upper bound of.
 * @return The upper bound of the interval.
 * @cost 1 op
 */
function intervalMax<T>(Interval<T> interval) => T;

/**
 * @brief Returns the lower bound of the interval.
 * @param[in] interval The interval to get the lower bound of.
 * @return The lower bound of the interval.
 * @cost 1 op
 */
function intervalMin<T>(Interval<T> interval) => T;

/**
 * @brief Returns the size of the interval.
 * @param[in] interval The interval to get the size of.
 * @return The size of the interval.
 * @cost 1 op
 */
function intervalSize<T>(Interval<T> interval) => T;

/**
 * @brief Returns an array containing all values in the interval with a given step.
 * @param[in] interval The interval to get the values from.
 * @param[in] step (optional) The step to use.
 * @return An array containing all values in the interval with a given step.
 * @cost O(n)
 */
function intervalValues<T>(Interval<T> interval, T step = 1) => Array<T>;

/**
 * @brief Returns a set containing all values in the interval.
 * @param[in] interval The interval to get the values from.
 * @return A set containing all values in the interval.
 * @cost O(n)
 */
function intervalToSet<T>(Interval<T> interval) => Set<T>;