// --- Functions ---

// === math ===

/**
 * @brief Renvoie la valeur absolue du nombre number.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Le nombre dont la valeur absolue sera calculée.
 * @return result La valeur absolue du nombre.
 */
function abs(integer|real number) => integer;

/**
 * @brief Calcule l'arc cosinus d'argument, dans l'intervalle [0, @ref PI].
 *
 * @category math
 * @cost 12 ops
 *
 * @param[in] argument Nombre dont l'arc cosinus sera calculé.
 * @return result L'arc cosinus d'argument.
 */
function acos(integer|real argument) => real;

/**
 * @brief Calcule l'arc sinus d'argument, dans l'intervalle [0, @ref PI].
 *
 * @category math
 * @cost 12 ops
 *
 * @param[in] argument Nombre dont l'arc sinus sera calculé.
 * @return result L'arc sinus d'argument.
 */
function asin(integer|real argument) => real;

/**
 * @brief Calcule l'arc tangente d'argument, dans l'intervalle [0, @ref PI].
 *
 * @category math
 * @cost 25 ops
 *
 * @param[in] argument Nombre dont l'arc tangente sera calculée.
 * @return result L'arc tangente d'argument.
 */
function atan(integer|real argument) => real;

/**
 * @brief Convertit les coordonnées cartésiennes (x, y) en coordonnées polaires (r, theta).
 *
 * Cette fonction retourne l'angle theta entre -@ref PI et @ref PI en utilisant les signes des
 * arguments.
 *
 * @category math
 * @cost 35 ops
 *
 * @param[in] y Coordonnée en y.
 * @param[in] x Coordonnée en x.
 * @return result L'angle theta en coordonnées polaires du point (x, y).
 */
function atan2(integer|real y, integer|real x) => real;

/**
 * @brief Renvoie une chaîne de caractères contenant le nombre x au format binaire.
 *
 * @category math
 * @cost 10 ops
 *
 * @param[in] x
 * @return string
 */
function binString(integer x) => string;

/**
 * @brief Renvoie le nombre de bits à 1 dans le nombre x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return bits
 */
function bitCount(integer x) => integer;

/**
 * @brief Inverse tous les bits du nombre x de gauche à droite.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return reversed
 */
function bitReverse(integer x) => integer;

/**
 * @brief Convertit les bits d'un entier en nombre flottant.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return real
 */
function bitsToReal(integer x) => real;

/**
 * @brief Inverse les octets (8 bits) d'un nombre x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return reversed
 */
function byteReverse(integer x) => integer;

/**
 * @brief Calcule la racine cubique de number
 *
 * @category math
 * @cost 62 ops
 *
 * @param[in] number Nombre dont on veut calculer la racine cubique.
 * @return result Racine cubique de number.
 */
function cbrt(integer|real number) => real;

/**
 * @brief Retourne l'arrondi à l'entier supérieur de number.
 *
 * Vous pouvez trouver l'arrondi à l'entier inférieur avec @ref floor, et l'arrondi avec @ref round.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Nombre dont on veut trouver l'arrondi supérieur.
 * @return result Arrondi à l'entier supérieur de number.
 */
function ceil(integer|real number) => integer;

/**
 * @brief Calcule le cosinus de angle.
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle Nombre dont le cosinus sera calculé (en radians).
 * @return cosine Le cosinus de angle, dans l'intervalle [-1, 1].
 */
function cos(integer|real angle) => real;

/**
 * @brief Éleve le nombre d'Euler @ref E à la puissance number.
 *
 * @category math
 * @cost 40 ops
 *
 * @param[in] number L'exposant auquel @ref E sera élevé.
 * @return result @ref E ** number.
 */
function exp(integer|real number) => real;

/**
 * @brief Calcule l'arrondi à l'entier inférieur de number.
 *
 * Vous pouvez trouver l'arrondi à l'entier supérieur avec @ref ceil, et l'arrondi avec @ref round.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Nombre dont on veut trouver l'arrondi inférieur.
 * @return result Arrondi à l'entier inférieur de number.
 */
function floor(integer|real number) => integer;

/**
 * @brief Renvoie une chaîne de caractères contenant le nombre x au format hexadécimal.
 *
 * @category math
 * @cost 10 ops
 *
 * @param[in] x
 * @return string
 */
function hexString(integer x) => string;

/**
 * @brief Renvoie l'hypoténuse du triangle rectangle de côtés x et y.
 *
 * Équivaut à sqrt(x**2 + y**2).
 *
 * @category math
 * @cost 187 ops
 *
 * @param[in] x La valeur x.
 * @param[in] y La valeur y.
 * @return hypotenuse sqrt(x**2 + y**2).
 */
function hypot(integer|real x, integer|real y) => real;

/**
 * @brief Renvoie true si le nombre x est fini, false sinon.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return finite
 */
function isFinite(real x) => boolean;

/**
 * @brief Renvoie true si le nombre x est infini, false sinon.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return infinite
 */
function isInfinite(real x) => boolean;

/**
 * @brief Renvoie *true* si le nombre x est une valeur NaN (Not a Number) dans sa représentation flottante, *false* sinon.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return nan
 */
function isNaN(real x) => boolean;

/**
 * @brief Renvoie *true* si les nombres x et y sont des permutations dans leur représentation décimale, *false* sinon.
 *
 * @category math
 * @cost 50 ops
 *
 * @param[in] x
 * @param[in] y
 * @return permutation
 */
function isPermutation(integer x, integer y) => boolean;

/**
 * @brief Renvoie le nombre de bits à 0 au début du nombre x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return zeros
 */
function leadingZeros(integer x) => integer;

/**
 * @brief Calcule le logarithme néperien du nombre number.
 *
 * @category math
 * @cost 39 ops
 *
 * @param[in] number Un nombre compris dans l'intervalle ]0; +∞[.
 * @return log Le logarithme néperien de number.
 */
function log(integer|real number) => real;

/**
 * @brief Calcule le logarithme en base 10 du nombre number.
 *
 * @category math
 * @cost 23 ops
 *
 * @param[in] number Un nombre compris dans l'intervalle ]0; +∞[.
 * @return log10 Le logarithme en base 10 de number.
 */
function log10(integer|real number) => real;

/**
 * @brief Calcule le logarithme en base 2 du nombre number.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] number Un nombre compris dans l'intervalle ]0; +∞[.
 * @return log2 Le logarithme en base 2 de number.
 */
function log2(integer|real number) => real;

/**
 * @brief Renvoie le plus grande valeur entre les deux nombres a et b.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] a Un nombre.
 * @param[in] b Un nombre.
 * @return max Le plus grand nombre entre a et b.
 */
function max(integer|real a, integer|real b) => integer|real;

/**
 * @brief Renvoie la plus petite valeur entre les deux nombres a et b.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] a Un nombre.
 * @param[in] b Un nombre.
 * @return min Le plus petit nombre entre a et b.
 */
function min(integer|real a, integer|real b) => integer|real;

/**
 * @brief Convertit une valeur en nombre.
 *
 * Si la valeur est une chaîne, la fonction number va essayer de la convertir en nombre, si
 * la valeur est déjà un nombre, la fonction renvoie le nombre, et pour tout autre type, elle
 * renvoie null.
 *
 * @category math
 * @cost 20 ops
 *
 * @param[in] value La valeur à convertir en nombre.
 * @return number Le nombre converti.
 */
function number(any value) => real;

/**
 * @brief Éleve le nombre base à la puissance exposant.
 *
 * @category math
 * @cost 140 ops
 *
 * @param[in] base La base.
 * @param[in] exp L'exposant.
 * @return result base élevée à la puissance exposant.
 */
function pow(integer|real base, integer|real exp) => real;

/**
 * @brief Renvoie un nombre aléatoire réel, compris entre 0 (inclus) et 1 (exclu).
 *
 * @category math
 * @cost 30 ops
 *
 * @return number Un nombre aléatoire dans l'intervalle [0; 1[.
 */
function rand() => real;

/**
 * @brief Renvoie un nombre aléatoire réel, compris entre a (inclus) et b (exclu).
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref randReal.
 * @sa randReal
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a Borne inférieure.
 * @param[in] b Borne supérieure.
 * @return number Un nombre aléatoire dans l'intervalle [a; b[.
 */
function randFloat(integer|real a, integer|real b) => integer;

/**
 * @brief Renvoie un nombre aléatoire entier, compris entre a (inclus) et b (exclu).
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a Borne inférieure.
 * @param[in] b Borne supérieure.
 * @return number Un nombre entier aléatoire dans l'intervalle [a; b[.
 */
function randInt(integer|real a, integer|real b) => integer;

/**
 * @brief Renvoie un nombre aléatoire réel, compris entre a (inclus) et b (exclu).
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a
 * @param[in] b
 * @return number
 */
function randReal(real a, real b) => real;

/**
 * @brief Renvoie les bits bruts du nombre x dans un nombre entier.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return bits
 */
function realBits(real x) => integer;

/**
 * @brief Renvoie un nouveau nombre avec les bits de x décalés de s par la gauche (remet les bits par la droite).
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @param[in] s
 * @return rotated
 */
function rotateLeft(integer x, integer s) => integer;

/**
 * @brief Renvoie un nouveau nombre avec les bits de x décalés de s par la droite (remet les bits par la gauche).
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @param[in] s
 * @return rotated
 */
function rotateRight(integer x, integer s) => integer;

/**
 * @brief Retourne l'arrondi de number.
 *
 * Vous pouvez trouver l'arrondi à l'entier inférieur avec @ref floor, et l'arrondi à l'entier
 * supérieur avec @ref ceil.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Nombre dont on veut trouver l'arrondi.
 * @return number Arrondi de number.
 */
function round(integer|real number) => integer;

/**
 * @brief Détermine le signe du nombre number.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Le nombre dont le signe sera déterminé.
 * @return sign 1 si le nombre est positif, 0 si le nombre est nul et -1 si le nombre est négatif.
 */
function signum(integer|real number) => integer;

/**
 * @brief Calcule le sinus de l'angle angle passé en paramètre
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle L'angle dont le sinus sera calculé
 * @return sine Retourne le sinus de l'angle angle
 */
function sin(integer|real angle) => real;

/**
 * @brief Calcule la racine carrée du nombre number.
 *
 * @category math
 * @cost 8 ops
 *
 * @param[in] number Nombre dont la racine sera calculée.
 * @return root Racine carrée de number.
 */
function sqrt(integer|real number) => real;

/**
 * @brief Calcule la tangente de l'angle angle (en radians).
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle Angle en radians.
 * @return tangent Tangente de angle.
 */
function tan(integer|real angle) => real;

/**
 * @brief Convertit l'angle radians en degrés.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] radians Valeur en radians
 * @return degrees Angle en degrés.
 */
function toDegrees(integer|real radians) => real;

/**
 * @brief Convertit l'angle degrees en radians.
 *
 * @category math
 * @cost 31 ops
 *
 * @param[in] degrees Valeur en degrés
 * @return radians Angle en radians.
 */
function toRadians(integer|real degrees) => real;

/**
 * @brief Renvoie le nombre de bits à 0 à la fin du nombre x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return zeros
 */
function trailingZeros(integer x) => integer;

// === string ===

/**
 * @brief Retourne le caractère de la chaîne string situé à la position position.
 *
 * Le premier caractère de la chaîne se trouve à la position 0.
 *
 * @category string
 * @cost 8 ops
 *
 * @param[in] string Chaîne dont on veut récupérer un caractère.
 * @param[in] position Position du caractère à trouver.
 * @return char chaîne contenant le caractère recherché, ou une chaîne vide si la position est
 *     invalide.
 */
function charAt(string string, integer|real position) => string;

/**
 * @brief Renvoie le codepoint unicode (32 bits, nombre entier) situé à la position index (ou 0 par défaut) dans la chaîne string.
 *
 * *Exemple* : codePointAt('salut', 1) // 97 (caractère 'a')
 *
 * @category string
 * @cost 5 ops
 *
 * @param[in] string
 * @param[in] index (optionnel)
 * @return codePoint
 */
function codePointAt(string string, integer index) => integer;
function codePointAt(string string) => integer;

/**
 * @brief Détermine si une chaîne search se trouve dans une chaîne string.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Chaîne dans laquelle la recherche sera effectuée.
 * @param[in] search Chaîne à rechercher.
 * @return contains true si search est dans string, false sinon.
 */
function contains(string string, string search) => boolean;

/**
 * @brief Détermine si une chaîne string se termine par une chaîne suffix.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Chaîne dans laquelle la recherche sera effectuée
 * @param[in] suffix Suffixe à rechercher
 * @return endsWith true si string se termine par suffix
 */
function endsWith(string string, string suffix) => boolean;

/**
 * @brief Détermine la position de la première occurrence de la chaîne search dans la chaîne string,…
 *
 * à partir de la position start.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string La chaîne où la recherche sera effectuée.
 * @param[in] search La chaîne à rechercher.
 * @param[in] start (optionnel) La position de départ de la recherche.
 * @return index La position de la première occurrence de search dans string à partir de start, -1 si
 *     la chaîne n'a pas été trouvée.
 */
function indexOf(string string, string search, integer|real start) => integer;
function indexOf(string string, string search) => integer;

/**
 * @brief Renvoie la longueur de la chaîne string.
 *
 * @category string
 * @cost 15 ops
 *
 * @param[in] string La chaîne dont la longueur sera retournée.
 * @return length La longueur de la chaîne string.
 */
function length(string string) => integer;

/**
 * @brief Remplace toutes les occurrences de search par replace dans la chaîne string.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Chaîne dans laquelle les remplacements sont effectués.
 * @param[in] search Sous-chaîne à remplacer.
 * @param[in] replace Chaîne de remplacement.
 * @return string La chaîne résultat, avec les remplacements.
 */
function replace(string string, string search, string replace) => string;

/**
 * @brief Découpe la chaîne string sous-chaînes en délimitées par delimiter.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Chaîne à découper.
 * @param[in] delimiter Chaîne délimitant le passage d'un élément à un autre.
 * @param[in] limit (optionnel) Nombre d'éléments maximum du tableau.
 * @return parts Tableau contenant les sous-chaînes trouvées.
 */
function split(string string, string delimiter, integer|real limit) => Array<string>;
function split(string string, string delimiter) => Array<string>;

/**
 * @brief Vérifie si la chaîne string commence par la chaîne prefix.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Chaîne de recherche.
 * @param[in] prefix Préfixe recherché.
 * @return startsWith Vrai si la string commence par prefix.
 */
function startsWith(string string, string prefix) => boolean;

/**
 * @brief Convertit une valeur en chaîne de caractères.
 *
 * Si la valeur est déjà une chaîne, elle est renvoyée.
 * Si la valeur est nombre x, "x" est renvoyé.
 * Si la valeur est un tableau, une chaîne sous la forme "[clé1 : valeur1, clé2 : valeur2,
 * ...]" est renvoyée.
 * Si la valeur est un booléen, "true" et "false" sont respectivement renvoyées pour les
 * valeurs true et false.
 * Si la valeur est null, "null" est renvoyée.
 *
 * @category string
 * @cost 8 ops
 *
 * @param[in] value La valeur à convertir en chaîne de caractères.
 * @return string La chaîne convertie.
 */
function string(any value) => string;

/**
 * @brief Retourne la sous-chaîne de la chaîne string à partir du caractère à l'indice start et de taille length.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Chaîne à découper.
 * @param[in] start Indice du caractère de départ.
 * @param[in] length (optionnel) Longueur de la sous-chaîne.
 * @return string Sous-chaîne.
 */
function substring(string string, integer|real start, integer|real length) => string;
function substring(string string, integer|real start) => string;

/**
 * @brief Convertit les caractères majuscules de la chaîne string en minuscules.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Chaîne à transformer
 * @return string Chaîne en minuscules
 */
function toLower(string string) => string;

/**
 * @brief Convertit les caractères minuscules de la chaîne string par des majuscules.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Chaîne à transformer.
 * @return string Chaîne en majuscules.
 */
function toUpper(string string) => string;

// === array ===

/**
 * @brief Cette fonction est disponible à partir du LeekScript 4 et plus.
 *
 * Découpe la liste array en sous-listes de taille chunkSize maximum et renvoie la liste de
 * ces sous-listes. La dernière sous-liste peut contenir moins de chunkSize élements.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] chunkSize (optionnel)
 * @return chunks
 */
function arrayChunk(Array array, integer chunkSize) => Array<Array>;
function arrayChunk(Array array) => Array<Array>;

/**
 * @brief Vide la liste array de tous ses éléments.
 *
 * *Exemple* : `` var liste = [1, 2, 3, 4] arrayClear(liste) debug(liste) // [] ``
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array
 */
function arrayClear(Array array) => void;

/**
 * @brief Ajoute les deux tableaux bout à bout.
 *
 * Les clés textuelles sont conservées et toutes les clés numériques sont réindexées.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array1 Premier tableau.
 * @param[in] array2 Second tableau.
 * @return newArray Somme des deux tableaux.
 */
function arrayConcat(Array array1, Array array2) => Array;

/**
 * @brief Renvoie true si le prédicat callback appliqué à chacun des éléments de la liste renvoie true.
 *
 * *Exemples* : arrayEvery([1, 2, 3, 4, 5], x => x > 0) // true arrayEvery([1, 2, 3, 4, 5], x
 * => x % 2 == 0) // false
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] callback
 * @return every
 */
function arrayEvery(Array array, Function callback) => boolean;

/**
 * @brief Retourne un nouveau tableau contenant tous les couples clé/valeur du tableau source pour lesquels la fonction callback a renvoyé true.
 *
 * Si la fonction callback prend un paramètre, c'est la valeur du tableau source qui sera
 * envoyée, si elle prend deux paramètres c'est la clé et la valeur qui seront envoyées.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau d'origine.
 * @param[in] callback Fonction appelée pour chaque élément.
 * @return newArray Nouveau tableau.
 */
function arrayFilter(Array array, Function callback) => Array;

/**
 * @brief Retourne un nouveau tableau contenant tous les éléments du tableau source.
 *
 * Tous les éléments contenus dans un sous tableau sont extraits dans le nouveau
 * tableau.L'argument depth détermine la profondeur maximale de sous tableau à extraire.
 * var tableau = [1, 2, [[3, 4], 5], [6]];
 * debug(arrayFlatten(tableau, 1)); // [1,2,[3,4],5,6]
 *
 * @category array
 * @cost ∞
 *
 * @param[in] array Tableau d'origine.
 * @param[in] depth (optionnel) Profondeur maximale.
 * @return newArray Nouveau tableau.
 */
function arrayFlatten(Array array, integer|real depth) => Array;
function arrayFlatten(Array array) => Array;

/**
 * @brief Réduit le tableau array [v1, v2, ..., vn] par la gauche en partant de la valeur v0 et en appliquant la fonction f.
 *
 * Équivaut à :
 * f(f(f(v0, v1), v2), ...)
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau d'origine.
 * @param[in] f Fonction à appliquer.
 * @param[in] v0 Valeur de départ.
 * @return result Tableau réduit.
 */
function arrayFoldLeft(Array array, Function f, any v0) => any;

/**
 * @brief Réduit le tableau array [v1, v2, ..., vn] par la droite en partant de la valeur v0 et en appliquant la fonction f.
 *
 * Équivaut à :
 * f(v1, f(v2, ..., f(vn, v0)))
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau d'origine.
 * @param[in] f Fonction à appliquer.
 * @param[in] v0 Valeur de départ.
 * @return result Tableau réduit.
 */
function arrayFoldRight(Array array, Function f, any v0) => any;

/**
 * @brief Renvoie une table associant pour chaque élément unique de la liste array sa quantité (element => quantité).
 *
 * *Exemple* : ``leekscript var liste = [1, 1, 2, 2, 2, 2, 3, 4, 4] var frequences =
 * arrayFrequencies(liste) debug(frequences) // [1 : 2, 2 : 4, 3 : 1, 4 : 2] ``
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @return frequencies
 */
function arrayFrequencies(Array array) => Map<any, integer>;

/**
 * @brief Renvoie l'élément de la liste array à la position index.
 *
 * Si l'index est hors de la liste, renvoie defaultValue à la place.
 *
 * @category array
 * @cost 1 op
 *
 * @param[in] array
 * @param[in] index
 * @param[in] defaultValue (optionnel)
 * @return element
 */
function arrayGet(Array array, integer index, any defaultValue) => any;
function arrayGet(Array array, integer index) => any;

/**
 * @brief Appelle la fonction callback pour chaque élément du tableau.
 *
 * Si la fonction callback prend un paramètre, c'est la valeur du tableau source qui sera
 * envoyée, si elle prend deux paramètres c'est la clé et la valeur qui seront envoyées.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau d'origine.
 * @param[in] callback Fonction appelée pour chaque élément.
 */
function arrayIter(Array array, Function callback) => void;

/**
 * @brief Retourne un nouveau tableau contenant pour chaque clé du tableau source, la valeur retournée par la fonction callback.
 *
 * Si la fonction callback prend un paramètre, c'est la valeur du tableau source qui sera
 * envoyée, si elle prend deux paramètres c'est la clé et la valeur qui seront envoyées.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau d'origine.
 * @param[in] callback Fonction appelée pour chaque élément.
 * @return newArray Nouveau tableau.
 */
function arrayMap(Array array, Function callback) => Array;

/**
 * @brief Retourne l'élément de valeur maximale du tableau array.
 *
 * Pour plus d'informations sur la valeur maximale d'un tableau voir @ref sort.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau dans lequel sera recherchée la valeur maximale.
 * @return element Elément de valeur maximale.
 */
function arrayMax(Array array) => any;

/**
 * @brief Retourne l'élément de valeur minimale du tableau array.
 *
 * Pour plus d'informations sur la valeur minimale d'un tableau voir @ref sort.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau dans lequel sera recherchée la valeur minimale.
 * @return element Elément de valeur minimale.
 */
function arrayMin(Array array) => any;

/**
 * @brief Retourne un nouveau tableau contenant deux listes, dans la première se trouvent tous les couples clés/valeurs pour lesquels la fonction callback a renvoyé true, dans la seconde se trouvent tous les autres.
 *
 * Si la fonction callback prend un paramètre, c'est la valeur du tableau source qui sera
 * envoyée, si elle prend deux paramètres c'est la clé et la valeur qui seront envoyées.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau d'origine.
 * @param[in] callback Fonction appelée pour chaque élément.
 * @return newArray Nouveau tableau.
 */
function arrayPartition(Array array, Function callback) => Array<Array>;

/**
 * @brief Renvoie une liste de count éléments aléatoires de la liste array, sans doublons.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] count
 * @return random
 */
function arrayRandom(Array array, integer count) => Array;

/**
 * @brief Supprime tous les éléments égaux à element dans la liste array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] element
 */
function arrayRemoveAll(Array array, any element) => void;

/**
 * @brief Renvoie une sous-liste de array contenant tous les éléments à partir de la position start…
 *
 * jusqu'à la position end (exclu).
 * Si le paramètre d'incrément stride est passé, la fonction ne sélectionne que un élément
 * tous les stride.
 * *Exemple* : nouvelle liste contenant les éléments de la position 10 à 20 (exclu). ``
 * arraySlice(liste, 10, 20) ``
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] start
 * @param[in] end (optionnel)
 * @param[in] stride (optionnel)
 * @return slice
 */
function arraySlice(Array array, any start, any end, integer stride) => Array;
function arraySlice(Array array, any start, any end) => Array;
function arraySlice(Array array, any start) => Array;

/**
 * @brief Renvoie true si le prédicat callback appliqué à un au moins un des éléments de la liste renvoie true
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] callback
 * @return some
 */
function arraySome(Array array, Function callback) => boolean;

/**
 * @brief Trie le tableau selon l'ordre définit par la fonction callback.
 *
 * Les éléments sont comparés deux à deux, la fonction callback doit renvoyer les valeurs -1,
 * 0 ou 1 selon si la premiere valeur est avant, au même niveau ou après la seconde valeur.
 * Si la fonction callback prend 2 paramètre, ce sont les deux valeurs qui sont envoyées, si
 * elle en prend 4, ce sont les couples clé/valeur qui sont envoyés.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Tableau d'origine
 * @param[in] callback (optionnel) Fonction de tri.
 * @return sortedArray Le tableau trié
 */
function arraySort(Array array, Function callback) => Array;
function arraySort(Array array) => Array;

/**
 * @brief (No `func_arrayToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @return set
 */
function arrayToSet(Array array) => Set;

/**
 * @brief Renvoie une liste contenant tous les éléments de la liste array en éliminant les doublons.
 *
 * @category array
 * @cost O(n²)
 *
 * @param[in] array
 * @return unique
 */
function arrayUnique(Array array) => Array;

/**
 * @brief Trie le tableau array en conservant l'association clé : valeur selon l'ordre order.
 *
 * @deprecated Cette fonction est dépréciée.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Le tableau à trier.
 * @param[in] order (optionnel) L'ordre de tri : @ref SORT_ASC ou @ref SORT_DESC.
 */
function assocSort(Array array, integer|real order) => void;
function assocSort(Array array) => void;

/**
 * @brief Calcule la moyenne des éléments contenus dans le tableau array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau dont on veut calculer la moyenne.
 * @return averageValue Valeur moyenne.
 */
function average(Array<integer|real> array) => real;

/**
 * @brief Compte le nombre d'éléments du tableau array.
 *
 * @category array
 * @cost 1 op
 *
 * @param[in] array Tableau dont le nombre d'éléments sera compté.
 * @return numberOfElements Nombre d'éléments du tableau.
 */
function count(Array array) => integer;

/**
 * @brief Redimensionne le tableau array à la taille size et remplit toutes ses cases avec value.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Le tableau à remplir.
 * @param[in] value La valeur pour chaque case du tableau.
 * @param[in] size (optionnel) Le nombre de cases. Par défaut, la taille courante du tableau.
 */
function fill(Array array, any value, integer|real size) => void;
function fill(Array array, any value) => void;

/**
 * @brief Détermine si l'élément element est dans le tableau array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Le tableau de recherche.
 * @param[in] element L'élément à rechercher.
 * @return inArray vrai si l'élément est dans le tableau, faux sinon.
 */
function inArray(Array array, any element) => boolean;

/**
 * @brief Insère un élément element dans le tableau array à la position position.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Le tableau où l'élément sera inséré.
 * @param[in] element L'élément à insérer.
 * @param[in] position La position de l'insertion.
 */
function insert(Array array, any element, integer|real position) => void;

/**
 * @brief Détermine si le tableau array est vide.
 *
 * Équivalent à count(array) == 0.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array Le tableau à tester.
 * @return empty vrai si le tableau est vide, faux sinon.
 */
function isEmpty(Array array) => boolean;

/**
 * @brief Fusionne plusieurs éléments en une chaîne de caractères, en les séparant par un délimiteur glue.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Un tableau d'éléments à fusionner.
 * @param[in] glue Le délimiteur des éléments.
 * @return string La chaîne de caractère résultante de la fusion.
 */
function join(Array array, string glue) => string;

/**
 * @brief Trie le tableau array selon les clés selon l'ordre order.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Le tableau à trier.
 * @param[in] order (optionnel) L'ordre de tri : @ref SORT_ASC ou @ref SORT_DESC.
 */
function keySort(Array array, integer|real order) => void;
function keySort(Array array) => void;

/**
 * @brief Supprime la dernière case du tableau array et renvoie l'élément correspondant.
 *
 * @category array
 * @cost 5 ops
 *
 * @param[in] array Le tableau dont la dernière case sera supprimée.
 * @return element L'élément qui était dans l'ancienne dernière case.
 */
function pop(Array array) => any;

/**
 * @brief Ajoute l'élément element à la fin du tableau array.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array Le tableau où l'on veut ajouter l'élément.
 * @param[in] element L'élément à ajouter.
 */
function push(Array array, any element) => void;

/**
 * @brief Ajoute tous les éléments du tableau elements à la fin du tableau array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Le tableau où l'on veut ajouter les éléments.
 * @param[in] elements Les éléments à ajouter.
 */
function pushAll(Array array, Array elements) => void;

/**
 * @brief Supprime un élément du tableau array à la position position, et retourne l'élément supprimé.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau dont on veut supprimer un élément.
 * @param[in] position Position de l'élément à supprimer.
 * @return element L'élément enlevé du tableau.
 */
function remove(Array array, integer|real position) => any;

/**
 * @brief Supprime la première occurrence d'un élément element dans le tableau array.
 *
 * Si l'élement n'est pas trouvé, le tableau n'est pas modifié.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau dont on veut supprimer un élément.
 * @param[in] element Élement à rechercher puis à supprimer.
 */
function removeElement(Array array, any element) => void;

/**
 * @brief Supprime un élément du tableau array associé à la clé key.
 *
 * @category array
 * @cost 5 ops
 *
 * @param[in] array Tableau dont on veut supprimer un élément.
 * @param[in] key La clé associée à l'élément à supprimer.
 */
function removeKey(Array array, any key) => void;

/**
 * @brief Inverse le tableau array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau à inverser.
 */
function reverse(Array array) => void;

/**
 * @brief Recherche l'élément element dans le tableau array, à partir de la position start.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Le tableau de recherche.
 * @param[in] element L'élément à rechercher.
 * @param[in] start (optionnel) La position du début de la recherche.
 * @return pos La position de la première occurrence de l'élément element dans le tableau array, à
 *     partir de start, null si l'élément n'a pas été trouvé.
 */
function search(Array array, any element, integer|real start) => integer;
function search(Array array, any element) => integer;

/**
 * @brief Supprime la première case du tableau array et renvoie l'élément correspondant.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Le tableau dont la première case sera supprimée.
 * @return element L'élément qui était dans l'ancienne première case.
 */
function shift(Array array) => any;

/**
 * @brief Mélange un tableau de manière aléatoire.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Le tableau à mélanger.
 */
function shuffle(Array array) => void;

/**
 * @brief Trie le tableau array par ordre croissant ou décroissant.
 *
 * L'ordre croissant par défaut est :
 * Tous les booléens (d'abord faux puis vrais); Tous les nombres (classés du plus petit au
 * plus grand); Toutes les chaînes (dans l'ordre alphabétique); Tous les éléments null.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Tableau à trier.
 * @param[in] order (optionnel) @ref SORT_ASC pour trier array dans l'ordre croissant ou @ref SORT_DESC pour le trier dans
 *     l'ordre décroissant.
 */
function sort(Array array, integer|real order) => void;
function sort(Array array) => void;

/**
 * @brief Retourne un sous-tableau de array commençant à la position start et finissant à la position end.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau source.
 * @param[in] start Indice de départ.
 * @param[in] end Indice de fin.
 * @return array Sous-tableau.
 */
function subArray(Array array, integer|real start, integer|real end) => Array;

/**
 * @brief Retourne la somme de tous les éléments numériques du tableau array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau à sommer.
 * @return sum Somme des éléments du tableau.
 */
function sum(Array<integer|real> array) => real;

/**
 * @brief Ajoute l'élément element au début du tableau array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tableau dans lequel l'élément sera ajouté.
 * @param[in] element Element à ajouter.
 */
function unshift(Array array, any element) => void;

// === map ===

/**
 * @brief Renvoie la moyenne de toutes les valeurs de la table map.
 *
 * Si la table est vide, renvoie 0.0.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return average
 */
function mapAverage(Map map) => real;

/**
 * @brief Vide la table map de tous ses éléments.
 *
 * @category map
 * @cost 1 op
 *
 * @param[in] map
 */
function mapClear(Map map) => void;

/**
 * @brief Renvoie *true* si la table map contient la valeur value, *false* sinon.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] value
 * @return contains
 */
function mapContains(Map map, any value) => boolean;

/**
 * @brief Renvoie true si la table map contient la clé key, false sinon.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map
 * @param[in] key
 * @return contains
 */
function mapContainsKey(Map map, any key) => boolean;

/**
 * @brief Renvoie true si le prédicat callback appliqué à chaque élément de la table map renvoie true, false sinon.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return every
 */
function mapEvery(Map map, Function callback) => boolean;

/**
 * @brief Remplace toutes les valeurs de la table map par la valeur value.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] value
 */
function mapFill(Map map, any value) => void;

/**
 * @brief Retourne une nouvelle table contenant toutes les valeurs de la table source map pour…
 *
 * lesquels le prédicat callback appliquée a renvoyé *true*.
 * La fonction callback prend les arguments *(valeur, clé, table)* dans cet ordre.
 * *Exemple* : ``leekscript var map = [1: '1', 2: '2', 3: '3'] var result = mapFilter(map,
 * function(value, key, map) { return key % 2 == 1 }) // [1: '1', 3: '3'] ``
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return filtered
 */
function mapFilter(Map map, Function callback) => Map;

/**
 * @brief Réduit la table map en partant de la valeur v et en appliquant la fonction f pour chaque élément.
 *
 * L'ordre des éléments est indéterminé.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] f
 * @param[in] v
 * @return result
 */
function mapFold(Map map, Function f, any v) => any;

/**
 * @brief Renvoie la valeur de la table map associée à la clé key, ou default si la clé n'existe pas dans la table.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map
 * @param[in] key
 * @param[in] default (optionnel)
 * @return element
 */
function mapGet(Map map, any key, any default) => any;
function mapGet(Map map, any key) => any;

/**
 * @brief Cette fonction est disponible à partir du LeekScript 4 et plus.
 *
 * Renvoie true si la table est vide, false si elle contient au moins une (clé, valeur).
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map
 * @return isEmpty
 */
function mapIsEmpty(Map map) => boolean;

/**
 * @brief Applique la fonction callback sur tous les valeurs de la table map.
 *
 * La fonction callback prend les arguments : *valeur*, *clé*, *table* dans cet ordre.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 */
function mapIter(Map map, Function callback) => void;

/**
 * @brief Renvoie une liste contenant toutes les clés de la table map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return keys
 */
function mapKeys(Map map) => Array;

/**
 * @brief Retourne une nouvelle table contenant les valeurs retournées par la fonction callback…
 *
 * appliquée à chacun des élements de la table map.
 * La fonction callback prend les arguments *(valeur, clé, table)* dans cet ordre.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return newMap
 */
function mapMap(Map map, Function callback) => Map;

/**
 * @brief Renvoie la valeur maximale de la table map.
 *
 * Si la table est vide, renvoie null.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return max
 */
function mapMax(Map map) => real;

/**
 * @brief Renvoie une table contenant toutes les valeurs des tables map1 et map2.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map1
 * @param[in] map2
 * @return merged
 */
function mapMerge(Map map1, Map map2) => Map;

/**
 * @brief Renvoie la valeur minimale de la table map.
 *
 * Si la table est vide, renvoie null.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return min
 */
function mapMin(Map map) => real;

/**
 * @brief Ajoute ou remplace la valeur associée à la clé key par la valeur value dans la table map.
 *
 * @category map
 * @cost 3 ops
 *
 * @param[in] map
 * @param[in] key
 * @param[in] value
 * @return value
 */
function mapPut(Map map, any key, any value) => any;

/**
 * @brief Ajoute ou remplace toutes les valeurs de la table elements dans la table map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] elements
 */
function mapPutAll(Map map, Map elements) => void;

/**
 * @brief Supprime la clé key de la table map.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map
 * @param[in] key
 * @return element
 */
function mapRemove(Map map, any key) => any;

/**
 * @brief Supprime toutes les valeurs égales à value dans la table map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] value
 */
function mapRemoveAll(Map map, any value) => void;

/**
 * @brief Remplace la valeur associée à la clé key par la valeur value dans la table map seulement…
 *
 * si une valeur est déjà associée à key.
 *
 * @category map
 * @cost 3 ops
 *
 * @param[in] map
 * @param[in] key
 * @param[in] value
 * @return value
 */
function mapReplace(Map map, any key, any value) => any;

/**
 * @brief Remplace toutes les valeurs de la table map1 par les valeurs de la table map2 seulement si…
 *
 * la valeur est déjà associée à une clé.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map1
 * @param[in] map2
 */
function mapReplaceAll(Map map1, Map map2) => void;

/**
 * @brief Renvoie la clé associée à une valeur value dans la table map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] value
 * @return key
 */
function mapSearch(Map map, any value) => real;

/**
 * @brief Renvoie le nombre d'entrées dans la table map.
 *
 * @category map
 * @cost 1 op
 *
 * @param[in] map
 * @return size
 */
function mapSize(Map map) => integer;

/**
 * @brief Renvoie true si le prédicat callback appliqué à au moins un élément de la table map renvoie true, false sinon.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return some
 */
function mapSome(Map map, Function callback) => boolean;

/**
 * @brief Renvoie la somme de toutes les valeurs de la table map.
 *
 * Si la table est vide, renvoie 0.0.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return sum
 */
function mapSum(Map map) => real;

/**
 * @brief Renvoie une liste contenant toutes les valeurs de la table map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return values
 */
function mapValues(Map map) => Array;

// === leek ===

/**
 * @brief Renvoie l'id de l'IA de l'entité entity.
 *
 * Utilisez getAIID sans paramètre pour récupérer l'id de votre IA.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optionnel) L'id de l'entité dont l'id d'IA sera renvoyé.
 * @return id L'id de l'IA de l'entité entity.
 */
function getAIID(integer|real entity) => integer;
function getAIID() => integer;

/**
 * @brief Renvoie le nom de l'IA de l'entité entity.
 *
 * Utilisez getAIName() sans paramètre pour récupérer le nom de votre IA.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optionnel) L'id de l'entité dont le nom d'IA sera renvoyé.
 * @return name Le nom de l'IA de l'entité entity.
 */
function getAIName(integer|real entity) => string;
function getAIName() => string;

/**
 * @brief Retourne le bouclier absolu de l'entité d'id entity.
 *
 * Pour récupérer directement le bouclier absolu de votre entité, utilisez
 * @ref getAbsoluteShield() sans paramètre.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optionnel) L'id de l'entité dont le bouclier absolu sera retourné.
 * @return shield Le bouclier absolu de l'entité entity.
 */
function getAbsoluteShield(integer|real entity) => integer;
function getAbsoluteShield() => integer;

/**
 * @brief Retourne l'agilité de l'entité d'id entity.
 *
 * Pour récupérer directement l'agilité de votre entité, utilisez @ref getAgility() sans
 * paramètre.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optionnel) L'id de l'entité dont l'agilité sera retournée.
 * @return agility L'agilité de l'entité entity.
 */
function getAgility(integer|real entity) => integer;
function getAgility() => integer;

/**
 * @brief Renvoie le tour du combat où est apparue l'entité entity.
 *
 * Renvoie 1 s'il s'agit d'un poireau par exemple, et 5 s'il d'agit d'une invocation invoquée
 * au tour 5.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optionnel) L'id de l'entité dont le tour d'apparition sera renvoyé.
 * @return turn Le tour de combat où entity est apparue.
 */
function getBirthTurn(integer|real entity) => integer;
function getBirthTurn() => integer;

/**
 * @brief Renvoie le type de bulbe de l'entité entity.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optionnel) L'id de l'entité dont le type de bulbe sera renvoyé.
 * @return bulbType Le type de bulbe de l'entité :@ref BULB_PUNY pour un bulbe Chétif.; @ref BULB_FIRE pour un
 *     bulbe de Feu.; @ref BULB_HEALER pour un bulbe Soigneur.; @ref BULB_ROCKY pour un bulbe
 *     Rocheux.; @ref BULB_ICED pour un bulbe Glacé.; @ref BULB_LIGHTNING pour un bulbe de Foudre.;
 *     @ref BULB_METALLIC pour un bulbe Métallique.; @ref BULB_WIZARD pour un bulbe Sorcier.;
 *     @ref BULB_TACTICIAN pour un bulbe Tacticien.; @ref BULB_SAVANT pour un bulbe Savant.Retourne
 *     -1 si l'entité n'est pas un bulbe, ou null si l'entité n'existe pas.
 */
function getBulbType(integer|real entity) => integer;
function getBulbType() => integer;

/**
 * @brief Retourne la cellule où se trouve l'entité d'id entity.
 *
 * Utilisez getCell() sans paramètre pour récupérer votre cellule.
 *
 * @category leek
 * @cost 5 ops
 *
 * @param[in] entity (optionnel) L'id de l'entité dont la cellule sera retournée.
 * @return cell Le numéro de la cellule où se trouve l'entité entity.
 */
function getCell(integer|real entity) => integer;
function getCell() => integer;

/**
 * @brief Renvoie les puces de l'entité d'id entity.
 *
 * @category leek
 * @cost 40 ops
 *
 * @param[in] entity (optionnel) L'id de l'entité dont les puces seront renvoyées.
 * @return chips Un tableau contenant les ids des puces de l'entité entity.
 */
function getChips(integer|real entity) => Array<integer>;
function getChips() => Array<integer>;

/**
 * @brief Renvoie le nombre de coeurs de l'entité d'id entity.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optionnel) L'entité dont le nombre de coeurs sera retournée.
 * @return cores Le nombre de coeurs de l'entité entity.
 */
function getCores(integer|real entity) => integer;
