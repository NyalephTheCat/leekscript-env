 *
 * @param[in] weapon L'id de l'arme dont la portée minimale sera renvoyée.
 * @return minRange La portée minimale de l'arme weapon.
 */
function getWeaponMinRange(integer|real weapon) => integer;

/**
 * @brief Renvoie la portée minimale de l'arme weapon.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref getWeaponMinRange.
 * @sa getWeaponMinRange
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon L'id de l'arme dont la portée minimale sera renvoyée.
 * @return minScope La portée minimale de l'arme weapon.
 */
function getWeaponMinScope(integer|real weapon) => integer;

/**
 * @brief Renvoie le nom de l'arme weapon.
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon L'id de l'arme dont le nom sera renvoyé.
 * @return name Le nom de l'arme weapon.
 */
function getWeaponName(integer|real weapon) => string;

/**
 * @brief Renvoie les effets passifs de l'arme weapon.
 *
 * @category weapon
 * @cost 125 ops
 *
 * @param[in] weapon L'id de l'arme dont les effets passifs seront retournés.
 * @return passiveEffects Un tableau contenant les effets de l'arme weapon. Chaque effet est lui-même un tableau
 *     de la forme [type, min, max, turns, targets, modifiers]. Ces effets sont les mêmes que
 *     ceux renvoyés par @ref getWeaponEffects.
 */
function getWeaponPassiveEffects(integer|real weapon) => Array<Array>;

/**
 * @brief Détermine si l'arme weapon peut être utilisée uniquement en ligne.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref getWeaponLaunchType.
 * @sa getWeaponLaunchType
 *
 * @category weapon
 * @cost 10 ops
 *
 * @param[in] weapon L'id de l'arme à tester.
 * @return isInline vrai si l'arme est utilisable uniquement en ligne, faux sinon.
 */
function isInlineWeapon(integer|real weapon) => boolean;

/**
 * @brief Détermine si une valeur est une constante représentant une arme.
 *
 * isWeapon(WEAPON_LASER) = true;
 * isWeapon(CHIP_TELEPORTATION) = false.
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] value Le nombre à déterminer.
 * @return weapon true si la valeur est une constante d'arme.
 */
function isWeapon(integer|real value) => boolean;

/**
 * @brief Utilise l'arme sélectionnée sur l'entité entity.
 *
 * @category weapon
 * @cost 3000 ops
 *
 * @param[in] entity Entité ciblée.
 * @return result Les valeurs de retour de useWeapon sont : @ref USE_CRITICAL, en cas de coup critique;
 *     @ref USE_SUCCESS, en cas de réussite; @ref USE_FAILED, en cas de d'échec; @ref USE_INVALID_TARGET,
 *     si la cible n'existe pas; @ref USE_NOT_ENOUGH_TP, si votre entité n'a pas assez de TP;
 *     @ref USE_INVALID_POSITION, si la portée est mauvaise ou la ligne de vue n'est pas dégagée
 */
function useWeapon(integer|real entity) => integer;

/**
 * @brief Utilise l'arme sélectionnée sur la cellule cell.
 *
 * @category weapon
 * @cost 3000 ops
 *
 * @param[in] cell Cellule ciblée.
 * @return result Une valeur supérieure à 0 si l'attaque a été lancée.
 */
function useWeaponOnCell(integer|real cell) => integer;

/**
 * @brief Renvoie si l'arme weapon a besoin d'une ligne de vue pour tirer.
 *
 * @category weapon
 * @cost 10 ops
 *
 * @param[in] weapon (optionnel) L'id de l'arme à tester.
 * @return needLos true si l'arme weapon a besoin d'une ligne de vue pour tirer, false sinon.
 */
function weaponNeedLos(integer|real weapon) => boolean;
function weaponNeedLos() => boolean;

// === chip ===

