// === utils ===

/**
 * @brief Efface tous les marquages effectués par mark() et markText() sur le terrain.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Copie la valeur value passée en paramètre sur level niveaux et retourne la copie.
 *
 * Dans le cas d'un tableau par exemple, un clone(tableau, 1) copiera le tableau mais pas ses
 * éléments, un clone(tableau, 2) copiera le tableau ainsi que tous les éléments.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value La valeur à cloner
 * @param[in] level (optionnel) Le nombre de niveaux à cloner
 * @return copy La valeur clonée
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Enregistre un message object dans le log personnel, disponible dans le rapport à la fin du combat.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Le message à enregistrer.
 */
function debug(any object) => void;

/**
 * @brief Enregistre un message object dans le log personnel, disponible dans le rapport à la fin du combat, de la couleur color.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Le message à enregistrer.
 * @param[in] color La couleur du message. Vous pouvez utiliser la fonction @ref getColor.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Enregistre un message d'erreur object dans le log personnel, disponible dans le rapport à la fin du combat.
 *
 * Les messages d'erreur apparaissent en rouge dans le rapport de combat.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Le message d'erreur à enregistrer.
 */
function debugE(any object) => void;

/**
 * @brief Enregistre un message d'avertissement object dans le log personnel, disponible dans le rapport à la fin du combat.
 *
 * Les messages d'avertissement apparaissent en orange dans le rapport de combat.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Le message d'avertissement à enregistrer.
 */
function debugW(any object) => void;

/**
 * @brief Supprime le registre associé à la clé key s'il existe.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key La clé du registre à supprimer.
 */
function deleteRegister(string key) => void;

/**
 * @brief Renvoie la date du combat, au format dd/MM/yyyy.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date La date du combat.
 */
function getDate() => string;

/**
 * @brief Renvoie le nombre d'instructions que votre entité a effectué durant le tour actuel.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Le nombre d'instructions que votre entité a effectué durant le tour actuel.
 */
function getInstructionsCount() => integer;

/**
 * @brief Retourne le nombre maximal d'opérations utilisable votre l'entité.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Renvoie la limite utilisable de RAM de votre IA.
 *
 * La RAM est consommée en créant des listes, des tables et des objets.
 * La limite actuelle est de 100 mégaoctets soit 12 500 000 éléments de liste.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Renvoie le nombre d'opérations consommées par votre entité depuis le début de son tour.
 *
 * Ce nombre doit rester inférieur à @ref OPERATIONS_LIMIT pour ne pas que l'entité plante.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Nombre d'opérations consommées par votre entité depuis le début de son tour.
 */
function getOperations() => integer;

/**
 * @brief Renvoie la valeur stockée dans le registre de l'entité associé à la clé key ou null si le registre n'existe pas.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key La clé du registre dont la valeur sera retournée.
 * @return value La valeur stockée dans le registre de clé key.
 */
function getRegister(string key) => string;

/**
 * @brief Renvoie l'ensemble des registres de l'entité sous la forme d'un tableau associatif [clé du registre : valeur du registre].
 *
 * Exemple : debug(getRegisters());
 * // Affiche par exemple :
 * // ['reg1' : '314323', 'reg2' : 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Le tableau associatif correspondant à tous les registres de l'entité.
 */
function getRegisters() => Array<string>;

/**
 * @brief Renvoie le temps du combat, au format HH:mm:ss.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Le temps du combat.
 */
function getTime() => string;

/**
 * @brief Renvoie l'horodatage du combat, égual au nombre de secondes depuis le 1er janvier 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp L'horodatage du combat.
 */
function getTimestamp() => integer;

/**
 * @brief Renvoie la quantité de RAM acteullement utilisée par votre IA.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Inclut l'IA de nom ai dans l'IA courante.
 *
 * Attention, la fonction include doit être appelée uniquement dans le bloc principal, et son
 * paramètre doit être une chaîne écrite directement
 * dans le code. Pour plus d'informations, voir la section dans le tutoriel :
 * http://leekwars.com/help/tutorial#includes.
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Le nom de l'IA à inclure.
 */
function include(string ai) => void;

/**
 * @brief Décode la chaîne json en objet LeekScript (nombre, chaîne, tableau...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json La chaîne JSON à décoder.
 * @return object L'objet LeekScript décodé.
 */
function jsonDecode(string json) => any;

/**
 * @brief Encode l'objet object en chaîne JSON.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object L'objet à encoder en JSON.
 * @return json La chaîne encodée en JSON.
 */
function jsonEncode(string object) => string;

/**
 * @brief Marque une ou plusieurs cellules de la couleur indiquée en paramètre sur le terrain pour le nombre de tour indiqué en paramètre.
 *
 * Ce marquage n'est visible que par l'éleveur de l'entité.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells La cellule ou tableau de plusieurs cellules à marquer
 * @param[in] color (optionnel) Couleur du marquage
 * @param[in] duration (optionnel) Durée du marquage
 * @return success Retourne true si tout s'est bien déroulé
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Écrit un texte sur une ou plusieurs cellules de la couleur indiquée en paramètre sur le terrain pour le nombre de tour indiqué en paramètre.
 *
 * Ces textes ne sont visibles que par l'éleveur de l'entité.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells La cellule ou tableau de plusieurs cellules où écrire
 * @param[in] text (optionnel) Le texte à écrire (maximum 10 caractères)
 * @param[in] color (optionnel) Couleur du texte
 * @param[in] duration (optionnel) Durée du texte
 * @return success Retourne true si tout s'est bien déroulé
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Met en pause le combat, uniquement pour l'éleveur de l'entité qui utilise la fonction.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Stocke la valeur value dans le registre de clé key.
 *
 * La clé et la valeur sont des chaînes qui doivent contenir respectivement 100 et 5000
 * caractères au maximum. Un poireau peut posséder au maximum 100 registres, le stockage dans
 * un nouveau registre ne fonctionnera pas si tous les registres
 * sont déjà occupés.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key La clé du registre où stocker la valeur.
 * @param[in] value La valeur à stocker.
 * @return success true si l'opération s'est bien passée, false sinon.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Montre aux joueurs une cellule cell de la couleur color sur le terrain pour 1 tour.
 *
 * L'utilisation de cette fonction coûte 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell La cellule à montrer
 * @param[in] color (optionnel) Couleur du marquage
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Renvoie le type de la valeur value, parmis les types : @ref TYPE_NULL, @ref TYPE_NUMBER,…
 *
 * @ref TYPE_BOOLEAN, @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value La valeur dont le type sera retourné.
 * @return type Le type de value.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Renvoie l'id de l'entité auteur du message message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Le message dont l'auteur sera renvoyé.
 * @return entity L'id de l'entité auteur du message message.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Renvoie le tableau des paramètres du message message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Le message dont les paramètres seront renvoyés.
 * @return params Les paramètres du message message.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Renvoie le type du message message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Le message dont le type sera renvoyé (parmis @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK, etc.).
 * @return type Le type du message message.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Renvoie le tableau des messages de l'entité entity.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (optionnel) L'entité dont les messages seront renvoyés.
 * @return messages Le tableau de vos messages. Un message est représenté lui-même sous la forme d'un
 *     tableau de la forme : [auteur, type, paramètres] Les différents types de messages sont
 *     représentés par les constantes : @ref MESSAGE_HEAL : demande de soins; @ref MESSAGE_ATTACK :
 *     demande d'attaquer; @ref MESSAGE_BUFF_FORCE : demande de boost force; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Envoie un message à toute votre équipe.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Le type du message à envoyer (voir les constantes MESSAGE_*).
 * @param[in] params Les paramètres du message, qui peuvent être n'importe quelle valeur.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Envoie un message à l'entité d'id entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity L'id de l'entité auquelle sera envoyé le message.
 * @param[in] type Le type du message à envoyer (voir les constantes MESSAGE_*).
 * @param[in] params Les paramètres du message, qui peuvent être n'importe quelle valeur.
 * @return sent true si l'envoi a été effecuté, false si une erreur est survenue.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Renvoie le taux de bleu dans la couleur color, entre 0 et 255.
 *
 * Par exemple, getBlue(@ref COLOR_BLUE) = 255 et getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color La couleur dont le taux de bleu sera renvoyé.
 * @return blue Le taux de bleu dans la couleur color
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Retourne l'entier correspondant à la couleur (red, green, blue) fournie en paramètres.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Valeur du rouge entre 0 et 255.
 * @param[in] green Valeur du vert entre 0 et 255.
 * @param[in] blue Valeur du bleu entre 0 et 255.
 * @return color int correspondant à la couleur fournie en paramètre.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Renvoie le taux de vert dans la couleur color, entre 0 et 255.
 *
 * Par exemple, getGreen(@ref COLOR_GREEN) = 255 et getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color La couleur dont le taux de vert sera renvoyé.
 * @return green Le taux de vert dans la couleur color
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Renvoie le taux de rouge dans la couleur color, entre 0 et 255.
 *
 * Par exemple, getRed(@ref COLOR_RED) = 255 et getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color La couleur dont le taux de rouge sera renvoyé.
 * @return red Le taux de rouge dans la couleur color
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Vide l'ensemble set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Recherche un élément element dans l'ensemble set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Retourne la différence des ensembles set1 et set2, c'est à dire tous les éléments de set1 qui ne sont pas dans set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Calcule la disjonction exclusive de deux ensembles set1 et set2, notée set1 ⊕ set2, qui…
 *
 * sont les éléments présent dans set1 ou set2, mais pas dans les deux en même temps.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Calcule l'intersection de deux ensembles set1 et set2, notée set1 ∩ set2, qui sont les…
 *
 * éléments communs des deux ensembles.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Renvoie si un ensemble set est vide ou non.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Détermine si un ensemble set1 est un sous-ensemble de set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Insère un élément element dans l'ensemble set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Supprime un élément element de l'ensemble set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Renvoie la taille de l'ensemble set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Renvoie une liste contenant tous les éléments de l'ensemble set.
 *
 * L'ordre des éléments est arbitraire.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Calcule l'union de deux ensembles set1 et set2, notée set1 ∪ set2, qui contient tous les…
 *
 * éléments présents dans set1 ou dans set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Calcule la moyenne de l'intervalle.
 *
 * - Si l'intervalle est borné à droite et à gauche, renvoie (intervalMin(i) +
 * intervalMax(i)) / 2. - Si l'intervalle est borné uniquement à gauche, renvoie +∞. - Si
 * l'intervalle est borné uniquement à droite, renvoie -∞. - Si l'intervalle n'est pas borné
 * ou vide, renvoie NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Combine deux intervalles interval1 et interval2.
 *
 * Équivaut à l'union si leur intersection est non-vide, sinon inclut aussi l'ensemble situé
 * entre les deux.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Calcule l'intersection de deux intervalles interval1 et interval2, contenant les éléments communs aux deux.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Renvoie si l'intervalle interval est borné à gauche et à droite ou non.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Indique is l'intervalle interval est fermé à gauche et à droite.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Renvoie si l'intervalle interval est vide ou non.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Renvoie si l'intervalle interval est borné à gauche ou non.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Indique si l'intervalle interval est fermé à gauche.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Indique si l'intervalle interval est borné à droite ou non.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Indique si l'intervalle interval est fermé à droite.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Renvoie la borne supérieure de l'intervalle interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Renvoie la borne inférieure de l'intervalle interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Renvoie la taille de l'intervalle interval.
 *
 * - Si l'intervalle est borné, renvoie max - min. - Si l'intervalle n'est pas borné, renvoie
 * +∞. - Si l'intervalle est vide, renvoie 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Renvoie une liste contenant les éléments de l'intervalle interval avec un écart de step entre chaque.
 *
 * Si l'écart est négatif, prend les éléments en sens inverse.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (optionnel)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
