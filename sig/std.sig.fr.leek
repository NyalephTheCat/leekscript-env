 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip La puce dont le pourcentage d'échec sera renvoyé.
 * @return failure Pourcentage d'échec de la puce chip, un nombre entier entre 0 et 100.
 */
function getChipFailure(integer|real chip) => integer;

/**
 * @brief Renvoie le mode de lancé de la puce chip, parmi les constantes LAUNCH_TYPE_*.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip L'id de la puce dont le mode de lancé sera renvoyé.
 * @return launchType Le mode de lancé de la puce chip.
 */
function getChipLaunchType(integer|real chip) => integer;

/**
 * @brief Renvoie la portée maximale de la puce chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip La puce dont la portée maximale sera renvoyée.
 * @return maxRange La portée maximale de la puce chip.
 */
function getChipMaxRange(integer|real chip) => integer;

/**
 * @brief Renvoie la portée maximale de la puce chip.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref getChipMaxRange.
 * @sa getChipMaxRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip La puce dont la portée maximale sera renvoyée.
 * @return maxScope La portée maximale de la puce chip.
 */
function getChipMaxScope(integer|real chip) => integer;

/**
 * @brief Renvoie le nombre maximum d'utilisations possibles d'une puce sur un tour.
 *
