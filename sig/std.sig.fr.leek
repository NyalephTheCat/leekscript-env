 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip
 * @return maxUses
 */
function getChipMaxUses(integer chip) => integer;

/**
 * @brief Renvoie la portée minimale de la puce chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip La puce dont la portée minimale sera renvoyée.
 * @return minRange La portée minimale de la puce chip.
 */
function getChipMinRange(integer|real chip) => integer;

/**
 * @brief Renvoie la portée minimale de la puce chip.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref getChipMinRange.
 * @sa getChipMinRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip La puce dont la portée minimale sera renvoyée.
 * @return minScope La portée minimale de la puce chip.
 */
function getChipMinScope(integer|real chip) => integer;

/**
 * @brief Renvoie le nom de la puce chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip La puce dont le nom sera renvoyé.
 * @return name Le nom de la puce chip.
 */
function getChipName(integer|real chip) => string;

/**
 * @brief Renvoie le cooldown actuel de la puce chip de l'entité entity.
 *
 * @category chip
 * @cost 30 ops
 *
 * @param[in] chip La puce dont le cooldown actuel sera renvoyé.
 * @param[in] entity (optionnel) L'entité dont le cooldown sera renvoyé.
 * @return cooldown Le cooldown actuel de la puce chip, il s'agit du nombre de tours avant lesquels la
 *     puce deviendra utilisable, 0 si elle est actuellement utilisable.
 */
function getCooldown(integer|real chip, integer|real entity) => integer;
function getCooldown(integer|real chip) => integer;

/**
 * @brief Détermine si une valeur est une constante représentant une puce.
 *
 * isChip(CHIP_RAGE) = true;
 * isChip(WEAPON_PISTOL) = false.
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] value Le nombre à déterminer.
 * @return chip true si la valeur est une constante de puce.
 */
function isChip(integer|real value) => boolean;

/**
 * @brief Détermine si la puce chip peut être utlisée uniquement en ligne.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref getChipLaunchType.
 * @sa getChipLaunchType
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip L'id de la puce à tester.
 * @return isInline vrai si la puce est utilisable uniquement en ligne, faux sinon.
 */
function isInlineChip(integer|real chip) => boolean;

/**
 * @brief Utilise la puce CHIP_RESURRECTION pour ressusciter une entité d'id entity morte, sur la cellule cell.
 *
 * @category chip
 * @cost 500 ops
 *
 * @param[in] entity L'id de l'entité à faire revivre.
 * @param[in] cell La cellule sur laquelle l'entité réapparaîtra.
 * @return result Le résultat du lancement de la puce, parmi les constantes USE_*.
 */
function resurrect(integer|real entity, integer|real cell) => integer;

/**
 * @brief Invoque une entité déterminée par la puce chip sur la cellule cell ayant pour IA la fonction ai.
 *
 * Un nom personnalisé peut être donné avec le paramètre optionnel name.
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip La puce utilisée pour l'invocation. La puce doit être une puce de type invocation et
 *     doit être équipée sur l'entité qui utilise la fonction summon.
 * @param[in] cell La cellule ou l'invocation doit apparaître.
 * @param[in] ai L'IA de l'invocation, sous la forme d'une fonction.
 * @param[in] name (optionnel) Le nom personnalisé du bulbe (optionnel). Par défaut, le nom du type de bulbe est
 *     utilisé.
 * @return return La fonction summon a le même retour que la fonction @ref useChip.
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief Utilise le chip chip sur l'entité entity.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip à utiliser.
 * @param[in] entity (optionnel) Entité cible.
 * @return result Les valeurs de retour de useChip sont : @ref USE_CRITICAL, en cas de coup critique;
 *     @ref USE_SUCCESS, en cas de réussite; @ref USE_FAILED, en cas de d'échec; @ref USE_INVALID_TARGET,
 *     si la cible n'existe pas; @ref USE_NOT_ENOUGH_TP, si votre entité n'a pas assez de TP;
 *     @ref USE_INVALID_COOLDOWN, si la puce n'est pas encore utilisable; @ref USE_INVALID_POSITION,
 *     si la portée est mauvaise ou la ligne de vue n'est pas dégagée
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief Utilise le chip chip sur la cellule cell.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip à utiliser.
 * @param[in] cell Cellule cible.
 * @return result Une valeur supérieure à 0 si l'attaque a été lancée.
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Retourne le contenu d'une cellule d'id cell.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell L'id de la cellule dont le contenu sera retourné.
 * @return content Le contenu de la cellule cell : @ref CELL_EMPTY pour une cellule vide, @ref CELL_ENTITY pour
 *     une entité, @ref CELL_OBSTACLE pour un obstacle.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Retourne la distance entre deux cellules cell1 et cell2.
 *
 * La distance retournée est exprimée en nombre de cellules, et ne tient pas compte des
 * divers obstacles entre les deux cellules.
 * Pour obtenir la distance à vol d'oiseau, voir @ref getDistance et pour obtenir la distance du
 * chemin entre les deux cellules en évitant les obstacles, voir @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 L'id de la cellule de départ.
 * @param[in] cell2 L'id de la cellule d'arrivée.
 * @return distance La distance entre les deux cellules cell1 et cell2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Retourne l'id de la cellule se trouvant à la position (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x La position en x de la cellule.
 * @param[in] y La position en y de la cellule.
 * @return cell L'id de la cellule à la position (x, y), null si la cellule n'existe pas.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Détermine la position en X de la cellule cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell La cellule dont la position en X sera déterminée.
 * @return x La position en X de la cellule.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Détermine la position en Y de la cellule cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell La cellule dont la position en Y sera déterminée.
 * @return y La position en Y de la cellule.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Calcule la distance à vol d'oiseau entre deux cellules cell1 et cell2.
 *
 * Pour obtenir la distance en nombre de cellules, voir @ref getCellDistance, et pour obtenir la
 * longueur du chemin entre les deux cellules en esquivant les divers obstacles, voir
 * @ref getPathLength.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 La cellule de départ.
 * @param[in] cell2 La cellule d'arrivée.
 * @return distance La distance à vol d'oiseau entre les deux cellules.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Renvoie l'entité qui se trouve sur la cellule cell.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell La cellule dont on veut récupérer l'entité.
 * @return entity L'id de l'entité se trouvant sur la cellule, ou -1 si la cellule ne comporte pas
 *     d'entité.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Renvoie l'entité qui se trouve sur la cellule cell.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell La cellule dont on veut récupérer l'entité.
 * @return entity L'id de l'entité se trouvant sur la cellule, ou -1 si la cellule ne comporte pas
 *     d'entité.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Renvoie le type de terrain sur lequel se déroule le combat (usine, désert, forêt etc.),…
 *
 * parmi les constantes @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER et
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Le type de terrain.
 */
function getMapType() => integer;

/**
 * @brief Renvoie la liste des cases obstacles du terrain.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Le tableau contenant les id des cellules obstacles.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Renvoie le chemin en évitant les obstacles entre deux cellules cell1 et cell2, si celui-ci existe, en ignorant les cellules contenues dans le tableau ignoredCells.
 *
 * Si un joueur se situe sur une cellule ignorée, le chemin peut passer sur lui.
 * La cellule de départ cell1 ne fait jamais partie du chemin résultant. La cellule cell2
 * fait partie du chemin résultant si et seulement si elle est vide ou ignorée par
 * ignoredCells.
 * Si aucun chemin n'existe entre les deux cellules, getPath renvoie null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start La cellule de départ.
 * @param[in] end La cellule d'arrivée.
 * @param[in] ignoredCells (optionnel) Le tableau des cellules à ignorer.
 * @return path Le tableau contenant les cellules constituant le chemin entre les deux cellules.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Renvoie la longueur du chemin entre deux cellules cell1 et cell2, en esquivant les obstacles, en ignorant les cellules contenues dans le tableau ignoredCells.
 *
 * Cette fonction équivaut à count(getPath(cell1, cell2, ignoredCells)).
 * Si un joueur se situe sur une cellule ignorée, le chemin peut passer sur lui.
 * La cellule de départ cell1 n'est jamais comptée dans le résultat. La cellule cell2 est
 * comptée dans le résultat si et seulement si elle est vide ou ignorée par ignoredCells.
 * Si aucun chemin n'existe entre les deux cellules, getPathLength renvoie null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 La cellule de départ.
 * @param[in] cell2 La cellule d'arrivée.
 * @param[in] ignoredCells (optionnel) Le tableau des cellules à ignorer.
 * @return length La longueur du chemin entre cell1 et cell2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Détermine si une cellule est vide.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La cellule à tester.
 * @return empty vrai si la cellule est vide, faux sinon.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Détermine si le contenu de la cellule cell est une entité.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell La cellule à tester.
 * @return isEntity vrai si la cellule contient une entité, faux sinon.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Détermine si le contenu de la cellule cell est une entité.
 *
 * @deprecated Cette fonction est dépréciée. Elle est remplacée par @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La cellule à tester.
 * @return isLeek vrai si la cellule contient une entité, faux sinon.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Détermine si le contenu de la cellule cell est un obstacle.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La cellule à tester.
 * @return isObstacle vrai si la cellule contient un obstacle, faux sinon.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Détermine si deux cellules cell1 et cell2 sont sur la même ligne.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 La première cellule.
 * @param[in] cell2 La deuxième cellule.
 * @return sameLine vrai si les deux cellules sont sur la même ligne, faux sinon.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

// === fight ===

/**
 * @brief Retourne un tableau de tous vos alliés vivants dans le combat.
 *
 * @category fight
 * @cost 100 ops
 *
 * @return allies Un tableau contenant les ids de tous vos alliés vivants.
 */
function getAliveAllies() => Array<integer>;

/**
 * @brief (No `func_getAliveAlliesCount` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category fight
 * @cost 25 ops
 *
 * @return allies
 */
function getAliveAlliesCount() => integer;

/**
 * @brief Retourne un tableau de tous vos ennemis vivants dans le combat.
 *
 * @category fight
 * @cost 100 ops
 *
 * @return enemies Un tableau contenant les ids de tous vos ennemis vivants.
 */
function getAliveEnemies() => Array<integer>;

/**
 * @brief Renvoie le nombre d'ennemis vivants dans le combat.
 *
 * @category fight
 * @cost 25 ops
 *
 * @return numAliveEnemies Le nombre d'ennemis vivants.
 */
