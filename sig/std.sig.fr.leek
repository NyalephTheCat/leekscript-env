 *
 * @param[in] weapon (optionnel)
 * @return maxUses
 */
function getWeaponMaxUses(integer weapon) => integer;
function getWeaponMaxUses() => integer;

/**
 * @brief Renvoie la portée minimale de l'arme weapon.
 *
 * @category weapon
