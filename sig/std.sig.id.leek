/**
 * @brief Menyalin nilai yang diteruskan sebagai parameter pada level level dan mengembalikan salinannya.
 *
 * Dalam kasus array misalnya, clone(array, 1) akan menyalin array tetapi bukan elemennya,
 * clone(array, 2) akan menyalin array serta semua elemen.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value Nilai untuk mengkloning
 * @param[in] level (opsional) Jumlah level yang akan dikloning
 * @return copy Nilai kloning
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

