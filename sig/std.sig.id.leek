 * @cost 15 ops
 *
 * @param[in] entity (opsional) Id entitas yang kelincahannya akan dikembalikan.
 * @return agility Kelincahan entitas entitas.
 */
function getAgility(integer|real entity) => integer;
function getAgility() => integer;

