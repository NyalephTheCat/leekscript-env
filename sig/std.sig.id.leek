 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Mengembalikan konten sel dengan id cell.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell Id sel yang isinya akan dikembalikan.
 * @return content Isi sel sel: @ref CELL_EMPTY untuk sel kosong, @ref CELL_ENTITY untuk entitas, @ref CELL_OBSTACLE
 *     untuk penghalang.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Mengembalikan jarak antara dua sel sel1 dan sel2.
 *
 * Jarak yang dikembalikan dinyatakan dalam jumlah sel, dan tidak memperhitungkan berbagai
 * kendala antara dua sel.
 * Untuk mendapatkan jarak saat gagak terbang, lihat @ref getDistance dan untuk mendapatkan jarak
 * jalur antara dua sel yang menghindari rintangan, lihat @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 ID sel awal.
 * @param[in] cell2 ID sel kedatangan.
 * @return distance Jarak antara dua sel sel1 dan sel2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Mengembalikan id sel pada posisi (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x Posisi x sel.
 * @param[in] y Posisi y sel.
 * @return cell ID sel pada posisi (x, y), null jika sel tidak ada.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Menentukan posisi di X sel sel.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Sel yang posisinya di X akan ditentukan.
 * @return x Posisi sel X.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Menentukan posisi Y sel sel.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Sel yang posisinya di Y akan ditentukan.
 * @return y Posisi Y sel.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Menghitung jarak saat burung gagak terbang di antara dua sel sel1 dan sel2.
 *
 * Untuk mendapatkan jarak dalam jumlah sel, lihat @ref getCellDistance, dan untuk mendapatkan
 * panjang jalur antara dua sel yang menghindari berbagai rintangan, lihat @ref getPathLength.
 *
 * @deprecated Fungsi ini sudah tidak digunakan lagi. Itu diganti dengan @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Sel awal.
 * @param[in] cell2 Sel kedatangan.
 * @return distance Jarak saat burung gagak terbang di antara dua sel.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Mengembalikan entitas yang ada di sel sel.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Sel yang entitasnya ingin kita ambil.
 * @return entity Id entitas pada sel, atau -1 jika sel tidak memiliki entitas.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Mengembalikan entitas yang ada di sel sel.
 *
 * @deprecated Fungsi ini sudah tidak digunakan lagi. Itu diganti dengan @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Sel yang entitasnya ingin kita ambil.
 * @return entity Id entitas pada sel, atau -1 jika sel tidak memiliki entitas.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Mengembalikan jenis medan tempat pertarungan berlangsung (pabrik, gurun, hutan, dll.), di…
 *
 * antara konstanta @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER, dan
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Jenis medan.
 */
function getMapType() => integer;

/**
 * @brief Mengembalikan daftar ruang rintangan di medan.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Larik yang berisi id sel rintangan.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Mengembalikan jalur yang menghindari rintangan antara dua sel cell1 dan cell2, jika ada, abaikan sel yang terdapat dalam larik ignoredCells.
 *
 * Jika pemain berada di sel yang diabaikan, jalur dapat melewatinya.
 * Sel awal sel1 tidak pernah menjadi bagian dari jalur yang dihasilkan. Sel cell2 adalah
 * bagian dari jalur hasil jika dan hanya jika kosong atau diabaikan oleh ignoredCells.
 * Jika tidak ada jalur di antara kedua sel, getPath mengembalikan null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Sel awal.
 * @param[in] end Sel kedatangan.
 * @param[in] ignoredCells (opsional) Susunan sel yang akan diabaikan.
 * @return path Larik yang berisi sel-sel yang membentuk jalur antara dua sel.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Mengembalikan panjang jalur antara dua sel cell1 dan cell2, menghindari rintangan, mengabaikan sel yang terdapat dalam larik ignoredCells.
 *
 * Fungsi ini setara dengan count(getPath(cell1, cell2, ignoredCells)).
 * Jika pemain berada di sel yang diabaikan, jalur dapat melewatinya.
 * Sel awal sel1 tidak pernah dihitung dalam hasil. Sel cell2 dihitung dalam hasil jika dan
 * hanya jika kosong atau diabaikan oleh ignoredCells.
 * Jika tidak ada jalur di antara kedua sel, getPathLength mengembalikan null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Sel awal.
 * @param[in] cell2 Sel kedatangan.
 * @param[in] ignoredCells (opsional) Susunan sel yang akan diabaikan.
 * @return length Panjang jalur antara sel1 dan sel2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Menentukan apakah sebuah sel kosong.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Sel yang akan diuji.
 * @return empty benar jika sel kosong, salah jika tidak.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Menentukan apakah konten sel sel adalah entitas.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell Sel yang akan diuji.
 * @return isEntity benar jika sel berisi entitas, salah jika tidak.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Menentukan apakah konten sel sel adalah entitas.
 *
 * @deprecated Fungsi ini sudah tidak digunakan lagi. Itu diganti dengan @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Sel yang akan diuji.
 * @return isLeek benar jika sel berisi entitas, salah jika tidak.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Menentukan apakah konten sel sel merupakan penghalang.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Sel yang akan diuji.
 * @return isObstacle benar jika sel berisi penghalang, salah jika tidak.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Menentukan apakah dua sel sel1 dan sel2 berada di baris yang sama.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Sel pertama.
 * @param[in] cell2 Sel kedua.
 * @return sameLine benar jika kedua sel berada pada baris yang sama, salah jika tidak.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

