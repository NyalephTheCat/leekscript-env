 *
 * @param[in] object Pesan yang akan direkam.
 */
function debug(any object) => void;

/**
 * @brief Rekam pesan objek di log pribadi, tersedia dalam laporan di akhir pertarungan, dari warna warna.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Pesan yang akan direkam.
 * @param[in] color Warna pesan. Anda dapat menggunakan fungsi @ref getColor.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Merekam pesan kesalahan objek di log pribadi, tersedia dalam laporan di akhir pertarungan.
 *
 * Pesan kesalahan muncul dengan warna merah di laporan pertarungan.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Pesan kesalahan untuk login.
 */
function debugE(any object) => void;

/**
 * @brief Merekam pesan peringatan objek di log pribadi, tersedia dalam laporan di akhir pertarungan.
 *
 * Pesan peringatan muncul dalam warna oranye di laporan pertempuran.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Pesan peringatan untuk direkam.
 */
function debugW(any object) => void;

/**
 * @brief Menghapus registri yang terkait dengan kunci key jika ada.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key Kunci registri untuk dihapus.
 */
function deleteRegister(string key) => void;

/**
 * @brief Mengembalikan tanggal pertarungan, dalam format dd/MM/yyyy.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date Tanggal pertarungan.
 */
function getDate() => string;

/**
 * @brief Mengembalikan jumlah instruksi yang telah dilakukan entitas Anda selama giliran saat ini.
 *
 * @deprecated Fungsi ini sudah tidak digunakan lagi. Itu diganti dengan @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Jumlah instruksi yang dilakukan entitas Anda selama giliran saat ini.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Mengembalikan batas RAM yang dapat digunakan AI Anda.
 *
 * RAM dikonsumsi dengan membuat daftar, tabel, dan objek.
 * Batas saat ini adalah 100 megabita atau 12.500.000 item daftar.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Mengembalikan jumlah operasi yang digunakan oleh entitas Anda sejak awal giliran.
 *
 * Angka ini harus tetap lebih rendah dari @ref OPERATIONS_LIMIT agar entitas tidak mogok.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Jumlah operasi yang digunakan oleh entitas Anda sejak awal giliran.
 */
function getOperations() => integer;

/**
 * @brief Mengembalikan nilai yang disimpan dalam registri entitas yang terkait dengan kunci key…
 *
 * atau null jika registri tidak ada.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key Kunci registri yang nilainya akan dikembalikan.
 * @return value Nilai disimpan di registri kunci.
 */
function getRegister(string key) => string;

/**
 * @brief Mengembalikan kumpulan register entitas sebagai larik asosiatif [kunci registri:nilai register].
 *
 * Contoh: debug(getRegisters());
 * // Tampilan misalnya:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Array asosiatif yang sesuai dengan semua register entitas.
 */
function getRegisters() => Array<string>;

/**
 * @brief Mengembalikan waktu pertempuran, dalam format HH:mm:ss.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Waktu pertarungan.
 */
function getTime() => string;

/**
 * @brief Mengembalikan stempel waktu pertarungan, sama dengan jumlah detik sejak 1 Januari 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Stempel waktu pertarungan.
 */
function getTimestamp() => integer;

/**
 * @brief Mengembalikan jumlah RAM yang saat ini digunakan oleh AI Anda.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Sertakan AI dengan nama ai di AI saat ini.
 *
 * Peringatan, fungsi include harus dipanggil hanya di blok utama, dan parameternya harus
 * berupa string yang ditulis langsung
 * dalam kode. Untuk informasi selengkapnya, lihat bagian dalam tutorial:
 * http://leekwars.com/help/tutorial#includes .
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Nama AI untuk disertakan.
 */
function include(string ai) => void;

/**
 * @brief Mendekodekan string json ke objek LeekScript (angka, string, larik...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json String JSON untuk didekode.
 * @return object Objek LeekScript yang didekodekan.
 */
function jsonDecode(string json) => any;

/**
 * @brief Mengkodekan objek objek menjadi string JSON.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object Objek yang akan dikodekan dalam JSON.
 * @return json String yang dikodekan JSON.
 */
function jsonEncode(string object) => string;

/**
 * @brief Menandai satu atau lebih sel dengan warna yang ditunjukkan dalam parameter di tanah untuk jumlah belokan yang ditunjukkan dalam parameter.
 *
 * Penandaan ini hanya dapat dilihat oleh peternak entitas.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Sel atau larik dari beberapa sel yang akan ditandai
 * @param[in] color (opsional) Menandai warna
 * @param[in] duration (opsional) Durasi penandaan
 * @return success Mengembalikan true jika semuanya berjalan dengan baik
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Menulis teks pada satu atau lebih sel dengan warna yang ditunjukkan dalam parameter di tanah untuk jumlah belokan yang ditunjukkan dalam parameter.
 *
 * Teks-teks ini hanya dapat dilihat oleh pemulia entitas.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Sel atau larik beberapa sel yang akan ditulisi
 * @param[in] text (opsional) Teks yang akan ditulis (maksimum 10 karakter)
 * @param[in] color (opsional) Warna teks
 * @param[in] duration (opsional) Durasi teks
 * @return success Mengembalikan true jika semuanya berjalan dengan baik
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Jeda pertarungan, hanya untuk peternak entitas yang menggunakan fungsi tersebut.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Menyimpan nilai di registri kunci.
 *
 * Kunci dan nilainya adalah string yang masing-masing harus berisi 100 dan 5000 karakter.
 * Daun bawang dapat memiliki maksimum 100 register, menyimpan dalam register baru tidak akan
 * berfungsi jika semua register
 * sudah sibuk.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Kunci registri tempat menyimpan nilai.
 * @param[in] value Nilai untuk disimpan.
 * @return success benar jika operasi berhasil, salah jika tidak.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Menampilkan pemain sel dari warna warna di lapangan selama 1 giliran.
 *
 * Menggunakan fitur ini dikenai biaya 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Sel untuk ditampilkan
 * @param[in] color (opsional) Menandai warna
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Mengembalikan jenis nilai nilai, di antara jenis: @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN,…
 *
 * @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Nilai yang jenisnya akan dikembalikan.
 * @return type Jenis nilai.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Mengembalikan id entitas yang menulis pesan pesan.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Pesan yang penulisnya akan dikembalikan.
 * @return entity ID entitas pembuat pesan pesan.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Mengembalikan larik parameter pesan pesan.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Pesan yang parameternya akan dikembalikan.
 * @return params Parameter pesan pesan.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Mengembalikan jenis pesan pesan.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Pesan yang jenisnya akan dikembalikan (antara @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK, dll.).
 * @return type Jenis pesan pesan.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Mengembalikan larik pesan entitas entitas.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (opsional) Entitas yang pesannya akan dikembalikan.
 * @return messages Tabel pesan Anda. Pesan itu sendiri direpresentasikan dalam bentuk a larik bentuk:
 *     [penulis, ketik, parameter] Berbagai jenis pesan diwakili oleh konstanta:
 *     @ref MESSAGE_HEAL: permintaan perhatian; @ref MESSAGE_ATTACK: permintaan untuk menyerang;
 *     @ref MESSAGE_BUFF_FORCE: paksa permintaan peningkatan; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Kirim pesan ke seluruh tim Anda.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Jenis pesan yang akan dikirim (lihat konstanta MESSAGE_*).
 * @param[in] params Parameter pesan, yang dapat berupa nilai apa pun.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Mengirim pesan ke entitas dengan id entitas.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity Id entitas tujuan pengiriman pesan.
 * @param[in] type Jenis pesan yang akan dikirim (lihat konstanta MESSAGE_*).
 * @param[in] params Parameter pesan, yang dapat berupa nilai apa pun.
 * @return sent benar jika pengiriman berhasil, salah jika terjadi kesalahan.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Mengembalikan jumlah biru dalam warna warna, antara 0 dan 255.
 *
 * Misalnya, getBlue(@ref COLOR_BLUE) = 255 dan getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Warna yang rate birunya akan dikembalikan.
 * @return blue Tingkat biru dalam warna warna
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Mengembalikan bilangan bulat yang sesuai dengan warna (merah, hijau, biru) yang diberikan sebagai parameter.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Nilai merah antara 0 dan 255.
 * @param[in] green Nilai hijau antara 0 dan 255.
 * @param[in] blue Nilai biru antara 0 dan 255.
 * @return color int sesuai dengan warna yang diberikan sebagai parameter.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Mengembalikan jumlah warna hijau dalam warna warna, antara 0 dan 255.
 *
 * Misalnya, getGreen(@ref COLOR_GREEN) = 255 dan getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Warna yang tingkat hijaunya akan dikembalikan.
 * @return green Tingkat hijau dalam warna warna
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Mengembalikan jumlah warna merah dalam warna warna, antara 0 dan 255.
 *
 * Misalnya, getRed(@ref COLOR_RED) = 255 dan getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Warna yang rate merahnya akan dikembalikan.
 * @return red Tingkat merah dalam warna warna
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Menghapus set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Mencari elemen elemen dalam set set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Mengembalikan perbedaan antara set set1 dan set2, yaitu semua elemen set1 yang tidak ada di set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Menghitung disjungsi eksklusif dari dua set set1 dan set2, dengan catatan set1 ⊕ set2,…
 *
 * yang merupakan elemen-elemen yang ada di set1 atau set2, tetapi tidak di kedua set
 * tersebut secara bersamaan.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Menghitung perpotongan dua set set1 dan set2, dengan mencatat set1 ∩ set2, yang merupakan elemen umum dari dua set.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Mengembalikan apakah set kosong atau tidak.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Menentukan apakah sebuah himpunan himpunan1 adalah subset dari himpunan2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Menyisipkan elemen elemen ke dalam set set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Menghapus elemen elemen dari set set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Mengembalikan ukuran set set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Mengembalikan daftar yang berisi semua elemen set set.
 *
 * Urutan elemen-elemennya bisa berubah-ubah.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Menghitung gabungan dua set set1 dan set2, dilambangkan set1 ∪ set2, yang berisi semua…
 *
 * elemen yang ada di set1 atau di set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Menghitung rata-rata interval.
 *
 * - Jika interval dibatasi kiri dan kanan, kembalikan (intervalMin(i) + intervalMax(i)) / 2.
 * - Jika interval hanya dibatasi di sebelah kiri, mengembalikan +∞. - Jika interval hanya
 * dibatasi di sebelah kanan, mengembalikan -∞. - Jika interval tidak terbatas atau kosong,
 * mengembalikan NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Menggabungkan dua interval interval1 dan interval2.
 *
 * Setara dengan gabungan jika perpotongannya tidak kosong, jika tidak, juga menyertakan
 * himpunan di antaranya.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Menghitung perpotongan dua interval interval1 dan interval2, yang berisi elemen-elemen yang sama pada keduanya.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Mengembalikan apakah interval interval dibatasi di kiri dan kanan atau tidak.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Pengembaliannya adalah interval interval tertutup di kiri dan kanan atau tidak.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Mengembalikan apakah interval kosong atau tidak.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Mengembalikan apakah interval interval terikat ke kiri atau tidak.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Mengembalikan apakah interval ditutup di sebelah kiri atau tidak.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Mengembalikan apakah interval interval berbatas kanan atau tidak.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Mengembalikan apakah interval interval tertutup di sebelah kanan atau tidak.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Mengembalikan batas atas interval interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Mengembalikan batas bawah interval interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Mengembalikan ukuran interval interval.
 *
 * - Jika interval dibatasi, mengembalikan max - min. - Jika interval tidak berbatas,
 * mengembalikan +∞. - Jika interval kosong, mengembalikan 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Mengembalikan daftar yang berisi elemen-elemen interval interval dengan jarak step di antara masing-masing.
 *
 * Jika intervalnya negatif, mengambil elemen dalam urutan terbalik.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (opsional)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
