 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (オプション) ブリーダー ID が返されるエンティティの ID。
 * @return id entity エンティティ ブリーダーの ID。
 */
function getFarmerID(integer|real entity) => integer;
function getFarmerID() => integer;

/**
 * @brief entity エンティティのブリーダー名を返します。
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (オプション) ブリーダー名が返されるエンティティの ID。
 * @return name エンティティエンティティのブリーダーの名前。
 */
function getFarmerName(integer|real entity) => string;
function getFarmerName() => string;

/**
 * @brief ID entity のエンティティの強度を返します。
 *
 * @deprecated この関数は非推奨です。 @ref getStrength に置き換えられます。
