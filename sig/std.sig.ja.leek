function moveTowardCells(Array<integer> cells, integer|real mp) => integer;
function moveTowardCells(Array<integer> cells) => integer;

/**
 * @brief 最大 mp の移動ポイントを使用して、エンティティを エンティティ のセットに近づけます。
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities エンティティがアプローチするエンティティの ID を含む配列。
 * @param[in] mp (オプション) 使用するMPの最大数。デフォルトでは制限なし。
 * @return mp 使用される移動ポイントの数。
 */
function moveTowardEntities(Array<integer> entities, integer|real mp) => integer;
function moveTowardEntities(Array<integer> entities) => integer;

/**
 * @brief 最大 mp の移動ポイントを使用して、エンティティを エンティティ のセットに近づけます。
 *
 * @deprecated この関数は非推奨です。 @ref moveTowardEntities に置き換えられます。
 * @sa moveTowardEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] leeks エンティティがアプローチするエンティティの ID を含む配列。
 * @param[in] mp (オプション) 使用するMPの最大数。デフォルトでは制限なし。
 * @return mp 使用される移動ポイントの数。
 */
function moveTowardLeeks(Array<integer> leeks, integer|real mp) => integer;
function moveTowardLeeks(Array<integer> leeks) => integer;

/**
 * @brief 最大 mp 移動ポイントを使用して、エンティティを 2 つのセル cell1 と cell2 で定義される線に近づけます。
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 セル 1。
 * @param[in] cell2 セル 2。
 * @param[in] mp (オプション) 使用するMPの最大数。デフォルトでは制限なし。
 * @return mp 使用される移動ポイントの数。
 */
function moveTowardLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveTowardLine(integer|real cell1, integer|real cell2) => integer;

// === utils ===

/**
 * @brief フィールド内の mark() および markText() によって作成されたすべてのマーキングをクリアします。
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief level レベルでパラメータとして渡された value をコピーし、そのコピーを返します。たとえば、配列の場合、clone(array, 1)…
 *
 * は配列をコピーしますが、その要素はコピーしません。clone(array, 2) は配列とすべての要素をコピーします。
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value 複製する値
 * @param[in] level (オプション) 複製するレベルの数
 * @return copy 複製された値
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief 個人ログに オブジェクト メッセージを記録し、戦闘終了時にレポートで確認できます。
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 記録するメッセージ。
 */
function debug(any object) => void;

/**
 * @brief オブジェクト メッセージを個人ログに記録します。これは、戦闘終了時にレポートで利用できる、色 色 のものです。
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 記録するメッセージ。
 * @param[in] color メッセージの色。 @ref getColor 関数を使用できます。
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief オブジェクトのエラー メッセージを個人ログに記録し、戦闘終了時にレポートで確認できます。
 *
 * エラー メッセージは戦闘レポートに赤で表示されます。
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object ログに記録するエラー メッセージ。
 */
function debugE(any object) => void;

/**
 * @brief オブジェクトの警告メッセージを個人ログに記録し、戦闘終了時にレポートで確認できます。
 *
 * 警告メッセージは、戦闘レポートにオレンジ色で表示されます。
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 記録する警告メッセージ。
 */
function debugW(any object) => void;

/**
 * @brief キー key に関連付けられているレジストリが存在する場合は削除します。
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key 削除するレジストリ キー。
 */
function deleteRegister(string key) => void;

/**
 * @brief 試合の日付を dd/MM/yyyy 形式で返します。
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date 戦いの日付。
 */
function getDate() => string;

/**
 * @brief 現在のターン中にエンティティが実行した命令の数を返します。
 *
 * @deprecated この関数は非推奨です。 @ref getOperations に置き換えられます。
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions 現在のターン中にエンティティが実行した命令の数。
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief AI の使用可能な RAM 制限を返します。 RAM は、リスト、テーブル、およびオブジェクトの作成によって消費されます。
 *
 * 現在の制限は 100 メガバイトまたは 12,500,000 リスト アイテムです。
 * ＃＃＃＃ フィードバック
 * - ram: RAM の制限。
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief ターンの開始以降、エンティティによって消費された操作の数を返します。エンティティがクラッシュしないように、この数は @ref OPERATIONS_LIMIT よりも小さくする必要があります。
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations ターンの開始以降にエンティティによって消費された操作の数。
 */
function getOperations() => integer;

/**
 * @brief キー key に関連付けられたエンティティ レジストリに格納されている値を返します。レジストリが存在しない場合は null を返します。
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key 値が返されるレジストリ キー。
 * @return value key レジストリに格納されている値。
 */
function getRegister(string key) => string;

/**
 * @brief 一連のエンティティ レジスタを連想配列 [レジストリ キー:レジスタ値] として返します。例: debug(getRegisters());
 *
 * // 表示例:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers エンティティのすべてのレジスタに対応する連想配列。
 */
function getRegisters() => Array<string>;

/**
 * @brief 戦闘時間を HH:mm:ss 形式で返します。
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time 戦いの時。
 */
function getTime() => string;

/**
 * @brief 1970 年 1 月 1 日からの秒数に等しい、戦いのタイムスタンプを返します。
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp 戦闘のタイムスタンプ。
 */
function getTimestamp() => integer;

/**
 * @brief AI が現在使用している RAM の量を返します。
 *
 * ＃＃＃＃ フィードバック
 * - ram: 現在使用されている RAM。
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief ai という名前の AI を現在の AI に含めます。
 *
 * 警告、インクルード関数はメイン ブロックでのみ呼び出す必要があり、そのパラメーターは直接記述された文字列でなければなりません
 * コードで。詳細については、チュートリアルのセクション http://leekwars.com/help/tutorial#includes を参照してください。
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai 含める AI の名前。
 */
function include(string ai) => void;

/**
 * @brief 文字列 json を LeekScript オブジェクト (数値、文字列、配列...) にデコードします。
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json デコードする JSON 文字列。
 * @return object デコードされた LeekScript オブジェクト。
 */
function jsonDecode(string json) => any;

/**
 * @brief object オブジェクトを JSON 文字列にエンコードします。
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object JSON でエンコードするオブジェクト。
 * @return json JSON でエンコードされた文字列。
 */
function jsonEncode(string object) => string;

/**
 * @brief パラメータで指定されたターン数の間、パラメータで指定された色の 1 つまたは複数のセルを地面にマークします。このマーキングは、エンティティのブリーダーのみが見ることができます。
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells マークするセルまたは複数のセルの配列
 * @param[in] color (オプション) マーキング色
 * @param[in] duration (オプション) マーキング期間
 * @return success すべてがうまくいった場合は true を返します
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief パラメータで指定されたターン数の間、地面のパラメータで指定された色の 1 つ以上のセルにテキストを書き込みます。これらのテキストは、エンティティの育成者にのみ表示されます。
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells 書き込むセルまたは複数のセルの配列
 * @param[in] text (オプション) 書くテキスト（最大10文字）
 * @param[in] color (オプション) テキストの色
 * @param[in] duration (オプション) テキストの長さ
 * @return success すべてがうまくいった場合は true を返します
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief 関数を使用しているエンティティのブリーダーに対してのみ、戦いを一時停止します。
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief 値をキーレジストリに保存します。
 *
 * キーと値は、それぞれ最大で 100 文字と 5000 文字を含む文字列です。ネギは最大 100
 * 個のレジスターを持つことができます。すべてのレジスターがある場合、新しいレジスターへの保存は機能しません。
 * すでに占有されています。
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key 値を格納するレジストリ キー。
 * @param[in] value 格納する値。
 * @return success 操作が成功した場合は true、それ以外の場合は false。
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief 1 ターンの間、プレイヤーに color の色の cell を表示します。この機能の使用には 1PT のコストがかかります。
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell 表示するセル
 * @param[in] color (オプション) マーキング色
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief タイプ @ref TYPE_NULL、@ref TYPE_NUMBER、@ref TYPE_BOOLEAN、@ref TYPE_STRING、@ref TYPE_ARRAY、@ref TYPE_FUNCTION の中から値 value のタイプを返します。
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value タイプが返される値。
 * @return type 値のタイプ。
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief メッセージ メッセージ を作成したエンティティの ID を返します。
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message 作成者が返されるメッセージ。
 * @return entity メッセージ メッセージ を作成するエンティティの ID。
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief メッセージ パラメータ message の配列を返します。
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message パラメータが返されるメッセージ。
 * @return params メッセージ メッセージ パラメータ。
 */
function getMessageParams(Array message) => any;

/**
 * @brief メッセージ タイプ メッセージ を返します。
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message タイプが返されるメッセージ (@ref MESSAGE_HEAL、@ref MESSAGE_ATTACK など)。
 * @return type メッセージ タイプ メッセージ。
 */
function getMessageType(Array message) => integer;

/**
 * @brief entity エンティティ メッセージ配列を返します。
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (オプション) メッセージが返されるエンティティ。
 * @return messages メッセージの表。 メッセージ自体は、 形式の配列: [作成者、タイプ、パラメータ] さまざまなタイプのメッセージが定数で表されます。 @ref MESSAGE_HEAL:
 *     ケアのリクエスト; @ref MESSAGE_ATTACK: 攻撃のリクエスト; @ref MESSAGE_BUFF_FORCE: 強制ブースト リクエスト; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief チーム全体にメッセージを送信します。
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type 送信するメッセージのタイプ (MESSAGE_* 定数を参照)。
 * @param[in] params メッセージ パラメータ。任意の値を指定できます。
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief ID entity のエンティティにメッセージを送信します。
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity メッセージの送信先エンティティの ID。
 * @param[in] type 送信するメッセージのタイプ (MESSAGE_* 定数を参照)。
 * @param[in] params メッセージ パラメータ。任意の値を指定できます。
 * @return sent 送信が成功した場合は true、エラーが発生した場合は false。
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief 色 color の青の量を 0 から 255 の範囲で返します。たとえば、getBlue(@ref COLOR_BLUE) = 255 および getBlue(@ref COLOR_GREEN) = 0 です。
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 青率が返される色。
 * @return blue 色 color の青の比率
 */
function getBlue(integer|real color) => integer;

/**
 * @brief パラメータとして指定された色 (赤、緑、青) に対応する整数を返します。
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red 0 ～ 255 の赤の値。
 * @param[in] green 0 ～ 255 の緑の値。
 * @param[in] blue 0 から 255 までの青の値。
 * @return color パラメーターとして提供される色に対応する int。
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief 色 color の緑の量を 0 から 255 の範囲で返します。たとえば、getGreen(@ref COLOR_GREEN) = 255 および getGreen(@ref COLOR_RED) = 0 です。
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 緑率が返される色。
 * @return green 色 color の緑の割合
 */
function getGreen(integer|real color) => integer;

/**
 * @brief 色 color の赤の量を 0 から 255 の間で返します。たとえば、getRed(@ref COLOR_RED) = 255 および getRed(@ref COLOR_BLUE) = 0 です。
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 赤率が返される色。
 * @return red 色の赤の割合 color
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief セット**をクリアする。
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief 要素 element を集合 set の中から探す。
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief set1とset2の差、つまりset1の要素でset2**に含まれないものをすべて返します。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief 2つの集合 set1 と set2 の排他的論理和を計算します（set1 set2 と表記）。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief set1∩set2` と表記される、2つの集合 set1 と set2 の交点を計算します。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief セット** が空であるかどうかを返す。
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief 集合 set1 が set2 の部分集合であるかどうかを判定する。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief 要素elementを集合setに挿入する。
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief 要素 element を集合 set から削除する。
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief set**セットのサイズを返す。
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief setToArray は、set セットのすべての要素を含むリストを返します。
 *
 * 要素の順序は任意である。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief 2つの集合 set1 と set2 の和を計算し、set1 ∪ set2 とする。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief 区間平均を計算する。
 *
 * - 区間が左右に区切られている場合、 (intervalMin(i) + intervalMax(i)) / 2 を返す。 - 区間が左側のみで区切られている場合、 +∞ を返す。
 * - 区間が右側にのみ境界がある場合， -∞ を返す． - 区間が非有界または空の場合， NaN を返す．
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief 二つの区間interval1とinterval2を結合する。
 *
 * 両者の交点が空でない場合は論理和に等しく、そうでない場合はその間の集合も含まれます。
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief 2つの区間interval1とinterval2の交点を計算します。
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief 区間intervalが左右で境界を持つかどうかを返す。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief 区間intervalが左右に閉じているかどうかを返します。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief interval**が空かどうかを返す。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief 区間intervalが左回りかどうかを返す。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief 区間**が左で閉じているかどうかを返します。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief 区間intervalが右有界であるか否かを返す。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief 区間intervalが右で閉じているかどうかを返します。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief 区間intervalの上限値を返します。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief 区間intervalの下限を返します。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief 区間intervalのサイズを返します。
 *
 * - 区間が有界の場合、 max - min を返す。 - 区間が有界でない場合、 +∞ を返す。 - 区間が空の場合、 0 を返す。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief 区間intervalの要素を、各要素の間にstepを含むリストを返す。
 *
 * 区間が負の場合、要素を逆順に取り出す。
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (オプション)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
