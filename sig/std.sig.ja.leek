 * @param[in] weapon 最小範囲が返される武器の ID。
 * @return minScope 武器武器の最小射程。
 */
function getWeaponMinScope(integer|real weapon) => integer;

/**
 * @brief 武器武器の名前を返します。
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon 名前が返される武器の ID。
 * @return name 武器武器の名前。
 */
function getWeaponName(integer|real weapon) => string;

/**
 * @brief 武器の武器のパッシブ効果を返します。
 *
 * @category weapon
 * @cost 125 ops
 *
 * @param[in] weapon パッシブ効果が返される武器の ID。
 * @return passiveEffects 武器武器の効果を含む配列。各効果は、それ自体が次の形式の配列です。 [タイプ、最小、最大、ターン、ターゲット、修飾子]。これらの効果は、@ref getWeaponEffects
 *     によって返されるものと同じです。
 */
function getWeaponPassiveEffects(integer|real weapon) => Array<Array>;

/**
 * @brief 武器武器がオンラインでのみ使用できるかどうかを決定します。
 *
 * @deprecated この関数は非推奨です。 @ref getWeaponLaunchType に置き換えられます。
 * @sa getWeaponLaunchType
 *
 * @category weapon
 * @cost 10 ops
 *
 * @param[in] weapon テストする武器の ID。
 * @return isInline 武器がオンラインでのみ使用できる場合は true、それ以外の場合は false。
 */
function isInlineWeapon(integer|real weapon) => boolean;

/**
 * @brief 値が武器を表す定数かどうかを決定します。
 *
 * isWeapon(WEAPON_LASER) = true;
 * isWeapon(CHIP_TELEPORTATION) = false。
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] value 決定する数。
 * @return weapon 値が武器定数の場合は true。
 */
function isWeapon(integer|real value) => boolean;

/**
 * @brief 選択した武器をエンティティに使用。
 *
 * @category weapon
 * @cost 3000 ops
 *
 * @param[in] entity ターゲット エンティティ。
 * @return result UseWeapon の戻り値は次のとおりです。 クリティカル ヒットで @ref USE_CRITICAL; @ref USE_SUCCESS、成功した場合;
 *     @ref USE_FAILED、失敗時; @ref USE_INVALID_TARGET、ターゲットが存在しない場合; @ref USE_NOT_ENOUGH_TP、エンティティに十分な TP
 *     がない場合; @ref USE_INVALID_POSITION、範囲が悪いか、見通しがはっきりしない場合
 */
function useWeapon(integer|real entity) => integer;

/**
 * @brief セルセルで選択した武器を使用します。
 *
 * @category weapon
 * @cost 3000 ops
 *
 * @param[in] cell 標的細胞。
 * @return result 攻撃が開始された場合は 0 より大きい値。
 */
function useWeaponOnCell(integer|real cell) => integer;

/**
 * @brief 武器の武器が発砲するために照準線が必要かどうかを返します。
 *
 * @category weapon
 * @cost 10 ops
 *
 * @param[in] weapon (オプション) テストする武器の ID。
 * @return needLos 武器の武器を発射するために照準線が必要な場合はtrue、それ以外の場合はfalse。
 */
function weaponNeedLos(integer|real weapon) => boolean;
function weaponNeedLos() => boolean;

// === chip ===

/**
 * @brief ID entity のエンティティでエンティティが chip チップを使用できるかどうかを決定します。
 *
 * @category chip
 * @cost 45 ops
 *
 * @param[in] chip テストするチップの番号。
 * @param[in] entity チップを使用するエンティティ ID。
 * @return canUse エンティティがチップを使用できる場合は true、そうでない場合は false。
 */
function canUseChip(integer|real chip, integer|real entity) => boolean;

/**
 * @brief エンティティが cell セルで chip チップを使用できるかどうかを決定します。
 *
 * @category chip
 * @cost 45 ops
 *
 * @param[in] chip テストするチップの番号。
 * @param[in] cell チップを使用するセルの番号。
 * @return canUse エンティティがチップを使用できる場合は true、それ以外の場合は false。
 */
function canUseChipOnCell(integer|real chip, integer|real cell) => boolean;

/**
 * @brief チップが見通し線を使用する必要があるかどうかを返します。
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip テストするチップの ID。
 * @return needLos チップが見通し線を使用する必要がある場合はtrue、それ以外の場合はfalse。
 */
function chipNeedLos(integer|real chip) => boolean;

/**
 * @brief ゲーム内のすべてのチップのリストを返します。
 *
 * @category chip
 * @cost 200 ops
 *
 * @return chips ゲーム内のすべてのチップのリスト。
 */
function getAllChips() => Array<integer>;

/**
 * @brief チップの効果タイプの領域を返します。
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip ゾーン タイプが返されるチップ。
 * @return area AREA_* 定数の中のチップ chip の領域タイプ: @ref AREA_POINT: 単一の正方形エリア; @ref AREA_LASER_LINE: レーザーのライン;
 *     @ref AREA_CIRCLE_1: 直径 3 マスの円形エリア; @ref AREA_CIRCLE_2: 直径 5 マスの円形領域; @ref AREA_CIRCLE_3: 直径 7
 *     マスの円形エリア
 */
function getChipArea(integer|real chip) => integer;

/**
 * @brief マーケットから取得した chip チップの回収時間を返します。
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip クールダウンが返されるチップ。
 * @return cooldown チップのクールダウン。
 */
function getChipCooldown(integer|real chip) => integer;

/**
 * @brief チップ chip のコストを TP で返します。
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip かかったチップは戻ってきます。
 * @return cost チップのコスト。
 */
function getChipCost(integer|real chip) => integer;

/**
 * @brief chip チップが from セルの cell セルで使用された場合に影響を受けるセルのリストを返します。
 *
 * @category chip
 * @cost 78 ops
 *
 * @param[in] chip テストするチップ。
 * @param[in] cell ターゲット セル。
 * @param[in] from (オプション) チップが使用されるセル。
 * @return cells 影響を受けるすべてのセルの ID を含む配列。
 */
function getChipEffectiveArea(integer|real chip, integer|real cell, integer|real from) => Array<integer>;
function getChipEffectiveArea(integer|real chip, integer|real cell) => Array<integer>;

/**
 * @brief chip チップの効果を返します。
 *
 * @category chip
 * @cost 125 ops
 *
 * @param[in] chip 効果が返されるチップ。
 * @return effects チップ チップの効果。 @ref getWeaponEffects 関数と同じ戻り値。
 */
function getChipEffects(integer|real chip) => Array<Array>;

/**
 * @brief チップ chip の故障リスクのパーセンテージを返します。
 *
 * @deprecated この関数は非推奨です。
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip 失敗率が返されるチップ。
 * @return failure chip チップの故障率。0 から 100 までの整数。
 */
function getChipFailure(integer|real chip) => integer;

/**
 * @brief LAUNCH_TYPE_* 定数の中から chip チップの起動モードを返します。
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip スロー モードが返されるチップの ID。
 * @return launchType chipチップの投げ方。
 */
function getChipLaunchType(integer|real chip) => integer;

/**
 * @brief chip チップの最大範囲を返します。
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip 最大範囲が返されるチップ。
 * @return maxRange チップの最大範囲。
 */
function getChipMaxRange(integer|real chip) => integer;

/**
 * @brief chip チップの最大範囲を返します。
 *
 * @deprecated この関数は非推奨です。 @ref getChipMaxRange に置き換えられます。
 * @sa getChipMaxRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip 最大範囲が返されるチップ。
 * @return maxScope チップの最大範囲。
 */
function getChipMaxScope(integer|real chip) => integer;

/**
 * @brief (No `func_getChipMaxUses` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip
 * @return maxUses
 */
function getChipMaxUses(integer chip) => integer;

/**
 * @brief chip チップの最小範囲を返します。
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip 最小範囲が返されるチップ。
 * @return minRange チップの最小範囲。
 */
function getChipMinRange(integer|real chip) => integer;

/**
 * @brief chip チップの最小範囲を返します。
 *
 * @deprecated この関数は非推奨です。 @ref getChipMinRange に置き換えられます。
 * @sa getChipMinRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip 最小範囲が返されるチップ。
 * @return minScope チップの最小範囲。
 */
function getChipMinScope(integer|real chip) => integer;

/**
 * @brief チップ chip の名前を返します。
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip 名前が返されるチップ。
 * @return name chip チップの名前。
 */
function getChipName(integer|real chip) => string;

/**
 * @brief entity エンティティの現在の chip クールダウンを返します。
 *
 * @category chip
 * @cost 30 ops
 *
 * @param[in] chip 現在のクールダウンが返されるチップ。
 * @param[in] entity (オプション) クールダウンが返されるエンティティ。
 * @return cooldown チップ chip の現在のクールダウン。これは、チップが使用可能になるまでのターン数です。現在使用可能な場合は 0 です。
 */
function getCooldown(integer|real chip, integer|real entity) => integer;
function getCooldown(integer|real chip) => integer;

/**
 * @brief 値がチップを表す定数かどうかを判断します。
 *
 * isChip(CHIP_RAGE) = true;
 * isChip(WEAPON_PISTOL) = false。
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] value 決定する数。
 * @return chip 値がチップ定数の場合は true。
 */
function isChip(integer|real value) => boolean;

/**
 * @brief チップをオンラインでのみ使用できるかどうかを決定します。
 *
 * @deprecated この関数は非推奨です。 @ref getChipLaunchType に置き換えられます。
 * @sa getChipLaunchType
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip テストするチップの ID。
 * @return isInline チップがオンラインのみの場合は true、それ以外の場合は false。
 */
function isInlineChip(integer|real chip) => boolean;

/**
 * @brief CHIP_RESURRECTION チップを使用して、セル cell で、ID entity の死んだエンティティを復活させます。
 *
 * @category chip
 * @cost 500 ops
 *
 * @param[in] entity 復活させるエンティティの ID。
 * @param[in] cell エンティティが再表示されるセル。
 * @return result 定数 USE_* の中で、チップを起動した結果。
 */
function resurrect(integer|real entity, integer|real cell) => integer;

/**
 * @brief IA の関数 ai を持つセル cell 上のチップ chip によって決定されるエンティティを呼び出します。
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip 召喚に使うチップ。チップは召喚タイプのチップでなければならず、召喚機能を使用するエンティティに装備する必要があります。
 * @param[in] cell セルまたは召喚が表示されます。
 * @param[in] ai 関数としての呼び出し AI。
 * @param[in] name (オプション)
 * @return return 召喚関数は @ref useChip 関数と同じリターンを持ちます。
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief エンティティ entity でチップ chip を使用します。
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip 使用するチップ。
 * @param[in] entity (オプション) ターゲット エンティティ。
 * @return result UseChip の戻り値は次のとおりです。 クリティカル ヒットで @ref USE_CRITICAL; @ref USE_SUCCESS、成功した場合; @ref USE_FAILED、失敗時;
 *     @ref USE_INVALID_TARGET、ターゲットが存在しない場合; @ref USE_NOT_ENOUGH_TP、エンティティに十分な TP がない場合;
 *     @ref USE_INVALID_COOLDOWN、チップがまだ使用できない場合; @ref USE_INVALID_POSITION、範囲が悪い場合、または見通しがはっきりしない場合
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief セル cell でチップ chip を使用します。
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip 使用するチップ。
 * @param[in] cell 標的細胞。
 * @return result 攻撃が開始された場合は 0 より大きい値。
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief ID cell のセルの内容を返します。
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell コンテンツが返されるセルの ID。
 * @return content cell セルの内容: 空のセルは @ref CELL_EMPTY、エンティティは @ref CELL_ENTITY、障害物は @ref CELL_OBSTACLE。
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief 2 つのセル cell1 と cell2 の間の距離を返します。
 *
 * 返される距離はセルの数で表され、2 つのセル間のさまざまな障害物は考慮されていません。
 * カラスが飛ぶ距離を取得するには、@ref getDistance を参照してください。障害物を回避する 2 つのセル間の経路距離を取得するには、@ref getPathLength
 * を参照してください。
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 開始セルの ID。
 * @param[in] cell2 到着セルの ID。
 * @return distance cell1 と cell2 の 2 つのセル間の距離。
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief 位置 (x, y) のセルの ID を返します。
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x セルの x 位置。
 * @param[in] y セルの y 位置。
 * @return cell 位置 (x, y) のセル ID。セルが存在しない場合は null。
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief セル cell の X 方向の位置を決定します。
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell X での位置が決定されるセル。
 * @return x セルの X 位置。
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief セル cell の Y 位置を決定します。
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Y での位置が決定されるセル。
 * @return y セルの Y 位置。
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief cell1 と cell2 の 2 つのセルの間をカラスが飛ぶ距離を計算します。
 *
 * セルの数で距離を取得するには、@ref getCellDistance を参照してください。さまざまな障害物を回避する 2
 * つのセル間のパスの長さを取得するには、@ref getPathLength を参照してください。
 *
 * @deprecated この関数は非推奨です。 @ref getCellDistance に置き換えられます。
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 開始セル。
 * @param[in] cell2 到着セル。
 * @return distance カラスが 2 つのセルの間を飛ぶ距離。
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief セル cell にあるエンティティを返します。
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell エンティティを取得するセル。
 * @return entity セル上のエンティティの ID、またはセルにエンティティがない場合は -1。
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief セル cell にあるエンティティを返します。
 *
 * @deprecated この関数は非推奨です。 @ref getEntityOnCell に置き換えられます。
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell エンティティを取得するセル。
 * @return entity セル上のエンティティの ID、またはセルにエンティティがない場合は -1。
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief 定数 @ref MAP_NEXUS、@ref MAP_FACTORY、@ref MAP_DESERT、@ref MAP_FOREST、@ref MAP_GLACIER、@ref MAP_BEACH の中から、戦闘が行われる地形のタイプ (工場、砂漠、森など) を返します。
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType 地形のタイプ。
 */
function getMapType() => integer;

/**
 * @brief 地形内の障害物スペースのリストを返します。
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles 障害物セル ID を含む配列。
 */
function getObstacles() => Array<integer>;

/**
 * @brief 2 つのセル cell1 と cell2 の間の障害物を回避するパスを返します。存在する場合は、配列 ignoredCells に含まれるセルを無視します。プレイヤーが無視されたセルにいる場合、パスはその上を通過できます。
 *
 * 開始セル cell1 は、結果のパスの一部にはなりません。セル cell2 は、空であるか、ignoredCells によって無視される場合にのみ、結果のパスの一部になります。
 * 2 つのセル間にパスが存在しない場合、getPath は null を返します。
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start 開始セル。
 * @param[in] end 到着セル。
 * @param[in] ignoredCells (オプション) 無視するセルの配列。
 * @return path 2 つのセル間のパスを構成するセルを含む配列。
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief 2 つのセル cell1 と cell2 の間のパスの長さを返します。障害物を避け、配列 ignoredCells…
 *
 * に含まれるセルを無視します。この関数は、count(getPath(cell1, cell2, ignoredCells)) と同等です。
 * プレイヤーが無視されたセルにいる場合、パスはその上を通過できます。
 * 開始セル cell1 は結果にカウントされません。セル cell2 は、空であるか、ignoredCells によって無視された場合にのみ、結果にカウントされます。
 * 2 つのセル間にパスが存在しない場合、getPathLength は null を返します。
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 開始セル。
 * @param[in] cell2 到着セル。
 * @param[in] ignoredCells (オプション) 無視するセルの配列。
 * @return length cell1 と cell2 の間のパスの長さ。
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief セルが空かどうかを判断します。
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell テストするセル。
 * @return empty セルが空の場合は true、それ以外の場合は false。
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief セル cell の内容がエンティティかどうかを判断します。
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell テストするセル。
 * @return isEntity セルにエンティティが含まれている場合は true、そうでない場合は false。
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief セル cell の内容がエンティティかどうかを判断します。
 *
 * @deprecated この関数は非推奨です。 @ref isEntity に置き換えられます。
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell テストするセル。
 * @return isLeek セルにエンティティが含まれている場合は true、そうでない場合は false。
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief セル cell の内容が障害物かどうかを判断します。
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell テストするセル。
 * @return isObstacle セルに障害物が含まれている場合は true、そうでない場合は false。
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief 2 つのセル cell1 と cell2 が同じ行にあるかどうかを判断します。
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 最初のセル。
 * @param[in] cell2 2 番目のセル。
 * @return sameLine 2 つのセルが同じ行にある場合は true、それ以外の場合は false。
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

// === fight ===

/**
 * @brief 戦闘中に生存しているすべての味方の配列を返します。
 *
 * @category fight
 * @cost 100 ops
 *
 * @return allies 生存しているすべての味方の ID を含む配列。
 */
function getAliveAllies() => Array<integer>;

/**
 * @brief (No `func_getAliveAlliesCount` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category fight
 * @cost 25 ops
 *
 * @return allies
 */
function getAliveAlliesCount() => integer;

/**
 * @brief 戦闘中に生きているすべての敵の配列を返します。
 *
 * @category fight
 * @cost 100 ops
 *
