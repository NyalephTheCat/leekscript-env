 * @return force entity エンティティの強さ。
 */
function getForce(integer|real entity) => integer;
function getForce() => integer;

/**
 * @brief ID entity のエンティティの頻度を返します。パラメータを指定せずに getFrequency() を使用して、頻度を取得します。
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (オプション) 頻度が返されるエンティティ。
