 *
 * @param[in] entity (オプション) 再生順序が返されるエンティティの ID
 * @return turnOrder エンティティ entity のプレイ順
 */
function getEntityTurnOrder(integer|real entity) => integer;
function getEntityTurnOrder() => integer;

/**
