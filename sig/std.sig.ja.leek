 */
function getFrequency(integer|real entity) => integer;
function getFrequency() => integer;

/**
 * @brief (No `func_getItemUses` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] item
 * @return uses
 */
function getItemUses(integer item) => integer;

/**
 * @brief ID entity のエンティティによって引き起こされる効果のリストを返します。
 *
 * @category leek
 * @cost 25 ops
 *
 * @param[in] entity (オプション) 引き起こされた効果のリストが返されるエンティティの ID。
 * @return effects @ref getEffects によって返される配列と同じ形式の、ID entity を持つエンティティによって引き起こされる効果のリスト。
 */
function getLaunchedEffects(integer|real entity) => Array<Array>;
