// === field ===

/**
 * @brief 返回 ID 为 cell 的单元格的内容。
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell 将返回其内容的单元格的 ID。
 * @return content cell 单元格的内容：@ref CELL_EMPTY 表示空单元格，@ref CELL_ENTITY 表示实体，@ref CELL_OBSTACLE 表示障碍物。
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief 返回两个单元格 cell1 和 cell2 之间的距离。
 *
 * 返回的距离以单元格数表示，不考虑两个单元格之间的各种障碍物。
 * 要获取乌鸦飞行时的距离，请参见@ref getDistance，要获取两个单元之间避开障碍物的路径距离，请参见@ref getPathLength。
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 起始单元格的 ID。
 * @param[in] cell2 到达小区的 ID。
 * @return distance 两个单元格 cell1 和 cell2 之间的距离。
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief 返回位置 (x, y) 处的单元格 ID。
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x 单元格的 x 位置。
 * @param[in] y 单元格的 y 位置。
 * @return cell 位置 (x, y) 的单元格 ID，如果单元格不存在，则为 null。
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief 确定单元格 cell 在 X 中的位置。
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell 将确定其在 X 中的位置的单元格。
 * @return x 单元格的 X 位置。
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief 确定单元格 cell 的 Y 位置。
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell 将确定其在 Y 中的位置的单元格。
 * @return y 单元格的 Y 位置。
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief 计算乌鸦在两个单元格 cell1 和 cell2 之间飞行时的距离。
 *
 * 要获取以单元格数量表示的距离，请参阅@ref getCellDistance，要获取两个单元格之间躲避各种障碍物的路径长度，请参阅@ref getPathLength。
 *
 * @deprecated 此功能已弃用。 它被 @ref getCellDistance 取代。
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 起始细胞。
 * @param[in] cell2 到达细胞。
 * @return distance 乌鸦在两个单元格之间飞行的距离。
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief 返回单元格 cell 上的实体。
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell 我们要检索其实体的单元格。
 * @return entity 单元格上实体的 ID，如果单元格没有实体，则为 -1。
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief 返回单元格 cell 上的实体。
 *
 * @deprecated 此功能已弃用。 它被 @ref getEntityOnCell 取代。
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell 我们要检索其实体的单元格。
 * @return entity 单元格上实体的 ID，如果单元格没有实体，则为 -1。
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief 返回发生战斗的地形类型（工厂、沙漠、森林等），在常量@ref MAP_NEXUS、@ref MAP_FACTORY、@ref MAP_DESERT、@ref MAP_FOREST、@ref MAP_GLACIER 和@ref MAP_BEACH 中。
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType 地形类型。
 */
function getMapType() => integer;

/**
 * @brief 返回地形中障碍空间的列表。
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles 包含障碍单元 ID 的数组。
 */
function getObstacles() => Array<integer>;

/**
 * @brief 返回避开两个单元格 cell1 和 cell2 之间的障碍物的路径，如果存在，则忽略数组 ignoredCells 中包含的单元格。如果玩家在被忽略的单元格上，路径可以越过他们。
 *
 * 起始单元格 cell1 永远不会成为结果路径的一部分。当且仅当单元格 cell2 为空或被 ignoredCells 忽略时，单元格 cell2 才是结果路径的一部分。
 * 如果两个单元格之间不存在路径，getPath 返回 null。
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start 起始细胞。
 * @param[in] end 到达细胞。
 * @param[in] ignoredCells (选修的) 要忽略的单元格数组。
 * @return path 包含构成两个单元格之间路径的单元格的数组。
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief 返回两个单元格 cell1 和 cell2 之间的路径长度，避开障碍物，忽略数组 ignoredCells 中包含的单元格。此函数等效于 count(getPath(cell1, cell2, ignoredCells))。
 *
 * 如果玩家在被忽略的单元格上，路径可以越过他们。
 * 起始单元格 cell1 永远不会计入结果。当且仅当单元格 cell2 为空或被 ignoredCells 忽略时，它才会计入结果。
 * 如果两个单元格之间不存在路径，getPathLength 返回 null。
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 起始细胞。
 * @param[in] cell2 到达细胞。
 * @param[in] ignoredCells (选修的) 要忽略的单元格数组。
 * @return length cell1 和 cell2 之间的路径长度。
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief 确定单元格是否为空。
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell 要测试的电池。
