 * @cost 100 ops
 *
 * @param[in] object 要记录的消息。
 * @param[in] color 消息的颜色。您可以使用@ref getColor 函数。
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief 在个人日志中记录一条对象错误信息，可在战斗结束时的报告中找到。
 *
 * 错误信息在战斗报告中以红色显示。
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 要记录的错误消息。
 */
function debugE(any object) => void;

/**
 * @brief 在个人日志中记录一条对象警告消息，可在战斗结束时的报告中找到。
 *
 * 战斗报告中的警告信息以橙色显示。
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 要记录的警告消息。
 */
function debugW(any object) => void;

/**
 * @brief 删除与密钥 key 关联的注册表（如果存在）。
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key 要删除的注册表项。
 */
function deleteRegister(string key) => void;

/**
 * @brief 以 dd/MM/yyyy 格式返回战斗日期。
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date 战斗的日期。
 */
function getDate() => string;

/**
 * @brief 返回您的实体在当前回合中执行的指令数。
 *
 * @deprecated 此功能已弃用。 它被 @ref getOperations 取代。
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions 您的实体在当前回合中执行的指令数。
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief 返回您的 AI 的可用 RAM 限制。创建列表、表格和对象会消耗 RAM。
 *
 * 当前限制为 100 兆字节或 12,500,000 个列表项。
 * ＃＃＃＃ 反馈
 * - ram：内存限制。
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief 返回您的实体自其回合开始以来消耗的操作数。此数字必须保持低于@ref OPERATIONS_LIMIT，这样实体才不会崩溃。
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations 您的实体自回合开始以来消耗的操作数。
 */
function getOperations() => integer;

/**
 * @brief 返回存储在与键 key 关联的实体注册表中的值，如果注册表不存在，则返回 null。
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key 将返回其值的注册表项。
 * @return value 存储在 key 注册表中的值。
 */
function getRegister(string key) => string;

/**
 * @brief 将实体寄存器集作为关联数组 [注册表键:寄存器值] 返回。示例：调试（getRegisters()）；
 *
 * // 显示例如：
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers 实体所有寄存器对应的关联数组。
 */
function getRegisters() => Array<string>;

/**
 * @brief 返回战斗时间，格式为 HH:mm:ss。
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time 战斗的时间。
 */
function getTime() => string;

/**
 * @brief 返回战斗的时间戳，等于自 1970 年 1 月 1 日以来的秒数。
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp 战斗的时间戳。
 */
function getTimestamp() => integer;

/**
 * @brief 返回您的 AI 当前使用的 RAM 量。
 *
 * ＃＃＃＃ 反馈
 * - ram：当前使用的 RAM。
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief 在当前AI中包含名称为ai的AI。
 *
 * 警告，include函数只能在主块中调用，参数必须是直接写的字符串
 * 在代码中。有关详细信息，请参阅教程中的部分：http://leekwars.com/help/tutorial#includes。
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai 要包含的 AI 的名称。
 */
function include(string ai) => void;

/**
 * @brief 将字符串 json 解码为 LeekScript 对象（数字、字符串、数组...）。
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json 要解码的 JSON 字符串。
 * @return object 解码后的 LeekScript 对象。
 */
function jsonDecode(string json) => any;

/**
 * @brief 将 object 对象编码为 JSON 字符串。
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object 要在 JSON 中编码的对象。
 * @return json JSON 编码的字符串。
 */
function jsonEncode(string object) => string;

/**
 * @brief 根据参数中指示的圈数，在地面上用参数中指示的颜色标记一个或多个单元格。此标记仅对实体的饲养者可见。
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells 要标记的单元格或多个单元格的数组
 * @param[in] color (选修的) 标记颜色
 * @param[in] duration (选修的) 打标时间
 * @return success 如果一切顺利则返回真
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief 根据参数中指示的圈数，在地面上参数中指示的颜色的一个或多个单元格上写入文本。这些文本仅对实体的培育者可见。
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells 要写入的单元格或多个单元格的数组
 * @param[in] text (选修的) 要写的文本（最多 10 个字符）
 * @param[in] color (选修的) 文字颜色
 * @param[in] duration (选修的) 文字时长
 * @return success 如果一切顺利则返回真
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief 暂停战斗，仅适用于使用该功能的实体的饲养员。
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief 将 value 存储在 key 注册表中。
 *
 * 键和值是字符串，最多分别包含100和5000字符。一个韭菜最多可以有100个寄存器，如果所有的寄存器都存储在一个新的寄存器中是行不通的
 * 已经被占用。
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key 存储值的注册表项。
 * @param[in] value 要存储的值。
 * @return success true 如果操作成功，false 否则。
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief 向玩家显示场上 color 颜色的 cell 1 回合。使用此功能需要 1PT。
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell 要显示的单元格
 * @param[in] color (选修的) 标记颜色
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief 返回值 value 的类型，类型包括：@ref TYPE_NULL、@ref TYPE_NUMBER、@ref TYPE_BOOLEAN、@ref TYPE_STRING、@ref TYPE_ARRAY、@ref TYPE_FUNCTION。
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value 将返回其类型的值。
 * @return type 值的类型。
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief 返回创作消息的实体的 ID 消息。
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message 将返回其作者的邮件。
 * @return entity 编写消息 message 的实体的 ID。
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief 返回消息参数数组 message。
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message 将返回其参数的消息。
 * @return params 消息消息参数。
 */
function getMessageParams(Array message) => any;

/**
 * @brief 返回消息类型消息。
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message 将返回其类型的消息（@ref MESSAGE_HEAL、@ref MESSAGE_ATTACK 等）。
 * @return type 消息类型消息。
 */
function getMessageType(Array message) => integer;

/**
 * @brief 返回 entity 实体消息数组。
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (选修的) 将返回其消息的实体。
 * @return messages 您的消息表。 消息本身以 形式的数组：[author, type, parameters] 不同类型的消息由常量表示： @ref MESSAGE_HEAL：请求护理;
 *     @ref MESSAGE_ATTACK：请求攻击; @ref MESSAGE_BUFF_FORCE：强制提升请求; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief 向您的整个团队发送消息。
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type 要发送的消息类型（请参阅 MESSAGE_* 常量）。
 * @param[in] params 消息参数，可以是任意值。
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief 向 ID 为 entity 的实体发送消息。
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity 消息将发送到的实体的 ID。
 * @param[in] type 要发送的消息类型（请参阅 MESSAGE_* 常量）。
 * @param[in] params 消息参数，可以是任意值。
 * @return sent true 如果发送成功，false 如果发生错误。
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief 返回颜色 color 中的蓝色量，介于 0 和 255 之间。例如，getBlue(@ref COLOR_BLUE) = 255 和 getBlue(@ref COLOR_GREEN) = 0。
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 将返回蓝色率的颜色。
 * @return blue 颜色color中蓝色的比例
 */
function getBlue(integer|real color) => integer;

/**
 * @brief 返回与作为参数提供的颜色（红色、绿色、蓝色）相对应的整数。
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red 红色值介于 0 和 255 之间。
 * @param[in] green 绿色值介于 0 和 255 之间。
 * @param[in] blue 蓝色值介于 0 和 255 之间。
 * @return color 与作为参数提供的颜色相对应的 int。
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief 返回颜色 color 中的绿色量，介于 0 和 255 之间。例如，getGreen(@ref COLOR_GREEN) = 255 和 getGreen(@ref COLOR_RED) = 0。
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 将返回其绿色率的颜色。
 * @return green 颜色color中绿色的比例
 */
function getGreen(integer|real color) => integer;

/**
 * @brief 返回颜色 color 中红色的数量，介于 0 和 255 之间。例如，getRed(@ref COLOR_RED) = 255 和 getRed(@ref COLOR_BLUE) = 0。
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 将返回其红色率的颜色。
 * @return red 颜色color中红色的比例
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief 清除集。
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief 在集合set中搜索元素element。
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief 返回集合 set1 和 set2 的差值，即 set1 中不在 set2 中的所有元素。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief 计算两个集合 set1和 set2的排他析取，记为set1 ⊕ set2，即存在于 set1或 set2中的元素，但不同时存在于两个集合中。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief 计算两个集合set1和set2的交集，记为set1 ∩ set2，即两个集合的公共元素。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief 返回 set 是否为空。
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief 确定集合 set1 是否是 set2 的子集。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief 将元素 element 插入集合 set 中。
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief 从集合 set 中删除元素 element 。
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief 返回 set 集合的大小。
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief 返回包含 set 集合所有元素的列表。
 *
 * 元素的顺序是任意的。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief 计算两个集合 set1和 set2的联合，表示set1∪set2，其中包含 set1或 set2中的所有元素。
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief 计算区间平均数。
 *
 * - 如果区间有左界和右界，则返回 (intervalMin(i) + intervalMax(i)) /2。 - 如果区间只有左边界，则返回 +∞。 -
 * 如果区间只在右边有界，则返回 -∞。 - 如果区间无界或为空，则返回 NaN。
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief 合并两个区间 interval1 和 interval2。
 *
 * 如果它们的交集是非空的，则等同于合并，否则也包括中间的集合。
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief 计算两个区间 interval1 和 interval2 的交集，包含两个区间的共同元素。
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief 返回区间 interval 的左右两边是否有界。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief 返回区间 interval 左右两边是否闭合。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief 返回 interval 是否为空。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief 返回区间 interval 是否左界。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief 返回 区间是否向左关闭。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief 返回区间 interval 是否有右界。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief 返回区间 interval 是否向右闭合。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief 返回区间 interval 的上限。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief 返回区间 interval 的下限。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief 返回区间 interval 的大小。
 *
 * - 如果区间有界，则返回 max - min。 - 如果区间没有边界，则返回 +∞。 - 如果区间为空，则返回 0。
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief 返回一个列表，其中包含区间 interval 的元素，每个元素之间的距离为 step 。
 *
 * 如果区间为负数，则按相反顺序取元素。
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (选修的)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
