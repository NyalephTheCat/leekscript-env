 * @return dead entity가 죽은 경우 true, 살아 있으면 false입니다.
 */
function isDead(integer|real entity) => boolean;

/**
 * @brief 개체가 당신의 적인지 판단합니다.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity 테스트할 엔터티의 ID입니다.
 * @return isEnemy 엔티티가 적이라면 참, 아군이거나 자신이라면 거짓입니다.
 */
function isEnemy(integer|real entity) => boolean;

/**
 * @brief 엔티티가 정적인지 여부를 반환합니다.
 *
 * 정적 엔터티는 이동하거나 이동할 수 없습니다.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (선택 과목) 테스트할 엔터티의 ID입니다.
 * @return static entity가 정적이면 true, 그렇지 않으면 false입니다.
 */
function isStatic(integer|real entity) => boolean;
function isStatic() => boolean;

/**
 * @brief 엔티티가 호출인지 여부를 반환합니다.
 *
 * @category leek
 * @cost 10 ops
 *
 * @param[in] entity (선택 과목) 테스트할 엔터티의 ID입니다.
 * @return summon entity가 호출이면 true, 그렇지 않으면 false입니다.
 */
function isSummon(integer|real entity) => boolean;
function isSummon() => boolean;

/**
 * @brief 이전 엔터티의 say() 배열을 [entity_id, message] 형식으로 반환합니다.
 *
 * @category leek
 * @cost 78 ops
 *
 * @return messages 이전 say()의 배열입니다.
 */
function listen() => Array;

/**
 * @brief 엔티티가 말하게하십시오.
 *
 * @category leek
 * @cost 30 ops
 *
 * @param[in] message 귀하의 엔티티가 경기장에서 발표할 메시지입니다.
 */
function say(string message) => void;

/**
 * @brief 독립체에 무기 무기를 장착하십시오.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] weapon 장착할 무기의 이드.
 */
function setWeapon(integer|real weapon) => void;

// === weapon ===

/**
 * @brief 엔티티가 무기 무기로 ID가 엔티티인 엔티티를 쏠 수 있는지 결정합니다.
