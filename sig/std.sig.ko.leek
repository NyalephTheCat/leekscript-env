 * @param[in] cell2 셀 2.
 * @param[in] mp (선택 과목) 사용할 수 있는 최대 MP 수입니다. 기본적으로 제한이 없습니다.
 * @return mp 사용된 이동 포인트 수입니다.
 */
function moveTowardLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveTowardLine(integer|real cell1, integer|real cell2) => integer;

// === utils ===

/**
 * @brief 필드에서 mark() 및 markText()로 만든 모든 표시를 지웁니다.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief 수준 수준에서 매개변수로 전달된 값을 복사하고 복사본을 반환합니다.
 *
 * 예를 들어 배열의 경우 clone(array, 1)은 배열을 복사하지만 요소는 복사하지 않고 clone(array, 2)는 배열과 모든 요소를 복사합니다.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value 복제할 값
 * @param[in] level (선택 과목) 복제할 레벨 수
 * @return copy 복제된 값
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief 개인 로그에 개체 메시지를 기록하고 전투 종료 시 보고서에서 확인할 수 있습니다.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 녹음할 메시지입니다.
 */
function debug(any object) => void;

/**
 * @brief 개인 로그에 색상 색상의 개체 메시지를 기록합니다.
 *
 * 전투 종료 시 보고서에서 확인할 수 있습니다.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 녹음할 메시지입니다.
 * @param[in] color 메시지의 색상입니다. @ref getColor 기능을 사용할 수 있습니다.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief 개인 로그에 개체 오류 메시지를 기록하고 전투 종료 시 보고서에서 확인할 수 있습니다.
 *
 * 오류 메시지는 전투 보고서에 빨간색으로 표시됩니다.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 기록할 오류 메시지입니다.
 */
function debugE(any object) => void;

/**
 * @brief 개인 로그에 개체 경고 메시지를 기록하고 전투 종료 시 보고서에서 확인할 수 있습니다.
 *
 * 전투 보고서에 경고 메시지가 주황색으로 표시됩니다.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object 기록할 경고 메시지입니다.
 */
function debugW(any object) => void;

/**
 * @brief 키 key가 있는 경우 해당 레지스트리를 삭제합니다.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key 삭제할 레지스트리 키입니다.
 */
function deleteRegister(string key) => void;

/**
 * @brief 경기 날짜를 dd/MM/yyyy 형식으로 반환합니다.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date 싸움의 날짜.
 */
function getDate() => string;

/**
 * @brief 엔티티가 현재 턴 동안 수행한 명령 수를 반환합니다.
 *
 * @deprecated 이 기능은 더 이상 사용되지 않습니다. @ref getOperations로 대체됩니다.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions 엔티티가 현재 턴 동안 수행한 명령의 수입니다.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief AI의 사용 가능한 RAM 제한을 반환합니다.
 *
 * RAM은 목록, 테이블 및 개체를 만드는 데 사용됩니다.
 * 현재 제한은 100MB 또는 12,500,000개의 목록 항목입니다.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief 차례가 시작된 이후 엔티티가 소비한 작업 수를 반환합니다.
 *
 * 엔티티가 충돌하지 않도록 이 숫자는 @ref OPERATIONS_LIMIT보다 낮게 유지되어야 합니다.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations 차례가 시작된 이후 엔터티에서 사용한 작업 수입니다.
 */
function getOperations() => integer;

/**
 * @brief 레지스트리가 존재하지 않는 경우 key 또는 null 키와 연결된 엔터티 레지스트리에 저장된 값을 반환합니다.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key 값이 반환될 레지스트리 키입니다.
 * @return value 키 레지스트리에 저장된 값입니다.
 */
function getRegister(string key) => string;

/**
 * @brief 엔티티 레지스터 집합을 연관 배열 [레지스트리 키:등록 값]으로 반환합니다.
 *
 * 예: debug(getRegisters());
 * // 예를 들면 다음과 같이 표시됩니다.
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers 엔터티의 모든 레지스터에 해당하는 연관 배열입니다.
 */
function getRegisters() => Array<string>;

/**
 * @brief 전투 시간을 HH:mm:ss 형식으로 반환합니다.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time 싸움의 시간.
 */
function getTime() => string;

/**
 * @brief 1970년 1월 1일 이후의 초 수와 동일한 싸움의 타임스탬프를 반환합니다.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp 싸움의 타임 스탬프.
 */
function getTimestamp() => integer;

/**
 * @brief AI가 현재 사용하고 있는 RAM의 양을 반환합니다.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief 현재 AI에 이름이 ai인 AI를 포함합니다.
 *
 * 경고, include 함수는 메인 블록에서만 호출해야 하며 해당 매개변수는 직접 작성된 문자열이어야 합니다.
 * 코드에서. 자세한 내용은 튜토리얼의 섹션을 참조하세요. http://leekwars.com/help/tutorial#includes .
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai 포함할 AI의 이름.
 */
function include(string ai) => void;

/**
 * @brief 문자열 json을 LeekScript 객체(숫자, 문자열, 배열...)로 디코딩합니다.
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json 디코딩할 JSON 문자열입니다.
 * @return object 디코딩된 LeekScript 개체입니다.
 */
function jsonDecode(string json) => any;

/**
 * @brief 객체 객체를 JSON 문자열로 인코딩합니다.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object JSON으로 인코딩할 개체입니다.
 * @return json JSON 인코딩 문자열입니다.
 */
function jsonEncode(string object) => string;

/**
 * @brief 매개변수에 표시된 회전 수만큼 바닥에 매개변수에 표시된 색상의 하나 이상의 셀을 표시합니다.
 *
 * 이 표시는 독립체의 사육자만 볼 수 있습니다.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells 표시할 셀 또는 여러 셀의 배열
 * @param[in] color (선택 과목) 마킹 색상
 * @param[in] duration (선택 과목) 마킹 기간
 * @return success 모든 것이 잘되면 true를 반환합니다.
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief 파라미터에 표시된 회전 수만큼 지면에 파라미터에 표시된 색상의 하나 이상의 셀에 텍스트를 씁니다.
 *
 * 이 텍스트는 독립체의 사육자만 볼 수 있습니다.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells 쓸 셀 또는 여러 셀의 배열
 * @param[in] text (선택 과목) 작성할 텍스트(최대 10자)
 * @param[in] color (선택 과목) 텍스트 색상
 * @param[in] duration (선택 과목) 텍스트 길이
 * @return success 모든 것이 잘되면 true를 반환합니다.
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief 기능을 사용하는 개체의 사육자에게만 전투를 일시 중지합니다.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief 키 레지스트리에 값을 저장합니다.
 *
 * 키와 값은 각각 최대 100 및 5000자를 포함해야 하는 문자열입니다. 리크는 최대 100개의 레지스터를 가질 수 있으며, 모든 레지스터가
 * 이미 점유되어 있습니다.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key 값을 저장할 레지스트리 키입니다.
 * @param[in] value 저장할 값입니다.
 * @return success 작업이 성공하면 true, 그렇지 않으면 false입니다.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief 플레이어에게 1턴 동안 필드에서 색상 색상의 셀을 보여줍니다.
 *
 * 이 기능을 사용하는 비용은 1PT입니다.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell 표시할 셀
 * @param[in] color (선택 과목) 마킹 색상
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN, @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION 유형 중에서 값 값의 유형을 반환합니다.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value 반환할 유형의 값입니다.
 * @return type 값의 유형입니다.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief 메시지 message를 작성하는 엔터티의 ID를 반환합니다.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message 작성자가 반환될 메시지입니다.
 * @return entity 메시지 message를 작성하는 엔터티의 ID입니다.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief 메시지 매개변수 message의 배열을 반환합니다.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message 매개변수가 반환될 메시지입니다.
 * @return params 메시지 메시지 매개변수.
 */
function getMessageParams(Array message) => any;

/**
 * @brief 메시지 유형 message를 반환합니다.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message 반환될 메시지 유형(@ref MESSAGE_HEAL, @ref MESSAGE_ATTACK 등).
 * @return type 메시지 유형 메시지.
 */
function getMessageType(Array message) => integer;

/**
 * @brief entity 항목 메시지 배열을 반환합니다.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (선택 과목) 메시지가 반환될 엔터티입니다.
 * @return messages 메시지 표입니다. 메시지 자체는 형식의 배열: [author, type, parameters] 다른 유형의 메시지는 상수로 표시됩니다.
 *     @ref MESSAGE_HEAL: 치료 요청; @ref MESSAGE_ATTACK: 공격 요청; @ref MESSAGE_BUFF_FORCE: 강제 부스트 요청
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief 팀 전체에 메시지를 보내십시오.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type 보낼 메시지 유형(MESSAGE_* 상수 참조).
 * @param[in] params 모든 값이 될 수 있는 메시지 매개변수.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief ID가 엔티티인 엔티티에 메시지를 보냅니다.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity 메시지를 보낼 엔터티의 ID입니다.
 * @param[in] type 보낼 메시지 유형(MESSAGE_* 상수 참조).
 * @param[in] params 모든 값이 될 수 있는 메시지 매개변수.
 * @return sent 전송에 성공하면 true, 오류가 발생하면 false입니다.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief color 색상의 파란색 양을 0에서 255 사이로 반환합니다.
 *
 * 예를 들어 getBlue(@ref COLOR_BLUE) = 255 및 getBlue(@ref COLOR_GREEN) = 0입니다.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 파란색 비율을 반환할 색상입니다.
 * @return blue color 색상의 파란색 비율
 */
function getBlue(integer|real color) => integer;

/**
 * @brief 매개변수로 제공된 색상(빨간색, 녹색, 파란색)에 해당하는 정수를 반환합니다.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red 0에서 255 사이의 빨간색 값.
 * @param[in] green 0에서 255 사이의 녹색 값입니다.
 * @param[in] blue 파란색 값은 0에서 255 사이입니다.
 * @return color 매개변수로 제공된 색상에 해당하는 int.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief color 색상의 녹색 양을 0에서 255 사이로 반환합니다.
 *
 * 예를 들어 getGreen(@ref COLOR_GREEN) = 255 및 getGreen(@ref COLOR_RED) = 0입니다.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 녹색 비율이 반환될 색상입니다.
 * @return green 색상 color의 녹색 비율
 */
function getGreen(integer|real color) => integer;

/**
 * @brief color 색상의 빨간색 양을 0에서 255 사이로 반환합니다.
 *
 * 예를 들어 getRed(@ref COLOR_RED) = 255 및 getRed(@ref COLOR_BLUE) = 0입니다.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color 빨간색 비율을 반환할 색상입니다.
 * @return red 색상 color의 빨간색 비율
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief 설정**을 지웁니다.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief 집합 세트에서 요소를 검색합니다.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief 집합 set1과 set2 사이의 차이, 즉 set2에 없는 set1의 모든 요소를 반환합니다.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Set1 또는 set2에 존재하지만 동시에 둘 다에 존재하지 않는 요소인 set1 ⊕ set2로 표시된 두 집합 set1과 set2**의 배타적 접합을 계산합니다.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief 두 집합의 공통 요소인 set1 ∩ set2에 주목하여 두 집합 set1과 set2의 교집합을 계산합니다.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief 세트**가 비어 있는지 여부를 반환합니다.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief 집합 set1이 set2의 부분집합인지 여부를 판단합니다.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief 집합 세트에 요소를 삽입합니다.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief 집합 세트에서 요소를 제거합니다.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Set** 집합의 크기를 반환합니다.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Set** 집합의 모든 요소가 포함된 목록을 반환합니다.
 *
 * 요소의 순서는 임의로 지정할 수 있습니다.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Set1 또는 set2에 존재하는 모든 요소를 포함하는 set1 ∪ set2로 표시되는 두 집합 set1과 set2**의 합집을 계산합니다.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief 간격 평균을 계산합니다.
 *
 * - 간격이 왼쪽 및 오른쪽 경계인 경우 (intervalMin(i) + intervalMax(i))/2를 반환합니다. - 간격이 왼쪽으로만 바운드된 경우 +∞를
 * 반환합니다. - 간격이 오른쪽에만 바운드된 경우 -∞를 반환합니다. - 구간이 경계가 없거나 비어 있으면 NaN을 반환합니다.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief 두 개의 간격 interval1과 interval2를 결합합니다.
 *
 * 교집합이 비어 있지 않은 경우 합집합과 동일하며, 그렇지 않은 경우 그 사이의 집합도 포함합니다.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief 두 간격 interval1과 interval2의 교집합을 계산하며, 두 간격에 공통된 요소를 포함합니다.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief 간격 간격이 왼쪽과 오른쪽에 경계가 있는지 여부를 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief 반환 값은 interval 간격이 왼쪽과 오른쪽에서 닫혔는지 여부입니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief 간격**이 비어 있는지 여부를 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief 간격 간격이 왼쪽 바운드인지 여부를 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief 간격**이 왼쪽에서 닫혔는지 여부를 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief 간격 간격이 우측 바운드인지 여부를 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief 간격 간격이 오른쪽에서 닫혔는지 여부를 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief 간격 간격의 상한을 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief 간격 interval의 하한을 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief 간격 간격의 크기를 반환합니다.
 *
 * - 간격이 경계인 경우 최대 - 최소를 반환합니다. - 간격이 경계가 없으면 +∞를 반환합니다. - 간격이 비어 있으면 0을 반환합니다.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief 간격 간격의 요소와 각 요소 사이에 단계가 포함된 목록을 반환합니다.
 *
 * 간격이 음수이면 요소를 역순으로 가져옵니다.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (선택 과목)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
