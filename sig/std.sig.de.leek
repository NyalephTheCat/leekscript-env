 */
function resurrect(integer|real entity, integer|real cell) => integer;

/**
 * @brief Ruft eine vom Chip bestimmte Entität chip auf der Zelle cell auf, die für IA die Funktion ai hat.
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip Der Chip, der zum Beschwören verwendet wird. Der Chip muss ein Beschwörungstyp-Chip
 *     sein und muss auf der Entität ausgerüstet sein, die die Beschwörungsfunktion
 *     verwendet.
 * @param[in] cell Die Zelle oder Vorladung sollte erscheinen.
 * @param[in] ai Der Aufruf AI als Funktion.
 * @param[in] name (optional)
 * @return return Die Summon-Funktion hat die gleiche Rückgabe wie die @ref useChip-Funktion.
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief Verwenden Sie Chip Chip auf Entität Entität.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip zu verwenden.
 * @param[in] entity (optional) Zieleinheit.
 * @return result Die Rückgabewerte von useChip sind: @ref USE_CRITICAL, bei kritischem Treffer;
 *     @ref USE_SUCCESS, falls erfolgreich; @ref USE_FAILED, bei Fehler; @ref USE_INVALID_TARGET, wenn
 *     das Ziel nicht existiert; @ref USE_NOT_ENOUGH_TP, wenn Ihre Entität nicht genug TP hat;
 *     @ref USE_INVALID_COOLDOWN, wenn der Chip noch nicht verwendbar ist; @ref USE_INVALID_POSITION,
 *     wenn die Reichweite schlecht oder die Sichtlinie nicht klar ist
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief Verwenden Sie Chip Chip auf Zelle Zelle.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip zu verwenden.
 * @param[in] cell Zielzelle.
 * @return result Ein Wert größer als 0, wenn der Angriff gestartet wurde.
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Gibt den Inhalt einer Zelle mit der ID cell zurück.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell Die ID der Zelle, deren Inhalt zurückgegeben wird.
 * @return content Der Inhalt der Zelle Zelle: @ref CELL_EMPTY für eine leere Zelle, @ref CELL_ENTITY für eine
 *     Entität, @ref CELL_OBSTACLE für ein Hindernis.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Gibt den Abstand zwischen zwei Zellen Zelle1 und Zelle2 zurück.
 *
 * Die zurückgegebene Entfernung wird in der Anzahl der Zellen ausgedrückt und berücksichtigt
 * nicht die verschiedenen Hindernisse zwischen den beiden Zellen.
 * Um die Distanz in Luftlinie zu erhalten, siehe @ref getDistance und um die Pfaddistanz
 * zwischen den beiden Zellen zu erhalten, die Hindernissen ausweichen, siehe @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Die ID der Startzelle.
 * @param[in] cell2 Die ID der Ankunftszelle.
 * @return distance Der Abstand zwischen den beiden Zellen cell1 und cell2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Gibt die ID der Zelle an Position (x, y) zurück.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x Die x-Position der Zelle.
 * @param[in] y Die y-Position der Zelle.
 * @return cell Die Zellen-ID an Position (x, y), null, wenn die Zelle nicht existiert.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Bestimmt die Position in X der Zelle cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Die Zelle, deren Position in X bestimmt wird.
 * @return x Die X-Position der Zelle.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Bestimmt die Y-Position der Zelle cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Die Zelle, deren Position in Y bestimmt wird.
 * @return y Die Y-Position der Zelle.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Berechnet die Entfernung in Luftlinie zwischen zwei Zellen Zelle1 und Zelle2.
 *
 * Um die Entfernung als Anzahl von Zellen zu erhalten, siehe @ref getCellDistance, und um die
 * Länge des Pfades zwischen den beiden Zellen zu erhalten, die den verschiedenen
 * Hindernissen ausweichen, siehe @ref getPathLength.
 *
 * @deprecated Diese Funktion ist veraltet. Es wird durch @ref getCellDistance ersetzt.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Die Ausgangszelle.
 * @param[in] cell2 Die Ankunftszelle.
 * @return distance Der Luftlinienabstand zwischen den beiden Zellen.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Gibt die Entität zurück, die sich auf Zelle cell befindet.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Die Zelle, deren Entität wir abrufen möchten.
 * @return entity Die ID der Entität in der Zelle oder -1, wenn die Zelle keine Entität hat.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Gibt die Entität zurück, die sich auf Zelle cell befindet.
 *
 * @deprecated Diese Funktion ist veraltet. Es wird durch @ref getEntityOnCell ersetzt.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Die Zelle, deren Entität wir abrufen möchten.
 * @return entity Die ID der Entität in der Zelle oder -1, wenn die Zelle keine Entität hat.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Gibt die Art des Geländes zurück, auf dem der Kampf stattfindet (Fabrik, Wüste, Wald…
 *
 * usw.), unter den Konstanten @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST,
 * @ref MAP_GLACIER und @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Die Art des Geländes.
 */
function getMapType() => integer;

/**
 * @brief Gibt die Liste der Hindernisfelder im Gelände zurück.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Das Array, das die IDs der Hinderniszellen enthält.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Gibt den Pfad zurück, der Hindernisse zwischen zwei Zellen cell1 und cell2 vermeidet, sofern vorhanden, wobei die im Array ignoredCells enthaltenen Zellen ignoriert werden.
 *
 * Wenn sich ein Spieler auf einem ignorierten Feld befindet, kann der Pfad über ihn
 * hinweggehen.
 * Die Startzelle cell1 ist niemals Teil des resultierenden Pfads. Zelle cell2 ist nur dann
 * Teil des resultierenden Pfads, wenn sie leer ist oder von ignoredCells ignoriert wird.
 * Wenn zwischen den beiden Zellen kein Pfad existiert, gibt getPath null zurück.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Die Ausgangszelle.
 * @param[in] end Die Ankunftszelle.
 * @param[in] ignoredCells (optional) Das zu ignorierende Array von Zellen.
 * @return path Das Array, das die Zellen enthält, die den Pfad zwischen den beiden Zellen bilden.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Gibt die Länge des Pfades zwischen zwei Zellen cell1 und cell2 zurück, wobei Hindernisse umgangen und die im Array ignoredCells enthaltenen Zellen ignoriert werden.
 *
 * Diese Funktion entspricht count(getPath(cell1, cell2, ignoredCells)).
 * Wenn sich ein Spieler auf einem ignorierten Feld befindet, kann der Pfad über ihn
 * hinweggehen.
 * Die Startzelle Zelle1 wird nie im Ergebnis gezählt. Zelle cell2 wird nur dann im Ergebnis
 * gezählt, wenn sie leer ist oder von ignoredCells ignoriert wird.
 * Wenn zwischen den beiden Zellen kein Pfad existiert, gibt getPathLength null zurück.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Die Ausgangszelle.
 * @param[in] cell2 Die Ankunftszelle.
 * @param[in] ignoredCells (optional) Das zu ignorierende Array von Zellen.
 * @return length Die Länge des Pfads zwischen cell1 und cell2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Bestimmt, ob eine Zelle leer ist.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Die zu testende Zelle.
 * @return empty true, wenn die Zelle leer ist, andernfalls false.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Bestimmt, ob der Inhalt der Zelle cell eine Entität ist.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell Die zu testende Zelle.
 * @return isEntity true, wenn die Zelle eine Entität enthält, andernfalls false.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Bestimmt, ob der Inhalt der Zelle cell eine Entität ist.
 *
 * @deprecated Diese Funktion ist veraltet. Es wird durch @ref isEntity ersetzt.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Die zu testende Zelle.
 * @return isLeek true, wenn die Zelle eine Entität enthält, andernfalls false.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Bestimmt, ob der Inhalt der Zelle cell ein Hindernis ist.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Die zu testende Zelle.
 * @return isObstacle true, wenn die Zelle ein Hindernis enthält, andernfalls false.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Bestimmt, ob sich zwei Zellen cell1 und cell2 in derselben Zeile befinden.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Die erste Zelle.
 * @param[in] cell2 Die zweite Zelle.
 * @return sameLine true, wenn die beiden Zellen auf derselben Zeile liegen, andernfalls false.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

// === fight ===

/**
 * @brief Gibt eine Reihe all deiner im Kampf lebenden Verbündeten zurück.
 *
 * @category fight
 * @cost 100 ops
 *
 * @return allies Ein Array, das die IDs aller Ihrer lebenden Verbündeten enthält.
 */
function getAliveAllies() => Array<integer>;

/**
 * @brief (No `func_getAliveAlliesCount` in doc lang — add an entry to match the client Documentation tab.)
 *
