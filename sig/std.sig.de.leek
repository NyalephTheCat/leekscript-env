 *
 * @param[in] entity (optional) Die ID der Entität, deren AI-ID zurückgegeben wird.
 * @return id Die Entität Entitäts-AI-ID.
 */
function getAIID(integer|real entity) => integer;
function getAIID() => integer;

/**
 * @brief Gibt den Namen der Entitäts-AI Entität zurück.
 *
 * Verwenden Sie getAINam() ohne Parameter, um den Namen Ihrer KI abzurufen.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Die ID der Entität, deren AI-Name zurückgegeben wird.
 * @return name Der Name der Entität der Entitäts-AI.
 */
function getAIName(integer|real entity) => string;
function getAIName() => string;

/**
 * @brief Gibt den absoluten Schild der Entität mit der ID entity zurück.
 *
 * Um den absoluten Schild Ihrer Entität direkt abzurufen, verwenden Sie @ref getAbsoluteShield()
 * ohne Parameter.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Die ID der Entität, deren absoluter Schild zurückgegeben wird.
 * @return shield Der absolute Schild der Entität Entität.
 */
function getAbsoluteShield(integer|real entity) => integer;
function getAbsoluteShield() => integer;

/**
 * @brief Gibt die Agilität der Entität mit der ID entity zurück.
 *
 * Um die Agilität Ihrer Entität direkt abzurufen, verwenden Sie @ref getAgility() ohne
 * Parameter.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Die ID der Entität, deren Agilität zurückgegeben wird.
 * @return agility Die Agilität der Entität-Entität.
 */
function getAgility(integer|real entity) => integer;
function getAgility() => integer;

/**
 * @brief Gibt die Runde des Kampfes zurück, in der die Entität erschienen ist.
 *
 * Gibt 1 zurück, wenn es sich beispielsweise um einen Lauch handelt, und 5, wenn es sich um
 * eine Beschwörung in Runde 5 handelt.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Die ID der Entität, deren Spawn-Runde zurückgegeben wird.
 * @return turn Die Kampfrunde, in der Entität erschien.
 */
function getBirthTurn(integer|real entity) => integer;
function getBirthTurn() => integer;

/**
 * @brief (No `func_getBulbType` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional)
 * @return bulbType
 */
function getBulbType(integer|real entity) => integer;
function getBulbType() => integer;

/**
 * @brief Gibt die Zelle zurück, in der sich die Entität mit der ID Entität befindet.
 *
 * Verwenden Sie getCell() ohne Parameter, um Ihre Zelle abzurufen.
 *
 * @category leek
