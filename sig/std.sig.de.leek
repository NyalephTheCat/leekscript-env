/**
 * @brief Kopiert den als Parameter übergebenen Wert auf Level-Ebenen und gibt die Kopie zurück.
 *
 * Im Fall eines Arrays zum Beispiel kopiert ein clone(array, 1) das Array, aber nicht seine
 * Elemente, ein clone(array, 2) kopiert das Array sowie alle Elemente.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value Der zu klonende Wert
 * @param[in] level (optional) Die Anzahl der zu klonenden Ebenen
 * @return copy Der geklonte Wert
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Zeichnet eine Objekt-Nachricht im persönlichen Protokoll auf, verfügbar im Bericht am Ende des Kampfes.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Die aufzuzeichnende Nachricht.
 */
function debug(any object) => void;

/**
 * @brief Zeichnet eine Objekt-Nachricht in der Farbe Farbe im persönlichen Protokoll auf, verfügbar…
 *
 * im Bericht am Ende des Kampfes.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Die aufzuzeichnende Nachricht.
 * @param[in] color Die Farbe der Nachricht. Sie können die Funktion @ref getColor verwenden.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Zeichnet eine Objekt-Fehlermeldung im persönlichen Log auf, verfügbar im Bericht am Ende des Kampfes.
 *
 * Fehlermeldungen erscheinen im Kampfbericht rot.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Die zu protokollierende Fehlermeldung.
 */
function debugE(any object) => void;

/**
 * @brief Zeichnet eine Objekt-Warnmeldung im persönlichen Logbuch auf, verfügbar im Bericht am Ende des Kampfes.
 *
 * Warnmeldungen erscheinen im Kampfbericht in Orange.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Die aufzuzeichnende Warnmeldung.
 */
function debugW(any object) => void;

/**
 * @brief Löscht die Registrierung, die dem Schlüssel Schlüssel zugeordnet ist, falls vorhanden.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key Der zu löschende Registrierungsschlüssel.
 */
function deleteRegister(string key) => void;

/**
 * @brief Gibt das Datum des Kampfes im Format TT/MM/JJJJ zurück.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date Das Datum des Kampfes.
 */
function getDate() => string;

/**
 * @brief Gibt die Anzahl der Anweisungen zurück, die Ihre Entität während der aktuellen Runde ausgeführt hat.
 *
 * @deprecated Diese Funktion ist veraltet. Es wird durch @ref getOperations ersetzt.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Die Anzahl der Anweisungen, die Ihre Entität während der aktuellen Runde ausgeführt
 *     hat.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Gibt das nutzbare RAM-Limit Ihrer KI zurück.
 *
 * RAM wird durch das Erstellen von Listen, Tabellen und Objekten verbraucht.
 * Das aktuelle Limit liegt bei 100 Megabyte oder 12.500.000 Listenelementen.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Gibt die Anzahl der Operationen zurück, die Ihre Entität seit Beginn ihrer Runde verbraucht hat.
 *
 * Diese Zahl muss kleiner als @ref OPERATIONS_LIMIT bleiben, damit die Entität nicht abstürzt.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Anzahl der Operationen, die Ihre Entität seit Beginn ihrer Runde verbraucht hat.
 */
function getOperations() => integer;

/**
 * @brief Gibt den Wert zurück, der in der Entitätsregistrierung gespeichert ist, die dem Schlüssel…
 *
 * key oder null zugeordnet ist, wenn die Registrierung nicht vorhanden ist.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key Der Registrierungsschlüssel, dessen Wert zurückgegeben wird.
 * @return value Der in der Schlüssel-Registrierung gespeicherte Wert.
 */
function getRegister(string key) => string;

/**
 * @brief Gibt den Satz von Entitätsregistern als assoziatives Array zurück [Registrierungsschlüssel:Registerwert].
 *
 * Beispiel: debug(getRegisters());
 * // Zeigt zum Beispiel an:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Das assoziative Array, das allen Registern der Entität entspricht.
 */
function getRegisters() => Array<string>;

/**
 * @brief Gibt die Kampfzeit im Format HH:mm:ss zurück.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Die Zeit des Kampfes.
 */
function getTime() => string;

/**
 * @brief Gibt den Zeitstempel des Kampfes zurück, der der Anzahl der Sekunden seit dem 1.
 *
 * Januar 1970 entspricht.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Der Zeitstempel des Kampfes.
 */
function getTimestamp() => integer;

/**
 * @brief Gibt die derzeit von Ihrer KI verwendete RAM-Menge zurück.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Fügen Sie die KI mit dem Namen ai in die aktuelle KI ein.
 *
 * Warnung, die Include-Funktion darf nur im Hauptblock aufgerufen werden, und ihr Parameter
 * muss ein direkt geschriebener String sein
 * im Code. Weitere Informationen finden Sie im Abschnitt des Tutorials:
 * http://leekwars.com/help/tutorial#includes .
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Der Name der einzuschließenden KI.
 */
function include(string ai) => void;

/**
 * @brief Dekodiert den String json in ein LeekScript-Objekt (Zahl, String, Array...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json Die zu decodierende JSON-Zeichenfolge.
 * @return object Das decodierte LeekScript-Objekt.
 */
function jsonDecode(string json) => any;

/**
 * @brief Codiert das Objekt object in eine JSON-Zeichenfolge.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object Das in JSON zu codierende Objekt.
 * @return json Die JSON-codierte Zeichenfolge.
 */
function jsonEncode(string object) => string;

/**
 * @brief Markiert ein oder mehrere Felder der im Parameter angegebenen Farbe auf dem Boden für die im Parameter angegebene Anzahl von Umdrehungen.
 *
 * Diese Kennzeichnung ist nur für den Züchter der Entität sichtbar.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Die zu markierende Zelle oder das Array aus mehreren Zellen
 * @param[in] color (optional) Markierungsfarbe
 * @param[in] duration (optional) Dauer der Markierung
 * @return success Gibt true zurück, wenn alles gut gelaufen ist
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Schreibt einen Text auf ein oder mehrere Felder der im Parameter angegebenen Farbe auf den Boden für die im Parameter angegebene Anzahl von Umdrehungen.
 *
 * Diese Texte sind nur für den Züchter der Entität sichtbar.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Die Zelle oder das Array aus mehreren Zellen, in die geschrieben werden soll
 * @param[in] text (optional) Der zu schreibende Text (maximal 10 Zeichen)
 * @param[in] color (optional) Textfarbe
 * @param[in] duration (optional) Textdauer
 * @return success Gibt true zurück, wenn alles gut gelaufen ist
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Pausiert den Kampf, nur für den Züchter der Entität, die die Funktion verwendet.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Speichert den Wert in der Schlüssel-Registrierung.
 *
 * Der Schlüssel und der Wert sind Zeichenfolgen, die höchstens 100 bzw. 5000 Zeichen
 * enthalten dürfen. Ein Porree kann maximal 100 Register haben, das Speichern in einem neuen
 * Register funktioniert nicht, wenn alle Register vorhanden sind
 * sind bereits besetzt.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Der Registrierungsschlüssel, in dem der Wert gespeichert werden soll.
 * @param[in] value Der zu speichernde Wert.
 * @return success true, wenn die Operation erfolgreich war, andernfalls false.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Zeigt den Spielern für 1 Runde ein Feld der Farbe Farbe auf dem Spielfeld.
 *
 * Die Nutzung dieser Funktion kostet 1 PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Die anzuzeigende Zelle
 * @param[in] color (optional) Markierungsfarbe
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Gibt den Typ des Werts Wert zurück, unter den Typen: @ref TYPE_NULL, @ref TYPE_NUMBER,…
 *
 * @ref TYPE_BOOLEAN, @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Der Wert, dessen Typ zurückgegeben wird.
 * @return type Der Typ des Werts.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Gibt die ID der Entität zurück, die die Nachricht verfasst hat message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Die Nachricht, deren Autor zurückgegeben wird.
 * @return entity Die ID der Entität, die die Nachricht verfasst hat message.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Gibt das Array von Nachrichtenparametern message zurück.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Die Nachricht, deren Parameter zurückgegeben werden.
 * @return params Die Nachrichtenparameter der Nachricht.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Gibt den Nachrichtentyp Nachricht zurück.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Die Nachricht, deren Typ zurückgegeben wird (unter anderem @ref MESSAGE_HEAL,
 *     @ref MESSAGE_ATTACK usw.).
 * @return type Der Nachrichtentyp Nachricht.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Gibt das Entity Message Array entity zurück.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (optional) Die Entität, deren Nachrichten zurückgegeben werden.
 * @return messages Die Tabelle Ihrer Nachrichten. Eine Nachricht selbst wird in Form von a dargestellt
 *     Array der Form: [Autor, Typ, Parameter] Die verschiedenen Arten von Nachrichten werden
 *     durch die Konstanten dargestellt: @ref MESSAGE_HEAL: Pflegeantrag; @ref MESSAGE_ATTACK:
 *     Angriffsanfrage; @ref MESSAGE_BUFF_FORCE: Verstärkungsanforderung erzwingen; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Senden Sie eine Nachricht an Ihr gesamtes Team.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Der Typ der zu sendenden Nachricht (siehe die MESSAGE_*-Konstanten).
 * @param[in] params Die Nachrichtenparameter, die einen beliebigen Wert haben können.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Sendet eine Nachricht an die Entität mit der ID Entität.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity Die ID der Entität, an die die Nachricht gesendet wird.
 * @param[in] type Der Typ der zu sendenden Nachricht (siehe die MESSAGE_*-Konstanten).
 * @param[in] params Die Nachrichtenparameter, die einen beliebigen Wert haben können.
 * @return sent true wenn der Versand erfolgreich war, false wenn ein Fehler aufgetreten ist.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Gibt den Blauanteil in der Farbe color zwischen 0 und 255 zurück.
 *
 * Beispiel: getBlue(@ref COLOR_BLUE) = 255 und getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Die Farbe, deren Blauanteil zurückgegeben wird.
 * @return blue Der Anteil von Blau in der Farbe Farbe
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Gibt die ganze Zahl zurück, die der als Parameter angegebenen Farbe (rot, grün, blau) entspricht.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Roter Wert zwischen 0 und 255.
 * @param[in] green Grüner Wert zwischen 0 und 255.
 * @param[in] blue Blauwert zwischen 0 und 255.
 * @return color int entsprechend der als Parameter bereitgestellten Farbe.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Gibt den Grünanteil in der Farbe color zwischen 0 und 255 zurück.
 *
 * Beispiel: getGreen(@ref COLOR_GREEN) = 255 und getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Die Farbe, deren Grünanteil zurückgegeben wird.
 * @return green Der Grünanteil in der Farbe Farbe
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Gibt den Rotanteil in der Farbe color zwischen 0 und 255 zurück.
 *
 * Beispiel: getRed(@ref COLOR_RED) = 255 und getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Die Farbe, deren Rotanteil zurückgegeben wird.
 * @return red Der Rotanteil in Farbe
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Leert die Menge set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Sucht in der Menge set nach einem Element element.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Gibt die Differenz der Mengen set1 und set2 zurück, d.
 *
 * h. alle Elemente in set1, die nicht in set2 sind.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Berechnet die exklusive Disjunktion zweier Mengen set1 und set2, notiert als set1 ⊕ set2,…
 *
 * welche die Elemente sind, die in set1 oder set2, aber nicht in beiden gleichzeitig
 * vorhanden sind.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Berechnet den Schnittpunkt zweier Mengen set1 und set2, notiert als set1 ∩ set2, welche…
 *
 * die gemeinsamen Elemente der beiden Mengen sind.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Gibt zurück, ob eine Menge set leer ist oder nicht.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Bestimmt, ob eine Menge set1 eine Teilmenge von set2 ist.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Fügt ein Element element in die Menge set ein.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Entfernt ein Element element aus der Menge set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Gibt die Größe des Satzes set zurück.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Gibt eine Liste zurück, die alle Elemente der Menge set enthält.
 *
 * Die Reihenfolge der Elemente ist beliebig.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Berechnet die Vereinigung der beiden Mengen set1 und set2, die als set1 ∪ set2 bezeichnet…
 *
 * wird und alle Elemente enthält, die entweder in set1 oder in set2 vorhanden sind.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Berechnet den Mittelwert des Intervalls.
 *
 * - Wenn das Intervall rechts- und linksbegrenzt ist, gibt (intervalMin(i) + intervalMax(i))
 * / 2 zurück. - Wenn das Intervall nur links begrenzt ist, gibt +∞ zurück. - Wenn das
 * Intervall nur nach rechts begrenzt ist, gibt -∞ zurück. - Wenn das Intervall nicht
 * begrenzt oder leer ist, gibt NaN zurück.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Kombiniert zwei Intervalle interval1 und interval2.
 *
 * Entspricht der Vereinigung, wenn ihr Schnittpunkt nicht leer ist, andernfalls schließt es
 * auch die Menge zwischen den beiden ein.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Berechnet den Schnittpunkt zweier Intervalle interval1 und interval2, der die Elemente…
 *
 * enthält, die beiden Intervallen gemeinsam sind.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Gibt zurück, ob das Intervall interval links und rechts begrenzt ist oder nicht.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Gibt zurück, ob das Intervall interval links und rechts geschlossen ist oder nicht.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Gibt zurück, ob das Intervall interval leer ist oder nicht.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Gibt zurück, ob das Intervall interval linksbündig ist oder nicht.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Gibt zurück, ob das Intervall interval links geschlossen ist oder nicht.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Gibt zurück, ob das Intervall interval rechtsbündig ist oder nicht.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Gibt zurück, ob das Intervall interval rechts geschlossen ist oder nicht.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Gibt die obere Grenze des Intervalls interval zurück.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Gibt die untere Grenze des Intervalls interval zurück.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Gibt die Größe des Intervalls interval zurück.
 *
 * - Wenn das Intervall begrenzt ist, gibt max - min zurück. - Wenn das Intervall nicht
 * begrenzt ist, gibt +∞ zurück. - Wenn das Intervall leer ist, gibt 0 zurück.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Gibt eine Liste zurück, die die Elemente des Intervalls interval mit einem Abstand von…
 *
 * step zwischen den einzelnen Elementen enthält.
 * Wenn der Abstand negativ ist, nimmt die Elemente in umgekehrter Reihenfolge.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (optional)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
