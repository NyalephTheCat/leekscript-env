 * @cost O(n)
 *
 * @param[in] array Array hvis gjennomsnitt vi ønsker å beregne.
 * @return averageValue Gjennomsnittlig verdi.
 */
function average(Array<integer|real> array) => real;

/**
 * @brief Teller antall elementer i matrisen matrisen.
 *
 * @category array
 * @cost 1 op
 *
 * @param[in] array Array hvis antall elementer vil telles.
 * @return numberOfElements Antall matriseelementer.
 */
function count(Array array) => integer;

/**
 * @brief Endrer størrelsen på matrisen til størrelsen og fyller alle boksene med verdi.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tabellen for å fullføre.
 * @param[in] value Verdien for hver firkant i matrisen.
 * @param[in] size (valgfri) Antall bokser. Som standard er gjeldende matrisestørrelse.
 */
function fill(Array array, any value, integer|real size) => void;
function fill(Array array, any value) => void;

/**
 * @brief Bestemmer om element-elementet er i array-matrisen.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Søketabellen.
 * @param[in] element Elementet å søke etter.
 * @return inArray true hvis elementet er i matrisen, false ellers.
 */
function inArray(Array array, any element) => boolean;

/**
 * @brief Setter inn et element i matrisen ved posisjon posisjon.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Matrisen der elementet skal settes inn.
 * @param[in] element Elementet som skal settes inn.
 * @param[in] position Plasseringen av innsettingen.
 */
function insert(Array array, any element, integer|real position) => void;

/**
 * @brief Bestemmer om arrayen array er tom.
 *
 * Tilsvarer count(array) == 0.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array Matrisen som skal testes.
 * @return empty true hvis matrisen er tom, false ellers.
 */
function isEmpty(Array array) => boolean;

/**
 * @brief Slår sammen flere elementer til en streng, og skiller dem med et lim-skilletegn.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array En rekke elementer som skal slås sammen.
 * @param[in] glue Elementavgrenseren.
 * @return string Den resulterende strengen av sammenslåingen.
 */
function join(Array array, string glue) => string;

/**
 * @brief Sorterer matrisen etter nøkler i rekkefølge.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Matrisen for å sortere.
 * @param[in] order (valgfri) Sorteringsrekkefølgen: @ref SORT_ASC eller @ref SORT_DESC.
 */
function keySort(Array array, integer|real order) => void;
function keySort(Array array) => void;

/**
 * @brief Fjerner den siste cellen fra array-matrisen og returnerer det tilsvarende elementet.
 *
 * @category array
 * @cost 5 ops
 *
 * @param[in] array Arrayen hvis siste boks vil bli slettet.
 * @return element Varen som var i den gamle siste boksen.
 */
function pop(Array array) => any;

/**
 * @brief Legger til element-elementet på slutten av matrisen.
 *
