 * @cost 16 ops
 *
 * @param[in] key Registernøkkelen som skal slettes.
 */
function deleteRegister(string key) => void;

/**
 * @brief Returnerer datoen for kampen, i formatet dd/MM/åååå.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date Datoen for kampen.
 */
function getDate() => string;

/**
 * @brief Returnerer antall instruksjoner enheten din har utført i løpet av gjeldende sving.
 *
 * @deprecated Denne funksjonen er utdatert. Den er erstattet av @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Antall instruksjoner enheten din har utført i løpet av den gjeldende svingen.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Returnerer den brukbare RAM-grensen til AI-en din.
 *
 * RAM forbrukes ved å lage lister, tabeller og objekter.
 * Gjeldende grense er 100 megabyte eller 12 500 000 listeelementer.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Returnerer antall operasjoner som er forbrukt av enheten din siden starten av sin tur.
 *
 * Dette tallet må være lavere enn @ref OPERATIONS_LIMIT slik at enheten ikke krasjer.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Antall operasjoner forbrukt av enheten din siden starten av sin tur.
 */
function getOperations() => integer;

/**
 * @brief Returnerer verdien som er lagret i enhetsregisteret knyttet til nøkkel nøkkel eller null hvis registret ikke eksisterer.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key Registernøkkelen hvis verdi vil bli returnert.
 * @return value Verdien som er lagret i nøkkel-registeret.
 */
function getRegister(string key) => string;

/**
 * @brief Returnerer settet med enhetsregistre som en assosiativ matrise [registernøkkel:registerverdi].
 *
 * Eksempel: debug(getRegisters());
 * // Viser for eksempel:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Den assosiative matrisen som tilsvarer alle registrene til enheten.
 */
function getRegisters() => Array<string>;

/**
 * @brief Returnerer kamptiden, i TT:mm:ss-format.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Tidspunktet for kampen.
 */
function getTime() => string;

/**
 * @brief Returnerer kampens tidsstempel, lik antall sekunder siden 1.
 *
 * januar 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Kampens tidsstempel.
 */
function getTimestamp() => integer;

/**
 * @brief Returnerer mengden RAM som brukes av AI-en din.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Inkluder AI med navnet ai i gjeldende AI.
 *
 * Advarsel, inkluderer funksjonen må kalles bare i hovedblokken, og parameteren må være en
 * streng skrevet direkte
 * i koden. For mer informasjon, se delen i opplæringen:
 * http://leekwas.com/help/tutorial#includes.
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Navnet på AI som skal inkluderes.
 */
function include(string ai) => void;

/**
 * @brief Dekod json-streng til LeekScript-objekt (nummer, streng, matrise...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json JSON-strengen som skal dekodes.
 * @return object Det dekodede LeekScript-objektet.
 */
function jsonDecode(string json) => any;

/**
 * @brief Koder objekt-objektet til en JSON-streng.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object Objektet som skal kodes i JSON.
 * @return json Den JSON-kodede strengen.
 */
function jsonEncode(string object) => string;

/**
 * @brief Merker én eller flere celler med fargen som er angitt i parameteren på bakken for antall svinger som er angitt i parameteren.
 *
 * Denne merkingen er kun synlig for oppdretteren av enheten.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Cellen eller matrisen med flere celler som skal merkes
 * @param[in] color (valgfri) Markeringsfarge
 * @param[in] duration (valgfri) Varighet av merking
 * @return success Returnerer sant hvis alt gikk bra
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Skriver en tekst på en eller flere celler med fargen som er angitt i parameter på bakken for antall svinger som er angitt i parameter.
 *
 * Disse tekstene er kun synlige for oppdretteren av enheten.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Cellen eller matrisen med flere celler det skal skrives til
 * @param[in] text (valgfri) Teksten som skal skrives (maks. 10 tegn)
 * @param[in] color (valgfri) Tekstfarge
 * @param[in] duration (valgfri) Tekstvarighet
 * @return success Returnerer sant hvis alt gikk bra
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Pauser kampen, kun for oppdretteren av enheten som bruker funksjonen.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Lagrer verdien i nøkkel-registeret.
 *
 * Nøkkelen og verdien er strenger som maksimalt må inneholde 100 og 5000 tegn. En purre kan
 * ha maksimalt 100 registre, lagring i et nytt register vil ikke fungere hvis alle registre
 * er allerede okkupert.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Registernøkkelen hvor verdien skal lagres.
 * @param[in] value Verdien å lagre.
 * @return success true hvis operasjonen var vellykket, ellers false.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Viser spillerne en celle med fargen farge på banen i 1 omgang.
 *
 * Bruk av denne funksjonen koster 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Cellen som skal vises
 * @param[in] color (valgfri) Markeringsfarge
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Returnerer typen til verdien verdi, blant typene: @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN,…
 *
 * @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Verdien hvis type vil bli returnert.
 * @return type Typen verdi.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Returnerer ID-en til enheten som skriver meldingen meldingen.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Meldingen hvis forfatter vil bli returnert.
 * @return entity ID-en til enheten som skriver meldingen meldingen.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Returnerer utvalget av meldingsparametere melding.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Meldingen hvis parametere vil bli returnert.
 * @return params Meldingsparametere for melding.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Returnerer meldingstypen melding.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Meldingen hvis type vil bli returnert (blant @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK osv.).
 * @return type Meldingstypen melding.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Returnerer entity-enhetsmeldingsmatrisen.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (valgfri) Enheten hvis meldinger vil bli returnert.
 * @return messages Tabellen over meldingene dine. En melding er i seg selv representert i form av en
 *     array av skjemaet: [author, type, parameters] De forskjellige typene meldinger er
 *     representert av konstantene: @ref MESSAGE_HEAL: forespørsel om omsorg; @ref MESSAGE_ATTACK:
 *     forespørsel om å angripe; @ref MESSAGE_BUFF_FORCE: tvinge forespørsel om boost; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Send en melding til hele teamet ditt.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Type melding som skal sendes (se MESSAGE_* konstantene).
 * @param[in] params Meldingsparameterne, som kan være en hvilken som helst verdi.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Sender en melding til enheten med id entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity ID-en til enheten som meldingen skal sendes til.
 * @param[in] type Type melding som skal sendes (se MESSAGE_* konstantene).
 * @param[in] params Meldingsparameterne, som kan være en hvilken som helst verdi.
 * @return sent true hvis sendingen var vellykket, false hvis det oppsto en feil.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Returnerer mengden blått i fargen farge, mellom 0 og 255.
 *
 * For eksempel, getBlue(@ref COLOR_BLUE) = 255 og getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Fargen hvis blåpris vil bli returnert.
 * @return blue Frekvensen av blått i fargen farge
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Returnerer heltallet som tilsvarer fargen (rød, grønn, blå) oppgitt som parametere.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Rød verdi mellom 0 og 255.
 * @param[in] green Grønn verdi mellom 0 og 255.
 * @param[in] blue Blå verdi mellom 0 og 255.
 * @return color int som tilsvarer fargen oppgitt som parameter.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Returnerer mengden grønt i fargen farge, mellom 0 og 255.
 *
 * For eksempel, getGreen(@ref COLOR_GREEN) = 255 og getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Fargen hvis grønne sats vil bli returnert.
 * @return green Frekvensen for grønt i fargen farge
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Returnerer mengden rødt i fargen farge, mellom 0 og 255.
 *
 * For eksempel, getRed(@ref COLOR_RED) = 255 og getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Fargen hvis røde rate vil bli returnert.
 * @return red Frekvensen for rødt i fargen farge
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Tømmer settet.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Søker etter et element element i settet set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Returnerer differansen mellom mengdene set1 og set2, dvs.
 *
 * alle elementene i set1 som ikke finnes i set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Beregner den eksklusive disjunksjonen av to sett set1 og set2, notert set1 ⊕ set2, som er…
 *
 * elementene som finnes i set1 eller set2, men ikke i begge samtidig.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Beregner skjæringspunktet mellom to sett set1 og set2, notert set1 ∩ set2, som er de felles elementene i de to settene.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Returnerer om et sett er tomt eller ikke.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Bestemmer om en mengde set1 er en delmengde av set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Setter inn et element element i mengden set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Fjerner et element element fra settet set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Returnerer størrelsen på set-settet.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Returnerer en liste som inneholder alle elementene i set-settet.
 *
 * Rekkefølgen på elementene er vilkårlig.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Beregner unionen av to sett set1 og set2, betegnet set1 ∪ set2, som inneholder alle elementene i set1 eller set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Beregner intervallgjennomsnittet.
 *
 * - Hvis intervallet er venstre- og høyrebegrenset, returneres (intervalMin(i) +
 * intervalMax(i)) / 2. - Hvis intervallet bare er venstrebegrenset, returneres +∞. - Hvis
 * intervallet bare er avgrenset til høyre, returneres -∞. - Hvis intervallet er ubegrenset
 * eller tomt, returneres NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Kombinerer to intervaller intervall1 og intervall2.
 *
 * Tilsvarer union hvis skjæringspunktet ikke er tomt, ellers inkluderes også mengden mellom
 * dem.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Beregner skjæringspunktet mellom to intervaller intervall1 og intervall2, som inneholder…
 *
 * elementene som er felles for begge.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Returnerer om intervallet intervall er avgrenset til venstre og høyre eller ikke.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Returnerer om intervallet intervall er lukket til venstre og høyre eller ikke.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Returnerer om intervall er tomt eller ikke.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Returnerer om intervallet intervall er venstrebundet eller ikke.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Returnerer om intervallet er lukket til venstre eller ikke.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Returnerer om intervallet intervall er høyrebegrenset eller ikke.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Returnerer om intervallet intervall er lukket på høyre side eller ikke.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Returnerer den øvre grensen for intervallet intervall.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Returnerer den nedre grensen for intervallet intervall.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Returnerer størrelsen på intervallet intervall.
 *
 * - Hvis intervallet er avgrenset, returneres max - min. - Hvis intervallet ikke er
 * avgrenset, returneres +∞. - Hvis intervallet er tomt, returneres 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Returnerer en liste som inneholder elementene i intervallet intervall med et steg mellom hvert.
 *
 * Hvis intervallet er negativt, tas elementene i omvendt rekkefølge.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (valgfri)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
