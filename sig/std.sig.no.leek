 *
 * @category map
 * @cost 1 op
 *
 * @param[in] map
 * @return size
 */
function mapSize(Map map) => integer;

/**
 * @brief Returnerer *true* hvis callback-predikatet brukt på minst ett element i map-tabellen returnerer *true*, ellers *false*.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return some
 */
function mapSome(Map map, Function callback) => boolean;

/**
 * @brief Returnerer summen av alle verdier i kart-tabellen.
