// === field ===

/**
 * @brief Returnerer innholdet i en celle med id celle.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell ID-en til cellen hvis innhold vil bli returnert.
 * @return content Innholdet i cellen-cellen: @ref CELL_EMPTY for en tom celle, @ref CELL_ENTITY for en enhet,
 *     @ref CELL_OBSTACLE for en hindring.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Returnerer avstanden mellom to celler celle1 og celle2.
 *
 * Den returnerte avstanden er uttrykt i antall celler, og tar ikke hensyn til de ulike
 * hindringene mellom de to cellene.
 * For å få avstanden i luftlinje, se @ref getDistance og for å få baneavstanden mellom de to
 * cellene for å unngå hindringer, se @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 IDen til startcellen.
 * @param[in] cell2 ID-en til ankomstcellen.
 * @return distance Avstanden mellom de to cellene celle1 og celle2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Returnerer ID-en til cellen ved posisjon (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x X-posisjonen til cellen.
 * @param[in] y Y-posisjonen til cellen.
 * @return cell Celle-ID-en ved posisjon (x, y), null hvis cellen ikke eksisterer.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Bestemmer posisjonen i X av cellen cellen.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Cellen hvis posisjon i X vil bli bestemt.
 * @return x X-posisjonen til cellen.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Bestemmer Y-posisjonen til cellen cellen.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Cellen hvis posisjon i Y vil bli bestemt.
 * @return y Y-posisjonen til cellen.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Beregner luftlinjeavstanden mellom to celler celle1 og celle2.
 *
 * For å få avstanden i antall celler, se @ref getCellDistance, og for å få lengden på banen
 * mellom de to cellene som unngår de forskjellige hindringene, se @ref getPathLength.
 *
 * @deprecated Denne funksjonen er utdatert. Den er erstattet av @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Startcellen.
 * @param[in] cell2 Ankomstcellen.
 * @return distance Avstanden i luftlinje mellom de to cellene.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Returnerer enheten som er på celle celle.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Cellen hvis enhet vi ønsker å hente.
 * @return entity ID-en til enheten på cellen, eller -1 hvis cellen ikke har noen enhet.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Returnerer enheten som er på celle celle.
 *
 * @deprecated Denne funksjonen er utdatert. Den er erstattet av @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Cellen hvis enhet vi ønsker å hente.
 * @return entity ID-en til enheten på cellen, eller -1 hvis cellen ikke har noen enhet.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Returnerer terrengtypen som kampen finner sted på (fabrikk, ørken, skog osv.), blant…
 *
 * konstantene @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER og
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Type terreng.
 */
function getMapType() => integer;

/**
 * @brief Returnerer listen over hinderplasser i terrenget.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Matrisen som inneholder hindringscelle-ID-ene.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Returnerer banen for å unngå hindringer mellom to celler celle1 og celle2, hvis den finnes, og ignorerer cellene i matrisen ignoredCells.
 *
 * Hvis en spiller er på en ignorert celle, kan banen gå over dem.
 * Startcellen celle1 er aldri en del av den resulterende banen. Celle celle2 er en del av
 * den resulterende banen hvis og bare hvis den er tom eller ignorert av ignoredCells.
 * Hvis det ikke finnes noen bane mellom de to cellene, returnerer getPath null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Startcellen.
 * @param[in] end Ankomstcellen.
 * @param[in] ignoredCells (valgfri) En rekke celler å ignorere.
 * @return path Matrisen som inneholder cellene som utgjør banen mellom de to cellene.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Returnerer lengden på banen mellom to celler celle1 og celle2, unngår hindringer, ignorerer cellene i arrayen ignoredCells.
 *
 * Denne funksjonen tilsvarer count(getPath(celle1, cell2, ignoredCells)).
 * Hvis en spiller er på en ignorert celle, kan banen gå over dem.
 * Startcellen celle1 telles aldri med i resultatet. Celle celle2 telles i resultatet hvis og
 * bare hvis den er tom eller ignorert av ignoredCells.
 * Hvis det ikke finnes noen bane mellom de to cellene, returnerer getPathLength null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Startcellen.
 * @param[in] cell2 Ankomstcellen.
 * @param[in] ignoredCells (valgfri) En rekke celler å ignorere.
 * @return length Lengden på banen mellom celle1 og celle2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Bestemmer om en celle er tom.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Cellen som skal testes.
 * @return empty true hvis cellen er tom, usant ellers.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Bestemmer om innholdet i celle celle er en enhet.
 *
