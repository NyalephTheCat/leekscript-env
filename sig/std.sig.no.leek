 *
 * @param[in] array Matrisen der vi ønsker å legge til elementet.
 * @param[in] element Elementet som skal legges til.
 */
function push(Array array, any element) => void;

/**
 * @brief Legger til alle elementene i elementer-matrisen til slutten av matrisen.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Matrisen der vi ønsker å legge til elementene.
 * @param[in] elements Elementer å legge til.
 */
function pushAll(Array array, Array elements) => void;

/**
 * @brief Fjerner et element fra arrayet array ved posisjon posisjon, og returnerer det slettede elementet.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array som vi ønsker å slette et element fra.
 * @param[in] position Plassering av elementet som skal slettes.
 * @return element Elementet fjernet fra matrisen.
 */
function remove(Array array, integer|real position) => any;

/**
 * @brief Sletter den første forekomsten av et element i matrisen.
 *
 * Hvis elementet ikke blir funnet, endres ikke matrisen.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array som vi ønsker å slette et element fra.
 * @param[in] element Element å finne og deretter slette.
 */
function removeElement(Array array, any element) => void;

/**
 * @brief Sletter et element fra matrisen matrise knyttet til nøkkelen nøkkel.
 *
 * @category array
 * @cost 5 ops
 *
 * @param[in] array Array som vi ønsker å slette et element fra.
 * @param[in] key Nøkkelen knyttet til elementet som skal slettes.
 */
function removeKey(Array array, any key) => void;

/**
 * @brief Reverserer matrisen.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tabell for å invertere.
 */
function reverse(Array array) => void;

/**
 * @brief Finner elementet element i arrayet array, med start fra posisjon start.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Søketabellen.
 * @param[in] element Elementet å søke etter.
 * @param[in] start (valgfri) Posisjonen for starten av søket.
 * @return pos Plasseringen av den første forekomsten av elementet-elementet i matrisen, starter fra
 *     start, null hvis elementet ikke er funnet.
 */
function search(Array array, any element, integer|real start) => integer;
function search(Array array, any element) => integer;

/**
 * @brief Fjerner den første cellen fra matrisen og returnerer det tilsvarende elementet.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Arrayen hvis første boks vil bli slettet.
 * @return element Elementet som var i den gamle første boksen.
 */
function shift(Array array) => any;

/**
 * @brief Blander et brett tilfeldig.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Shufflebrettet.
 */
function shuffle(Array array) => void;

/**
 * @brief Sorterer matrisen i stigende eller synkende rekkefølge.
 *
 * Standard stigende rekkefølge er:
 * Alle booleaner (først usant og deretter sant); Alle tall (ordnet fra minste til største);
 * Alle kanaler (i alfabetisk rekkefølge); Alle null-elementer.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Array for å sortere.
 * @param[in] order (valgfri) @ref SORT_ASC for å sortere array i stigende rekkefølge eller @ref SORT_DESC for å sortere den
 *     i synkende rekkefølge.
 */
function sort(Array array, integer|real order) => void;
function sort(Array array) => void;

/**
 * @brief Returnerer en undermatrise av matrise som starter ved posisjon start og slutter ved posisjon slutt.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Kildetabell.
 * @param[in] start Startindeks.
 * @param[in] end Sluttindeks.
 * @return array Sub-array.
 */
function subArray(Array array, integer|real start, integer|real end) => Array;

/**
 * @brief Returnerer summen av alle de numeriske elementene i matrisen matrise.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tabell for å summere.
 * @return sum Summen av matriseelementer.
 */
function sum(Array<integer|real> array) => real;

/**
 * @brief Legger til element-elementet i begynnelsen av matrisen.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array der elementet vil bli lagt til.
 * @param[in] element Element å legge til.
 */
function unshift(Array array, any element) => void;

