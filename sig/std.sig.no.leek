 *
 * @param[in] cell Cellen som skal testes.
 * @return isObstacle true hvis cellen inneholder en hindring, usant ellers.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Bestemmer om to celler celle1 og celle2 er på samme linje.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Den første cellen.
 * @param[in] cell2 Den andre cellen.
 * @return sameLine true hvis de to cellene er på samme linje, false ellers.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

