 * @return newArray Nytt bord.
 */
function arrayPartition(Array array, Function callback) => Array<Array>;

/**
 * @brief Returnerer en liste over tilfeldige count-elementer fra matrise-listen, uten duplikater.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] count
 * @return random
 */
function arrayRandom(Array array, integer count) => Array;

/**
 * @brief Fjerner alle elementer som er lik element i matrise-listen.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] element
 */
function arrayRemoveAll(Array array, any element) => void;

/**
 * @brief Returnerer en underliste med matrise som inneholder alle elementer fra posisjon start til posisjon slutt (eksklusivt).
 *
 * Hvis inkrementparameteren skritt passeres (som standard 1), velger funksjonen bare ett
 * element for hvert skritt.
 * *Eksempel*: ny liste som inneholder elementer fra posisjon 10 til 20 (ekskludert). ``
 * arraySlice(liste, 10, 20) ``
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] start
 * @param[in] end (valgfri)
 * @param[in] stride (valgfri)
 * @return slice
 */
function arraySlice(Array array, any start, any end, integer stride) => Array;
function arraySlice(Array array, any start, any end) => Array;
function arraySlice(Array array, any start) => Array;

/**
 * @brief Returnerer true hvis predikatet callback brukt på minst ett av elementene i listen returnerer true
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] callback
 * @return some
 */
function arraySome(Array array, Function callback) => boolean;

/**
 * @brief Sorterer matrisen i henhold til rekkefølgen definert av tilbakeringingsfunksjonen.
 *
 * Elementene sammenlignes to og to, tilbakeringingsfunksjonen må returnere verdiene -1, 0
 * eller 1 avhengig av om den første verdien er før, på samme nivå eller etter den andre
 * verdien. Hvis tilbakeringingsfunksjonen tar 2 parametere, sendes de to verdiene, hvis den
 * tar 4, sendes nøkkel/verdi-parene.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Originalt bord
 * @param[in] callback (valgfri) Sorteringsfunksjon.
 * @return sortedArray Den sorterte matrisen
 */
function arraySort(Array array, Function callback) => Array;
function arraySort(Array array) => Array;

/**
 * @brief (No `func_arrayToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @return set
 */
function arrayToSet(Array array) => Set;

/**
 * @brief Returnerer en liste som inneholder alle elementene i listen matrise ved å eliminere duplikater.
 *
 * @category array
 * @cost O(n²)
 *
 * @param[in] array
 * @return unique
 */
function arrayUnique(Array array) => Array;

/**
 * @brief Sorterer matrisen matrise og beholder nøkkel:verdi-tilknytningen i henhold til rekkefølgen rekkefølge.
 *
 * @deprecated Denne funksjonen er utdatert.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Matrisen for å sortere.
 * @param[in] order (valgfri) Sorteringsrekkefølgen: @ref SORT_ASC eller @ref SORT_DESC.
 */
function assocSort(Array array, integer|real order) => void;
function assocSort(Array array) => void;

/**
 * @brief Beregner gjennomsnittet av elementene i arrayen array.
 *
