/**
 * @brief Registrerer en objekt-besked i den personlige log, tilgængelig i rapporten ved slutningen af kampen.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Beskeden der skal optages.
 */
function debug(any object) => void;

/**
 * @brief Registrerer en objekt besked i den personlige log, tilgængelig i rapporten ved kampens afslutning, med farven farve.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Beskeden der skal optages.
 * @param[in] color Farven på beskeden. Du kan bruge @ref getColor-funktionen.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Registrerer en objekt fejlmeddelelse i den personlige log, tilgængelig i rapporten ved kampens afslutning.
 *
 * Fejlmeddelelser vises med rødt i kamprapporten.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Fejlmeddelelsen til at logge.
 */
function debugE(any object) => void;

/**
 * @brief Registrerer en advarselsmeddelelse om objekt i den personlige log, tilgængelig i rapporten ved slutningen af kampen.
 *
 * Advarselsmeddelelser vises i orange i kamprapporten.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Advarselsmeddelelsen om at optage.
 */
function debugW(any object) => void;

/**
 * @brief Sletter registreringsdatabasen, der er knyttet til nøglen nøgle, hvis den findes.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key Registreringsnøglen til at slette.
 */
function deleteRegister(string key) => void;

/**
 * @brief Returnerer datoen for kampen i formatet dd/MM/åååå.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date Datoen for kampen.
 */
function getDate() => string;

/**
 * @brief Returnerer antallet af instruktioner, din enhed har udført under den aktuelle tur.
 *
 * @deprecated Denne funktion er forældet. Den erstattes af @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Antallet af instruktioner, din enhed har udført under den aktuelle tur.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Returnerer den brugbare RAM-grænse for din AI.
 *
 * RAM forbruges ved at skabe lister, tabeller og objekter.
 * Den aktuelle grænse er 100 megabyte eller 12.500.000 listeelementer.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Returnerer antallet af operationer, der er forbrugt af din enhed siden starten af dets tur.
 *
 * Dette tal skal forblive lavere end @ref OPERATIONS_LIMIT, så enheden ikke går ned.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Antal operationer forbrugt af din enhed siden starten af dets tur.
 */
function getOperations() => integer;

/**
 * @brief Returnerer den værdi, der er gemt i enhedsregistret tilknyttet nøgle nøgle eller null,…
 *
 * hvis registreringsdatabasen ikke eksisterer.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key Registreringsnøglen, hvis værdi vil blive returneret.
 * @return value Værdien gemt i nøgle registreringsdatabasen.
 */
function getRegister(string key) => string;

/**
 * @brief Returnerer sættet af enhedsregistre som en associativ matrix [registreringsnøgle:registerværdi].
 *
 * Eksempel: debug(getRegisters());
 * // Viser for eksempel:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Det associative array, der svarer til alle entitetens registre.
 */
function getRegisters() => Array<string>;

/**
 * @brief Returnerer kamptiden i HH:mm:ss-format.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Kampens tidspunkt.
 */
function getTime() => string;

/**
 * @brief Returnerer kampens tidsstempel svarende til antallet af sekunder siden 1.
 *
 * januar 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Kampens tidsstempel.
 */
function getTimestamp() => integer;

/**
 * @brief Returnerer mængden af RAM, der aktuelt bruges af din AI.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Inkluder AI med navnet ai i den aktuelle AI.
 *
 * Advarsel, include-funktionen må kun kaldes i hovedblokken, og dens parameter skal være en
 * streng skrevet direkte
 * i koden. For mere information, se afsnittet i selvstudiet:
 * http://leekwas.com/help/tutorial#includes.
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Navnet på den AI, der skal inkluderes.
 */
function include(string ai) => void;

/**
 * @brief Afkoder streng json til LeekScript-objekt (nummer, streng, matrix...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json JSON-strengen, der skal afkodes.
 * @return object Det afkodede LeekScript-objekt.
 */
function jsonDecode(string json) => any;

/**
 * @brief Koder objekt-objektet til en JSON-streng.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object Objektet, der skal kodes i JSON.
 * @return json Den JSON-kodede streng.
 */
function jsonEncode(string object) => string;

/**
 * @brief Markerer en eller flere celler i den farve, der er angivet i parameteren, på jorden for det antal drejninger, der er angivet i parameteren.
 *
 * Denne mærkning er kun synlig for opdrætteren af enheden.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Cellen eller matrixen af flere celler, der skal markeres
 * @param[in] color (valgfri) Markeringsfarve
 * @param[in] duration (valgfri) Mærkningens varighed
 * @return success Returnerer sandt, hvis alt gik godt
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Skriver en tekst på en eller flere celler af den farve, der er angivet i parameter på jorden for det antal drejninger, der er angivet i parameter.
 *
 * Disse tekster er kun synlige for opdrætteren af enheden.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Cellen eller rækken af flere celler, der skal skrives til
 * @param[in] text (valgfri) Teksten der skal skrives (maks. 10 tegn)
 * @param[in] color (valgfri) Tekstfarve
 * @param[in] duration (valgfri) Tekstvarighed
 * @return success Returnerer sandt, hvis alt gik godt
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Sætter kampen på pause, kun for opdrætteren af den enhed, der bruger funktionen.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Gemmer værdien i nøgle registreringsdatabasen.
 *
 * Nøglen og værdien er strenge, som højst må indeholde 100 og 5000 tegn. En porre kan
 * maksimalt have 100 registre, lagring i et nyt register fungerer ikke, hvis alle registre
 * er allerede besat.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Registreringsnøglen, hvor værdien skal gemmes.
 * @param[in] value Værdien at opbevare.
 * @return success sand hvis handlingen lykkedes, ellers false.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Viser spillerne en celle af farven farve på banen i 1 omgang.
 *
 * Brug af denne funktion koster 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Cellen der skal vises
 * @param[in] color (valgfri) Markeringsfarve
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Returnerer typen af værdien værdi blandt typerne: @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN,…
 *
 * @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Værdien, hvis type vil blive returneret.
 * @return type Typen værdi.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Returnerer id'et for den enhed, der forfatter meddelelsen meddelelsen.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Den besked, hvis forfatter vil blive returneret.
 * @return entity Id'et for den enhed, der forfatter meddelelsen meddelelsen.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Returnerer rækken af meddelelsesparametre meddelelse.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Den besked, hvis parametre vil blive returneret.
 * @return params meddelelses-meddelelsesparametrene.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Returnerer beskedtypen meddelelse.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Den besked, hvis type vil blive returneret (blandt @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK
 *     osv.).
 * @return type Meddelelsestypen meddelelse.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Returnerer entity enhedsmeddelelsesarrayet.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (valgfri) Den enhed, hvis meddelelser vil blive returneret.
 * @return messages Tabellen over dine beskeder. En besked er i sig selv repræsenteret i form af en matrix
 *     af formen: [forfatter, type, parametre] De forskellige typer meddelelser er
 *     repræsenteret af konstanterne: @ref MESSAGE_HEAL: anmodning om pleje; @ref MESSAGE_ATTACK:
 *     anmodning om at angribe; @ref MESSAGE_BUFF_FORCE: force boost anmodning; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Send en besked til hele dit team.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Den type besked, der skal sendes (se MESSAGE_* konstanterne).
 * @param[in] params Meddelelsesparametrene, som kan være en hvilken som helst værdi.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Sender en besked til enheden med id entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity Id'et for den enhed, som meddelelsen vil blive sendt til.
 * @param[in] type Den type besked, der skal sendes (se MESSAGE_* konstanterne).
 * @param[in] params Meddelelsesparametrene, som kan være en hvilken som helst værdi.
 * @return sent true hvis afsendelsen lykkedes, false hvis der opstod en fejl.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Returnerer mængden af blå i farven farve, mellem 0 og 255.
 *
 * For eksempel getBlue(@ref COLOR_BLUE) = 255 og getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Den farve, hvis blå sats vil blive returneret.
 * @return blue Frekvensen af blå i farven farve
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Returnerer det heltal, der svarer til farven (rød, grøn, blå), der er angivet som parametre.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Rød værdi mellem 0 og 255.
 * @param[in] green Grøn værdi mellem 0 og 255.
 * @param[in] blue Blå værdi mellem 0 og 255.
 * @return color int svarende til farven angivet som parameter.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Returnerer mængden af grønt i farven farve mellem 0 og 255.
 *
 * For eksempel getGreen(@ref COLOR_GREEN) = 255 og getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Den farve, hvis grønne sats vil blive returneret.
 * @return green Frekvensen for grøn i farven farve
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Returnerer mængden af rød i farven farve mellem 0 og 255.
 *
 * For eksempel getRed(@ref COLOR_RED) = 255 og getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Den farve, hvis røde sats vil blive returneret.
 * @return red Frekvensen af rød i farve
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Rydder sættet.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Søger efter et element element i sættet set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Returnerer forskellen mellem sættene set1 og set2, dvs.
 *
 * alle de elementer i set1, der ikke er i set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Beregner den eksklusive disjunktion af to sæt set1 og set2, noteret set1 ⊕ set2, som er de…
 *
 * elementer, der findes i set1 eller set2, men ikke i begge på samme tid.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Beregner skæringspunktet mellem to sæt set1 og set2, noteret set1 ∩ set2, som er de fælles elementer i de to sæt.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Returnerer, om et sæt er tomt eller ej.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Bestemmer, om en mængde set1 er en delmængde af set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Indsætter et element element i mængden set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Fjerner et element element fra sættet set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Returnerer størrelsen på sættet.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Returnerer en liste, der indeholder alle elementerne i set-sættet.
 *
 * Elementernes rækkefølge er vilkårlig.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Beregner foreningen af to sæt set1 og set2, betegnet set1 ∪ set2, som indeholder alle de…
 *
 * elementer, der findes i set1 eller i set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Beregner intervalgennemsnittet.
 *
 * - Hvis intervallet er venstre- og højreafgrænset, returneres (intervalMin(i) +
 * intervalMax(i)) / 2. - Hvis intervallet kun er venstrebundet, returneres +∞. - Hvis
 * intervallet kun er afgrænset til højre, returneres -∞. - Hvis intervallet er uafgrænset
 * eller tomt, returneres NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Kombinerer to intervaller interval1 og interval2.
 *
 * Svarer til union, hvis deres skæringspunkt ikke er tomt, ellers inkluderer det også
 * mængden derimellem.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Beregner skæringspunktet mellem to intervaller interval1 og interval2, der indeholder de…
 *
 * elementer, der er fælles for begge.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Returnerer, om intervallet interval er afgrænset til venstre og højre eller ej.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Returnerer, om intervallet interval er lukket til venstre og højre eller ej.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Returnerer, om interval er tomt eller ej.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Returnerer, om intervallet interval er venstrebundet eller ej.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Returnerer, om intervallet er lukket til venstre eller ej.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Returnerer, om intervallet interval er højreafgrænset eller ej.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Returnerer, om intervallet interval er lukket til højre eller ej.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Returnerer den øvre grænse for intervallet interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Returnerer den nedre grænse for intervallet interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Returnerer størrelsen på intervallet interval.
 *
 * - Hvis intervallet er afgrænset, returneres max - min. - Hvis intervallet ikke er
 * afgrænset, returneres +∞. - Hvis intervallet er tomt, returneres 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Returnerer en liste, der indeholder elementerne i intervallet interval med et trin mellem hvert.
 *
 * Hvis intervallet er negativt, tages elementerne i omvendt rækkefølge.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (valgfri)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
