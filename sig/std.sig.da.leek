// === field ===

/**
 * @brief Returnerer indholdet af en celle med id celle.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell Id'et for den celle, hvis indhold vil blive returneret.
 * @return content Indholdet af cellen-cellen: @ref CELL_EMPTY for en tom celle, @ref CELL_ENTITY for en enhed,
 *     @ref CELL_OBSTACLE for en forhindring.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Returnerer afstanden mellem to celler celle1 og celle2.
 *
 * Den returnerede afstand er udtrykt i antal celler og tager ikke højde for de forskellige
 * forhindringer mellem de to celler.
 * For at få afstanden i luftlinje, se @ref getDistance og for at få vejafstanden mellem de to
 * celler, hvor du undgår forhindringer, se @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Startcellens id.
 * @param[in] cell2 Ankomstcellens id.
 * @return distance Afstanden mellem de to celler celle1 og celle2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Returnerer id'et for cellen ved position (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x Cellens x-position.
 * @param[in] y Cellens y-position.
 * @return cell Celle-id'et ved position (x, y), null, hvis cellen ikke eksisterer.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Bestemmer positionen i X af cellen cellen.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Den celle, hvis position i X vil blive bestemt.
 * @return x Cellens X-position.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Bestemmer Y-positionen for cellen cellen.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Den celle, hvis position i Y vil blive bestemt.
 * @return y Cellens Y-position.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Beregner afstanden i luftlinje mellem to celler celle1 og celle2.
 *
 * For at få afstanden i antal celler, se @ref getCellDistance, og for at få længden af stien
 * mellem de to celler, der undviger de forskellige forhindringer, se @ref getPathLength.
 *
 * @deprecated Denne funktion er forældet. Den erstattes af @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Startcellen.
 * @param[in] cell2 Ankomstcellen.
 * @return distance Afstanden i luftlinje mellem de to celler.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Returnerer den enhed, der er på celle celle.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Cellen, hvis enhed vi ønsker at hente.
 * @return entity Enhedens id i cellen eller -1, hvis cellen ikke har nogen entitet.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Returnerer den enhed, der er på celle celle.
 *
 * @deprecated Denne funktion er forældet. Den erstattes af @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Cellen, hvis enhed vi ønsker at hente.
 * @return entity Enhedens id i cellen eller -1, hvis cellen ikke har nogen entitet.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Returnerer den type terræn, som kampen finder sted på (fabrik, ørken, skov osv.), blandt…
 *
 * konstanterne @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER og
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Terrænets type.
 */
function getMapType() => integer;

/**
 * @brief Returnerer listen over forhindringspladser i terrænet.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Arrayet, der indeholder forhindringscelle-id'erne.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Returnerer stien, der undgår forhindringer mellem to celler celle1 og celle2, hvis den findes, og ignorerer cellerne indeholdt i arrayet ignoredCells.
 *
 * Hvis en spiller er på en ignoreret celle, kan stien passere over dem.
 * Startcellen celle1 er aldrig en del af den resulterende sti. Celle celle2 er en del af den
 * resulterende sti, hvis og kun hvis den er tom eller ignoreret af ignoredCells.
 * Hvis der ikke er nogen sti mellem de to celler, returnerer getPath null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Startcellen.
 * @param[in] end Ankomstcellen.
 * @param[in] ignoredCells (valgfri) Den række af celler, der skal ignoreres.
 * @return path Arrayet, der indeholder cellerne, der udgør stien mellem de to celler.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Returnerer længden af stien mellem to celler celle1 og celle2, undgår forhindringer, ignorerer cellerne indeholdt i arrayet ignoredCells.
 *
 * Denne funktion svarer til count(getPath(celle1, cell2, ignoredCells)).
 * Hvis en spiller er på en ignoreret celle, kan stien passere over dem.
 * Startcellen celle1 tælles aldrig med i resultatet. Celle celle2 tælles med i resultatet,
 * hvis og kun hvis den er tom eller ignoreret af ignoredCells.
 * Hvis der ikke er nogen sti mellem de to celler, returnerer getPathLength null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Startcellen.
 * @param[in] cell2 Ankomstcellen.
 * @param[in] ignoredCells (valgfri) Den række af celler, der skal ignoreres.
 * @return length Længden af stien mellem celle1 og celle2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Bestemmer om en celle er tom.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Cellen, der skal testes.
 * @return empty sand hvis cellen er tom, false ellers.
