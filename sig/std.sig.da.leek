 */
function getCell(integer|real entity) => integer;
function getCell() => integer;

/**
 * @brief Returnerer punkterne for objektet med id entity.
 *
 * @category leek
 * @cost 40 ops
 *
 * @param[in] entity (valgfri) Id'et for den enhed, hvis kugler vil blive returneret.
 * @return chips Et array, der indeholder punkt-id'erne for entiteten entitet.
 */
function getChips(integer|real entity) => Array<integer>;
function getChips() => Array<integer>;

/**
