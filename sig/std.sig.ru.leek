function canUseChipOnCell(integer|real chip, integer|real cell) => boolean;

/**
 * @brief Возвращает информацию о том, нужна ли чипу прямая видимость для использования.
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip Идентификатор тестируемого чипа.
 * @return needLos true, если для микросхемы требуется прямая видимость, false в противном случае.
 */
function chipNeedLos(integer|real chip) => boolean;

/**
 * @brief Возвращает список всех фишек в игре.
 *
 * @category chip
 * @cost 200 ops
 *
 * @return chips Список всех фишек в игре.
 */
function getAllChips() => Array<integer>;

/**
 * @brief Возвращает тип области эффекта чипа.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип, тип зоны которого будет возвращен.
 * @return area Тип области чипа chip среди констант AREA_*: @ref AREA_POINT: один квадрат.
 *     @ref AREA_LASER_LINE: линия лазера @ref AREA_CIRCLE_1: круглая область диаметром 3 квадрата.
 *     @ref AREA_CIRCLE_2: круглая область диаметром 5 квадратов. @ref AREA_CIRCLE_3: круглая область
 *     диаметром 7 квадратов.
 */
function getChipArea(integer|real chip) => integer;

/**
 * @brief Возвращает время восстановления чипа chip, взятое с рынка.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип, время перезарядки которого будет возвращено.
 * @return cooldown Перезарядка чипа.
 */
function getChipCooldown(integer|real chip) => integer;

/**
 * @brief Возвращает стоимость чипа chip в TP.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип стоимость которого будет возвращена.
 * @return cost Стоимость чипа.
 */
function getChipCost(integer|real chip) => integer;

/**
 * @brief Возвращает список ячеек, которые будут затронуты, если чип chip используется в ячейке cell из ячейки from.
 *
 * @category chip
 * @cost 78 ops
 *
 * @param[in] chip Чип для тестирования.
 * @param[in] cell Целевая ячейка.
 * @param[in] from (необязательный) Ячейка, из которой используется чип.
 * @return cells Массив, содержащий идентификаторы всех ячеек, которые будут затронуты.
 */
function getChipEffectiveArea(integer|real chip, integer|real cell, integer|real from) => Array<integer>;
function getChipEffectiveArea(integer|real chip, integer|real cell) => Array<integer>;

/**
 * @brief Возвращает эффекты чипа chip.
 *
 * @category chip
 * @cost 125 ops
 *
 * @param[in] chip Фишка, эффекты которой будут возвращены.
 * @return effects Эффекты чипа чипа. То же возвращаемое значение, что и для функции @ref getWeaponEffects.
 */
function getChipEffects(integer|real chip) => Array<Array>;

/**
 * @brief Возвращает процент риска отказа чипа chip.
 *
 * @deprecated Эта функция устарела.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип, процент отказов которого будет возвращен.
 * @return failure chip процент отказа чипа, целое число от 0 до 100.
 */
function getChipFailure(integer|real chip) => integer;

/**
 * @brief Возвращает режим запуска чипа chip среди констант LAUNCH_TYPE_*.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Идентификатор чипа, режим метания которого будет возвращен.
 * @return launchType Режим метания чипа chip.
 */
function getChipLaunchType(integer|real chip) => integer;

/**
 * @brief Возвращает максимальный диапазон чипа chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип, максимальный диапазон которого будет возвращен.
 * @return maxRange Максимальная дальность действия чипа.
 */
function getChipMaxRange(integer|real chip) => integer;

/**
 * @brief Возвращает максимальный диапазон чипа chip.
 *
 * @deprecated Эта функция устарела. Он заменен на @ref getChipMaxRange.
 * @sa getChipMaxRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип, максимальный диапазон которого будет возвращен.
 * @return maxScope Максимальная дальность действия чипа.
 */
function getChipMaxScope(integer|real chip) => integer;

/**
 * @brief (No `func_getChipMaxUses` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip
 * @return maxUses
 */
function getChipMaxUses(integer chip) => integer;

/**
 * @brief Возвращает минимальный диапазон чипа chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип, минимальный диапазон которого будет возвращен.
 * @return minRange Минимальный диапазон чипа.
 */
function getChipMinRange(integer|real chip) => integer;

/**
 * @brief Возвращает минимальный диапазон чипа chip.
 *
 * @deprecated Эта функция устарела. Он заменен на @ref getChipMinRange.
 * @sa getChipMinRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип, минимальный диапазон которого будет возвращен.
 * @return minScope Минимальный диапазон чипа.
 */
function getChipMinScope(integer|real chip) => integer;

/**
 * @brief Возвращает имя чипа chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Чип, имя которого будет возвращено.
 * @return name Имя чипа chip.
 */
function getChipName(integer|real chip) => string;

/**
 * @brief Возвращает текущее время восстановления chip объекта entity.
 *
 * @category chip
 * @cost 30 ops
 *
 * @param[in] chip Чип, текущее время восстановления которого будет возвращено.
 * @param[in] entity (необязательный) Сущность, время восстановления которой будет возвращено.
 * @return cooldown Текущее время восстановления чипа chip, это количество ходов, прежде чем чип станет
 *     пригодным для использования, 0, если он в настоящее время может быть использован.
 */
function getCooldown(integer|real chip, integer|real entity) => integer;
function getCooldown(integer|real chip) => integer;

/**
 * @brief Определяет, является ли значение константой, представляющей чип.
 *
 * isChip(CHIP_RAGE) = true;
 * isChip(WEAPON_PISTOL) = false.
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] value Количество, которое необходимо определить.
 * @return chip true, если значение является константой чипа.
 */
function isChip(integer|real value) => boolean;

/**
 * @brief Определяет, можно ли использовать чип только онлайн.
 *
 * @deprecated Эта функция устарела. Он заменен на @ref getChipLaunchType.
 * @sa getChipLaunchType
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip Идентификатор тестируемого чипа.
 * @return isInline true, если чип подключен только к сети, false в противном случае.
 */
function isInlineChip(integer|real chip) => boolean;

/**
 * @brief Использует чип CHIP_RESURRECTION для воскрешения мертвого объекта с идентификатором entity в ячейке cell.
 *
 * @category chip
 * @cost 500 ops
 *
 * @param[in] entity Идентификатор объекта для возрождения.
 * @param[in] cell Ячейка, в которой сущность будет возрождаться.
 * @return result Результат запуска чипа, среди констант USE_*.
 */
function resurrect(integer|real entity, integer|real cell) => integer;

/**
 * @brief Вызывает объект, определяемый чипом chip в ячейке cell, имеющей для IA функцию ai.
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip Чип, используемый для призыва. Чип должен быть чипом призыва и должен быть установлен
 *     на объекте, использующем функцию вызова.
 * @param[in] cell Ячейка или вызов должны появиться.
 * @param[in] ai Вызов ИИ как функции.
 * @param[in] name (необязательный)
 * @return return Функция вызова имеет тот же результат, что и функция @ref useChip.
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief Использовать чип chip на объекте entity.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Чип для использования.
 * @param[in] entity (необязательный) Целевая сущность.
 * @return result Возвращаемые значения useChip: @ref USE_CRITICAL, при критическом попадании @ref USE_SUCCESS,
 *     в случае успеха @ref USE_FAILED, при ошибке @ref USE_INVALID_TARGET, если цель не существует
 *     @ref USE_NOT_ENOUGH_TP, если у вашего объекта недостаточно TP @ref USE_INVALID_COOLDOWN, если
 *     чип еще не используется @ref USE_INVALID_POSITION, если диапазон плохой или линия прямой
 *     видимости не ясна
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief Используйте чип chip на ячейке cell.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Чип для использования.
 * @param[in] cell Целевая ячейка.
 * @return result Значение больше 0, если атака была запущена.
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Возвращает содержимое ячейки с идентификатором cell.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell Идентификатор ячейки, содержимое которой будет возвращено.
 * @return content Содержимое ячейки cell: @ref CELL_EMPTY для пустой ячейки, @ref CELL_ENTITY для объекта,
 *     @ref CELL_OBSTACLE для препятствия.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Возвращает расстояние между двумя ячейками cell1 и cell2.
 *
 * Возвращенное расстояние выражается в количестве ячеек и не учитывает различные препятствия
 * между двумя ячейками.
 * Чтобы получить расстояние по прямой, см. @ref getDistance, а чтобы получить расстояние пути
 * между двумя ячейками, минуя препятствия, см. @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Идентификатор начальной ячейки.
 * @param[in] cell2 Идентификатор ячейки прибытия.
 * @return distance Расстояние между двумя ячейками cell1 и cell2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Возвращает идентификатор ячейки в позиции (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x X-позиция ячейки.
 * @param[in] y Y-позиция ячейки.
 * @return cell Идентификатор ячейки в позиции (x, y), null, если ячейка не существует.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Определяет положение по оси X ячейки cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Ячейка, положение которой в X будет определено.
 * @return x X-позиция ячейки.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Определяет положение Y ячейки cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Ячейка, положение которой в Y будет определено.
 * @return y Положение Y ячейки.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Вычисляет расстояние по прямой между двумя ячейками cell1 и cell2.
 *
 * Чтобы получить расстояние в количестве ячеек, см. @ref getCellDistance, а чтобы получить длину
 * пути между двумя ячейками, уклоняясь от различных препятствий, см. @ref getPathLength.
 *
 * @deprecated Эта функция устарела. Он заменен на @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Стартовая ячейка.
 * @param[in] cell2 Ячейка прибытия.
 * @return distance Расстояние по прямой между двумя ячейками.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Возвращает объект, который находится в ячейке cell.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Ячейка, сущность которой мы хотим получить.
 * @return entity Идентификатор объекта в ячейке или -1, если в ячейке нет объекта.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Возвращает объект, который находится в ячейке cell.
 *
 * @deprecated Эта функция устарела. Он заменен на @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Ячейка, сущность которой мы хотим получить.
 * @return entity Идентификатор объекта в ячейке или -1, если в ячейке нет объекта.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Возвращает тип местности, на которой происходит бой (фабрика, пустыня, лес и т.
 *
 * д.), среди констант @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER и
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Тип местности.
 */
function getMapType() => integer;

/**
 * @brief Возвращает список мест препятствий на местности.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Массив, содержащий идентификаторы ячеек препятствия.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Возвращает путь в обход препятствий между двумя ячейками cell1 и cell2, если он существует, игнорируя ячейки, содержащиеся в массиве ignoredCells.
 *
 * Если игрок находится в игнорируемой ячейке, путь может пройти через него.
 * Начальная ячейка cell1 никогда не является частью результирующего пути. Ячейка cell2
 * является частью результирующего пути тогда и только тогда, когда она пуста или
 * игнорируется ignoredCells.
 * Если пути между двумя ячейками не существует, getPath возвращает null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Стартовая ячейка.
 * @param[in] end Ячейка прибытия.
 * @param[in] ignoredCells (необязательный) Массив ячеек для игнорирования.
 * @return path Массив, содержащий ячейки, составляющие путь между двумя ячейками.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Возвращает длину пути между двумя ячейками cell1 и cell2, минуя препятствия, игнорируя ячейки, содержащиеся в массиве ignoredCells.
 *
 * Эта функция эквивалентна count(getPath(cell1, cell2, ignoredCells)).
 * Если игрок находится в игнорируемой ячейке, путь может пройти через него.
 * Начальная ячейка cell1 никогда не учитывается в результате. Ячейка cell2 учитывается в
 * результате тогда и только тогда, когда она пуста или игнорируется ignoredCells.
 * Если пути между двумя ячейками не существует, getPathLength возвращает null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Стартовая ячейка.
 * @param[in] cell2 Ячейка прибытия.
 * @param[in] ignoredCells (необязательный) Массив ячеек для игнорирования.
 * @return length Длина пути между cell1 и cell2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Определяет, пуста ли ячейка.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Тестируемая ячейка.
 * @return empty true, если ячейка пуста, false в противном случае.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Определяет, является ли содержимое ячейки cell сущностью.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell Тестируемая ячейка.
 * @return isEntity true, если ячейка содержит объект, false в противном случае.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Определяет, является ли содержимое ячейки cell сущностью.
 *
 * @deprecated Эта функция устарела. Он заменен на @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Тестируемая ячейка.
 * @return isLeek true, если ячейка содержит объект, false в противном случае.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Определяет, является ли содержимое ячейки cell препятствием.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Тестируемая ячейка.
 * @return isObstacle true, если ячейка содержит препятствие, false в противном случае.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Определяет, находятся ли две ячейки cell1 и cell2 на одной строке.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Первая ячейка.
 * @param[in] cell2 Вторая ячейка.
 * @return sameLine true, если две ячейки находятся на одной строке, false в противном случае.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

