 * @cost 500 ops
 *
 * @param[in] entities Массив, содержащий идентификаторы сущностей, к которым должна подойти ваша сущность.
 * @param[in] mp (необязательный) Максимальное количество MP для использования. По умолчанию без ограничений.
 * @return mp Количество использованных очков движения.
 */
function moveTowardEntities(Array<integer> entities, integer|real mp) => integer;
function moveTowardEntities(Array<integer> entities) => integer;

/**
 * @brief Приближает вашу сущность к набору сущностей, используя максимальное количество mp очков движения.
 *
 * @deprecated Эта функция устарела. Он заменен на @ref moveTowardEntities.
 * @sa moveTowardEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] leeks Массив, содержащий идентификаторы сущностей, к которым должна подойти ваша сущность.
 * @param[in] mp (необязательный) Максимальное количество MP для использования. По умолчанию без ограничений.
 * @return mp Количество использованных очков движения.
 */
function moveTowardLeeks(Array<integer> leeks, integer|real mp) => integer;
function moveTowardLeeks(Array<integer> leeks) => integer;

/**
 * @brief Приближает вашу сущность к линии, определяемой двумя ячейками cell1 и cell2, используя…
 *
 * максимальное количество очков движения mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 Ячейка 1.
 * @param[in] cell2 Ячейка 2.
 * @param[in] mp (необязательный) Максимальное количество MP для использования. По умолчанию без ограничений.
 * @return mp Количество использованных очков движения.
 */
function moveTowardLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveTowardLine(integer|real cell1, integer|real cell2) => integer;

// === utils ===

/**
 * @brief Удаляет все отметки, сделанные функциями mark() и markText() в поле.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Копирует значение, переданное в качестве параметра на уровнях level, и возвращает копию.
 *
 * Например, в случае массива клон (массив, 1) скопирует массив, но не его элементы, клон
 * (массив, 2) скопирует массив, а также все элементы.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value Значение для клонирования
 * @param[in] level (необязательный) Количество уровней для клонирования
 * @return copy Клонированное значение
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Записывает сообщение object в личный журнал, доступное в отчете по окончании боя.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Сообщение для записи.
 */
function debug(any object) => void;

/**
 * @brief Записывает в личный журнал объектное сообщение, доступное в отчете по окончании боя, цвета color.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Сообщение для записи.
 * @param[in] color Цвет сообщения. Вы можете использовать функцию @ref getColor.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Записывает сообщение об ошибке объекта в личный журнал, доступный в отчете по окончании боя.
 *
 * Сообщения об ошибках отображаются в отчете о бое красным цветом.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Сообщение об ошибке для регистрации.
 */
function debugE(any object) => void;

/**
 * @brief Записывает предупреждающее сообщение об объекте в личном журнале, доступном в отчете по окончании боя.
 *
 * Предупреждающие сообщения отображаются в боевом отчете оранжевым цветом.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Предупреждающее сообщение для записи.
 */
function debugW(any object) => void;

/**
 * @brief Удаляет реестр, связанный с ключом key, если он существует.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key Раздел реестра для удаления.
 */
function deleteRegister(string key) => void;

/**
 * @brief Возвращает дату боя в формате дд/мм/гггг.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date Дата боя.
 */
function getDate() => string;

/**
 * @brief Возвращает количество инструкций, которые ваша сущность выполнила за текущий ход.
 *
 * @deprecated Эта функция устарела. Он заменен на @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Количество инструкций, которые ваша сущность выполнила за текущий ход.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Возвращает доступный лимит оперативной памяти вашего ИИ.
 *
 * Оперативная память расходуется на создание списков, таблиц и объектов.
 * Текущий предел составляет 100 мегабайт или 12 500 000 элементов списка.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Возвращает количество операций, потребленных вашей сущностью с начала ее хода.
 *
 * Это число должно оставаться меньше @ref OPERATIONS_LIMIT, чтобы не произошло сбоя сущности.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Количество операций, потребленных вашей сущностью с начала ее хода.
 */
function getOperations() => integer;

/**
 * @brief Возвращает значение, хранящееся в реестре сущностей, связанное с ключом key или null, если реестр не существует.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key Раздел реестра, значение которого будет возвращено.
 * @return value Значение, хранящееся в реестре key.
 */
function getRegister(string key) => string;

/**
 * @brief Возвращает набор регистров сущностей в виде ассоциативного массива [ключ реестра:значение регистра].
 *
 * Пример: debug(getRegisters());
 * // Отображает, например:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Ассоциативный массив, соответствующий всем регистрам объекта.
 */
function getRegisters() => Array<string>;

/**
 * @brief Возвращает время боя в формате ЧЧ:мм:сс.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Время боя.
 */
function getTime() => string;

/**
 * @brief Возвращает временную метку боя, равную количеству секунд с 1 января 1970 года.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Отметка времени боя.
 */
function getTimestamp() => integer;

/**
 * @brief Возвращает объем оперативной памяти, используемой в настоящее время вашим ИИ.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Включить ИИ с именем ai в текущий ИИ.
 *
 * Внимание, функция включения должна вызываться только в основном блоке, а ее параметр
 * должен быть строкой, записанной напрямую
 * в коде. Для получения дополнительной информации см. раздел руководства:
 * http://leekwars.com/help/tutorial#includes.
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Имя ИИ для включения.
 */
function include(string ai) => void;

/**
 * @brief Декодирует строку json в объект LeekScript (число, строка, массив...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json Строка JSON для декодирования.
 * @return object Расшифрованный объект LeekScript.
 */
function jsonDecode(string json) => any;

/**
 * @brief Кодирует объект object в строку JSON.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object Объект для кодирования в JSON.
 * @return json Строка в формате JSON.
 */
function jsonEncode(string object) => string;

/**
 * @brief Отмечает одну или несколько ячеек указанного в параметре цвета на земле на указанное в параметре количество ходов.
 *
 * Эта маркировка видна только заводчику объекта.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Ячейка или массив из нескольких ячеек для пометки
 * @param[in] color (необязательный) Цвет маркировки
 * @param[in] duration (необязательный) Продолжительность маркировки
 * @return success Возвращает true, если все прошло хорошо
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Пишет текст на одной или нескольких ячейках указанного в параметре цвета на земле за указанное в параметре количество ходов.
 *
 * Эти тексты видны только создателю сущности.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Ячейка или массив из нескольких ячеек для записи
 * @param[in] text (необязательный) Текст для написания (максимум 10 символов)
 * @param[in] color (необязательный) Цвет текста
 * @param[in] duration (необязательный) Длительность текста
 * @return success Возвращает true, если все прошло хорошо
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Приостанавливает бой, только для заводчика существа, использующего эту функцию.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Сохраняет значение в реестре ключей.
 *
 * Ключ и значение представляют собой строки, которые должны содержать не более 100 и 5000
 * символов соответственно. Лук-порей может иметь не более 100 регистров, сохранение в новом
 * регистре не будет работать, если все регистры
 * уже заняты.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Раздел реестра, в котором будет храниться значение.
 * @param[in] value Значение для сохранения.
 * @return success true, если операция прошла успешно, false в противном случае.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Показывает игрокам ячейку цвета color на поле на 1 ход.
 *
 * Использование этой функции стоит 1 PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Ячейка для отображения
 * @param[in] color (необязательный) Цвет маркировки
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Возвращает тип значения значение из следующих типов: @ref TYPE_NULL, @ref TYPE_NUMBER,…
 *
 * @ref TYPE_BOOLEAN, @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Значение, тип которого будет возвращен.
 * @return type Тип значения.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Возвращает идентификатор объекта, создавшего сообщение message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Сообщение, автор которого будет возвращен.
 * @return entity Идентификатор объекта, создавшего сообщение message.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Возвращает массив параметров сообщения message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Сообщение, параметры которого будут возвращены.
 * @return params Параметры сообщения message.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Возвращает тип сообщения message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Сообщение, тип которого будет возвращен (среди @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK и т.
 *     д.).
 * @return type Тип сообщения сообщение.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Возвращает массив сообщений объекта entity.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (необязательный) Сущность, чьи сообщения будут возвращены.
 * @return messages Таблица ваших сообщений. Само сообщение представлено в виде массив вида: [автор, тип,
 *     параметры] Различные типы сообщений представлены константами: @ref MESSAGE_HEAL: запрос на
 *     помощь @ref MESSAGE_ATTACK: запрос на атаку @ref MESSAGE_BUFF_FORCE: запрос принудительного
 *     повышения ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Отправьте сообщение всей вашей команде.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Тип сообщения для отправки (см. константы MESSAGE_*).
 * @param[in] params Параметры сообщения, которые могут быть любыми значениями.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Отправляет сообщение объекту с идентификатором entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity Идентификатор объекта, которому будет отправлено сообщение.
 * @param[in] type Тип сообщения для отправки (см. константы MESSAGE_*).
 * @param[in] params Параметры сообщения, которые могут быть любыми значениями.
 * @return sent true, если отправка прошла успешно, false, если произошла ошибка.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Возвращает количество синего в цвете color в диапазоне от 0 до 255.
 *
 * Например, getBlue(@ref COLOR_BLUE) = 255 и getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Цвет, скорость синего которого будет возвращена.
 * @return blue Доля синего цвета в цвете color
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Возвращает целое число, соответствующее цвету (красный, зеленый, синий), указанному в качестве параметров.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Красное значение от 0 до 255.
 * @param[in] green Зеленое значение от 0 до 255.
 * @param[in] blue Значение синего от 0 до 255.
 * @return color int, соответствующий цвету, указанному в качестве параметра.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Возвращает количество зеленого в цвете color в диапазоне от 0 до 255.
 *
 * Например, getGreen(@ref COLOR_GREEN) = 255 и getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Цвет, уровень зеленого которого будет возвращен.
 * @return green Коэффициент зеленого цвета в цвете color
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Возвращает количество красного в цвете color в диапазоне от 0 до 255.
 *
 * Например, getRed(@ref COLOR_RED) = 255 и getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Цвет, красный показатель которого будет возвращен.
 * @return red Доля красного в цвете
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Очищает набор.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Поиск элемента element в множестве set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Возвращает разность между множествами set1 и set2, т.е.
 *
 * все элементы set1, которых нет в set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Вычисляет исключительную дизъюнкцию двух множеств set1 и set2, выраженную set1 ⊕ set2, то…
 *
 * есть элементы, присутствующие в set1 или set2, но не присутствующие в обоих одновременно.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Вычисляет пересечение двух множеств set1 и set2, отмеченных как set1 ∩ set2, которые…
 *
 * являются общими элементами двух множеств.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Возвращает, является ли набор пустым или нет.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Определяет, является ли множество set1 подмножеством set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Вставляет элемент element в множество set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Удаляет элемент element из множества set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Возвращает размер набора set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Возвращает список, содержащий все элементы множества set.
 *
 * Порядок следования элементов произвольный.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Вычисляет объединение двух множеств set1 и set2, обозначаемое set1 ∪ set2, которое…
 *
 * содержит все элементы, присутствующие в set1 или в set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Вычисляет интервальное среднее значение.
 *
 * - Если интервал ограничен слева и справа, возвращается (intervalMin(i) + intervalMax(i)) /
 * 2. - Если интервал ограничен только слева, возвращается +∞. - Если интервал ограничен
 * только справа, возвращается -∞. - Если интервал не ограничен или пуст, возвращается NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Объединяет два интервала интервал1 и интервал2.
 *
 * Эквивалентна объединению, если их пересечение непусто, в противном случае включает также
 * множество между ними.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Вычисляет пересечение двух интервалов интервал1 и интервал2, содержащее общие для них элементы.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Возвращает, является ли интервал interval ограниченным слева и справа или нет.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Возвращает, является ли интервал interval замкнутым слева и справа или нет.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Возвращает, является ли интервал пустым или нет.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Возвращает, является ли интервал interval левограничным или нет.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Возвращает, является ли интервал замкнутым слева.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Возвращает, является ли интервал interval правосторонне ограниченным или нет.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Возвращает, является ли интервал interval замкнутым справа или нет.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Возвращает верхнюю границу интервала интервал.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Возвращает нижнюю границу интервала интервал.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Возвращает размер интервала interval.
 *
 * - Если интервал ограничен, возвращается max - min. - Если интервал не ограничен,
 * возвращается +∞. - Если интервал пуст, возвращается 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Возвращает список, содержащий элементы интервала интервал с шагом между каждым.
 *
 * Если интервал отрицательный, то элементы берутся в обратном порядке.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (необязательный)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
