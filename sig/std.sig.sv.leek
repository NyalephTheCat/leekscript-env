// === utils ===

/**
 * @brief Rensar alla markeringar gjorda av mark() och markText() i fältet.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Kopierar värdet som skickats som en parameter på nivå-nivåer och returnerar kopian.
 *
 * I fallet med en array till exempel, kommer en klon(array, 1) att kopiera arrayen men inte
 * dess element, en clone(array, 2) kommer att kopiera arrayen såväl som alla element.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value Värdet att klona
 * @param[in] level (frivillig) Antalet nivåer att klona
 * @return copy Det klonade värdet
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Spelar in ett objekt-meddelande i den personliga loggen, tillgänglig i rapporten i slutet av kampen.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Meddelandet att spela in.
 */
function debug(any object) => void;

/**
 * @brief Spelar in ett objekt-meddelande i den personliga loggen, tillgänglig i rapporten i slutet av kampen, med färgen färg.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Meddelandet att spela in.
 * @param[in] color Färgen på meddelandet. Du kan använda @ref getColor-funktionen.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Registrerar ett objekt-felmeddelande i den personliga loggen, tillgängligt i rapporten i slutet av kampen.
 *
 * Felmeddelanden visas i rött i kamprapporten.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Felmeddelandet att logga.
 */
function debugE(any object) => void;

/**
 * @brief Spelar in ett objekt-varningsmeddelande i den personliga loggen, tillgänglig i rapporten i slutet av kampen.
 *
 * Varningsmeddelanden visas i orange i stridsrapporten.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Varningsmeddelandet att spela in.
 */
function debugW(any object) => void;

