/**
 * @brief Returnerar kampens tidsstämpel, lika med antalet sekunder sedan 1 januari 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Kampens tidsstämpel.
 */
function getTimestamp() => integer;

/**
 * @brief Returnerar mängden RAM som för närvarande används av din AI.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Inkludera AI med namnet ai i den aktuella AI:n.
 *
 * Varning, funktionen include måste endast anropas i huvudblocket, och dess parameter måste
 * vara en sträng skriven direkt
 * i koden. För mer information, se avsnittet i handledningen:
 * http://leekwas.com/help/tutorial#includes.
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Namnet på den AI som ska inkluderas.
 */
function include(string ai) => void;

/**
 * @brief Avkodar sträng json till LeekScript-objekt (nummer, sträng, array...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json JSON-strängen som ska avkodas.
 * @return object Det avkodade LeekScript-objektet.
 */
function jsonDecode(string json) => any;

/**
 * @brief Kodar object-objektet till en JSON-sträng.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object Objektet som ska kodas i JSON.
 * @return json Den JSON-kodade strängen.
 */
function jsonEncode(string object) => string;

/**
 * @brief Markerar en eller flera celler med den färg som anges i parametern på marken för antalet varv som anges i parametern.
 *
 * Denna märkning är endast synlig för uppfödaren av enheten.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Cellen eller arrayen med flera celler som ska markeras
 * @param[in] color (frivillig) Markeringsfärg
 * @param[in] duration (frivillig) Märkningens varaktighet
 * @return success Returnerar sant om allt gick bra
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Skriver en text på en eller flera celler med den färg som anges i parametern på marken för antalet varv som anges i parametern.
 *
 * Dessa texter är endast synliga för uppfödaren av enheten.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Cellen eller arrayen med flera celler att skriva till
 * @param[in] text (frivillig) Texten att skriva (max 10 tecken)
 * @param[in] color (frivillig) Text färg
 * @param[in] duration (frivillig) Textens varaktighet
 * @return success Returnerar sant om allt gick bra
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Pausar kampen, endast för uppfödaren av enheten som använder funktionen.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Lagrar värdet i nyckel-registret.
 *
 * Nyckeln och värdet är strängar som högst måste innehålla 100 respektive 5000 tecken. En
 * purjolök kan ha maximalt 100 register, lagring i ett nytt register fungerar inte om alla
 * register
 * är redan upptagna.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Registernyckeln där värdet ska lagras.
 * @param[in] value Värdet att lagra.
 * @return success true om operationen lyckades, false annars.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Visar spelarna en cell med färgen färg på fältet under 1 tur.
 *
 * Att använda denna funktion kostar 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Cellen som ska visas
 * @param[in] color (frivillig) Markeringsfärg
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Returnerar typen av värdet värde, bland typerna: @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN,…
 *
 * @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Värdet vars typ kommer att returneras.
 * @return type Typen av värde.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Returnerar id:t för den enhet som skapar meddelandet meddelandet.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Meddelandet vars författare kommer att returneras.
 * @return entity Id för den enhet som skapar meddelandet meddelande.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Returnerar arrayen av meddelandeparametrar meddelande.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Meddelandet vars parametrar kommer att returneras.
 * @return params Parametrarna för meddelande.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Returnerar meddelandetypen meddelande.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Meddelandet vars typ kommer att returneras (bland @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK,
 *     etc.).
 * @return type Meddelandetypen meddelande.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Returnerar entitetsmeddelandematrisen entity.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (frivillig) Entiteten vars meddelanden kommer att returneras.
 * @return messages Tabellen över dina meddelanden. Ett meddelande representeras i sig självt i form av en
 *     array av formen: [författare, typ, parametrar] De olika typerna av meddelanden
 *     representeras av konstanterna: @ref MESSAGE_HEAL: begäran om vård; @ref MESSAGE_ATTACK:
 *     begäran om attack; @ref MESSAGE_BUFF_FORCE: tvinga fram förstärkningsbegäran; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Skicka ett meddelande till hela ditt team.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Typen av meddelande som ska skickas (se MESSAGE_* konstanterna).
 * @param[in] params Meddelandeparametrarna, som kan vara vilket värde som helst.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Skickar ett meddelande till entiteten med id entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity Id för den enhet som meddelandet kommer att skickas till.
 * @param[in] type Typen av meddelande som ska skickas (se MESSAGE_* konstanterna).
 * @param[in] params Meddelandeparametrarna, som kan vara vilket värde som helst.
 * @return sent true om sändningen lyckades, false om ett fel inträffade.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Returnerar mängden blått i färgen färg, mellan 0 och 255.
 *
 * Till exempel getBlue(@ref COLOR_BLUE) = 255 och getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Färgen vars blå kurs kommer att returneras.
 * @return blue Hastigheten för blått i färgen färg
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Returnerar det heltal som motsvarar färgen (röd, grön, blå) som anges som parametrar.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Rött värde mellan 0 och 255.
 * @param[in] green Grönt värde mellan 0 och 255.
 * @param[in] blue Blått värde mellan 0 och 255.
 * @return color int som motsvarar den färg som anges som en parameter.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Returnerar mängden grönt i färgen färg, mellan 0 och 255.
 *
 * Till exempel getGreen(@ref COLOR_GREEN) = 255 och getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Färgen vars gröna kurs kommer att returneras.
 * @return green Frekvensen för grönt i färgen färg
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Returnerar mängden rött i färgen färg, mellan 0 och 255.
 *
 * Till exempel getRed(@ref COLOR_RED) = 255 och getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Färgen vars röda frekvens kommer att returneras.
 * @return red Frekvensen för rött i färg
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Rensar uppsättningen.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Söker efter ett element element i uppsättningen set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Returnerar skillnaden mellan uppsättningarna set1 och set2, dvs.
 *
 * alla element i set1 som inte finns i set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Beräknar den exklusiva disjunktionen av två mängder set1 och set2, noterade set1 ⊕ set2,…
 *
 * som är de element som finns i set1 eller set2, men inte i båda samtidigt.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Beräknar skärningen mellan två uppsättningar set1 och set2, noterade set1 ∩ set2, som är…
 *
 * de gemensamma elementen i de två uppsättningarna.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Returnerar om en set är tom eller inte.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Avgör om en uppsättning set1 är en delmängd av set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Infogar ett element element i mängden mängd.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Tar bort ett element element från mängden mängd.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Returnerar storleken på uppsättningen set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Returnerar en lista som innehåller alla element i uppsättningen set.
 *
 * Elementens ordning är godtycklig.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Beräknar unionen av två uppsättningar set1 och set2, betecknad set1 ∪ set2, som innehåller…
 *
 * alla element som finns i set1 eller i set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Beräknar intervallgenomsnittet.
 *
 * - Om intervallet är vänster- och högerbundet returneras (intervallMin(i) +
 * intervallMax(i)) / 2. - Om intervallet endast är vänsterbundet returneras +∞. - Om
 * intervallet endast är högerbundet returneras -∞. - Om intervallet är obegränsat eller
 * tomt, returneras NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Kombinerar två intervall intervall1 och intervall2.
 *
 * Motsvarar union om deras skärningspunkt är icke-tom, annars inkluderas även mängden
 * däremellan.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Beräknar skärningspunkten mellan två intervall intervall1 och intervall2, som innehåller…
 *
 * de element som är gemensamma för båda.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Returnerar om intervallet intervall är begränsat till vänster och höger eller inte.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Returnerar om intervallet intervall är slutet till vänster och höger eller inte.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Returnerar om intervall är tomt eller inte.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Returnerar om intervallet intervall är vänsterbundet eller inte.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Returnerar om intervall är stängt till vänster eller inte.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Returnerar om intervallet intervall är högerbundet eller inte.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Returnerar om intervallet intervall är stängt till höger eller inte.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Returnerar den övre gränsen för intervallet intervall.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Returnerar den nedre gränsen för intervallet intervall.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Returnerar storleken på intervallet intervall.
 *
 * - Om intervallet är begränsat returneras max - min. - Om intervallet inte är begränsat
 * returneras +∞. - Om intervallet är tomt returneras 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Returnerar en lista som innehåller elementen i intervallet intervall med ett steg mellan varje element.
 *
 * Om intervallet är negativt tas elementen i omvänd ordning.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (frivillig)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
