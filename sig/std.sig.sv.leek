 * @return value Värdet som lagras i nyckel-registret.
 */
function getRegister(string key) => string;

/**
 * @brief Returnerar uppsättningen av entitetsregister som en associativ array [registernyckel:registervärde].
 *
 * Exempel: debug(getRegisters());
 * // Visar till exempel:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Den associativa matrisen som motsvarar enhetens alla register.
 */
function getRegisters() => Array<string>;

