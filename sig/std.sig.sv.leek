 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Antalet instruktioner din enhet har utfört under den aktuella svängen.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Returnerar den användbara RAM-gränsen för din AI.
