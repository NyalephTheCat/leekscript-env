// === field ===

/**
 * @brief Returnerar innehållet i en cell med id cell.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell Id för cellen vars innehåll kommer att returneras.
 * @return content Innehållet i cellen cell: @ref CELL_EMPTY för en tom cell, @ref CELL_ENTITY för en enhet,
 *     @ref CELL_OBSTACLE för ett hinder.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Returnerar avståndet mellan två celler cell1 och cell2.
 *
 * Det returnerade avståndet uttrycks i antal celler och tar inte hänsyn till de olika
 * hindren mellan de två cellerna.
 * För att få avståndet fågelvägen, se @ref getDistance och för att få vägavståndet mellan de två
 * cellerna för att undvika hinder, se @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Id för startcellen.
 * @param[in] cell2 Ankomstcellens ID.
 * @return distance Avståndet mellan de två cellerna cell1 och cell2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Returnerar cellens id vid position (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x Cellens x-position.
 * @param[in] y Cellens y-position.
 * @return cell Cell-ID vid position (x, y), null om cellen inte finns.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Bestämmer positionen i X för cellens cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Cellen vars position i X kommer att bestämmas.
 * @return x Cellens X-position.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Bestämmer Y-positionen för cellens cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Cellen vars position i Y kommer att bestämmas.
 * @return y Cellens Y-position.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Beräknar fågelvägsavståndet mellan två celler cell1 och cell2.
 *
 * För att få avståndet i antal celler, se @ref getCellDistance, och för att få längden på vägen
 * mellan de två cellerna som undviker de olika hindren, se @ref getPathLength.
 *
 * @deprecated Denna funktion är föråldrad. Den ersätts av @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Startcellen.
 * @param[in] cell2 Ankomstcellen.
 * @return distance Avståndet fågelvägen mellan de två cellerna.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Returnerar entiteten som finns i cell cell.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Cellen vars enhet vi vill hämta.
 * @return entity Entitetens ID i cellen, eller -1 om cellen inte har någon enhet.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Returnerar entiteten som finns i cell cell.
 *
 * @deprecated Denna funktion är föråldrad. Den ersätts av @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Cellen vars enhet vi vill hämta.
 * @return entity Entitetens ID i cellen, eller -1 om cellen inte har någon enhet.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Returnerar typen av terräng där kampen äger rum (fabrik, öken, skog etc.), bland…
 *
 * konstanterna @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER och
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Typen av terräng.
 */
function getMapType() => integer;

/**
 * @brief Returnerar listan över hinderutrymmen i terrängen.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Arrayen som innehåller hindercells-ID.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Returnerar sökvägen som undviker hinder mellan två celler cell1 och cell2, om den finns, ignorerar cellerna i arrayen ignoredCells.
 *
 * Om en spelare befinner sig i en ignorerad cell, kan vägen passera över dem.
 * Startcellen cell1 är aldrig en del av den resulterande sökvägen. Cell cell2 är en del av
 * den resulterande sökvägen om och bara om den är tom eller ignoreras av ignoredCells.
 * Om det inte finns någon sökväg mellan de två cellerna returnerar getPath null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Startcellen.
 * @param[in] end Ankomstcellen.
 * @param[in] ignoredCells (frivillig) Uppsättningen av celler att ignorera.
 * @return path Arrayen som innehåller cellerna som utgör vägen mellan de två cellerna.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Returnerar längden på sökvägen mellan två celler cell1 och cell2, undviker hinder, ignorerar cellerna i arrayen ignoredCells.
 *
 * Denna funktion motsvarar count(getPath(cell1, cell2, ignoredCells)).
 * Om en spelare befinner sig i en ignorerad cell, kan vägen passera över dem.
 * Startcellen cell1 räknas aldrig med i resultatet. Cell cell2 räknas i resultatet om och
 * endast om den är tom eller ignoreras av ignoredCells.
 * Om det inte finns någon sökväg mellan de två cellerna returnerar getPathLength null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Startcellen.
 * @param[in] cell2 Ankomstcellen.
 * @param[in] ignoredCells (frivillig) Uppsättningen av celler att ignorera.
 * @return length Längden på sökvägen mellan cell1 och cell2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Bestämmer om en cell är tom.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Cellen som ska testas.
 * @return empty true om cellen är tom, false annars.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Bestämmer om innehållet i cell cell är en enhet.
