 * Den nuvarande gränsen är 100 megabyte eller 12 500 000 listobjekt.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Returnerar antalet operationer som förbrukats av din enhet sedan starten av sin tur.
 *
 * Detta nummer måste förbli lägre än @ref OPERATIONS_LIMIT så att enheten inte kraschar.
 *
 * @category utils
