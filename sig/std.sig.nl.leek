 * @param[in] element Het item om naar te zoeken.
 * @return inArray true als het element in de array staat, false anders.
 */
function inArray(Array array, any element) => boolean;

/**
 * @brief Voegt een element element in de array in op positie position.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array De array waarin het element wordt ingevoegd.
 * @param[in] element Het item dat moet worden ingevoegd.
 * @param[in] position De positie van de insertie.
 */
function insert(Array array, any element, integer|real position) => void;

/**
 * @brief Bepaalt of de array array leeg is.
 *
 * Gelijk aan count(array) == 0.
 *
