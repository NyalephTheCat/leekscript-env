 *
 * @param[in] array Bron tabel.
 * @param[in] start Startindex.
 * @param[in] end Eindindex.
 * @return array Subarray.
 */
function subArray(Array array, integer|real start, integer|real end) => Array;

/**
 * @brief Retourneert de som van alle numerieke elementen in de array array.
