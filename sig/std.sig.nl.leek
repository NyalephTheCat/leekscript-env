 * @cost O(n)
 *
 * @param[in] array Een reeks items om samen te voegen.
 * @param[in] glue Het elementscheidingsteken.
 * @return string De resulterende tekenreeks van de samenvoeging.
 */
function join(Array array, string glue) => string;

/**
 * @brief Sorteert de array op sleutels in volgorde volgorde.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array De array die moet worden gesorteerd.
 * @param[in] order (optioneel) De sorteervolgorde: @ref SORT_ASC of @ref SORT_DESC.
 */
function keySort(Array array, integer|real order) => void;
function keySort(Array array) => void;

/**
 * @brief Verwijdert de laatste cel uit de array array en retourneert het overeenkomstige element.
 *
 * @category array
