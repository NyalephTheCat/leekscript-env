 * @return averageValue Gemiddelde waarde.
 */
function average(Array<integer|real> array) => real;

/**
 * @brief Telt het aantal elementen in de array array.
 *
 * @category array
 * @cost 1 op
 *
 * @param[in] array Array waarvan het aantal elementen wordt geteld.
 * @return numberOfElements Aantal array-elementen.
 */
function count(Array array) => integer;

/**
 * @brief Wijzigt de grootte van de array array naar size en vult alle vakjes met waarde.
