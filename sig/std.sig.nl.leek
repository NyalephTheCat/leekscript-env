 *     start, null als het element niet is gevonden.
 */
function search(Array array, any element, integer|real start) => integer;
function search(Array array, any element) => integer;

/**
 * @brief Verwijdert de eerste cel uit de matrix en retourneert het overeenkomstige element.
 *
