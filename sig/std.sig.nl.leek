 * @cost 2 ops
 *
 * @param[in] array De array die moet worden getest.
 * @return empty true als de array leeg is, false anders.
 */
function isEmpty(Array array) => boolean;

/**
 * @brief Voegt meerdere elementen samen tot een tekenreeks en scheidt ze met een glue scheidingsteken.
 *
