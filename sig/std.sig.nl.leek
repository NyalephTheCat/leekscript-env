// === field ===

/**
 * @brief Retourneert de inhoud van een cel met id cel.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell De id van de cel waarvan de inhoud wordt geretourneerd.
 * @return content De inhoud van de cel cel: @ref CELL_EMPTY voor een lege cel, @ref CELL_ENTITY voor een
 *     entiteit, @ref CELL_OBSTACLE voor een obstakel.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Retourneert de afstand tussen twee cellen cel1 en cel2.
 *
 * De geretourneerde afstand wordt uitgedrukt in aantal cellen en houdt geen rekening met de
 * verschillende obstakels tussen de twee cellen.
 * Om de afstand hemelsbreed te krijgen, zie @ref getDistance en om de padafstand tussen de twee
 * cellen te krijgen om obstakels te vermijden, zie @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 De id van de startcel.
 * @param[in] cell2 De id van de aankomstcel.
 * @return distance De afstand tussen de twee cellen cel1 en cel2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Retourneert de id van de cel op positie (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x De x-positie van de cel.
 * @param[in] y De y-positie van de cel.
 * @return cell De cel-ID op positie (x, y), null als de cel niet bestaat.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Bepaalt de positie in X van de cel cel.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell De cel waarvan de positie in X wordt bepaald.
 * @return x De X-positie van de cel.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Bepaalt de Y-positie van de cel cel.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell De cel waarvan de positie in Y zal worden bepaald.
 * @return y De Y-positie van de cel.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Berekent hemelsbreed de afstand tussen twee cellen cel1 en cel2.
 *
 * Om de afstand in aantal cellen te krijgen, zie @ref getCellDistance, en om de lengte te
 * krijgen van het pad tussen de twee cellen die de verschillende obstakels ontwijken, zie
 * @ref getPathLength.
 *
 * @deprecated Deze functie is verouderd. Het wordt vervangen door @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 De startcel.
 * @param[in] cell2 De aankomstcel.
 * @return distance De afstand hemelsbreed tussen de twee cellen.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Retourneert de entiteit die zich op cel cel bevindt.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell De cel waarvan we de entiteit willen ophalen.
 * @return entity De id van de entiteit in de cel, of -1 als de cel geen entiteit heeft.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Retourneert de entiteit die zich op cel cel bevindt.
 *
 * @deprecated Deze functie is verouderd. Het wordt vervangen door @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell De cel waarvan we de entiteit willen ophalen.
 * @return entity De id van de entiteit in de cel, of -1 als de cel geen entiteit heeft.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Geeft het type terrein terug waarop het gevecht plaatsvindt (fabriek, woestijn, bos etc.),…
 *
 * tussen de constanten @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER en
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Het type terrein.
 */
function getMapType() => integer;

/**
 * @brief Geeft de lijst met hindernissen op het terrein terug.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles De array met de ID's van de obstakelcellen.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Retourneert het pad waarbij obstakels tussen twee cellen cell1 en cell2 worden vermeden, indien aanwezig, waarbij de cellen in de array ignoredCells worden genegeerd.
 *
 * Als een speler zich op een genegeerde cel bevindt, kan het pad er overheen gaan.
 * De startcel cell1 maakt nooit deel uit van het resulterende pad. Cel cell2 maakt deel uit
 * van het resulterende pad als en slechts als het leeg is of wordt genegeerd door
 * ignoredCells.
 * Als er geen pad tussen de twee cellen bestaat, retourneert getPath null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start De startcel.
 * @param[in] end De aankomstcel.
 * @param[in] ignoredCells (optioneel) De reeks cellen die moet worden genegeerd.
 * @return path De array met de cellen die het pad tussen de twee cellen vormen.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Retourneert de lengte van het pad tussen twee cellen cell1 en cell2, vermijdt obstakels en negeert de cellen in de array ignoredCells.
 *
 * Deze functie is gelijk aan count(getPath(cell1, cell2, ignoredCells)).
 * Als een speler zich op een genegeerde cel bevindt, kan het pad er overheen gaan.
 * De startcel cell1 wordt nooit meegeteld in het resultaat. Cel cell2 wordt meegeteld in het
 * resultaat als en alleen als deze leeg is of wordt genegeerd door ignoredCells.
 * Als er geen pad bestaat tussen de twee cellen, retourneert getPathLength null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 De startcel.
 * @param[in] cell2 De aankomstcel.
 * @param[in] ignoredCells (optioneel) De reeks cellen die moet worden genegeerd.
 * @return length De lengte van het pad tussen cel1 en cel2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Bepaalt of een cel leeg is.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell De te testen cel.
 * @return empty true als de cel leeg is, false anders.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Bepaalt of de inhoud van cel cel een entiteit is.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell De te testen cel.
 * @return isEntity true als de cel een entiteit bevat, false anders.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Bepaalt of de inhoud van cel cel een entiteit is.
 *
 * @deprecated Deze functie is verouderd. Het wordt vervangen door @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell De te testen cel.
 * @return isLeek true als de cel een entiteit bevat, false anders.
 */
