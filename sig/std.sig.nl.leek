 */
function removeKey(Array array, any key) => void;

/**
 * @brief Keert de array om.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tabel om te keren.
 */
function reverse(Array array) => void;

/**
 * @brief Vindt het element element in de array array, beginnend vanaf positie start.
