 *
 * @param[in] array De array waarvan de eerste cel wordt verwijderd.
 * @return element Het element dat in de oude eerste doos zat.
 */
function shift(Array array) => any;

/**
 * @brief Schudt een bord willekeurig.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Het sjoelbord.
 */
function shuffle(Array array) => void;

/**
 * @brief Sorteert de matrix in oplopende of aflopende volgorde.
 *
 * De standaard oplopende volgorde is:
 * Alle booleans (eerst onwaar, dan waar)
 * Alle getallen (gerangschikt van klein naar groot)
 * Alle zenders (in alfabetische volgorde)
 * Alle null-elementen.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Matrix om te sorteren.
 * @param[in] order (optioneel) @ref SORT_ASC om array in oplopende volgorde te sorteren of @ref SORT_DESC om in aflopende
 *     volgorde te sorteren.
 */
function sort(Array array, integer|real order) => void;
function sort(Array array) => void;

/**
