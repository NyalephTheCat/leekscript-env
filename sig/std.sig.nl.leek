function moveTowardLeeks(Array<integer> leeks, integer|real mp) => integer;
function moveTowardLeeks(Array<integer> leeks) => integer;

/**
 * @brief Brengt uw entiteit dichter bij een lijn gedefinieerd door twee cellen cell1 en cell2, met maximale mp bewegingspunten.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 Cel 1.
 * @param[in] cell2 Cel 2.
 * @param[in] mp (optioneel) Het maximale aantal te gebruiken MP's. Standaard geen limiet.
 * @return mp Het aantal gebruikte bewegingspunten.
 */
function moveTowardLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveTowardLine(integer|real cell1, integer|real cell2) => integer;

// === utils ===

/**
 * @brief Wist alle markeringen gemaakt door mark() en markText() in het veld.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Kopieert de waarde doorgegeven als een parameter op niveau niveaus en retourneert de kopie.
 *
 * In het geval van een array bijvoorbeeld, kopieert een kloon (array, 1) de array maar niet
 * de elementen ervan, een kloon (array, 2) kopieert zowel de array als alle elementen.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value De waarde om te klonen
 * @param[in] level (optioneel) Het aantal niveaus dat moet worden gekloond
 * @return copy De gekloonde waarde
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Neemt een object-bericht op in het persoonlijke logboek, beschikbaar in het rapport aan het einde van het gevecht.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Het bericht om op te nemen.
 */
function debug(any object) => void;

/**
 * @brief Neemt een object-bericht op in het persoonlijke logboek, beschikbaar in het rapport aan…
 *
 * het einde van het gevecht, van de kleur kleur.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Het bericht om op te nemen.
 * @param[in] color De kleur van het bericht. U kunt de functie @ref getColor gebruiken.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Registreert een object-foutmelding in het persoonlijke logboek, beschikbaar in het rapport…
 *
 * aan het einde van het gevecht.
 * Foutmeldingen verschijnen in rood in het gevechtsrapport.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object De foutmelding om te loggen.
 */
function debugE(any object) => void;

/**
 * @brief Neemt een object-waarschuwingsbericht op in het persoonlijke logboek, beschikbaar in het…
 *
 * rapport aan het einde van het gevecht.
 * Waarschuwingsberichten verschijnen in het oranje in het gevechtsrapport.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Het waarschuwingsbericht om op te nemen.
 */
function debugW(any object) => void;

/**
 * @brief Verwijdert het register dat is gekoppeld aan sleutel sleutel als deze bestaat.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key De registersleutel die moet worden verwijderd.
 */
function deleteRegister(string key) => void;

/**
 * @brief Retourneert de datum van het gevecht, in de notatie dd/MM/jjjj.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date De datum van het gevecht.
 */
function getDate() => string;

/**
 * @brief Retourneert het aantal instructies dat uw entiteit tijdens de huidige beurt heeft uitgevoerd.
 *
 * @deprecated Deze functie is verouderd. Het wordt vervangen door @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Het aantal instructies dat je entiteit tijdens de huidige beurt heeft uitgevoerd.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Retourneert de bruikbare RAM-limiet van uw AI.
 *
 * RAM wordt verbruikt door lijsten, tabellen en objecten te maken.
 * De huidige limiet is 100 megabyte of 12.500.000 lijstitems.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Retourneert het aantal bewerkingen dat door uw entiteit is verbruikt sinds het begin van zijn beurt.
 *
 * Dit aantal moet lager blijven dan @ref OPERATIONS_LIMIT zodat de entiteit niet vastloopt.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Aantal bewerkingen dat door uw entiteit is verbruikt sinds het begin van zijn beurt.
 */
function getOperations() => integer;

/**
 * @brief Retourneert de waarde die is opgeslagen in het entiteitsregister dat is gekoppeld aan…
 *
 * sleutel key of null als het register niet bestaat.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key De registersleutel waarvan de waarde wordt geretourneerd.
 * @return value De waarde die is opgeslagen in het register sleutel.
 */
function getRegister(string key) => string;

/**
 * @brief Retourneert de set entiteitsregisters als een associatieve array [registersleutel:registerwaarde].
 *
 * Voorbeeld: debug(getRegisters());
 * // Toont bijvoorbeeld:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers De associatieve array die overeenkomt met alle registers van de entiteit.
 */
function getRegisters() => Array<string>;

/**
 * @brief Retourneert de gevechtstijd, in de notatie UU:mm:ss.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time De tijd van het gevecht.
 */
function getTime() => string;

/**
 * @brief Retourneert de tijdstempel van het gevecht, gelijk aan het aantal seconden sinds 1 januari 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp De tijdstempel van het gevecht.
 */
function getTimestamp() => integer;

/**
 * @brief Retourneert de hoeveelheid RAM die momenteel door uw AI wordt gebruikt.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Neem de AI genaamd ai op in de huidige AI.
 *
 * Waarschuwing, de functie include mag alleen in het hoofdblok worden aangeroepen en de
 * parameter moet een rechtstreeks geschreven tekenreeks zijn
 * in de code. Zie voor meer informatie het gedeelte in de tutorial:
 * http://leekwars.com/help/tutorial#includes .
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai De naam van de op te nemen AI.
 */
function include(string ai) => void;

/**
 * @brief Decodeert string json naar LeekScript-object (nummer, string, array...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json De JSON-tekenreeks die moet worden gedecodeerd.
 * @return object Het gedecodeerde LeekScript-object.
 */
function jsonDecode(string json) => any;

/**
 * @brief Codeert het object-object in een JSON-tekenreeks.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object Het object dat moet worden gecodeerd in JSON.
 * @return json De JSON-gecodeerde tekenreeks.
 */
function jsonEncode(string object) => string;

/**
 * @brief Markeert een of meer cellen van de kleur aangegeven in parameter op de grond voor het aantal beurten aangegeven in parameter.
 *
 * Deze markering is alleen zichtbaar voor de fokker van de entiteit.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells De cel of matrix van meerdere cellen die moet worden gemarkeerd
 * @param[in] color (optioneel) Kleur markeren
 * @param[in] duration (optioneel) Duur van de markering
 * @return success Retourneert waar als alles goed is gegaan
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Schrijft een tekst op een of meer cellen van de kleur aangegeven in parameter op de grond voor het aantal beurten aangegeven in parameter.
 *
 * Deze teksten zijn alleen zichtbaar voor de fokker van de entiteit.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells De cel of array van meerdere cellen om naar te schrijven
 * @param[in] text (optioneel) De te schrijven tekst (maximaal 10 tekens)
 * @param[in] color (optioneel) Tekst kleur
 * @param[in] duration (optioneel) Tekst duur
 * @return success Retourneert waar als alles goed is gegaan
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Pauzeert het gevecht, alleen voor de fokker van de entiteit die de functie gebruikt.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Slaat waarde op in het register sleutel.
 *
 * De sleutel en de waarde zijn strings die maximaal respectievelijk 100 en 5000 tekens mogen
 * bevatten. Een prei kan maximaal 100 registers hebben, opslaan in een nieuw register werkt
 * niet als alle registers
 * zijn al bezig.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key De registersleutel waar de waarde moet worden opgeslagen.
 * @param[in] value De waarde om op te slaan.
 * @return success true als de operatie succesvol was, false anders.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Toont spelers een cel van de kleur kleur op het veld gedurende 1 beurt.
 *
 * Het gebruik van deze functie kost 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell De cel die moet worden weergegeven
 * @param[in] color (optioneel) Kleur markeren
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Retourneert het type van de waarde waarde, onder de typen: @ref TYPE_NULL, @ref TYPE_NUMBER,…
 *
 * @ref TYPE_BOOLEAN, @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value De waarde waarvan het type wordt geretourneerd.
 * @return type Het type waarde.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Retourneert de id van de entiteit die het bericht bericht heeft geschreven.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Het bericht waarvan de auteur wordt geretourneerd.
 * @return entity De id van de entiteit die het bericht bericht opstelt.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Retourneert de reeks berichtparameters message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Het bericht waarvan de parameters worden geretourneerd.
 * @return params De bericht berichtparameters.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Retourneert het berichttype bericht.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Het bericht waarvan het type wordt geretourneerd (tussen @ref MESSAGE_HEAL,
 *     @ref MESSAGE_ATTACK, enz.).
 * @return type Het berichttype bericht.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Retourneert de berichtarray van de entiteit entiteit.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (optioneel) De entiteit waarvan de berichten worden geretourneerd.
 * @return messages De tabel met uw berichten. Een bericht wordt zelf weergegeven in de vorm van een
 *     matrix van de vorm: [auteur, type, parameters] De verschillende soorten berichten
 *     worden weergegeven door de constanten: @ref MESSAGE_HEAL: verzoek om zorg @ref MESSAGE_ATTACK:
 *     verzoek om aan te vallen @ref MESSAGE_BUFF_FORCE: boostverzoek forceren ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Stuur een bericht naar je hele team.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Het type bericht dat moet worden verzonden (zie de MESSAGE_*-constanten).
 * @param[in] params De berichtparameters, die elke waarde kunnen zijn.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Stuurt een bericht naar de entiteit met id entiteit.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity De id van de entiteit waarnaar het bericht wordt verzonden.
 * @param[in] type Het type bericht dat moet worden verzonden (zie de MESSAGE_*-constanten).
 * @param[in] params De berichtparameters, die elke waarde kunnen zijn.
 * @return sent true als de verzending succesvol was, false als er een fout is opgetreden.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Retourneert de hoeveelheid blauw in de kleur kleur, tussen 0 en 255.
 *
 * Bijvoorbeeld getBlue(@ref COLOR_BLUE) = 255 en getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color De kleur waarvan de blauwwaarde wordt geretourneerd.
 * @return blue De mate van blauw in de kleur kleur
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Retourneert het gehele getal dat overeenkomt met de kleur (rood, groen, blauw) die als parameters is opgegeven.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Roodwaarde tussen 0 en 255.
 * @param[in] green Groenwaarde tussen 0 en 255.
 * @param[in] blue Blauwwaarde tussen 0 en 255.
 * @return color int die overeenkomt met de kleur die als parameter is opgegeven.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Retourneert de hoeveelheid groen in de kleur kleur, tussen 0 en 255.
 *
 * Bijvoorbeeld getGreen(@ref COLOR_GREEN) = 255 en getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color De kleur waarvan de groensnelheid wordt geretourneerd.
 * @return green De snelheid van groen in de kleur kleur
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Retourneert de hoeveelheid rood in de kleur kleur, tussen 0 en 255.
 *
 * Bijvoorbeeld getRed(@ref COLOR_RED) = 255 en getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color De kleur waarvan de roodsnelheid wordt geretourneerd.
 * @return red De snelheid van rood in de kleur kleur
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Wist de set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set De set.
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Zoekt naar een element element in de set set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set De set.
 * @param[in] element Het element waarnaar gezocht moet worden.
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Geeft als resultaat het verschil tussen de verzamelingen set1 en set2, dat wil zeggen alle…
 *
 * elementen van set1 die niet in set2 zitten.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1 De eerste set. - set2 : De tweede set.
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Berekent de exclusieve scheiding van twee verzamelingen set1 en set2, genoteerd set1 ⊕…
 *
 * set2, dat zijn de elementen die aanwezig zijn in set1 of set2, maar niet in beide
 * tegelijkertijd.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Berekent de intersectie van twee verzamelingen set1 en set2, genoteerd set1 ∩ set2, die de…
 *
 * gemeenschappelijke elementen van de twee verzamelingen zijn.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1 De eerste verzameling. - set2 : De tweede set.
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Geeft als resultaat of een set leeg is of niet.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set De set.
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Bepaalt of een verzameling set1 een subset is van set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1 De eerste set. - set2 : De tweede set.
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Voegt een element element in de set set in.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set De verzameling.
 * @param[in] element Het element dat toegevoegd moet worden.
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Verwijdert een element element uit de set set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set Set.
 * @param[in] element Het element dat verwijderd moet worden.
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Geeft de grootte van de set set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set De set.
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Geeft een lijst terug die alle elementen van de set set bevat.
 *
 * De volgorde van de elementen is willekeurig.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set De verzameling.
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Berekent de unie van twee verzamelingen set1 en set2, aangeduid als set1 ∪ set2, die alle…
 *
 * elementen bevat die aanwezig zijn in set1 of in set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1 De eerste set. - set2 : De tweede set.
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Berekent het intervalgemiddelde.
 *
 * - Als het interval links en rechts begrensd is, geeft dit (intervalMin(i) +
 * intervalMax(i)) / 2. - Als het interval alleen links begrensd is, geeft dit +∞. - Als het
 * interval alleen rechts begrensd is, geeft dit -∞. - Als het interval niet begrensd of leeg
 * is, geeft dit NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval Het interval.
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Combineert twee intervallen interval1 en interval2.
 *
 * Equivalent aan unie als hun snijpunt niet-leeg is, anders omvat het ook de verzameling
 * ertussen.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Berekent het snijpunt van twee intervallen interval1 en interval2, met de elementen die…
 *
 * beide intervallen gemeenschappelijk hebben.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Geeft als resultaat of het interval interval links en rechts begrensd is of niet.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval Het interval.
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Geeft als resultaat of het interval interval links en rechts gesloten is of niet.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval Het interval.
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Geeft als resultaat of het interval leeg is of niet.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Geeft als resultaat of het interval interval al dan niet linksgebonden is.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Geeft als resultaat of het interval al dan niet aan de linkerkant gesloten is.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval Het interval.
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Geeft als resultaat of het interval interval al dan niet rechtsbegrensd is.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Geeft als resultaat of het interval interval rechts gesloten is of niet.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval Het interval.
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Geeft als resultaat de bovengrens van het interval interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Geeft de ondergrens van het interval interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Geeft de grootte van het interval interval.
 *
 * - Als het interval begrensd is, geeft dit max - min. - Als het interval niet begrensd is,
 * geeft dit +∞. - Als het interval leeg is, geeft dit 0 terug.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval Het interval.
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Geeft een lijst terug met de elementen van het interval interval met een stap afstand tussen elk.
 *
 * Als het interval negatief is, worden de elementen in omgekeerde volgorde weergegeven.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (optioneel)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
