 */
function getAIID(integer|real entity) => integer;
function getAIID() => integer;

/**
 * @brief Returns the name of given entity's AI.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Leek whose AI name you want.
 * @return name The name of entity's AI.
 */
function getAIName(integer|real entity) => string;
function getAIName() => string;

/**
 * @brief Return a entity's absolute shield value.
 *
 * For your entity, prefer @ref getAbsoluteShield() with no input.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Leek whose absolute shield you want.
 * @return shield Leek's absolute shield value.
 */
function getAbsoluteShield(integer|real entity) => integer;
function getAbsoluteShield() => integer;

/**
 * @brief Returns given entity's agility.
 *
 * For your entity's agility, prefer @ref getAgility() with no input.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Leek whose agility you want.
 * @return agility entity's agility.
 */
function getAgility(integer|real entity) => integer;
function getAgility() => integer;

/**
 * @brief Returns the turn during which given entity has appeared.
 *
 * For instance, returns 1 for a leek or 5 for a bulb summonned during turn 5.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Desired entity.
 * @return turn Combat turn during which given entity has appeared.
 */
function getBirthTurn(integer|real entity) => integer;
function getBirthTurn() => integer;

/**
 * @brief Returns the bulb type of the given entity.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) The entity's ID.
 * @return bulbType The bulb type of the entity:@ref BULB_PUNY for a puny bulb.; @ref BULB_FIRE for a fire bulb.;
 *     @ref BULB_HEALER for a healer bulb.; @ref BULB_ROCKY for a rocky bulb.; @ref BULB_ICED for an iced
 *     bulb.; @ref BULB_LIGHTNING for a lightning bulb.; @ref BULB_METALLIC for a metallic bulb.;
 *     @ref BULB_WIZARD for a wizard bulb.; @ref BULB_TACTICIAN for a tactician bulb.; @ref BULB_SAVANT
 *     for a savant bulb.Returns -1 if the entity is not a bulb, or null if the entity does
 *     not exist.
 */
function getBulbType(integer|real entity) => integer;
function getBulbType() => integer;

/**
 * @brief Returns given entity's position, as a cell id.
 *
 * @category leek
 * @cost 5 ops
 *
 * @param[in] entity (optional) Leek whose position is determined.
 * @return cell Cell id of given entity's position.
 */
function getCell(integer|real entity) => integer;
function getCell() => integer;

/**
 * @brief Lists given entity's chips.
 *
 * @category leek
 * @cost 40 ops
 *
 * @param[in] entity (optional) Desired entity.
 * @return chips Array containing all of given entity's chips.
 */
function getChips(integer|real entity) => Array<integer>;
function getChips() => Array<integer>;

/**
 * @brief Returns given entity's number of cores.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Desired entity.
 * @return cores Given entity's number of cores.
 */
function getCores(integer|real entity) => integer;
function getCores() => integer;

/**
 * @brief Returns given entity's damage return ratio.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Desired entity's id.
 * @return damageReturn Entity's damage return ratio (in %).
 */
function getDamageReturn(integer|real entity) => integer;
function getDamageReturn() => integer;

/**
 * @brief Returns the list of effects of the entity with id entity.
 *
 * To directly retrieve the list of effects for your entity, use @ref getEffects without
 * parameters.
 *
 * @category leek
 * @cost 25 ops
 *
 * @param[in] entity (optional) The id of the entity whose list of effects will be returned.
 * @return effects The list of effects currently present on the entity entity. The effects list is an
 *     array containing the effects. An effect is itself an array of 8 boxes of the form: ``
 *     [type, value, caster_id, turns, critical, item_id, target_id, modifiers] `` - *type*
 *     is the type of the effect among: - @ref EFFECT_DAMAGE, value is the damage number -
 *     @ref EFFECT_HEAL, value is the number of HP healed - @ref EFFECT_BUFF_STRENGTH, value
 *     is strength gained - @ref EFFECT_BUFF_AGILITY, value is the agility gained - @ref
 *     EFFECT_BUFF_TP, value is the number of TP gained - @ref EFFECT_BUFF_MP, value is the
 *     number of MP gained - @ref EFFECT_ABSOLUTE_SHIELD, value is absolute shield gained -
 *     @ref EFFECT_RELATIVE_SHIELD, value is relative shield gained - @ref EFFECT_DEBUFF,
 *     indicates a debuff, value is the percentage of effects removed. etc - *value*: The
 *     value of the effect. - *caster_id*: The id of the entity that launched the effect. -
 *     *turns*: The number of remaining turns of the effect. - *critical*: Is the effect a
 *     critical hit. - *item_id*: The id of the item that caused this effect. - *target_id*:
 *     The id of the effect target (entity). - *modifiers*: Effect modifiers (bit mask with
 *     EFFECT_MODIFIER_* constants).
 */
function getEffects(integer|real entity) => Array<Array>;
function getEffects() => Array<Array>;

/**
 * @brief Returns the id of your entity
 *
 * @category leek
 * @cost 5 ops
 *
 * @return entity The id of your entity.
 */
function getEntity() => integer;

