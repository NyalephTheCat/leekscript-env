/**
 * @brief Moves your entity away from a given group of entities, using at most mp Movement Points.
 *
 * @deprecated This function is deprecated. It is replaced by @ref moveAwayFromEntities.
 * @sa moveAwayFromEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities Array containing the entities from which you want to flee.
 * @param[in] mp (optional) The maximum amount of MP to spend.
 * @return mp The actual amount of MP spent.
 */
function moveAwayFromLeeks(Array<integer|real> entities, integer|real mp) => integer;
function moveAwayFromLeeks(Array<integer|real> entities) => integer;

/**
 * @brief Moves your entity away from the line between cell1 and cell2, using at most mp Movement Points.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 First cell of the line.
 * @param[in] cell2 Final cell of the line.
 * @param[in] mp (optional) The maximum amount of MP to spend.
 * @return mp The actual amount of MP spent.
 */
function moveAwayFromLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveAwayFromLine(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Moves your entity closer to another entity, using at most mp Movement Points.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entity The entity you want to get closer to.
 * @param[in] mp (optional) The maximum amount of MP to spend.
 * @return mp The actual amount of MP spent.
 */
function moveToward(integer|real entity, integer|real mp) => integer;
function moveToward(integer|real entity) => integer;

/**
 * @brief Moves your entity closer to given cell, using at most mp Movement Points.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell The cell you want to get closer to.
 * @param[in] mp (optional) The maximum amount of MP to spend.
 * @return mp The actual amount of MP spent.
 */
function moveTowardCell(integer|real cell, integer|real mp) => integer;
function moveTowardCell(integer|real cell) => integer;

/**
 * @brief Moves your entity closer to a given group of cells, using at most mp Movement Points.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cells Array containing the cells to which you want to get closer.
 * @param[in] mp (optional) The maximum amount of MP to spend.
 * @return mp The actual amount of MP spent.
 */
function moveTowardCells(Array<integer> cells, integer|real mp) => integer;
function moveTowardCells(Array<integer> cells) => integer;

/**
 * @brief Moves your entity closer to a set of entities entities, using at most mp movement points
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities The array containing the ids of the entities to which your entity should move closer.
 * @param[in] mp (optional) The maximum number of MP to use.
 * @return mp The number of movement points used.
 */
function moveTowardEntities(Array<integer> entities, integer|real mp) => integer;
function moveTowardEntities(Array<integer> entities) => integer;

/**
 * @brief Moves your entity closer to a given group of entities, using at most mp Movement Points.
 *
 * @deprecated This function is deprecated. It is replaced by @ref moveTowardEntities.
 * @sa moveTowardEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] leeks Array containing the entities to which you want to get closer.
 * @param[in] mp (optional) The maximum amount of MP to spend.
 * @return mp The actual amount of MP spent.
 */
function moveTowardLeeks(Array<integer> leeks, integer|real mp) => integer;
function moveTowardLeeks(Array<integer> leeks) => integer;

/**
 * @brief Moves your entity towards the line between cell1 and cell2, using at most mp Movement Points.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 The first cell of the line.
 * @param[in] cell2 The final cell of the line.
 * @param[in] mp (optional) The maximum amount of MP to spend.
 * @return mp The actual amount of MP spent.
 */
function moveTowardLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveTowardLine(integer|real cell1, integer|real cell2) => integer;

// === utils ===

/**
 * @brief Erases all markings made by mark() and markText() in the field.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Copies the value passed in parameter to level levels and returns the copy.
 *
 * In the case of an array for example, a clone(array, 1) will copy the array but not its
 * elements, a clone(array, 2) will copy the array as well as all elements.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value The value to clone
 * @param[in] level (optional) The number of levels to clone
 * @return copy The cloned value
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Logs an object message into your personnal log, available at the end of a fight.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object A message to log.
 */
function debug(any object) => void;

/**
 * @brief Logs an object message into your personnal log, available at the end of a fight, of the color color.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object A message to log.
 * @param[in] color The message color. You can use the function @ref getColor.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Logs an object error message into your personnal log, available at the end of a fight.
 *
 * Error messages appear in red.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object A message to log.
 */
function debugE(any object) => void;

/**
 * @brief Logs an object warning message into your personnal log, available at the end of a fight.
 *
 * Warning messages appear in orange.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object A message to log.
 */
function debugW(any object) => void;

/**
 * @brief Removes given key (and associated value) from your entity's register.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key Key of the (key: value) pair to be deleted.
 */
function deleteRegister(string key) => void;

/**
 * @brief Returns the fight date, in the dd/MM/yyyy format.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date The date of fight.
 */
function getDate() => string;

/**
 * @brief Returns the number of instructions used by your entity this turn.
 *
 * @deprecated This function is deprecated. It is replaced by @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions The number of instructions used by your entity this turn.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Returns the usable RAM limit of your AI.
 *
 * RAM is consumed by creating lists, tables and objects.
 * The current limit is 200 megabytes or 25,000,000 array items.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram The RAM limit.
 */
function getMaxRAM() => integer;

/**
 * @brief Returns the operations' counter, as started at the beginning of turn.
 *
 * This counter needs to stay below @ref OPERATIONS_LIMIT in order for the entity not to stop
 * processing.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Count of operations since the beginning of the turn.
 */
function getOperations() => integer;

/**
 * @brief Returns the value associated to given key in your entity's register, null if it is not found.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key Desired key.
 * @return value The value associated to given key in your entity's register.
 */
function getRegister(string key) => string;

/**
 * @brief Returns your entity's whole register, as a [key: value] associative array.
 *
 * For example:
 * debug(getRegisters());
 * // would, for example, debug :
 * // ['reg1' : '314323', 'reg2' : 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Your entity's register, as an associative array.
 */
function getRegisters() => Array<string>;

/**
 * @brief Returns the fight date, in the HH:mm:ss format.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time The time of fight.
 */
function getTime() => string;

/**
 * @brief Returns the timestamp of the fight, equal to the number of seconds since January 1, 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp The timestamp of the fight
 */
function getTimestamp() => integer;

/**
 * @brief Returns the amount of RAM currently used by your AI.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram The RAM currently used.
 */
function getUsedRAM() => integer;

/**
 * @brief Includes the AI named ai inside current AI.
 *
 * Warning: the include function shall only be called inside the main AI block, and its
 * parameter shall NOT be a variable. More information in the tutorial:
 * http://leekwars.com/help/tutorial#includes.
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai AI's name (hard-coded string only)
 */
function include(string ai) => void;

/**
 * @brief Decode the string json into a LeekScript object (number, string, array...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json The string to decode.
 * @return object The decoded LeekScript Object.
 */
function jsonDecode(string json) => any;

/**
 * @brief Encode the object object into a JSON string.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object The object to encode in JSON.
 * @return json The JSON encoded string
 */
function jsonEncode(string object) => string;

/**
 * @brief Marks one or several cells on terrain in given color for the given duration.
 *
 * The mark is only visible by the marking entity's farmer.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells A cell or array of cells.
 * @param[in] color (optional) Marking's color (see @ref getColor()).
 * @param[in] duration (optional) Duration of the marking.
 * @return success true if all went well, false otherwise.
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Writes a text on one or more cells of the color indicated in parameter on the field for the number of turns indicated in parameter.
 *
 * These texts are visible only by the farmer of the entity
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells The cell or array of several cells to write to
 * @param[in] text (optional) The text to write (maximum 10 characters)
 * @param[in] color (optional) Text color
 * @param[in] duration (optional) Text duration
 * @return success Returns true if everything went well
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Pauses the fight, only for the pausing entity's farmer.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Stores given value in your entity's register, associated with given key.
 *
 * Given key and value are strings, respectively with maximum lengths of 100 and 5000
 * characters. A leek can have at most 100 distinct keys in its register, any additionnal
 * (key:value) pair will not be stored if your entity's register is full.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Register key to index given value.
 * @param[in] value Value to be stored.
 * @return success true if operation succeeded, false otherwise.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Shows all players given cell in given color, for one turn.
 *
 * Costs one TP.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Cell to be showned.
 * @param[in] color (optional) Marking's color (see @ref getColor()).
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Determines the type of given value, among: @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN,…
 *
 * @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Value that needs testing.
 * @return type values's type.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Returns given message's author (entity).
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Message whose author is desired.
 * @return entity Given message's author.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Returns given message's parameters.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Message whose parameters are desired.
 * @return params Given message's parameters.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Returns given message's message type.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Message whose type is desired.
 * @return type Given message's type.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Lists all messages addressed to given entity.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (optional) Leek whose messages are returned.
 * @return messages Array of messages. A message itself is a 3-cell array of the following form: [author,
 *     type, parameters] Message types are: @ref MESSAGE_HEAL: request for heal; @ref MESSAGE_ATTACK:
 *     request for attack; @ref MESSAGE_BUFF_FORCE: request for strength buff; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Sends a message to all of your allies.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type The type of message to send (see MESSAGE_* constants).
 * @param[in] params The parameters of the message, which can take any form.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Sends a message to given entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity Message's addressee
 * @param[in] type The type of message to send (see MESSAGE_* constants).
 * @param[in] params The parameters of the message, which can take any form.
 * @return sent true if the message was successfully sent, false if an error occured.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Returns the blue component of given color.
 *
 * For instance getBlue(@ref COLOR_BLUE) = 255 and getBlue(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Color whose blue component is to be returned.
 * @return blue Blue component of given color
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Gives an integer that corresponds to given color on a (red, green, blue) scale.
 *
 * See @ref mark on how to use given integer.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Red value, between 0 and 255.
 * @param[in] green Green value, between 0 and 255.
 * @param[in] blue Blue value, between 0 and 255.
 * @return color integer that corresponds to given color.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Returns the green component of given color.
 *
 * For instance getGreen(@ref COLOR_GREEN) = 255 and getGreen(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Color whose green component is to be returned.
 * @return green Green component of given color.
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Returns the red component of given color.
 *
 * For instance getRed(@ref COLOR_RED) = 255 and getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Color whose red component is to be returned.
 * @return red Red component of given color.
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Clears the set set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Searches for an element element in the set set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set The set.
 * @param[in] element The element to search for.
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Returns the difference between sets set1 and set2, i.e.
 *
 * all elements of set1 that are not in set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1 The first set. - set2 : The second set.
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Calculates the exclusive disjunction of two sets set1 and set2, noted set1 ⊕ set2, which…
 *
 * are the elements present in set1 or set2, but not in both at the same time.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Calculates the intersection of two sets set1 and set2, noted set1 ∩ set2, which are the common elements of the two sets.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1 The first set. - set2 : The second set.
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Returns whether a set is empty or not.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set The set.
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Determines whether a set set1 is a subset of set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1 The first set. - set2 : The second set.
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Inserts a element element into the set set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set Set.
 * @param[in] element The element to be added.
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Removes an element element from the set set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set Set.
 * @param[in] element The element to be deleted.
 * @return existed true if the element existed in the set, false if it was not present.
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Returns the size of the set set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set The set.
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Returns a list containing all elements of the set set.
 *
 * The order of the elements is arbitrary.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array A list containing all the elements of the set.
 */
function setToArray(Set set) => Array;

/**
 * @brief Calculates the union of two sets set1 and set2, noted set1 ∪ set2, which contains all…
 *
 * elements present in set1 or in set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1 The first set. - set2 : The second set.
 * @param[in] set2
 * @return union The union of the two sets set1 ∪ set2.
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Calculates the interval average.
 *
 * - If the interval is bounded on the right and left, returns (intervalMin(i) +
 * intervalMax(i)) / 2. - If the interval is left-bound only, returns +∞. - If the interval
 * is bounded only on the right, returns -∞. - If the interval is unbounded or empty, returns
 * NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval The interval.
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Combines two intervals interval1 and interval2.
 *
 * Equivalent to union if their intersection is non-empty, otherwise also includes the set in
 * between.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Calculates the intersection of two intervals interval1 and interval2, containing the elements common to both.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Returns whether the interval interval is bounded on the left and right or not.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval The interval.
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Indicates if the interval interval is closed on the left and right.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval The interval.
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Returns whether the interval is empty or not.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval The interval.
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Returns whether the interval interval is left bounded or not.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Returns whether the interval is closed on the left or not.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval The interval.
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Returns whether the interval interval is right-bounded or not.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Returns whether the interval is closed on the right or not.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval The interval.
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Returns the upper limit of the interval interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Returns the lower limit of the interval interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Returns the size of the interval interval.
 *
 * - If the interval is bounded, returns max - min. - If the interval is not bounded, returns
 * +∞. - If the interval is empty, returns 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval The interval.
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Returns a list containing the elements of the interval interval with a step distance between each.
 *
 * If the interval is negative, takes the elements in reverse order.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (optional)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
