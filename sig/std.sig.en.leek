// --- Functions ---

// === math ===

/**
 * @brief Returns the absolute value of given number.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number A number.
 * @return result Given number's absolute value.
 */
function abs(integer|real number) => integer;

/**
 * @brief Computes the arccos of argument, within [0, @ref PI].
 *
 * @category math
 * @cost 12 ops
 *
 * @param[in] argument A number.
 * @return result Given number's arccos.
 */
function acos(integer|real argument) => real;

/**
 * @brief Computes the arcsin of argument, within [0, @ref PI].
 *
 * @category math
 * @cost 12 ops
 *
 * @param[in] argument A number.
 * @return result Given number's arcsin.
 */
function asin(integer|real argument) => real;

/**
 * @brief Computes the arctan of argument, within [0, @ref PI].
 *
 * @category math
 * @cost 25 ops
 *
 * @param[in] argument A number.
 * @return result Given number's arctan.
 */
function atan(integer|real argument) => real;

/**
 * @brief Computes the azimuth of given point (x, y) in polar coordinates.
 *
 * Return value is between - @ref PI and @ref PI, depending on parameters' signs.
 *
 * @category math
 * @cost 35 ops
 *
 * @param[in] y X coordinate.
 * @param[in] x Y coordinate.
 * @return result Azimuth of given point, in polar coordinates.
 */
function atan2(integer|real y, integer|real x) => real;

/**
 * @brief Returns a string containing the number x in binary format.
 *
 * @category math
 * @cost 10 ops
 *
 * @param[in] x The number to format in binary.
 * @return string The binary string representing the number x.
 */
function binString(integer x) => string;

/**
 * @brief Returns the number of bits at 1 in the number x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number whose number of bits will be returned.
 * @return bits The number of bits of x.
 */
function bitCount(integer x) => integer;

/**
 * @brief Reverses all bits of number x from left to right.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number to invert.
 * @return reversed The reversed number.
 */
function bitReverse(integer x) => integer;

/**
 * @brief Converts bits of an integer to a floating point number.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The bits to convert.
 * @return real Floating number converts.
 */
function bitsToReal(integer x) => real;

/**
 * @brief Reverses the bytes (8 bits) of a number x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number to invert byte by byte.
 * @return reversed The reversed number.
 */
function byteReverse(integer x) => integer;

/**
 * @brief Computes the cubic root of given number.
 *
 * @category math
 * @cost 62 ops
 *
 * @param[in] number A number.
 * @return result Given number's cubic root.
 */
function cbrt(integer|real number) => real;

/**
 * @brief Computes the rounded up value of given number.
 *
 * The rounded down value can be computed using @ref floor and the closest integer using @ref round.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number A number.
 * @return result Number's value as an integer, rounded up.
 */
function ceil(integer|real number) => integer;

/**
 * @brief Computes an angle's cosine.
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle A number.
 * @return cosine Given number's cosine, within [-1, 1].
 */
function cos(integer|real angle) => real;

/**
 * @brief Computes the exponential of number, by exponentiation of @ref E.
 *
 * @category math
 * @cost 40 ops
 *
 * @param[in] number A number.
 * @return result @ref E ** number.
 */
function exp(integer|real number) => real;

/**
 * @brief Computes the rounded down value of given number.
 *
 * The rounded up value can be computed using @ref ceil and the closest integer using @ref round.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number A number.
 * @return result Number's value as an integer, rounded down.
 */
function floor(integer|real number) => integer;

/**
 * @brief Returns a character string containing the number x in hexadecimal format.
 *
 * @category math
 * @cost 10 ops
 *
 * @param[in] x The number to format in hexadecimal.
 * @return string The hexadecimal string representing the number x.
 */
function hexString(integer x) => string;

/**
 * @brief Returns the hypothenuse of a right-angled triangle with sides x and y.
 *
 * Equivalent to sqrt(x**2 + y**2).
 *
 * @category math
 * @cost 187 ops
 *
 * @param[in] x X value.
 * @param[in] y Y value.
 * @return hypotenuse sqrt(x**2 + y**2).
 */
function hypot(integer|real x, integer|real y) => real;

/**
 * @brief Returns true if the number x is finite, false otherwise.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number to check.
 * @return finite true if the number x is finite, false otherwise.
 */
function isFinite(real x) => boolean;

/**
 * @brief Returns true if the number x is infinite, false otherwise.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number to check.
 * @return infinite true if the number x is infinite, false otherwise.
 */
function isInfinite(real x) => boolean;

/**
 * @brief Returns *true* if the number x is a NaN (Not a Number) value in its float representation, *false* otherwise.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number to check.
 * @return nan *true* if the number x is a NaN value, *false* otherwise.
 */
function isNaN(real x) => boolean;

/**
 * @brief Returns *true* if the numbers x and y are permutations in their decimal representation, *false* otherwise.
 *
 * @category math
 * @cost 50 ops
 *
 * @param[in] x First number.
 * @param[in] y Second number.
 * @return permutation *true* if the numbers x and y are permutations, *false* otherwise.
 */
function isPermutation(integer x, integer y) => boolean;

/**
 * @brief Returns the number of bits at 0 at the beginning of the number x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number.
 * @return zeros The number of zeros at the beginning of x.
 */
function leadingZeros(integer x) => integer;

/**
 * @brief Computes the natural logarithm of given number.
 *
 * @category math
 * @cost 39 ops
 *
 * @param[in] number A positive number (within ]0; +∞[ ).
 * @return log Given number's natural logarithm.
 */
function log(integer|real number) => real;

/**
 * @brief Computes the decimal logarithm of given number.
 *
 * @category math
 * @cost 23 ops
 *
 * @param[in] number A positive number (within ]0; +∞[ ).
 * @return log10 Given number's decimal logarithm.
 */
function log10(integer|real number) => real;

/**
 * @brief Computes the base 2 logarithm of given number.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] number A positive number (within ]0; +∞[ ).
 * @return log2 Given number's base 2 logarithm.
 */
function log2(integer|real number) => real;

/**
 * @brief Finds the greatest value among two numbers a and b.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] a A number.
 * @param[in] b Another number.
 * @return max The greatest of the two numbers.
 */
function max(integer|real a, integer|real b) => integer|real;

/**
 * @brief Finds the least value among two numbers a and b.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] a A number.
 * @param[in] b Another number.
 * @return min The least of the two numbers.
 */
function min(integer|real a, integer|real b) => integer|real;

/**
 * @brief Casts a value into a number.
 *
 * If the value is a string, this function attempts to convert it into a number. If the value
 * is a number, this function returns the number. For any other type,
 * this function returns null
 *
 * @category math
 * @cost 20 ops
 *
 * @param[in] value The value to convert.
 * @return number The resulting number.
 */
function number(any value) => real;

/**
 * @brief Exponentiates a base number to the exp power.
 *
 * @category math
 * @cost 140 ops
 *
 * @param[in] base Number to exponentiate.
 * @param[in] exp Exponant.
 * @return result base**exp.
 */
function pow(integer|real base, integer|real exp) => real;

/**
 * @brief Returns a random real number, between 0 (included) and 1 (excluded).
 *
 * @category math
 * @cost 30 ops
 *
 * @return number A random number within [0;1).
 */
function rand() => real;

/**
 * @brief Returns a random real number, between a (included) and b (excluded).
 *
 * @deprecated This function is deprecated. It is replaced by @ref randReal.
 * @sa randReal
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a The lower bound of the interval.
 * @param[in] b The upper bound of the interval.
 * @return number A random number within [a;b).
 */
function randFloat(integer|real a, integer|real b) => integer;

/**
 * @brief Returns a random integer, between a (included) and b (excluded).
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a The lower bound of the interval.
 * @param[in] b The upper bound of the interval.
 * @return number A random integer within [a;b).
 */
function randInt(integer|real a, integer|real b) => integer;

/**
 * @brief Returns a real random number, between a (inclusive) and b (exclusive).
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a Lower bound (included).
 * @param[in] b Upper bound (excluded).
 * @return number A real random number in the interval [a; b[.
 */
function randReal(real a, real b) => real;

/**
 * @brief Returns the raw bits of the number x in an integer.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number
 * @return bits The bits of x.
 */
function realBits(real x) => integer;

/**
 * @brief Returns a new number with the bits of x shifted by s from the left (resets the bits from the right).
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number to rotate.
 * @param[in] s The size of the rotation.
 * @return rotated The rotated number.
 */
function rotateLeft(integer x, integer s) => integer;

/**
 * @brief Returns a new number with the bits of x shifted by s to the right (resets the bits to the left).
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number to rotate.
 * @param[in] s The size of the rotation.
 * @return rotated The rotated number.
 */
function rotateRight(integer x, integer s) => integer;

/**
 * @brief Computes the integer closest to a given number.
 *
 * The rounded down value can be computed using @ref floor and the rounded up value using @ref ceil.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Number
 * @return number Rounded value of number, to the closest integer.
 */
function round(integer|real number) => integer;

/**
 * @brief Checks the sign of given number.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Input number.
 * @return sign 1 if number is positive, 0 if it is 0 and -1 if it is negative.
 */
function signum(integer|real number) => integer;

/**
 * @brief Computes an angle's sine.
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle A number.
 * @return sine Given number's sine, within [-1, 1].
 */
function sin(integer|real angle) => real;

/**
 * @brief Computes given number's square root.
 *
 * @category math
 * @cost 8 ops
 *
 * @param[in] number A number.
 * @return root Given number's square root.
 */
function sqrt(integer|real number) => real;

/**
 * @brief Computes given angle's tangent.
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle A number.
 * @return tangent Given angle's tangent.
 */
function tan(integer|real angle) => real;

/**
 * @brief Converts given angle from radians to degrees.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] radians Angle's measure in radians.
 * @return degrees Angle's measure in degrees.
 */
function toDegrees(integer|real radians) => real;

/**
 * @brief Converts given angle from degrees to radians.
 *
 * @category math
 * @cost 31 ops
 *
 * @param[in] degrees Angle's measure in degrees.
 * @return radians Angle's measure in radians.
 */
function toRadians(integer|real degrees) => real;

/**
 * @brief Returns the number of bits to 0 at the end of the number x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x The number.
 * @return zeros The number of zeros at the end of x.
 */
function trailingZeros(integer x) => integer;

// === string ===

/**
 * @brief Returns the character at given position within given string.
 *
 * First character is at position 0.
 *
 * @category string
 * @cost 8 ops
 *
 * @param[in] string A string.
 * @param[in] position Position of the character to return.
 * @return char character from given position. Empty string if position is invalid.
 */
function charAt(string string, integer|real position) => string;

/**
 * @brief Returns the unicode codepoint (32 bits, integer) located at position index (or 0 by default) in the string string.
 *
 * @category string
 * @cost 5 ops
 *
 * @param[in] string The string.
 * @param[in] index (optional) The codepoint index, by default 0.
 * @return codePoint The unicode codepoint.
 */
function codePointAt(string string, integer index) => integer;
function codePointAt(string string) => integer;

/**
 * @brief Checks whether search string is contained within string.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string String in which the search is performed.
 * @param[in] search String to be loooked for.
 * @return contains true if search string is contained in string, false otherwise.
 */
function contains(string string, string search) => boolean;

/**
 * @brief Checks whether given string ends with given suffix
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string String to be checked
 * @param[in] suffix Suffix to be found
 * @return endsWith true if string ends with suffix, false otherwise
 */
function endsWith(string string, string suffix) => boolean;

/**
 * @brief Finds the first occurrence of search string within given string, starting at given position.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string String to be looked into.
 * @param[in] search String to be looked for.
 * @param[in] start (optional) Position within string where the search starts.
 * @return index First matching substring's position , -1 if no match was found.
 */
function indexOf(string string, string search, integer|real start) => integer;
function indexOf(string string, string search) => integer;

/**
 * @brief Returns given string's length.
 *
 * @category string
 * @cost 15 ops
 *
 * @param[in] string Desired string.
 * @return length Given string's length
 */
function length(string string) => integer;

/**
 * @brief Replaces all occurrence of search string with replace string, within given string.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string String inside which substitutions are performed.
 * @param[in] search Substring to be replaced.
 * @param[in] replace Replacing substring.
 * @return string Resulting string.
 */
function replace(string string, string search, string replace) => string;

/**
 * @brief Splits given string into substrings separated by given delimiter.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string String that needs splitting.
 * @param[in] delimiter String that separates desired substrings.
 * @param[in] limit (optional) Maximum size of output array.
 * @return parts Array containing all substrings.
 */
function split(string string, string delimiter, integer|real limit) => Array<string>;
function split(string string, string delimiter) => Array<string>;

/**
 * @brief Checks whether given string starts with given prefix.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string String to look into.
 * @param[in] prefix Prefix to look for.
 * @return startsWith true if given string starts with given prefix, false otherwise.
 */
function startsWith(string string, string prefix) => boolean;

/**
 * @brief Casts a value to a string container.
 *
 * Returns:
 * value if it is a string; "value" if it is a number; "[key1: value1, key2: value2... ...]"
 * if value is an array; "true" or "false" if value is a boolean; "null" if value is null.
 *
 * @category string
 * @cost 8 ops
 *
 * @param[in] value Value that needs conversion.
 * @return string Resulting string.
 */
function string(any value) => string;

/**
 * @brief Extracts a substring, starting at start position and of given length, from given string
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Source string.
 * @param[in] start Starting position.
 * @param[in] length (optional) Length of the output.
 * @return string The desired substring.
 */
function substring(string string, integer|real start, integer|real length) => string;
function substring(string string, integer|real start) => string;

/**
 * @brief Converts all capital letters from given string to lower characters.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Input string.
 * @return string String in lower characters.
 */
function toLower(string string) => string;

/**
 * @brief Converts all lower characters from given string to capital letters.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Input string.
 * @return string String in upper characters.
 */
function toUpper(string string) => string;

// === array ===

/**
 * @brief Splits the array array into sub-arrays of maximum size chunkSize and returns the array of these sub-arrays.
 *
 * The last sub-array can contain less that chunkSize elements.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The array to split.
 * @param[in] chunkSize (optional) The maximum size of sub-arrays.
 * @return chunks The produced sub-arrays.
 */
function arrayChunk(Array array, integer chunkSize) => Array<Array>;
function arrayChunk(Array array) => Array<Array>;

/**
 * @brief Empties the array list of all its elements.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array The list to empty.
 */
function arrayClear(Array array) => void;

/**
 * @brief Chains given arrays together.
 *
 * String keys are kept while numerical keys are reindexed.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array1 First array.
 * @param[in] array2 Second array.
 * @return newArray Resulting array.
 */
function arrayConcat(Array array1, Array array2) => Array;

/**
 * @brief Returns true if the predicate callback applied to each of the elements of the list returns true
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The list to browse.
 * @param[in] callback The predicate to call.
 * @return every true if the predicate returned true for each element, false otherwise.
 */
function arrayEvery(Array array, Function callback) => boolean;

/**
 * @brief Returns an array containing all (key: value) pairs from given array for which callback function returned true.
 *
 * If the callback function is single-input, it is
 * applied on the array's values, if the callback
 * function requires two inputs, it is applied on the array's (key: value) pairs.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Source array.
 * @param[in] callback Filtering function.
 * @return newArray Resulting array.
 */
function arrayFilter(Array array, Function callback) => Array;

/**
 * @brief Returns an array containing all elements contained in given array.
 *
 * All elements within a sub-array are recursively exported to the new array, stopping given
 * recursion depth.
 * var tableau = [1, 2, [3, [4]], 5, [6]];
 * debug(arrayFlatten(tableau,1)); // [1,2,3,[4],5,6]
 *
 * @category array
 * @cost ∞
 *
 * @param[in] array Source array.
 * @param[in] depth (optional) Maximun recursion depth.
 * @return newArray Resulting array.
 */
function arrayFlatten(Array array, integer|real depth) => Array;
function arrayFlatten(Array array) => Array;

/**
 * @brief Reduces given array [v1, v2, ..., vn] from the left and starting with v0, through successive application of f function.
 *
 * Is equivalent to:
 * f(f(f(v0, v1), v2), ...).
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Source array.
 * @param[in] f Reducing function.
 * @param[in] v0 Starting value.
 * @return result Array reduced to final result.
 */
function arrayFoldLeft(Array array, Function f, any v0) => any;

/**
 * @brief Reduces given array [v1, v2, ..., vn]
 *
 * from the right and starting with v0, through
 * successive application of f function. Is equivalent
 * to:
 * f(v1, f(v2, ..., f(vn, v0))).
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Source array.
 * @param[in] f Reducing function.
 * @param[in] v0 Starting value.
 * @return result Array reduced to final result.
 */
function arrayFoldRight(Array array, Function f, any v0) => any;

/**
 * @brief Returns a table associating for each unique element of the list array its quantity (element => quantity).
 *
 * *Example* : ``leekscript var list = [1, 1, 2, 2, 2, 2, 3, 4, 4] var frequencies =
 * arrayFrequencies(list) debug(frequencies) // [1 : 2, 2 : 4, 3 : 1, 4 : 2] ``
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The list.
 * @return frequencies The frequency table.
 */
function arrayFrequencies(Array array) => Map<any, Integer>;

/**
 * @brief Returns the element of the list array at position index.
 *
 * If the index is out of the list, return defaultValue instead.
 *
 * @category array
 * @cost 1 op
 *
 * @param[in] array The list.
 * @param[in] index The position of the desired element.
 * @param[in] defaultValue (optional) The default value (by default null).
 * @return element The element of the list array at position index.
 */
function arrayGet(Array array, integer index, any defaultValue) => any;
function arrayGet(Array array, integer index) => any;

/**
 * @brief Calls a callback function for each element
 *
 * within given array. If the callback function
 * is single-input, it is applied on the array's values, if the
 * callback function requires two inputs, it is applied
 * on the array's (key: value) pairs.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Source array.
 * @param[in] callback Callback function.
 */
function arrayIter(Array array, Function callback) => void;

/**
 * @brief Returns an array which contains the results of callback function when called on each element within given array (and indexed with the same keys as the original array).
 *
 * If the callback
 * function is single-input, it is applied on the array's values, if the callback function
 * requires two inputs, it is applied on the array's (key: value) pairs.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Source array.
 * @param[in] callback Function to be applied on each element from given array.
 * @return newArray Resulting array.
 */
function arrayMap(Array array, Function callback) => Array;

/**
 * @brief Finds the greatest value within given array.
 *
 * See also: @ref sort.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array An array of numbers.
 * @return element The greatest value contained in given array.
 */
function arrayMax(Array array) => any;

/**
 * @brief Finds the least value within given array.
 *
 * See also: @ref sort.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array An array of numbers.
 * @return element The least value contained in given array.
 */
function arrayMin(Array array) => any;

/**
 * @brief Returns a two elements array, each being a list of (key: value) pairs from given array.
 *
 * The first element contains pairs for which callback function returned true, and the second
 * one
 * contains all other pairs. If the callback function is single-input, it is applied on the
 * array's values, if the callback
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Source array.
 * @param[in] callback Callback function.
 * @return newArray Resulting two element array.
 */
function arrayPartition(Array array, Function callback) => Array<Array>;

/**
 * @brief Returns a list of random count elements from the array list, with no duplicates.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The list.
 * @param[in] count The number of elements to return.
 * @return random A list containing count random elements of array.
 */
function arrayRandom(Array array, integer count) => Array;

/**
 * @brief Removes all elements equal to element in the array list.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The list.
 * @param[in] element The element to delete.
 */
function arrayRemoveAll(Array array, any element) => void;

/**
 * @brief Returns a sublist of array containing all elements from position start to position end (exclusive).
 *
 * If the increment parameter stride is passed, the function selects only one element every
 * stride.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The original list.
 * @param[in] start The start position.
 * @param[in] end (optional) The end position (excluded).
 * @param[in] stride (optional) The increment (by default 1).
 * @return slice The produced sub-list.
 */
function arraySlice(Array array, any start, any end, integer stride) => Array;
function arraySlice(Array array, any start, any end) => Array;
function arraySlice(Array array, any start) => Array;

/**
 * @brief Returns true if the predicate callback applied to at least one of the elements of the list returns true
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The list to browse.
 * @param[in] callback The predicate to call.
 * @return some true if the predicate returned true for at least one element, false otherwise.
 */
function arraySome(Array array, Function callback) => boolean;

/**
 * @brief Sorts the elements from given array according to callback function.
 *
 * Elements are compared by pairs, each one being an input of the callback function. The
 * callback functions needs to return
 * -1, 0 or 1, respectively if the first input element is before, at the same place or after
 * the second input element.
 * If the callback function requires two inputs, it is
 * applied on the array's values, if the callback
 * function requires four inputs, it is applied on the array's (key: value) pairs.
 * var tableau = [1, 8, 4, 5, 3, 2, 7, 6];
 * debug(arraySort(tableau, function(a, b) {'{'}
 * return (a == b) ? 0 : (a < b ? (-1) : 1);
 * {'}'})); // returns [1, 2, 3, 4, 5, 6, 7, 8]
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Source array.
 * @param[in] callback (optional) Sorting function.
 * @return sortedArray Sorted array
 */
function arraySort(Array array, Function callback) => Array;
function arraySort(Array array) => Array;

/**
 * @brief (No `func_arrayToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @return set
 */
function arrayToSet(Array array) => Set;

/**
 * @brief Returns a list containing all the elements of the list array by eliminating duplicates.
 *
 * @category array
 * @cost O(n²)
 *
 * @param[in] array The original list.
 * @return unique The new list without duplicates.
 */
function arrayUnique(Array array) => Array;

/**
 * @brief Sorts an array, while keeping the key: value coupling, using given order.
 *
 * @deprecated This function is deprecated.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Array that needs sorting.
 * @param[in] order (optional) Sorting order: @ref SORT_ASC or @ref SORT_DESC.
 */
function assocSort(Array array, integer|real order) => void;
function assocSort(Array array) => void;

/**
 * @brief Computes the average of an array's elements.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array An array.
 * @return averageValue Average of given array's elements.
 */
function average(Array<integer|real> array) => real;

/**
 * @brief Counts the elements contained within an array.
 *
 * @category array
 * @cost 1 op
 *
 * @param[in] array An array.
 * @return numberOfElements Given array's number of elements.
 */
function count(Array array) => integer;

/**
 * @brief Resizes array to given size and fills it with value.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array to be filled.
 * @param[in] value Value to fill array with.
 * @param[in] size (optional) Size of final array.
 */
function fill(Array array, any value, integer|real size) => void;
function fill(Array array, any value) => void;

/**
 * @brief Checks whether given element is inside given array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array in which search is performed.
 * @param[in] element Element to look for.
 * @return inArray true if given element is contained in array, false otherwise.
 */
function inArray(Array array, any element) => boolean;

/**
 * @brief Inserts an element in an array, at given position.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array in which element is added.
 * @param[in] element Element to add.
 * @param[in] position Insertion position.
 */
function insert(Array array, any element, integer|real position) => void;

/**
 * @brief Checks whether given array is empty.
 *
 * Equivalent to count(array) == 0.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array Array to check.
 * @return empty true if array is empty, false otherwise.
 */
function isEmpty(Array array) => boolean;

/**
 * @brief Creates a single string containing all elements of given array, separated by glue delimiters.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array An array of elements to be joined into a string.
 * @param[in] glue A string that is inserted between consecutive elements of the array.
 * @return string The resulting string.
 */
function join(Array array, string glue) => string;

/**
 * @brief Sorts an array using key values, using given sorting order.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Array that is sorted.
 * @param[in] order (optional) Sorting order: @ref SORT_ASC or @ref SORT_DESC.
 */
function keySort(Array array, integer|real order) => void;
function keySort(Array array) => void;

/**
 * @brief Removes the last element of an array, and returns this element.
 *
 * @category array
 * @cost 5 ops
 *
 * @param[in] array The array to truncate.
 * @return element The truncated element.
 */
function pop(Array array) => any;

/**
 * @brief Adds given element at the end of given array.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array Array which will be lengthen.
 * @param[in] element Additionnal element.
 */
function push(Array array, any element) => void;

/**
 * @brief Adds all elements from elements array at the end of given array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array which will be lengthen.
 * @param[in] elements Array containing elements to add.
 */
function pushAll(Array array, Array elements) => void;

/**
 * @brief Removes the element at given position from given array, and returns this element.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The array from which an element is removed.
 * @param[in] position The position of the element to remove.
 * @return element The removed element.
 */
function remove(Array array, integer|real position) => any;

/**
 * @brief Removes the first occurrence of given element from given array.
 *
 * array is unchanged if element cannot be found.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The array from which an element is removed.
 * @param[in] element The element to look for and remove.
 */
function removeElement(Array array, any element) => void;

/**
 * @brief Removes the element of given array associated with given key.
 *
 * @category array
 * @cost 5 ops
 *
 * @param[in] array The array from which an element is removed.
 * @param[in] key The key of the element to remove.
 */
function removeKey(Array array, any key) => void;

/**
 * @brief Reverses the given array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array that is reversed.
 */
function reverse(Array array) => void;

/**
 * @brief Searches for given element inside given array, starting at start position.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The array to look into.
 * @param[in] element The element to look for.
 * @param[in] start (optional) The starting position.
 * @return pos The position of the first occurrence of given element inside given array starting at
 *     given start position, null if no match was found.
 */
function search(Array array, any element, integer|real start) => integer;
function search(Array array, any element) => integer;

/**
 * @brief Removes the first element of given array, and returns the corresponding element.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array The array to be truncated.
 * @return element The removed element.
 */
function shift(Array array) => any;

/**
 * @brief Shuffles the contents of given array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array to be shuffled.
 */
function shuffle(Array array) => void;

/**
 * @brief Sorts given array, using the following order:
 *
 * Booleans (false then true); Numbers (least to greatest); Strings (sorted alphabetically);
 * null elements, using the given order.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Array that needs sorting.
 * @param[in] order (optional) @ref SORT_ASC to sort from least to greatest, or @ref SORT_DESC to sort from greatest to
 *     least. More details in @ref sort (especially for multiple types arrays).
 */
function sort(Array array, integer|real order) => void;
function sort(Array array) => void;

/**
 * @brief Extracts a sub-array, starting at start position and ending at end position, from given array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Source array.
 * @param[in] start Starting position.
 * @param[in] end Ending position.
 * @return array The desired sub-array.
 */
function subArray(Array array, integer|real start, integer|real end) => Array;

/**
 * @brief Computes the sum of all elements within given array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Source array.
 * @return sum Computed sum.
 */
function sum(Array<integer|real> array) => real;

/**
 * @brief Adds given element at the beginning of given array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array.
 * @param[in] element Additional element.
 */
function unshift(Array array, any element) => void;

// === map ===

/**
 * @brief Returns the average of all values in the map table.
 *
 * If the table is empty, returns 0.0.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @return average The average.
 */
function mapAverage(Map map) => real;

/**
 * @brief Empties the map table of all its elements.
 *
 * @category map
 * @cost 1 op
 *
 * @param[in] map The table to empty.
 */
function mapClear(Map map) => void;

/**
 * @brief Returns *true* if the table map contains the value value, *false* otherwise.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] value The value to look for.
 * @return contains *true* if the value is found, *false* otherwise.
 */
function mapContains(Map map, any value) => boolean;

/**
 * @brief Returns true if the table map contains the key key, false otherwise.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map The table.
 * @param[in] key The key to search for.
 * @return contains true if the table map contains the key key, false otherwise.
 */
function mapContainsKey(Map map, any key) => boolean;

/**
 * @brief Returns true if the callback predicate applied to each element of the map table returns true, false otherwise.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] callback The predicate.
 * @return every true if the predicate callback returned true for each element, false otherwise.
 */
function mapEvery(Map map, Function callback) => boolean;

/**
 * @brief Replaces all values in the map table with the value value.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] value The replacement value.
 */
function mapFill(Map map, any value) => void;

/**
 * @brief Returns a new table containing all values from the source table map for which the applied…
 *
 * callback predicate returned *true*.
 * The callback function takes the arguments (value, key, table) in this order.
 * *Example* : ``leekscript var map = [1: '1', 2: '2', 3: '3'] var result = mapFilter(map,
 * function(value, key, map) { return key % 2 == 1 }) // [1: '1', 3: '3'] ``
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] callback The predicate.
 * @return filtered The filtered table.
 */
function mapFilter(Map map, Function callback) => Map;

/**
 * @brief Reduces the map table starting from the value v and applying the function f for each element.
 *
 * The order of the elements is indeterminate.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] f The reduction function.
 * @param[in] v The initial value.
 * @return result The reduced value.
 */
function mapFold(Map map, Function f, any v) => any;

/**
 * @brief Returns the value of the map table associated with the key key, or default if the key does not exist in the table.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map The table.
 * @param[in] key The key.
 * @param[in] default (optional) The default value (by default null).
 * @return element The value.
 */
function mapGet(Map map, any key, any default) => any;
function mapGet(Map map, any key) => any;

/**
 * @brief Returns true if the table is empty, false if it contains at least one (key, value).
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map The table
 * @return isEmpty true if the table is empty, false otherwise.
 */
function mapIsEmpty(Map map) => boolean;

/**
 * @brief Applies the callback function on all values of the map table.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] callback The function to call.
 */
function mapIter(Map map, Function callback) => void;

/**
 * @brief Returns a list containing all the keys of the map table.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @return keys The keys of the table.
 */
function mapKeys(Map map) => Array;

/**
 * @brief Returns a new table containing the values returned by the callback function applied to each element of the map table.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] callback
 * @return newMap The new map.
 */
function mapMap(Map map, Function callback) => Map;

/**
 * @brief Returns the maximum value of the map table.
 *
 * If the table is empty, return null.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @return max The maximum value.
 */
function mapMax(Map map) => real;

/**
 * @brief Returns a table containing all values from the map1 and map2 tables.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map1 The first table.
 * @param[in] map2 The second table.
 * @return merged The merging of the two tables.
 */
function mapMerge(Map map1, Map map2) => Map;

/**
 * @brief Returns the minimum value of the map table.
 *
 * If the table is empty, return null.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @return min The minimum value.
 */
function mapMin(Map map) => real;

/**
 * @brief Adds or replaces the value associated with the key key by the value value in the table map.
 *
 * @category map
 * @cost 3 ops
 *
 * @param[in] map The table.
 * @param[in] key The key.
 * @param[in] value The value.
 * @return value The value previously associated with key, or null if there was none.
 */
function mapPut(Map map, any key, any value) => any;

/**
 * @brief Adds or replaces all values from the elements table to the map table.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] elements The table whose elements will be added.
 */
function mapPutAll(Map map, Map elements) => void;

/**
 * @brief Deletes the key from the map table.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map The table.
 * @param[in] key The key to delete
 * @return element The value previously associated with the key key.
 */
function mapRemove(Map map, any key) => any;

/**
 * @brief Removes all values equal to value in the map table.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] value The value to delete.
 */
function mapRemoveAll(Map map, any value) => void;

/**
 * @brief Replaces the value associated with the key key by the value value in the table map only if…
 *
 * a value is already associated with key.
 *
 * @category map
 * @cost 3 ops
 *
 * @param[in] map The table.
 * @param[in] key The key.
 * @param[in] value The value.
 * @return value The value previously associated with key.
 */
function mapReplace(Map map, any key, any value) => any;

/**
 * @brief Replaces all values from table map1 with values from table map2 only if the value is already associated with a key.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map1 The first table.
 * @param[in] map2 The second table.
 */
function mapReplaceAll(Map map1, Map map2) => void;

/**
 * @brief Returns the key associated with a value in the map table.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] value The value to look for.
 * @return key The key associated with the value, null if none is found.
 */
function mapSearch(Map map, any value) => real;

/**
 * @brief Returns the number of keys in the map table.
 *
 * @category map
 * @cost 1 op
 *
 * @param[in] map The table.
 * @return size The size of map.
 */
function mapSize(Map map) => integer;

/**
 * @brief Returns true if the callback predicate applied to at least one element of the map table returns true, false otherwise.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @param[in] callback The predicate.
 * @return some true if the predicate callback returned true for at least one element, false
 *     otherwise.
 */
function mapSome(Map map, Function callback) => boolean;

/**
 * @brief Returns the sum of all values in the map table.
 *
 * If the table is empty, returns 0.0.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @return sum The sum of the table values.
 */
function mapSum(Map map) => real;

/**
 * @brief Returns a list containing all values from the map table.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map The table.
 * @return values The values of the map table.
 */
function mapValues(Map map) => Array;

// === leek ===

/**
 * @brief Returns the id of given entity's AI.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (optional) Leek whose AI ID you want.
