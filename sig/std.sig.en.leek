 * moveTowardCell(cell) useWeapon(enemy) ``
 *
 * @category fight
 * @cost 38080 ops
 *
 * @param[in] weapon (optional) The weapon to test. Defaults to your currently equipped weapon.
 * @param[in] entity The target entity.
 * @param[in] ignoredCells (optional) Table of cells to ignore. By default your entity is ignored.
 * @return cell The cell where the weapon can be used.
 */
function getCellToUseWeapon(integer|real weapon, integer|real entity, Array<integer> ignoredCells) => integer;
function getCellToUseWeapon(integer|real weapon, integer|real entity) => integer;

