/**
 * @brief Uses given chip to summon the corresponding entity on given cell.
 *
 * The entity uses the AI contained in given ai function. A custom name can be given with the
 * optional name parameter.
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip Desired chip. It has to be a summoning chip, equipped on the sumonning entity.
 * @param[in] cell Cell where the summon should appear.
 * @param[in] ai The sumonned entity's AI, as a function.
 * @param[in] name (optional) Custom name for the bulb (optional). By default, the bulb type name is used.
 * @return return Summoning result, see @ref useChip for details.
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief Use given chip, targeting given entity.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip to use.
 * @param[in] entity (optional) Targeted entity.
 * @return result @ref USE_CRITICAL, in case of critical hit; @ref USE_SUCCESS, in case of success; @ref USE_FAILED,
 *     in case of failure; @ref USE_INVALID_TARGET, if the target does not exist;
 *     @ref USE_NOT_ENOUGH_TP, if your entity does not have enough TP; @ref USE_INVALID_COOLDOWN, if
 *     given chip's cooldown is not expired; @ref USE_INVALID_POSITION, if the chip's range does
 *     not allow its use, or line of sight is not clear.
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief Use given chip, targeting given cell.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip to use.
 * @param[in] cell Targeted cell.
 * @return result See @ref useChip.
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Determines the content of given cell.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell Id of the cell to be tested.
 * @return content Content of cell: @ref CELL_EMPTY for an empty cell, @ref CELL_ENTITY for an entity,
 *     @ref CELL_OBSTACLE for an obstacle.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Computes the distance between cells cell1 and cell2.
 *
 * Distance is in amount of cells and does not take obstacles into account.
 * For as a crow's flies distance, see @ref getDistance and for an actual path (taking obstacles
 * into account), see @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Cell id of starting point.
 * @param[in] cell2 Cell id of destination.
 * @return distance Distance between cell1 and cell2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Returns the id of the cell at coordinates (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x X-coordinate of the desired cell.
 * @param[in] y Y-coordinate of the desired cell.
 * @return cell Id of the cell at coordinates (x, y). null if it does not exist.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Computes the x-coordinate of given cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Id of the cell.
 * @return x Its x-coordinate/
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Computes the y-coordinate of given cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Id of the cell.
 * @return y Its y-coordinate/
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Computes as the crow flies distance between cell1 and cell2.
 *
 * For distance in number of cells, see @ref getCellDistance, and for an actual path (taking
 * obstacles into account), see @ref getPathLength.
 *
 * @deprecated This function is deprecated. It is replaced by @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Cell id of starting point.
 * @param[in] cell2 Cell id of arrival.
 * @return distance Crow's fly distance between given cells.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Returns the entity that is on the cell cell.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell The cell from which we want to retrieve the entity.
 * @return entity The id of the entity located on the cell, or -1 if the cell has no entity
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Returns the entity present on given cell, if any.
 *
 * @deprecated This function is deprecated. It is replaced by @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Desired cell.
 * @return entity The id of an entity that is currently occupying given cell, -1 if cell is not occupied
 *     by an entity.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Returns the map type on which the fight takes place (factory, desert, forest, etc.), among…
 *
 * the constants @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER and
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType The map type.
 */
function getMapType() => integer;

/**
 * @brief Lists all cells that are occupied by obstacles.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Array of cells occupied by obstacles.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Finds a path between cell1 and cell2, avoiding occupied cells, except ignoredCells, which…
 *
 * are considered empty even when an entity occupies them.
 * The starting cell cell1 is never included in the resulting path. The destination cell
 * cell2 is included in the resulting path if and only if it is empty or ignored by
 * ignoredCells.
 * If no path exists between the two cells, getPath returns null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Cell id of starting point.
 * @param[in] end Cell id of destination.
 * @param[in] ignoredCells (optional) Array of cells considered inoccupied even when an entity is present.
 * @return path Array of cells that build a path between given cells. Considering ignoredCells as
 *     empty. Empty array if no path is found.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Returns the length of a path between cell1 and cell2 that avoids occupied cells, except ignoredCells which are considered empty even when an entity is present.
 *
 * This function is equivalent to count(getPath(cell1, cell2, ignoredCells)).
 * The starting cell cell1 is never counted in the result. The destination cell cell2 is
 * counted in the result if and only if it is empty or ignored by ignoredCells.
 * If no path exists between the two cells, getPathLength returns null
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Cell id of starting point.
 * @param[in] cell2 Cell id of destination.
 * @param[in] ignoredCells (optional) Array of cells considered inoccupied even when an entity is present.
 * @return length Length of the path between cell1 and cell2. -1 if no path is found.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Checks whether given cell is empty.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Cell to check.
 * @return empty true if cell is empty, false otherwise.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Determines whether the contents of cell cell is an entity.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell The cell to be tested.
 * @return isEntity true if the cell contains an entity, false otherwise.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Checks whether given cell is occupied by an entity.
 *
 * @deprecated This function is deprecated. It is replaced by @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Cell to check.
 * @return isLeek true if cell is occupied by an entity, false otherwise.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Checks whether given cell is occupied by an obstacle.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Cell to check.
 * @return isObstacle true if cell is occupied by an obstacle, false otherwise.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Checks whether cell1 and cell2 are on the same line.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 First cell.
 * @param[in] cell2 Second cell.
 * @return sameLine true if cells are on the same line, false otherwise.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

