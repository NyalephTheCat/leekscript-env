/**
 * @brief Siirtää entiteetin pois joukosta soluja käyttämällä enimmäisliikepisteitä mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cells Matriisi, joka sisältää solut, joista kokonaisuuden tulisi siirtyä pois.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveAwayFromCells(Array<integer|real> cells, integer|real mp) => integer;
function moveAwayFromCells(Array<integer|real> cells) => integer;

/**
 * @brief Siirtää entiteettiäsi pois entiteettien joukosta käyttämällä enimmäisliikepisteitä mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities Taulukko, joka sisältää niiden entiteettien tunnukset, joista entiteettisi pitäisi
 *     siirtyä pois.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveAwayFromEntities(Array<integer> entities, integer|real mp) => integer;
function moveAwayFromEntities(Array<integer> entities) => integer;

/**
 * @brief Siirtää entiteettiäsi pois entiteettien joukosta käyttämällä enimmäisliikepisteitä mp.
 *
 * @deprecated Tämä toiminto on vanhentunut. Se korvataan tekstillä @ref moveAwayFromEntities.
 * @sa moveAwayFromEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities Taulukko, joka sisältää niiden entiteettien tunnukset, joista entiteettisi pitäisi
 *     siirtyä pois.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveAwayFromLeeks(Array<integer|real> entities, integer|real mp) => integer;
function moveAwayFromLeeks(Array<integer|real> entities) => integer;

/**
 * @brief Siirtää entiteetin pois kahden solun solu1 ja solu2 määrittelemästä viivasta käyttämällä enintään mp liikepistettä.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 Solu 1.
 * @param[in] cell2 Solu 2.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveAwayFromLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveAwayFromLine(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Tuo entiteettiäsi lähemmäksi toista entiteettiä käyttämällä enimmäisliikepisteitä mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entity Entiteetti, jonka yksikkösi tulisi lähestyä.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveToward(integer|real entity, integer|real mp) => integer;
function moveToward(integer|real entity) => integer;

/**
 * @brief Siirtää entiteettiäsi yhden solun solua lähemmäs käyttämällä enimmäisliikepisteitä mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell Solu, jonka ominaisuuden tulisi lähestyä.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveTowardCell(integer|real cell, integer|real mp) => integer;
function moveTowardCell(integer|real cell) => integer;

/**
 * @brief Siirtää entiteetin lähemmäksi solujen solujoukkoa käyttämällä enimmäisliikepisteitä mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cells Taulukko, joka sisältää solut, joita entiteetin tulee lähestyä.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveTowardCells(Array<integer> cells, integer|real mp) => integer;
function moveTowardCells(Array<integer> cells) => integer;

/**
 * @brief Tuo entiteettiäsi lähemmäksi kokonaisuuksien joukkoa käyttämällä enimmäisliikepisteitä mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities Taulukko, joka sisältää niiden entiteettien tunnukset, joita entiteettisi tulee
 *     lähestyä.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveTowardEntities(Array<integer> entities, integer|real mp) => integer;
function moveTowardEntities(Array<integer> entities) => integer;

/**
 * @brief Tuo entiteettiäsi lähemmäksi kokonaisuuksien joukkoa käyttämällä enimmäisliikepisteitä mp.
 *
 * @deprecated Tämä toiminto on vanhentunut. Se korvataan tekstillä @ref moveTowardEntities.
 * @sa moveTowardEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] leeks Taulukko, joka sisältää niiden entiteettien tunnukset, joita entiteettisi tulee
 *     lähestyä.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveTowardLeeks(Array<integer> leeks, integer|real mp) => integer;
function moveTowardLeeks(Array<integer> leeks) => integer;

/**
 * @brief Tuo entiteettiäsi lähemmäksi kahden solun solu1 ja solu2 määrittelemää linjaa käyttämällä enimmäisliikepisteitä mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 Solu 1.
 * @param[in] cell2 Solu 2.
 * @param[in] mp (valinnainen) Käytettävien MP-tiedostojen enimmäismäärä. Oletuksena ei rajoitusta.
 * @return mp Käytettyjen liikepisteiden määrä.
 */
function moveTowardLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveTowardLine(integer|real cell1, integer|real cell2) => integer;

// === utils ===

/**
 * @brief Tyhjentää kaikki mark()- ja markText()-kentässä tekemät merkinnät.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Kopioi tason-tasolla parametrina välitetyn arvon ja palauttaa kopion.
 *
 * Esimerkiksi taulukon tapauksessa klooni(taulukko, 1) kopioi taulukon, mutta ei sen
 * elementtejä, klooni(taulukko, 2) kopioi taulukon sekä kaikki elementit.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value Kloonattava arvo
 * @param[in] level (valinnainen) Kloonattavien tasojen määrä
 * @return copy Kloonattu arvo
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Tallentaa objekti-viestin henkilökohtaiseen lokiin, joka on käytettävissä raportissa taistelun lopussa.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Tallennettava viesti.
 */
function debug(any object) => void;

/**
 * @brief Tallentaa objekti-viestin henkilökohtaiseen lokiin, joka on saatavilla taistelun lopussa…
 *
 * olevassa raportissa, väriltään väri.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Tallennettava viesti.
 * @param[in] color Viestin väri. Voit käyttää @ref getColor-toimintoa.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Tallentaa objektin virheilmoituksen henkilökohtaiseen lokiin, joka on saatavilla raportissa taistelun lopussa.
 *
 * Virheilmoitukset näkyvät punaisina taisteluraportissa.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Virheilmoitus kirjattavaksi.
 */
function debugE(any object) => void;

/**
 * @brief Tallentaa objektin varoitusviestin henkilökohtaiseen lokiin, joka on käytettävissä raportissa taistelun lopussa.
 *
 * Varoitusviestit näkyvät oranssina taisteluraportissa.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Varoitusviesti tallennettavaksi.
 */
function debugW(any object) => void;

/**
 * @brief Poistaa avaimeen avain liittyvän rekisterin, jos sellainen on olemassa.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key Poistettava rekisteriavain.
 */
function deleteRegister(string key) => void;

/**
 * @brief Palauttaa ottelun päivämäärän muodossa pp/KK/vvvv.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date Taistelun päivämäärä.
 */
function getDate() => string;

/**
 * @brief Palauttaa ohjeiden määrän, jotka entiteettisi on suorittanut nykyisen käännöksen aikana.
 *
 * @deprecated Tämä toiminto on vanhentunut. Se korvataan tekstillä @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Entiteettisi suorittamien ohjeiden määrä nykyisen käännöksen aikana.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Palauttaa tekoälysi käytettävissä olevan RAM-muistin rajan.
 *
 * RAM-muistia kuluu luetteloiden, taulukoiden ja objektien luomiseen.
 * Nykyinen raja on 100 megatavua tai 12 500 000 luettelokohdetta.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Palauttaa entiteettisi kuluttamien toimintojen määrän vuoronsa alusta.
 *
 * Tämän luvun on oltava pienempi kuin @ref OPERATIONS_LIMIT, jotta kokonaisuus ei kaatuisi.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Entiteettisi käyttämien toimintojen määrä vuoronsa alusta.
 */
function getOperations() => integer;

/**
 * @brief Palauttaa arvon, joka on tallennettu kokonaisuusrekisteriin, joka liittyy avaimeen avain…
 *
 * tai null, jos rekisteriä ei ole olemassa.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key Rekisteriavain, jonka arvo palautetaan.
 * @return value avain-rekisteriin tallennettu arvo.
 */
function getRegister(string key) => string;

/**
 * @brief Palauttaa kokonaisuusrekisterien joukon assosiatiivisena taulukkona [rekisteriavain:rekisteriarvo].
 *
 * Esimerkki: debug(getRegisters());
 * // Näyttää esimerkiksi:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Assosiatiivinen taulukko, joka vastaa kokonaisuuden kaikkia rekistereitä.
 */
function getRegisters() => Array<string>;

/**
 * @brief Palauttaa taisteluajan muodossa HH:mm:ss.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Taistelun aika.
 */
function getTime() => string;

/**
 * @brief Palauttaa ottelun aikaleiman, joka on yhtä monta sekuntia 1.
 *
 * tammikuuta 1970 lähtien.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Taistelun aikaleima.
 */
function getTimestamp() => integer;

/**
 * @brief Palauttaa tekoälysi käyttämän RAM-muistin määrän.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Sisällytä tekoäly nimellä ai nykyiseen tekoälyyn.
 *
 * Varoitus, include-funktiota tulee kutsua vain päälohkossa ja sen parametrin on oltava
 * suoraan kirjoitettu merkkijono
 * koodissa. Lisätietoja on opetusohjelman osiossa:
 * http://leekwars.com/help/tutorial#includes.
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Sisällytettävän tekoälyn nimi.
 */
function include(string ai) => void;

/**
 * @brief Purkaa merkkijonon json LeekScript-objektiksi (numero, merkkijono, taulukko...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json Purettava JSON-merkkijono.
 * @return object Purettu LeekScript-objekti.
 */
function jsonDecode(string json) => any;

/**
 * @brief Koodaa objektin-objektin JSON-merkkijonoksi.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object JSON-muotoon koodattava objekti.
 * @return json JSON-koodattu merkkijono.
 */
function jsonEncode(string object) => string;

/**
 * @brief Merkitsee yhden tai useamman parametrissa ilmoitetun värin solun maahan parametrissa ilmoitetun kierrosmäärän verran.
 *
 * Tämä merkintä näkyy vain kokonaisuuden kasvattajalle.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Merkittävä solu tai useiden solujen ryhmä
 * @param[in] color (valinnainen) Merkintäväri
 * @param[in] duration (valinnainen) Merkinnän kesto
 * @return success Palauttaa todeksi, jos kaikki meni hyvin
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Kirjoittaa tekstin yhteen tai useampaan soluun parametrissa ilmoitetun värin kanssa maahan parametrissa ilmoitetun kierrosmäärän ajan.
 *
 * Nämä tekstit näkyvät vain entiteetin kasvattajalle.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Solu tai useiden solujen ryhmä, johon kirjoitetaan
 * @param[in] text (valinnainen) Kirjoitettava teksti (enintään 10 merkkiä)
 * @param[in] color (valinnainen) Tekstin väri
 * @param[in] duration (valinnainen) Tekstin kesto
 * @return success Palauttaa todeksi, jos kaikki meni hyvin
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Keskeyttää taistelun vain toimintoa käyttävän entiteetin kasvattajalle.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Tallentaa arvon avain-rekisteriin.
 *
 * Avain ja arvo ovat merkkijonoja, joissa saa olla enintään 100 ja 5000 merkkiä. Purjossa
 * voi olla enintään 100 rekisteriä, tallentaminen uuteen rekisteriin ei toimi, jos kaikki
 * rekisterit
 * ovat jo kiireisiä.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Rekisteriavain, johon arvo tallennetaan.
 * @param[in] value Tallennettava arvo.
 * @return success tosi, jos toiminto onnistui, false muussa tapauksessa.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Näyttää pelaajille solun värillä väri kentällä 1 kierroksen ajan.
 *
 * Tämän ominaisuuden käyttö maksaa 1 PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Näytettävä solu
 * @param[in] color (valinnainen) Merkintäväri
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Palauttaa arvon arvon tyypin seuraavista tyypeistä: @ref TYPE_NULL, @ref TYPE_NUMBER,…
 *
 * @ref TYPE_BOOLEAN, @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Arvo, jonka tyyppi palautetaan.
 * @return type arvon tyyppi.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Palauttaa viestin viestin luoneen entiteetin tunnuksen.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Viesti, jonka kirjoittaja palautetaan.
 * @return entity Viestin viestin kirjoittajan tunnus.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Palauttaa viestiparametrien joukon viesti.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Viesti, jonka parametrit palautetaan.
 * @return params viesti-viestin parametrit.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Palauttaa viestin tyypin viesti.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Viesti, jonka tyyppi palautetaan (@ref MESSAGE_HEAL, @ref MESSAGE_ATTACK jne.).
 * @return type Viestityyppi viesti.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Palauttaa entiteetin entiteettiviestitaulukon.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (valinnainen) Entiteetti, jonka viestit palautetaan.
 * @return messages Viestisi taulukko. Viesti itsessään esitetään muodossa a lomakkeen joukko: [tekijä,
 *     tyyppi, parametrit] Erityyppiset viestit esitetään vakioilla: @ref MESSAGE_HEAL:
 *     hoitopyyntö; @ref MESSAGE_ATTACK: hyökkäyspyyntö; @ref MESSAGE_BUFF_FORCE: pakota
 *     tehostuspyyntö; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Lähetä viesti koko tiimillesi.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Lähetettävän viestin tyyppi (katso MESSAGE_* vakiot).
 * @param[in] params Viestin parametrit, jotka voivat olla mikä tahansa arvo.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Lähettää viestin entiteetille, jonka tunnus on entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity Sen entiteetin tunnus, jolle viesti lähetetään.
 * @param[in] type Lähetettävän viestin tyyppi (katso MESSAGE_* vakiot).
 * @param[in] params Viestin parametrit, jotka voivat olla mikä tahansa arvo.
 * @return sent tosi, jos lähetys onnistui, false, jos tapahtui virhe.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Palauttaa sinisen määrän värissä väri välillä 0–255.
 *
 * Esimerkiksi getBlue(@ref COLOR_BLUE) = 255 ja getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Väri, jonka sininen hinta palautetaan.
 * @return blue Sinisen määrä värissä väri
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Palauttaa parametreina annettua väriä (punainen, vihreä, sininen) vastaavan kokonaisluvun.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Punainen arvo välillä 0 - 255.
 * @param[in] green Vihreä arvo välillä 0 - 255.
 * @param[in] blue Sininen arvo välillä 0 - 255.
 * @return color int, joka vastaa parametrina annettua väriä.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Palauttaa vihreän määrän värissä väri välillä 0–255.
 *
 * Esimerkiksi getGreen(@ref COLOR_GREEN) = 255 ja getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Väri, jonka vihreä hinta palautetaan.
 * @return green Vihreän määrä värissä väri
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Palauttaa punaisen määrän värissä väri välillä 0–255.
 *
 * Esimerkiksi getRed(@ref COLOR_RED) = 255 ja getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Väri, jonka punainen hinta palautetaan.
 * @return red Punaisen määrä värissä
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Tyhjentää set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Etsii elementtiä element joukosta set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Palauttaa joukkojen joukko1 ja joukko2 välisen eron, eli kaikki joukon joukko1 elementit,…
 *
 * jotka eivät ole joukossa joukko2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Laskee kahden joukon joukko1 ja joukko2 eksklusiivisen disjunktion, merkinnällä joukko1 ⊕…
 *
 * joukko2, eli ne elementit, jotka esiintyvät joukossa joukko1 tai joukko2, mutta eivät
 * molemmissa samaan aikaan.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Laskee kahden joukon joukko1 ja joukko2 leikkauspisteen, merkitään joukko1 ∩ joukko2,…
 *
 * jotka ovat näiden kahden joukon yhteisiä elementtejä.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Palauttaa, onko joukko tyhjä vai ei.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Määrittää, onko joukko set1 set2:n osajoukko.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Lisää elementin element joukkoon set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Poistaa elementin element joukosta set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Palauttaa set -joukon koon.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Palauttaa listan, joka sisältää kaikki set-joukon elementit.
 *
 * Elementtien järjestys on mielivaltainen.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Laskee kahden joukon joukko1 ja joukko2 liiton, jota merkitään joukko1 ∪ joukko2, joka…
 *
 * sisältää kaikki joukon joukko1 tai joukko2 elementit.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Laskee intervallikeskiarvon.
 *
 * - Jos intervalli on vasemmalle ja oikealle rajattu, palauttaa (intervalMin(i) +
 * intervalMax(i)) / 2. - Jos intervalli on vain vasemmalle rajattu, palauttaa +∞. - Jos
 * intervalli on rajattu vain oikealta, palautetaan -∞. - Jos väli on rajoittamaton tai
 * tyhjä, palautetaan NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Yhdistää kaksi intervallia interval1 ja interval2.
 *
 * Vastaa unionia, jos niiden leikkauspiste ei ole tyhjä, muuten sisältää myös niiden välisen
 * joukon.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Laskee kahden intervallin interval1 ja interval2 leikkauspisteen, joka sisältää molemmille yhteiset elementit.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Palauttaa, onko intervalli interval rajattu vasemmalta ja oikealta vai ei.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Palauttaa, onko väli interval suljettu vasemmalta ja oikealta vai ei.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Palauttaa, onko interval tyhjä vai ei.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Palauttaa, onko intervalli interval vasemmalle rajattu vai ei.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Palauttaa, onko intervalli suljettu vasemmalta vai ei.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Palauttaa, onko intervalli interval oikealle rajattu vai ei.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Palauttaa, onko intervalli interval suljettu oikealta vai ei.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Palauttaa aikavälin interval ylärajan.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Palauttaa aikavälin interval alarajan.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Palauttaa aikavälin interval koon.
 *
 * - Jos väli on rajattu, palauttaa max - min. - Jos väli ei ole rajattu, palauttaa +∞. - Jos
 * väli on tyhjä, palautetaan 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Palauttaa listan, joka sisältää interval-välin elementit ja askeleen etäisyyden niiden välillä.
 *
 * Jos väli on negatiivinen, elementit otetaan käänteisessä järjestyksessä.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (valinnainen)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
