 * @return result Arvo on suurempi kuin 0, jos hyökkäys aloitettiin.
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Palauttaa solun sisällön, jonka tunnus on solu.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell Sen solun tunnus, jonka sisältö palautetaan.
 * @return content solun sisältö: @ref CELL_EMPTY tyhjälle solulle, @ref CELL_ENTITY kokonaisuudelle,
 *     @ref CELL_OBSTACLE esteelle.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Palauttaa kahden solun solu1 ja solu2 välisen etäisyyden.
 *
 * Palautettu etäisyys ilmaistaan solujen lukumääränä, eikä siinä oteta huomioon solujen
 * välisiä erilaisia esteitä.
 * Jos haluat saada etäisyyden linnuntietä, katso @ref getDistance ja saadaksesi selville kahden
 * solun välisen polun etäisyyden välttäen esteitä, katso @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Aloitussolun tunnus.
 * @param[in] cell2 Saapumissolun tunnus.
 * @return distance Kahden solun solu1 ja solu2 välinen etäisyys.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Palauttaa asemassa olevan solun tunnuksen (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x Solun x-sijainti.
 * @param[in] y Solun y-sijainti.
 * @return cell Solun tunnus sijainnissa (x, y), null, jos solua ei ole olemassa.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Määrittää solun solun sijainnin X:ssä.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Solu, jonka sijainti X:ssä määritetään.
 * @return x Solun X-sijainti.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Määrittää solun solun Y-paikan.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Solu, jonka sijainti Y:ssä määritetään.
 * @return y Solun Y-sijainti.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Laskee etäisyyden linnuntietä kahden solun solu1 ja solu2 välillä.
 *
 * Jos haluat saada etäisyyden solujen lukumääränä, katso @ref getCellDistance, ja saadaksesi
 * selville kahden eri esteitä välttävän solun välisen reitin pituuden kohdasta
 * @ref getPathLength.
 *
 * @deprecated Tämä toiminto on vanhentunut. Se korvataan tekstillä @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Aloitussolu.
 * @param[in] cell2 Saapumissolu.
 * @return distance Kahden solun välinen etäisyys linnuntietä.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Palauttaa solussa solussa olevan entiteetin.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Solu, jonka entiteetin haluamme noutaa.
 * @return entity Solun entiteetin tunnus tai -1, jos solussa ei ole entiteettiä.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Palauttaa solussa solussa olevan entiteetin.
 *
 * @deprecated Tämä toiminto on vanhentunut. Se korvataan tekstillä @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Solu, jonka entiteetin haluamme noutaa.
 * @return entity Solun entiteetin tunnus tai -1, jos solussa ei ole entiteettiä.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Palauttaa maaston tyypin, jolla taistelu käydään (tehdas, aavikko, metsä jne.), vakioiden…
 *
 * @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIE ja @ref MAP_BEACH joukosta.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Maaston tyyppi.
 */
function getMapType() => integer;

/**
 * @brief Palauttaa luettelon maaston estetiloista.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Matriisi, joka sisältää estesolujen tunnukset.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Palauttaa polun välttäen esteitä kahden solun solu1 ja solu2 välillä, jos sellainen on olemassa, jättäen huomioimatta taulukon ignoredCells sisältämät solut.
 *
 * Jos pelaaja on ohitetussa solussa, polku voi kulkea hänen yli.
 * Aloitussolu solu1 ei koskaan ole osa tuloksena olevaa polkua. Solu solu2 on osa tuloksena
 * olevaa polkua silloin ja vain, jos se on tyhjä tai jos ignoredCells jättää sen huomiotta.
 * Jos näiden kahden solun välillä ei ole polkua, getPath palauttaa nollan.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Aloitussolu.
 * @param[in] end Saapumissolu.
 * @param[in] ignoredCells (valinnainen) Ohitettavien solujen joukko.
 * @return path Matriisi, joka sisältää solut, jotka muodostavat reitin kahden solun välillä.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Palauttaa kahden solun solu1 ja solu2 välisen polun, välttäen esteitä ja jättäen huomioimatta taulukon ignoredCells sisältämät solut.
 *
 * Tämä funktio vastaa funktiota count(getPath(solu1, cell2, ignoreedCells)).
 * Jos pelaaja on ohitetussa solussa, polku voi kulkea hänen yli.
 * Aloitussolua solu1 ei koskaan lasketa tulokseen. Solu solu2 lasketaan tulokseen silloin ja
 * vain, jos se on tyhjä tai jos ignoredCells jättää sen huomiotta.
 * Jos kahden solun välillä ei ole polkua, getPathLength palauttaa nollan.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Aloitussolu.
 * @param[in] cell2 Saapumissolu.
 * @param[in] ignoredCells (valinnainen) Ohitettavien solujen joukko.
 * @return length Polun pituus solun1 ja solun2 välillä.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Määrittää, onko solu tyhjä.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Testattava solu.
 * @return empty tosi, jos solu on tyhjä, false muussa tapauksessa.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Määrittää, onko solun solu sisältö kokonaisuus.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell Testattava solu.
 * @return isEntity tosi, jos solu sisältää entiteetin, false muussa tapauksessa.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Määrittää, onko solun solu sisältö kokonaisuus.
 *
 * @deprecated Tämä toiminto on vanhentunut. Se korvataan tekstillä @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Testattava solu.
 * @return isLeek tosi, jos solu sisältää entiteetin, false muussa tapauksessa.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Määrittää, onko solun solu sisältö este.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Testattava solu.
 * @return isObstacle tosi, jos solu sisältää esteen, false muussa tapauksessa.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Määrittää, ovatko kaksi solua solu1 ja solu2 samalla rivillä.
