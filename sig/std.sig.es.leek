 * @return turn El turno de combate donde apareció la entidad.
 */
function getBirthTurn(integer|real entity) => integer;
function getBirthTurn() => integer;

/**
 * @brief (No `func_getBulbType` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (opcional)
 * @return bulbType
 */
function getBulbType(integer|real entity) => integer;
function getBulbType() => integer;

/**
 * @brief Devuelve la celda donde se encuentra la entidad con id entidad.
 *
 * Use getCell() sin parámetros para recuperar su celda.
 *
 * @category leek
 * @cost 5 ops
 *
 * @param[in] entity (opcional) El id de la entidad cuya celda será devuelta.
 * @return cell El número de celular donde se encuentra la entidad.
 */
function getCell(integer|real entity) => integer;
function getCell() => integer;

/**
 * @brief Devuelve las viñetas de la entidad con id entidad.
 *
 * @category leek
 * @cost 40 ops
 *
 * @param[in] entity (opcional) El id de la entidad cuyas viñetas se devolverán.
 * @return chips Una matriz que contiene los identificadores de viñetas de la entidad entidad.
 */
function getChips(integer|real entity) => Array<integer>;
function getChips() => Array<integer>;

/**
 * @brief Devuelve el número de núcleos de la entidad con id entidad.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (opcional) La entidad cuyo número de núcleos se devolverá.
 * @return cores El número de núcleos de la entidad entidad.
 */
function getCores(integer|real entity) => integer;
function getCores() => integer;

/**
 * @brief Devuelve la tasa de devolución de daños de la entidad con id entidad.
 *
 * @category leek
