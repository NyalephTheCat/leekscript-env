 *
 * @category fight
 * @cost 50 ops
 *
 * @return life La salud total de tus aliados.
 */
function getAlliesLife() => integer;

/**
 * @brief (No `func_getBulbCharacteristics` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getBulbStats.
 * @sa getBulbStats
 *
 * @category fight
 * @cost 40 ops
 *
 * @param[in] bulbChip
 * @return stats
 */
function getBulbCharacteristics(integer|real bulbChip) => Array<string>;

/**
 * @brief Devuelve la lista de chips que se equiparán en una bombilla invocada por el chip bulb_chip.
 *
 * @category fight
 * @cost 40 ops
 *
 * @param[in] bulbChip El chip del bulbo.
 * @return chips Los chips de una bombilla invocados por el chip bulb_chip.
 */
function getBulbChips(integer|real bulbChip) => Array<integer>;

/**
 * @brief Devuelve las características mínimas y máximas de mercado de una bombilla invocada por el chip bulb_chip.
 *
 * El resultado es un mapa indexado por las constantes STAT_*, donde cada valor es un array
 * [min, max].
 *
 * @category fight
 * @cost 40 ops
 *
 * @param[in] bulbChip El chip de la bombilla.
 * @return stats Las características mínimas y máximas de la bombilla invocada por el chip bulb_chip, o
 *     null si el chip no es válido.
 */
function getBulbStats(integer|real bulbChip) => Array<string>;

/**
 * @brief Devuelve una celda donde su entidad puede usar el chip chip en la entidad entidad.
 *
 * La celda devuelta no es necesariamente la más cercana. Si no es posible ninguna celda, la
 * función devuelve -1.
 * Ejemplo para lanzar una @ref Piedra: `` var celda = getCellToUseChip(CHIP_ROCK, enemigo)
 * moveTowardCell(celda) useChip(CHIP_ROCK, enemigo) ``
 *
 * @category fight
 * @cost 38080 ops
 *
 * @param[in] chip
 * @param[in] entity
 * @param[in] ignoredCells (opcional)
 * @return cell
 */
function getCellToUseChip(integer|real chip, integer|real entity, Array<integer> ignoredCells) => integer;
function getCellToUseChip(integer|real chip, integer|real entity) => integer;

/**
 * @brief Determina una celda donde su entidad puede usar el chip chip en la celda cell.
 *
 * La celda devuelta no es necesariamente la más cercana. Si no es posible ninguna celda, la
 * función devuelve -1.
 *
 * @category fight
 * @cost 38080 ops
 *
 * @param[in] chip
 * @param[in] cell
 * @param[in] ignoredCells (opcional)
 * @return cell
 */
function getCellToUseChipOnCell(integer|real chip, integer|real cell, Array<integer> ignoredCells) => integer;
function getCellToUseChipOnCell(integer|real chip, integer|real cell) => integer;

/**
 * @brief Devuelve una celda donde su entidad puede usar el arma arma en la entidad.
 *
 * La celda devuelta no es necesariamente la más cercana. Si no es posible ninguna celda, la
 * función devuelve -1.
 * Ejemplo para usar el @ref Láser: `` var celda = getCellToUseWeapon(WEAPON_LASER, enemigo)
 * moveTowardCell(celda) usar arma (enemigo) ``
 *
 * @category fight
 * @cost 38080 ops
 *
 * @param[in] weapon (opcional)
 * @param[in] entity
 * @param[in] ignoredCells (opcional)
 * @return cell
 */
function getCellToUseWeapon(integer|real weapon, integer|real entity, Array<integer> ignoredCells) => integer;
function getCellToUseWeapon(integer|real weapon, integer|real entity) => integer;

/**
 * @brief Determina una celda donde tu entidad puede usar el arma arma en una celda celda.
 *
 * La celda devuelta no es necesariamente la más cercana. Si no es posible ninguna celda, la
 * función devuelve -1.
 *
 * @category fight
 * @cost 38080 ops
 *
 * @param[in] weapon (opcional)
 * @param[in] cell
 * @param[in] ignoredCells (opcional)
 * @return cell
 */
function getCellToUseWeaponOnCell(integer|real weapon, integer|real cell, Array<integer> ignoredCells) => integer;
function getCellToUseWeaponOnCell(integer|real weapon, integer|real cell) => integer;

/**
 * @brief Devuelve la lista de celdas desde las que su entidad podrá usar el chip chip en la entidad entidad.
 *
