// === utils ===

/**
 * @brief Borra todas las marcas hechas por mark() y markText() en el campo.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Copia el valor pasado como parámetro en los niveles de nivel y devuelve la copia.
 *
 * En el caso de un arreglo, por ejemplo, un clon(arreglo, 1) copiará el arreglo pero no sus
 * elementos, un clon(arreglo, 2) copiará el arreglo así como todos los elementos.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value El valor a clonar
 * @param[in] level (opcional) El número de niveles a clonar.
 * @return copy El valor clonado
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Registra un mensaje de objeto en el registro personal, disponible en el informe al final de la pelea.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object El mensaje a grabar.
 */
function debug(any object) => void;

/**
 * @brief Registra un mensaje de objeto en el registro personal, disponible en el informe al final de la pelea, del color color.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object El mensaje a grabar.
 * @param[in] color El color del mensaje. Puede utilizar la función @ref getColor.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Registra un mensaje de error de objeto en el registro personal, disponible en el informe al final del combate.
 *
 * Los mensajes de error aparecen en rojo en el informe del combate.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object El mensaje de error para iniciar sesión.
 */
function debugE(any object) => void;

/**
 * @brief Registra un mensaje de advertencia de objeto en el registro personal, disponible en el informe al final de la pelea.
 *
 * Los mensajes de advertencia aparecen en naranja en el informe de combate.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object El mensaje de advertencia a grabar.
 */
function debugW(any object) => void;

/**
 * @brief Elimina el registro asociado con la clave clave si existe.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key La clave de registro para eliminar.
 */
function deleteRegister(string key) => void;

/**
 * @brief Devuelve la fecha de la pelea, en formato dd/MM/yyyy.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date La fecha de la pelea.
 */
function getDate() => string;

/**
 * @brief Devuelve el número de instrucciones que ha realizado su entidad durante el turno actual.
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions El número de instrucciones que ha realizado su entidad durante el turno actual.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Devuelve el límite de RAM utilizable de su IA.
 *
 * La memoria RAM se consume creando listas, tablas y objetos.
 * El límite actual es de 100 megabytes o 12 500 000 elementos de lista.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Devuelve el número de operaciones consumidas por tu entidad desde el inicio de su turno.
 *
 * Este número debe permanecer por debajo de @ref OPERATIONS_LIMIT para que la entidad no se
 * bloquee.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Número de operaciones consumidas por tu entidad desde el inicio de su turno.
 */
function getOperations() => integer;

/**
 * @brief Devuelve el valor almacenado en el registro de entidad asociado a la clave key o null si el registro no existe.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key La clave de registro cuyo valor se devolverá.
 * @return value El valor almacenado en el registro clave.
 */
function getRegister(string key) => string;

/**
 * @brief Devuelve el conjunto de registros de entidad como una matriz asociativa [clave de registro:valor de registro].
 *
 * Ejemplo: debug(getRegisters());
 * // Muestra por ejemplo:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers La matriz asociativa correspondiente a todos los registros de la entidad.
 */
function getRegisters() => Array<string>;

/**
 * @brief Devuelve el tiempo de batalla, en formato HH:mm:ss.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time El tiempo de la pelea.
 */
function getTime() => string;

/**
 * @brief Devuelve la marca de tiempo de la pelea, igual a la cantidad de segundos desde el 1 de enero de 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp La marca de tiempo de la pelea.
 */
function getTimestamp() => integer;

/**
 * @brief Devuelve la cantidad de RAM utilizada actualmente por su IA.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Incluya la IA denominada ai en la IA actual.
 *
 * Advertencia, la función de inclusión debe llamarse solo en el bloque principal y su
 * parámetro debe ser una cadena escrita directamente
 * en el código. Para obtener más información, consulte la sección del tutorial:
 * http://leekwars.com/help/tutorial#includes.
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai El nombre de la IA a incluir.
 */
function include(string ai) => void;

/**
 * @brief Decodifica la cadena json al objeto LeekScript (número, cadena, matriz...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json La cadena JSON para decodificar.
 * @return object El objeto LeekScript decodificado.
 */
function jsonDecode(string json) => any;

/**
 * @brief Codifica el objeto object en una cadena JSON.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object El objeto a codificar en JSON.
 * @return json La cadena codificada en JSON.
 */
function jsonEncode(string object) => string;

/**
 * @brief Marca una o más celdas del color indicado en el parámetro en el suelo para el número de vueltas indicadas en el parámetro.
 *
 * Esta marca solo es visible para el criador de la entidad.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells La celda o matriz de múltiples celdas para marcar
 * @param[in] color (opcional) Color de marcado
 * @param[in] duration (opcional) Duración del marcado
 * @return success Devuelve verdadero si todo salió bien
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Escribe un texto en una o más celdas del color indicado en el parámetro en el suelo por el número de vueltas indicadas en el parámetro.
 *
 * Estos textos solo son visibles para el criador de la entidad.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells La celda o matriz de múltiples celdas para escribir
 * @param[in] text (opcional) El texto a escribir (máximo 10 caracteres)
 * @param[in] color (opcional) Color de texto
 * @param[in] duration (opcional) Duración del texto
 * @return success Devuelve verdadero si todo salió bien
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Pausa la pelea, solo para el criador de la entidad que usa la función.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Almacena el valor en el registro clave.
 *
 * La clave y el valor son cadenas que deben contener respectivamente 100 y 5000 caracteres
 * como máximo. Un puerro puede tener un máximo de 100 registros, almacenar en un nuevo
 * registro no funcionará si todos los registros
 * ya están ocupados.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key La clave de registro donde almacenar el valor.
 * @param[in] value El valor a almacenar.
 * @return success verdadero si la operación fue exitosa, falso de lo contrario.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Muestra a los jugadores una celda del color color en el campo durante 1 turno.
 *
 * El uso de esta función cuesta 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell La celda para mostrar
 * @param[in] color (opcional) Color de marcado
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Devuelve el tipo del valor valor, entre los tipos: @ref TYPE_NULL, @ref TYPE_NUMBER,…
 *
 * @ref TYPE_BOOLEAN, @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value El valor cuyo tipo se devolverá.
 * @return type El tipo de valor.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Devuelve el id de la entidad autora del mensaje mensaje.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message El mensaje cuyo autor será devuelto.
 * @return entity La identificación de la entidad que crea el mensaje mensaje.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Devuelve la matriz de parámetros de mensaje mensaje.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message El mensaje cuyos parámetros se devolverán.
 * @return params Los parámetros del mensaje message.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Devuelve el tipo de mensaje mensaje.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message El mensaje cuyo tipo se devolverá (entre @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK, etc.).
 * @return type El tipo de mensaje mensaje.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Devuelve la matriz de mensajes de entidad entidad.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (opcional) La entidad cuyos mensajes se devolverán.
 * @return messages La tabla de sus mensajes. Un mensaje se representa a sí mismo en forma de matriz de la
 *     forma: [autor, tipo, parámetros] Los diferentes tipos de mensajes están representados
 *     por las constantes: @ref MESSAGE_HEAL: solicitud de atención; @ref MESSAGE_ATTACK: solicitud
 *     de ataque; @ref MESSAGE_BUFF_FORCE: forzar solicitud de impulso; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Envía un mensaje a todo tu equipo.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type El tipo de mensaje a enviar (ver las constantes MESSAGE_*).
 * @param[in] params Los parámetros del mensaje, que pueden ser cualquier valor.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Envía un mensaje a la entidad con id entidad.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity El id de la entidad a la que se enviará el mensaje.
 * @param[in] type El tipo de mensaje a enviar (ver las constantes MESSAGE_*).
 * @param[in] params Los parámetros del mensaje, que pueden ser cualquier valor.
 * @return sent verdadero si el envío fue exitoso, falso si ocurrió un error.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Devuelve la cantidad de azul en el color color, entre 0 y 255.
 *
 * Por ejemplo, getBlue(@ref COLOR_BLUE) = 255 y getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color El color cuya tarifa azul se devolverá.
 * @return blue La tasa de azul en el color color
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Devuelve el entero correspondiente al color (rojo, verde, azul) proporcionado como parámetro.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Valor rojo entre 0 y 255.
 * @param[in] green Valor verde entre 0 y 255.
 * @param[in] blue Valor azul entre 0 y 255.
 * @return color int correspondiente al color proporcionado como parámetro.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Devuelve la cantidad de verde en el color color, entre 0 y 255.
 *
 * Por ejemplo, getGreen(@ref COLOR_GREEN) = 255 y getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color El color cuya tasa verde se devolverá.
 * @return green La tasa de verde en el color color
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Devuelve la cantidad de rojo en el color color, entre 0 y 255.
 *
 * Por ejemplo, getRed(@ref COLOR_RED) = 255 y getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color El color cuya tasa roja se devolverá.
 * @return red La tasa de rojo en el color color
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Borra el set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Busca un elemento elemento en el conjunto conjunto.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Devuelve la diferencia entre los conjuntos conjunto1 y conjunto2, es decir, todos los…
 *
 * elementos de conjunto1 que no están en conjunto2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Calcula la disyunción exclusiva de dos conjuntos conjunto1 y conjunto2, anotados conjunto1…
 *
 * ⊕ conjunto2, que son los elementos presentes en conjunto1 o conjunto2, pero no en ambos a
 * la vez.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Calcula la intersección de dos conjuntos conjunto1 y conjunto2, anotando conjunto1 ∩…
 *
 * conjunto2, que son los elementos comunes de los dos conjuntos.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Devuelve si un conjunto está vacío o no.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Determina si un conjunto conjunto1 es un subconjunto de conjunto2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Inserta un elemento elemento en el conjunto conjunto.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Elimina un elemento elemento del conjunto conjunto.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Devuelve el tamaño del conjunto set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Devuelve una lista que contiene todos los elementos del conjunto set.
 *
 * El orden de los elementos es arbitrario.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Calcula la unión de dos conjuntos conjunto1 y conjunto2, denotado conjunto1 ∪ conjunto2,…
 *
 * que contiene todos los elementos presentes en conjunto1 o en conjunto2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Calcula la media del intervalo.
 *
 * - Si el intervalo está delimitado por la izquierda y la derecha, devuelve (intervalMin(i)
 * + intervalMax(i)) / 2. - Si el intervalo está acotado sólo por la izquierda, devuelve +∞.
 * - Si el intervalo está acotado sólo por la derecha, devuelve -∞. - Si el intervalo no está
 * acotado o está vacío, devuelve NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Combina dos intervalos intervalo1 e intervalo2.
 *
 * Equivale a la unión si su intersección no es vacía, en caso contrario incluye también el
 * conjunto intermedio.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Calcula la intersección de dos intervalos intervalo1 e intervalo2, conteniendo los elementos comunes a ambos.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Devuelve si el intervalo intervalo está acotado por la izquierda y por la derecha o no.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Devuelve si el intervalo intervalo está cerrado por la izquierda y por la derecha o no.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Devuelve si el intervalo está vacío o no.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Devuelve si el intervalo intervalo está delimitado por la izquierda o no.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Devuelve si el intervalo está cerrado por la izquierda o no.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Devuelve si el intervalo intervalo está delimitado por la derecha o no.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Devuelve si el intervalo intervalo está cerrado por la derecha o no.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Devuelve el límite superior del intervalo intervalo.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Devuelve el límite inferior del intervalo intervalo.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Devuelve el tamaño del intervalo intervalo.
 *
 * - Si el intervalo está acotado, devuelve max - min. - Si el intervalo no está acotado,
 * devuelve +∞. - Si el intervalo está vacío, devuelve 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Devuelve una lista que contiene los elementos del intervalo intervalo con una distancia paso entre cada uno.
 *
 * Si el intervalo es negativo, toma los elementos en orden inverso.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (opcional)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
