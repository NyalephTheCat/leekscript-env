 *
 * @param[in] chip El chip cuyo rango máximo será devuelto.
 * @return maxRange El alcance máximo del chip.
 */
function getChipMaxRange(integer|real chip) => integer;

/**
 * @brief Devuelve el rango máximo del chip chip.
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getChipMaxRange.
 * @sa getChipMaxRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip El chip cuyo rango máximo será devuelto.
 * @return maxScope El alcance máximo del chip.
 */
function getChipMaxScope(integer|real chip) => integer;

/**
 * @brief (No `func_getChipMaxUses` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip
 * @return maxUses
 */
function getChipMaxUses(integer chip) => integer;

/**
 * @brief Devuelve el rango mínimo del chip chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip El chip cuyo rango mínimo será devuelto.
 * @return minRange El rango mínimo del chip.
 */
function getChipMinRange(integer|real chip) => integer;

/**
 * @brief Devuelve el rango mínimo del chip chip.
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getChipMinRange.
 * @sa getChipMinRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip El chip cuyo rango mínimo será devuelto.
 * @return minScope El rango mínimo del chip.
 */
function getChipMinScope(integer|real chip) => integer;

/**
 * @brief Devuelve el nombre del chip chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip El chip cuyo nombre será devuelto.
 * @return name El nombre del chip chip.
 */
function getChipName(integer|real chip) => string;

/**
 * @brief Devuelve el tiempo de reutilización actual del chip de la entidad entidad.
 *
 * @category chip
 * @cost 30 ops
 *
 * @param[in] chip El chip cuyo tiempo de reutilización actual se devolverá.
 * @param[in] entity (opcional) La entidad cuyo tiempo de reutilización se devolverá.
 * @return cooldown El tiempo de reutilización actual del chip chip, este es el número de turnos antes de
 *     que el chip sea utilizable, 0 si es utilizable actualmente.
 */
function getCooldown(integer|real chip, integer|real entity) => integer;
function getCooldown(integer|real chip) => integer;

/**
 * @brief Determina si un valor es una constante que representa un chip.
 *
 * isChip(CHIP_RAGE) = true;
 * isChip(WEAPON_PISTOL) = false.
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] value El número a determinar.
 * @return chip verdadero si el valor es una constante de chip.
 */
function isChip(integer|real value) => boolean;

/**
 * @brief Determina si el chip solo se puede usar en línea.
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getChipLaunchType.
 * @sa getChipLaunchType
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip El id del chip a probar.
 * @return isInline verdadero si el chip es solo en línea, falso de lo contrario.
 */
function isInlineChip(integer|real chip) => boolean;

/**
 * @brief Utiliza el chip CHIP_RESURRECTION para resucitar una entidad muerta con id entidad, en la celda celda.
 *
 * @category chip
 * @cost 500 ops
 *
 * @param[in] entity El id de la entidad a revivir.
 * @param[in] cell La celda en la que reaparecerá la entidad.
 * @return result El resultado de lanzar el chip, entre las constantes USE_*.
 */
function resurrect(integer|real entity, integer|real cell) => integer;

/**
 * @brief Invoca una entidad determinada por el chip chip en la celda celda que tiene por IA la función ai.
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip El chip utilizado para invocar. El chip debe ser un chip de tipo invocación y debe
 *     estar equipado en la entidad que usa la función de invocación.
 * @param[in] cell Debería aparecer la celda o la convocatoria.
 * @param[in] ai La invocación AI, como una función.
 * @param[in] name (opcional)
 * @return return La función de convocatoria tiene el mismo retorno que la función @ref useChip.
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief Utilice el chip chip en la entidad entidad.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip para usar.
 * @param[in] entity (opcional) Entidad objetivo.
 * @return result Los valores de retorno de useChip son: @ref USE_CRITICAL, en golpe crítico; @ref USE_SUCCESS,
 *     si tiene éxito; @ref USE_FAILED, en caso de falla; @ref USE_INVALID_TARGET, si el objetivo no
 *     existe; @ref USE_NOT_ENOUGH_TP, si su entidad no tiene suficiente TP;
 *     @ref USE_INVALID_COOLDOWN, si el chip aún no se puede usar; @ref USE_INVALID_POSITION, si el
 *     rango es malo o la línea de visión no está clara
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief Utilice el chip chip en la celda celda.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip para usar.
 * @param[in] cell Célula diana.
 * @return result Un valor mayor que 0 si se lanzó el ataque.
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Devuelve el contenido de una celda con id celda.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell El id de la celda cuyo contenido se devolverá.
 * @return content El contenido de la celda cell: @ref CELL_EMPTY para una celda vacía, @ref CELL_ENTITY para una
 *     entidad, @ref CELL_OBSTACLE para un obstáculo.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Devuelve la distancia entre dos celdas celda1 y celda2.
 *
 * La distancia devuelta se expresa en número de celdas y no tiene en cuenta los diversos
 * obstáculos entre las dos celdas.
 * Para obtener la distancia a vuelo de pájaro, consulte @ref getDistance y para obtener la
 * distancia del camino entre las dos celdas evitando obstáculos, consulte @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 El id de la celda inicial.
 * @param[in] cell2 El id de la celda de llegada.
 * @return distance La distancia entre las dos celdas celda1 y celda2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Devuelve el id de la celda en la posición (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x La posición x de la celda.
 * @param[in] y La posición y de la celda.
 * @return cell La identificación de la celda en la posición (x, y), null si la celda no existe.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Determina la posición en X de la celda celda.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell La celda cuya posición en X será determinada.
 * @return x La posición X de la celda.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Determina la posición Y de la celda celda.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell La celda cuya posición en Y se determinará.
 * @return y La posición Y de la celda.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Calcula la distancia a vuelo de pájaro entre dos celdas celda1 y celda2.
 *
 * Para obtener la distancia en número de celdas, vea @ref getCellDistance, y para obtener la
 * longitud del camino entre las dos celdas esquivando varios obstáculos, vea @ref getPathLength.
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 La celda inicial.
 * @param[in] cell2 La celda de llegada.
 * @return distance La distancia en línea recta entre las dos celdas.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Devuelve la entidad que está en la celda celda.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell La celda cuya entidad queremos recuperar.
 * @return entity El id de la entidad en la celda, o -1 si la celda no tiene entidad.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Devuelve la entidad que está en la celda celda.
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell La celda cuya entidad queremos recuperar.
 * @return entity El id de la entidad en la celda, o -1 si la celda no tiene entidad.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Devuelve el tipo de terreno en el que se desarrolla la lucha (fábrica, desierto, bosque,…
 *
 * etc.), entre las constantes @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST,
 * @ref MAP_GLACIER y @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType El tipo de terreno.
 */
function getMapType() => integer;

/**
 * @brief Devuelve la lista de espacios de obstáculos en el terreno.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles La matriz que contiene los ID de las celdas de obstáculos.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Devuelve el camino evitando obstáculos entre dos celdas cell1 y cell2, si existe, ignorando las celdas contenidas en el array ignoredCells.
 *
 * Si un jugador está en una celda ignorada, el camino puede pasar por encima de él.
 * La celda inicial celda1 nunca forma parte de la ruta resultante. La celda celda2 es parte
 * de la ruta resultante si y solo si está vacía o es ignorada por ignoredCells.
 * Si no existe una ruta entre las dos celdas, getPath devuelve null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start La celda inicial.
 * @param[in] end La celda de llegada.
 * @param[in] ignoredCells (opcional) La matriz de celdas a ignorar.
 * @return path La matriz que contiene las celdas que forman el camino entre las dos celdas.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Devuelve la longitud del camino entre dos celdas cell1 y cell2, evitando obstáculos, ignorando las celdas contenidas en el array ignoredCells.
 *
 * Esta función es equivalente a count(getPath(cell1, cell2, ignoredCells)).
 * Si un jugador está en una celda ignorada, el camino puede pasar por encima de él.
 * La celda inicial cell1 nunca se cuenta en el resultado. La celda cell2 se cuenta en el
 * resultado si y solo si está vacía o es ignorada por ignoredCells.
 * Si no existe una ruta entre las dos celdas, getPathLength devuelve null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 La celda inicial.
 * @param[in] cell2 La celda de llegada.
 * @param[in] ignoredCells (opcional) La matriz de celdas a ignorar.
 * @return length La longitud de la ruta entre celda1 y celda2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Determina si una celda está vacía.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La celda a probar.
 * @return empty verdadero si la celda está vacía, falso en caso contrario.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Determina si el contenido de la celda celda es una entidad.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell La celda a probar.
 * @return isEntity verdadero si la celda contiene una entidad, falso de lo contrario.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Determina si el contenido de la celda celda es una entidad.
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La celda a probar.
 * @return isLeek verdadero si la celda contiene una entidad, falso de lo contrario.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Determina si el contenido de la celda celda es un obstáculo.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La celda a probar.
 * @return isObstacle verdadero si la celda contiene un obstáculo, falso de lo contrario.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Determina si dos celdas celda1 y celda2 están en la misma línea.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 La primera celda.
 * @param[in] cell2 La segunda celda.
 * @return sameLine verdadero si las dos celdas están en la misma línea, falso de lo contrario.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

