 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getWeaponMinRange.
 * @sa getWeaponMinRange
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon El id del arma cuyo rango mínimo será devuelto.
 * @return minScope El alcance mínimo del arma arma.
 */
function getWeaponMinScope(integer|real weapon) => integer;

/**
 * @brief Devuelve el nombre del arma arma.
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon El id del arma cuyo nombre será devuelto.
 * @return name El nombre del arma arma.
 */
function getWeaponName(integer|real weapon) => string;

/**
 * @brief Devuelve los efectos pasivos del arma arma.
 *
 * @category weapon
 * @cost 125 ops
 *
 * @param[in] weapon El id del arma cuyos efectos pasivos serán devueltos.
 * @return passiveEffects Una matriz que contiene los efectos del arma arma. Cada efecto es en sí mismo una
 *     matriz de la forma [tipo, min, max, turnos, objetivos, modificadores]. Estos efectos
 *     son los mismos que los devueltos por @ref getWeaponEffects.
 */
function getWeaponPassiveEffects(integer|real weapon) => Array<Array>;

/**
 * @brief Determina si el arma arma solo se puede usar en línea.
 *
 * @deprecated Esta función está obsoleta. Se reemplaza por @ref getWeaponLaunchType.
 * @sa getWeaponLaunchType
 *
 * @category weapon
 * @cost 10 ops
 *
 * @param[in] weapon El ID del arma a probar.
 * @return isInline verdadero si el arma solo se puede usar en línea, falso de lo contrario.
 */
function isInlineWeapon(integer|real weapon) => boolean;

/**
 * @brief Determina si un valor es una constante que representa un arma.
 *
 * isWeapon(WEAPON_LASER) = true;
 * isWeapon(CHIP_TELEPORTATION) = false.
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] value El número a determinar.
 * @return weapon verdadero si el valor es una constante de arma.
 */
function isWeapon(integer|real value) => boolean;

/**
 * @brief Usa el arma seleccionada en la entidad.
 *
 * @category weapon
 * @cost 3000 ops
 *
 * @param[in] entity Entidad objetivo.
 * @return result Los valores de retorno de useWeapon son: @ref USE_CRITICAL, en golpe crítico;
 *     @ref USE_SUCCESS, si tiene éxito; @ref USE_FAILED, en caso de falla; @ref USE_INVALID_TARGET, si
 *     el objetivo no existe; @ref USE_NOT_ENOUGH_TP, si su entidad no tiene suficiente TP;
 *     @ref USE_INVALID_POSITION, si el rango es malo o la línea de visión no es clara
 */
function useWeapon(integer|real entity) => integer;

/**
 * @brief Usa el arma seleccionada en la celda celda.
 *
 * @category weapon
 * @cost 3000 ops
 *
 * @param[in] cell Célula diana.
 * @return result Un valor mayor que 0 si se lanzó el ataque.
 */
function useWeaponOnCell(integer|real cell) => integer;

/**
 * @brief Devuelve si el arma arma necesita línea de visión para disparar.
 *
 * @category weapon
 * @cost 10 ops
 *
 * @param[in] weapon (opcional) El ID del arma a probar.
 * @return needLos verdadero si el arma arma necesita línea de visión para disparar, falso de lo
 *     contrario.
 */
function weaponNeedLos(integer|real weapon) => boolean;
function weaponNeedLos() => boolean;

// === chip ===

/**
 * @brief Determina si su entidad puede usar el chip chip en la entidad con id entidad.
