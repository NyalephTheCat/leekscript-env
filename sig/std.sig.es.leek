 * @return cells La matriz que contiene los ID de todas las celdas que se verán afectadas.
 */
function getChipEffectiveArea(integer|real chip, integer|real cell, integer|real from) => Array<integer>;
function getChipEffectiveArea(integer|real chip, integer|real cell) => Array<integer>;

/**
 * @brief Devuelve los efectos del chip chip.
 *
 * @category chip
 * @cost 125 ops
 *
 * @param[in] chip El chip cuyos efectos serán devueltos.
 * @return effects Los efectos del chip chip. Mismo valor de retorno que para la función
 *     @ref getWeaponEffects.
 */
function getChipEffects(integer|real chip) => Array<Array>;

/**
 * @brief Devuelve el porcentaje de riesgo de fallo del chip chip.
 *
 * @deprecated Esta función está obsoleta.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip El chip cuyo porcentaje de falla será devuelto.
 * @return failure chip porcentaje de falla del chip, un número entero entre 0 y 100.
 */
function getChipFailure(integer|real chip) => integer;

/**
 * @brief Devuelve el modo de lanzamiento del chip chip, entre las constantes LAUNCH_TYPE_*.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip La identificación del chip cuyo modo de lanzamiento será devuelto.
 * @return launchType El modo de lanzamiento del chip chip.
 */
function getChipLaunchType(integer|real chip) => integer;

/**
 * @brief Devuelve el rango máximo del chip chip.
 *
