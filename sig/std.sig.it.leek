 * @param[in] weapon L'id dell'arma di cui verrà restituita la gittata massima.
 * @return maxScope La portata massima dell'arma arma.
 */
function getWeaponMaxScope(integer|real weapon) => integer;

/**
 * @brief (No `func_getWeaponMaxUses` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon (opzionale)
 * @return maxUses
 */
function getWeaponMaxUses(integer weapon) => integer;
function getWeaponMaxUses() => integer;

/**
 * @brief Restituisce la gittata minima dell'arma arma.
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon L'id dell'arma la cui gittata minima verrà restituita.
 * @return minRange La portata minima dell'arma arma.
 */
function getWeaponMinRange(integer|real weapon) => integer;

/**
 * @brief Restituisce la gittata minima dell'arma arma.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref getWeaponMinRange.
 * @sa getWeaponMinRange
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon L'id dell'arma la cui gittata minima verrà restituita.
 * @return minScope La portata minima dell'arma arma.
 */
function getWeaponMinScope(integer|real weapon) => integer;

/**
 * @brief Restituisce il nome dell'arma arma.
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] weapon L'id dell'arma il cui nome verrà restituito.
 * @return name Il nome dell'arma dell'arma.
 */
function getWeaponName(integer|real weapon) => string;

/**
 * @brief Restituisce gli effetti passivi dell'arma arma.
 *
 * @category weapon
 * @cost 125 ops
 *
 * @param[in] weapon L'id dell'arma i cui effetti passivi verranno restituiti.
 * @return passiveEffects Un array contenente gli effetti dell'arma dell'arma. Ogni effetto è esso stesso un
 *     array della forma [tipo, minimo, massimo, turni, bersagli, modificatori]. Questi
 *     effetti sono gli stessi di quelli restituiti da @ref getWeaponEffects.
 */
function getWeaponPassiveEffects(integer|real weapon) => Array<Array>;

/**
 * @brief Determina se l'arma dell'arma può essere utilizzata solo online.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref getWeaponLaunchType.
 * @sa getWeaponLaunchType
 *
 * @category weapon
 * @cost 10 ops
 *
 * @param[in] weapon L'ID dell'arma da testare.
 * @return isInline true se l'arma può essere utilizzata solo online, false in caso contrario.
 */
function isInlineWeapon(integer|real weapon) => boolean;

/**
 * @brief Determina se un valore è una costante che rappresenta un'arma.
 *
 * isWeapon(WEAPON_LASER) = true;
 * isWeapon(CHIP_TELEPORTATION) = false.
 *
 * @category weapon
 * @cost 15 ops
 *
 * @param[in] value Il numero da determinare.
 * @return weapon true se il valore è una costante dell'arma.
 */
function isWeapon(integer|real value) => boolean;

/**
 * @brief Usa l'arma selezionata sull'entità entità.
 *
 * @category weapon
 * @cost 3000 ops
 *
 * @param[in] entity Entità di destinazione.
 * @return result I valori di ritorno di useWeapon sono: @ref USE_CRITICAL, in caso di colpo critico;
 *     @ref USE_SUCCESS, in caso di successo; @ref USE_FAILED, in caso di errore;
 *     @ref USE_INVALID_TARGET, se la destinazione non esiste; @ref USE_NOT_ENOUGH_TP, se la tua
 *     entità non ha abbastanza TP; @ref USE_INVALID_POSITION, se la portata è scarsa o la linea
 *     di vista non è chiara
 */
function useWeapon(integer|real entity) => integer;

/**
 * @brief Usa l'arma selezionata sulla cella cella.
 *
 * @category weapon
 * @cost 3000 ops
 *
 * @param[in] cell Cella di destinazione.
 * @return result Un valore maggiore di 0 se l'attacco è stato lanciato.
 */
function useWeaponOnCell(integer|real cell) => integer;

/**
 * @brief Restituisce se l'arma dell'arma necessita di linea di vista per sparare.
 *
 * @category weapon
 * @cost 10 ops
 *
 * @param[in] weapon (opzionale) L'ID dell'arma da testare.
 * @return needLos true se l'arma arma ha bisogno di una linea di vista per sparare, false altrimenti.
 */
function weaponNeedLos(integer|real weapon) => boolean;
function weaponNeedLos() => boolean;

// === chip ===

/**
 * @brief Determina se la tua entità può utilizzare il chip chip sull'entità con id entity.
 *
 * @category chip
 * @cost 45 ops
 *
 * @param[in] chip Il numero del chip da testare.
 * @param[in] entity L'ID entità su cui vuoi utilizzare il chip.
 * @return canUse true se la tua entità può utilizzare il chip, false in caso contrario.
 */
function canUseChip(integer|real chip, integer|real entity) => boolean;

/**
 * @brief Determina se la tua entità può utilizzare il chip chip sulla cella cell.
 *
 * @category chip
 * @cost 45 ops
 *
 * @param[in] chip Il numero del chip da testare.
 * @param[in] cell Il numero della cella su cui vuoi utilizzare il chip.
 * @return canUse true se la tua entità può utilizzare il chip, false in caso contrario.
 */
function canUseChipOnCell(integer|real chip, integer|real cell) => boolean;

/**
 * @brief Restituisce se il chip necessita di linea di vista per essere utilizzato.
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip L'id del chip da testare.
 * @return needLos true se il chip richiede l'uso della linea di vista, false in caso contrario.
 */
function chipNeedLos(integer|real chip) => boolean;

/**
 * @brief Restituisce l'elenco di tutte le fiche del gioco.
 *
 * @category chip
 * @cost 200 ops
 *
 * @return chips L'elenco di tutte le fiches nel gioco.
 */
function getAllChips() => Array<integer>;

/**
 * @brief Restituisce il tipo di area di effetto del chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Il chip di cui verrà restituito il tipo di zona.
 * @return area Il tipo di area del chip chip tra le costanti AREA_*: @ref AREA_POINT: singola area
 *     quadrata; @ref AREA_LASER_LINE: linea di un laser; @ref AREA_CIRCLE_1: area circolare di 3
 *     quadrati di diametro; @ref AREA_CIRCLE_2: area circolare di 5 quadrati di diametro;
 *     @ref AREA_CIRCLE_3: area circolare di 7 quadrati di diametro
 */
function getChipArea(integer|real chip) => integer;

/**
 * @brief Restituisce il tempo di recupero del chip chip, preso dal market.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Il chip il cui tempo di recupero verrà restituito.
 * @return cooldown Il tempo di recupero del chip.
 */
function getChipCooldown(integer|real chip) => integer;

/**
 * @brief Restituisce il costo in TP del chip chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Verrà restituito il chip quale costo.
 * @return cost Il costo del chip.
 */
function getChipCost(integer|real chip) => integer;

/**
 * @brief Restituisce l'elenco delle celle che saranno interessate se il chip chip viene utilizzato…
 *
 * sulla cella cell da una cella from.
 *
 * @category chip
 * @cost 78 ops
 *
 * @param[in] chip Il chip da testare.
 * @param[in] cell La cellula bersaglio.
 * @param[in] from (opzionale) La cella da cui viene utilizzato il chip.
 * @return cells L'array contenente gli ID di tutte le celle interessate.
 */
function getChipEffectiveArea(integer|real chip, integer|real cell, integer|real from) => Array<integer>;
function getChipEffectiveArea(integer|real chip, integer|real cell) => Array<integer>;

/**
 * @brief Restituisce gli effetti del chip chip.
 *
 * @category chip
 * @cost 125 ops
 *
 * @param[in] chip Il chip i cui effetti verranno restituiti.
 * @return effects Gli effetti del chip chip. Stesso valore di ritorno della funzione @ref getWeaponEffects.
 */
function getChipEffects(integer|real chip) => Array<Array>;

/**
 * @brief Restituisce la percentuale di rischio di guasto del chip chip.
 *
 * @deprecated Questa funzione è deprecata.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Il chip di cui verrà restituita la percentuale di errore.
 * @return failure chip percentuale di guasto del chip, un numero intero compreso tra 0 e 100.
 */
function getChipFailure(integer|real chip) => integer;

/**
 * @brief Restituisce la modalità di avvio del chip chip, tra le costanti LAUNCH_TYPE_*.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip L'id del chip di cui verrà restituita la modalità di lancio.
 * @return launchType La modalità di lancio del chip chip.
 */
function getChipLaunchType(integer|real chip) => integer;

/**
 * @brief Restituisce la portata massima del chip chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Il chip la cui portata massima verrà restituita.
 * @return maxRange La portata massima del chip.
 */
function getChipMaxRange(integer|real chip) => integer;

/**
 * @brief Restituisce la portata massima del chip chip.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref getChipMaxRange.
 * @sa getChipMaxRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Il chip la cui portata massima verrà restituita.
 * @return maxScope La portata massima del chip.
 */
function getChipMaxScope(integer|real chip) => integer;

/**
 * @brief (No `func_getChipMaxUses` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip
 * @return maxUses
 */
function getChipMaxUses(integer chip) => integer;

/**
 * @brief Restituisce l'intervallo minimo del chip chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Il chip il cui raggio minimo verrà restituito.
 * @return minRange L'intervallo minimo del chip.
 */
function getChipMinRange(integer|real chip) => integer;

/**
 * @brief Restituisce l'intervallo minimo del chip chip.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref getChipMinRange.
 * @sa getChipMinRange
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Il chip il cui raggio minimo verrà restituito.
 * @return minScope L'intervallo minimo del chip.
 */
function getChipMinScope(integer|real chip) => integer;

/**
 * @brief Restituisce il nome del chip chip.
 *
 * @category chip
 * @cost 15 ops
 *
 * @param[in] chip Il chip il cui nome verrà restituito.
 * @return name Il nome del chip chip.
 */
function getChipName(integer|real chip) => string;

/**
 * @brief Restituisce l'attuale cooldown chip dell'entità entity.
 *
 * @category chip
 * @cost 30 ops
 *
 * @param[in] chip Il chip il cui tempo di recupero attuale verrà restituito.
 * @param[in] entity (opzionale) L'entità il cui cooldown verrà restituito.
 * @return cooldown L'attuale cooldown del chip chip, questo è il numero di turni prima che il chip
 *     diventi utilizzabile, 0 se è attualmente utilizzabile.
 */
function getCooldown(integer|real chip, integer|real entity) => integer;
function getCooldown(integer|real chip) => integer;

/**
 * @brief Determina se un valore è una costante che rappresenta un chip.
 *
 * isChip(CHIP_RAGE) = true;
 * isChip(WEAPON_PISTOL) = false.
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] value Il numero da determinare.
 * @return chip true se il valore è una costante chip.
 */
function isChip(integer|real value) => boolean;

/**
 * @brief Determina se il chip può essere utilizzato solo online.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref getChipLaunchType.
 * @sa getChipLaunchType
 *
 * @category chip
 * @cost 10 ops
 *
 * @param[in] chip L'id del chip da testare.
 * @return isInline true se il chip è solo online, false altrimenti.
 */
function isInlineChip(integer|real chip) => boolean;

/**
 * @brief Utilizza il chip CHIP_RESURRECTION per resuscitare un'entità morta con id entity, sulla cella cell.
 *
 * @category chip
 * @cost 500 ops
 *
 * @param[in] entity L'id dell'entità da far rivivere.
 * @param[in] cell La cella in cui l'entità verrà rigenerata.
 * @return result Il risultato del lancio del chip, tra le costanti USE_*.
 */
function resurrect(integer|real entity, integer|real cell) => integer;

/**
 * @brief Invoca un'entità determinata dal chip chip sulla cella cell avente per IA la funzione ai.
 *
 * Un nome personalizzato può essere dato con il parametro opzionale name.
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip Il chip utilizzato per l'evocazione. Il chip deve essere di tipo Summon e deve essere
 *     equipaggiato sull'entità che utilizza la funzione Summon.
 * @param[in] cell Dovrebbe apparire la cella o l'evocazione.
 * @param[in] ai L'invocazione AI, come funzione.
 * @param[in] name (opzionale) Il nome personalizzato del bulbo (opzionale). Per impostazione predefinita, viene
 *     utilizzato il nome del tipo di bulbo.
 * @return return La funzione summon ha lo stesso ritorno della funzione @ref useChip.
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief Usa chip chip sull'entità entity.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip da usare.
 * @param[in] entity (opzionale) Entità di destinazione.
 * @return result I valori di ritorno di useChip sono: @ref USE_CRITICAL, in caso di colpo critico;
 *     @ref USE_SUCCESS, in caso di successo; @ref USE_FAILED, in caso di errore;
 *     @ref USE_INVALID_TARGET, se la destinazione non esiste; @ref USE_NOT_ENOUGH_TP, se la tua
 *     entità non ha abbastanza TP; @ref USE_INVALID_COOLDOWN, se il chip non è ancora
 *     utilizzabile; @ref USE_INVALID_POSITION, se la portata è scarsa o la linea di vista non è
 *     chiara
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief Usa chip chip sulla cella cell.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip da usare.
 * @param[in] cell Cella di destinazione.
 * @return result Un valore maggiore di 0 se l'attacco è stato lanciato.
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Restituisce il contenuto di una cella con id cella.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell L'id della cella il cui contenuto verrà restituito.
 * @return content Il contenuto della cella cell: @ref CELL_EMPTY per una cella vuota, @ref CELL_ENTITY per
 *     un'entità, @ref CELL_OBSTACLE per un ostacolo.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Restituisce la distanza tra due celle cell1 e cell2.
 *
 * La distanza restituita è espressa in numero di celle, e non tiene conto dei vari ostacoli
 * tra le due celle.
 * Per ottenere la distanza in linea d'aria, vedere @ref getDistance e per ottenere la distanza
 * del percorso tra le due celle evitando gli ostacoli, vedere @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 L'id della cella iniziale.
 * @param[in] cell2 L'id della cella di arrivo.
 * @return distance La distanza tra le due celle cell1 e cell2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Restituisce l'id della cella in posizione (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x La posizione x della cella.
 * @param[in] y La posizione y della cella.
 * @return cell L'id della cella alla posizione (x, y), null se la cella non esiste.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Determina la posizione in X della cella cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell La cella di cui verrà determinata la posizione in X.
 * @return x La posizione X della cella.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Determina la posizione Y della cella cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell La cella di cui verrà determinata la posizione in Y.
 * @return y La posizione Y della cella.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Calcola la distanza in linea d'aria tra due celle cell1 e cell2.
 *
 * Per ottenere la distanza in numero di celle, vedi @ref getCellDistance, e per ottenere la
 * lunghezza del percorso tra le due celle schivando i vari ostacoli, vedi @ref getPathLength.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 La cella di partenza.
 * @param[in] cell2 La cella di arrivo.
 * @return distance La distanza in linea d'aria tra le due celle.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Restituisce l'entità che si trova sulla cella cell.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell La cella di cui vogliamo recuperare l'entità.
 * @return entity L'id dell'entità nella cella o -1 se la cella non ha entità.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Restituisce l'entità che si trova sulla cella cella.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell La cella di cui vogliamo recuperare l'entità.
 * @return entity L'id dell'entità nella cella o -1 se la cella non ha entità.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Restituisce il tipo di terreno su cui si svolge il combattimento (fabbrica, deserto,…
 *
 * foresta ecc.), tra le costanti @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST,
 * @ref MAP_GLACIER e @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Il tipo di terreno.
 */
function getMapType() => integer;

/**
 * @brief Restituisce l'elenco degli spazi ostacolo nel terreno.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles L'array contenente gli ID delle celle dell'ostacolo.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Restituisce il percorso evitando gli ostacoli tra due celle cell1 e cell2, se esiste, ignorando le celle contenute nell'array ignoredCells.
 *
 * Se un giocatore si trova su una cella ignorata, il percorso può passarci sopra.
 * La cella iniziale cella1 non fa mai parte del percorso risultante. La cella cell2 fa parte
 * del percorso risultante se e solo se è vuota o ignorata da ignoredCells.
 * Se non esiste alcun percorso tra le due celle, getPath restituisce null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start La cella di partenza.
 * @param[in] end La cella di arrivo.
 * @param[in] ignoredCells (opzionale) Matrice di celle da ignorare.
 * @return path La matrice contenente le celle che compongono il percorso tra le due celle.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Restituisce la lunghezza del percorso tra due celle cell1 e cell2, evitando gli ostacoli, ignorando le celle contenute nell'array ignoredCells.
 *
 * Questa funzione equivale a count(getPath(cell1, cell2, ignoredCells))).
 * Se un giocatore si trova su una cella ignorata, il percorso può passarci sopra.
 * La cella iniziale cella1 non viene mai conteggiata nel risultato. La cella cell2 viene
 * conteggiata nel risultato se e solo se è vuota o ignorata da ignoredCells.
 * Se non esiste alcun percorso tra le due celle, getPathLength restituisce null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 La cella di partenza.
 * @param[in] cell2 La cella di arrivo.
 * @param[in] ignoredCells (opzionale) Matrice di celle da ignorare.
 * @return length La lunghezza del percorso tra cell1 e cell2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Determina se una cella è vuota.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La cella da testare.
 * @return empty true se la cella è vuota, false in caso contrario.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Determina se il contenuto della cella cell è un'entità.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell La cella da testare.
 * @return isEntity true se la cella contiene un'entità, false in caso contrario.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Determina se il contenuto della cella cell è un'entità.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La cella da testare.
 * @return isLeek true se la cella contiene un'entità, false in caso contrario.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Determina se il contenuto della cella cell è un ostacolo.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell La cella da testare.
 * @return isObstacle true se la cella contiene un ostacolo, false in caso contrario.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Determina se due celle cell1 e cell2 si trovano sulla stessa riga.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 La prima cella.
 * @param[in] cell2 La seconda cella.
 * @return sameLine true se le due celle sono sulla stessa riga, false altrimenti.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

// === fight ===

/**
 * @brief Restituisce una schiera di tutti i tuoi alleati vivi in combattimento.
 *
 * @category fight
 * @cost 100 ops
 *
 * @return allies Un array contenente gli ID di tutti i tuoi alleati viventi.
 */
function getAliveAllies() => Array<integer>;

/**
 * @brief (No `func_getAliveAlliesCount` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category fight
 * @cost 25 ops
 *
 * @return allies
 */
function getAliveAlliesCount() => integer;

/**
 * @brief Restituisce una serie di tutti i tuoi nemici vivi in combattimento.
 *
 * @category fight
 * @cost 100 ops
 *
 * @return enemies Un array contenente gli ID di tutti i tuoi nemici viventi.
 */
function getAliveEnemies() => Array<integer>;

/**
 * @brief Restituisce il numero di nemici vivi nel combattimento.
 *
 * @category fight
 * @cost 25 ops
 *
 * @return numAliveEnemies Il numero di nemici viventi.
 */
function getAliveEnemiesCount() => integer;

/**
 * @brief Restituisce l'elenco di tutti gli effetti nel gioco.
 *
 * @category fight
 * @cost 200 ops
 *
 * @return effects L'elenco di tutti gli effetti nel gioco.
 */
function getAllEffects() => Array<integer>;

/**
 * @brief Restituisce l'id della torretta della tua squadra o -1 se non esiste.
 *
 * @category fight
 * @cost 15 ops
 *
 * @return alliedTurret L'ID della torretta della tua squadra.
 */
function getAlliedTurret() => integer;

/**
