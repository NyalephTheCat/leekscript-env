// === utils ===

/**
 * @brief Cancella tutti i contrassegni fatti da mark() e markText() nel campo.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Copia il valore passato come parametro sui livelli level e restituisce la copia.
 *
 * Nel caso di un array, ad esempio, un clone(array, 1) copierà l'array ma non i suoi
 * elementi, un clone(array, 2) copierà l'array così come tutti gli elementi.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value Il valore da clonare
 * @param[in] level (opzionale) Il numero di livelli da clonare
 * @return copy Il valore clonato
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Registra un oggetto messaggio nel registro personale, disponibile nel rapporto al termine del combattimento.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Il messaggio da registrare.
 */
function debug(any object) => void;

/**
 * @brief Registra un oggetto messaggio nel log personale, disponibile nel report a fine combattimento, del colore color.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Il messaggio da registrare.
 * @param[in] color Il colore del messaggio. Puoi usare la funzione @ref getColor.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Registra un messaggio di errore dell'oggetto nel registro personale, disponibile nel…
 *
 * report al termine del combattimento.
 * I messaggi di errore vengono visualizzati in rosso nel report del combattimento.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Il messaggio di errore da registrare.
 */
function debugE(any object) => void;

/**
 * @brief Registra un messaggio di avviso oggetto nel registro personale, disponibile nel rapporto alla fine del combattimento.
 *
 * I messaggi di avviso appaiono in arancione nel rapporto di combattimento.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Il messaggio di avviso da registrare.
 */
function debugW(any object) => void;

/**
 * @brief Elimina il registro associato alla chiave key se esiste.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key La chiave di registro da eliminare.
 */
function deleteRegister(string key) => void;

/**
 * @brief Restituisce la data del combattimento, nel formato gg/MM/aaaa.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date La data del combattimento.
 */
function getDate() => string;

/**
 * @brief Restituisce il numero di istruzioni che la tua entità ha eseguito durante il turno corrente.
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Il numero di istruzioni che la tua entità ha eseguito durante il turno corrente.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Restituisce il limite di RAM utilizzabile della tua IA.
 *
 * La RAM viene consumata creando elenchi, tabelle e oggetti.
 * Il limite attuale è di 100 megabyte o 12.500.000 voci di elenco.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Restituisce il numero di operazioni consumate dalla tua entità dall'inizio del suo turno.
 *
 * Questo numero deve rimanere inferiore a @ref OPERATIONS_LIMIT in modo che l'entità non vada in
 * crash.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Numero di operazioni consumate dalla tua entità dall'inizio del suo turno.
 */
function getOperations() => integer;

/**
 * @brief Restituisce il valore memorizzato nel registro entità associato alla chiave key o null se il registro non esiste.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key La chiave di registro il cui valore verrà restituito.
 * @return value Il valore memorizzato nel registro key.
 */
function getRegister(string key) => string;

/**
 * @brief Restituisce l'insieme di registri di entità come un array associativo [chiave di registro:valore registro].
 *
 * Esempio: debug(getRegisters());
 * // Visualizza ad esempio:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers L'array associativo corrispondente a tutti i registri dell'entità.
 */
function getRegisters() => Array<string>;

/**
 * @brief Restituisce l'ora della battaglia, nel formato HH:mm:ss.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Il tempo della combattimento.
 */
function getTime() => string;

/**
 * @brief Restituisce il timestamp del combattimento, pari al numero di secondi dal 1 gennaio 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Il timestamp del combattimento.
 */
function getTimestamp() => integer;

/**
 * @brief Restituisce la quantità di RAM attualmente utilizzata dalla tua IA.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Includere l'IA con nome ai nell'IA corrente.
 *
 * Attenzione, la funzione include deve essere chiamata solo nel blocco principale e il suo
 * parametro deve essere una stringa scritta direttamente
 * nel codice. Per ulteriori informazioni, consulta la sezione del tutorial:
 * http://leekwars.com/help/tutorial#includes .
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Il nome dell'IA da includere.
 */
function include(string ai) => void;

/**
 * @brief Decodifica la stringa json nell'oggetto LeekScript (numero, stringa, array...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json La stringa JSON da decodificare.
 * @return object L'oggetto LeekScript decodificato.
 */
function jsonDecode(string json) => any;

/**
 * @brief Codifica l'oggetto object in una stringa JSON.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object L'oggetto da codificare in JSON.
 * @return json La stringa con codifica JSON.
 */
function jsonEncode(string object) => string;

/**
 * @brief Segna a terra una o più celle del colore indicato in parametro per il numero di giri indicato in parametro.
 *
 * Questa marcatura è visibile solo all'allevatore dell'entità.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells La cella o la matrice di più celle da contrassegnare
 * @param[in] color (opzionale) Colore della marcatura
 * @param[in] duration (opzionale) Durata della marcatura
 * @return success Restituisce vero se tutto è andato bene
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Scrive a terra un testo su una o più celle del colore indicato in parametro per il numero di giri indicato in parametro.
 *
 * Questi testi sono visibili solo all'allevatore dell'entità.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells La cella o l'array di più celle in cui scrivere
 * @param[in] text (opzionale) Il testo da scrivere (massimo 10 caratteri)
 * @param[in] color (opzionale) Colore del testo
 * @param[in] duration (opzionale) Durata del testo
 * @return success Restituisce vero se tutto è andato bene
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Mette in pausa il combattimento, solo per l'allevatore dell'entità che utilizza la funzione.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Memorizza il valore nel registro chiave.
 *
 * La chiave e il valore sono stringhe che devono contenere rispettivamente 100 e 5000
 * caratteri al massimo. Un porro può avere un massimo di 100 registri, la memorizzazione in
 * un nuovo registro non funzionerà se tutti i registri
 * sono già occupati.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key La chiave di registro in cui archiviare il valore.
 * @param[in] value Il valore da memorizzare.
 * @return success true se l'operazione è andata a buon fine, false in caso contrario.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Mostra ai giocatori una cella del colore colore sul campo per 1 turno.
 *
 * L'utilizzo di questa funzione costa 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell La cella da mostrare
 * @param[in] color (opzionale) Colore della marcatura
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Restituisce il tipo del valore value, tra i tipi: @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN,…
 *
 * @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Il valore di cui verrà restituito il tipo.
 * @return type Il tipo di valore.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Restituisce l'id dell'entità che crea il messaggio message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Il messaggio di cui verrà restituito l'autore.
 * @return entity L'id dell'entità che crea il messaggio message.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Restituisce l'array dei parametri del messaggio message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Il messaggio i cui parametri verranno restituiti.
 * @return params I parametri del messaggio message.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Restituisce il tipo di messaggio message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Il messaggio il cui tipo verrà restituito (tra @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK, ecc.).
 * @return type Il tipo di messaggio message.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Restituisce l'array del messaggio dell'entità entity.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (opzionale) L'entità i cui messaggi verranno restituiti.
 * @return messages La tabella dei tuoi messaggi. Un messaggio è esso stesso rappresentato sotto forma di
 *     a array della forma: [autore, tipo, parametri] I diversi tipi di messaggi sono
 *     rappresentati dalle costanti: @ref MESSAGE_HEAL: richiesta di assistenza; @ref MESSAGE_ATTACK:
 *     richiesta di attacco; @ref MESSAGE_BUFF_FORCE: richiesta potenziamento forzato; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Invia un messaggio a tutta la tua squadra.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Il tipo di messaggio da inviare (vedere le costanti MESSAGE_*).
 * @param[in] params I parametri del messaggio, che possono essere qualsiasi valore.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Invia un messaggio all'entità con id entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity L'id dell'entità a cui verrà inviato il messaggio.
 * @param[in] type Il tipo di messaggio da inviare (vedere le costanti MESSAGE_*).
 * @param[in] params I parametri del messaggio, che possono essere qualsiasi valore.
 * @return sent true se l'invio è andato a buon fine, false se si è verificato un errore.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Restituisce la quantità di blu nel colore color, compresa tra 0 e 255.
 *
 * Ad esempio, getBlue(@ref COLOR_BLUE) = 255 e getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Il colore di cui verrà restituito il tasso di blu.
 * @return blue Il tasso di blu nel colore color
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Restituisce l'intero corrispondente al colore (rosso, verde, blu) fornito come parametri.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Valore rosso compreso tra 0 e 255.
 * @param[in] green Valore verde compreso tra 0 e 255.
 * @param[in] blue Valore blu compreso tra 0 e 255.
 * @return color int corrispondente al colore fornito come parametro.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Restituisce la quantità di verde nel colore color, compresa tra 0 e 255.
 *
 * Ad esempio, getGreen(@ref COLOR_GREEN) = 255 e getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Il colore di cui verrà restituito il tasso verde.
 * @return green Il tasso di verde nel colore color
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Restituisce la quantità di rosso nel colore color, compresa tra 0 e 255.
 *
 * Ad esempio, getRed(@ref COLOR_RED) = 255 e getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Il colore di cui verrà restituito il tasso rosso.
 * @return red Il tasso di rosso in color
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Cancella il set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Cerca un elemento element nell'insieme set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Restituisce la differenza tra gli insiemi set1 e set2, ovvero tutti gli elementi di set1 che non si trovano in set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Calcola la disgiunzione esclusiva di due insiemi set1 e set2, nota come set1 ⊕ set2,…
 *
 * ovvero gli elementi presenti in set1 o set2, ma non in entrambi contemporaneamente.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Calcola l'intersezione di due insiemi set1 e set2, nota set1 ∩ set2, che sono gli elementi comuni dei due insiemi.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Restituisce se un set è vuoto o meno.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Determina se un insieme set1 è un sottoinsieme di set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Inserisce un elemento element nell'insieme set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Rimuove un elemento element dall'insieme set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Restituisce la dimensione dell'insieme set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Restituisce un elenco contenente tutti gli elementi dell'insieme set.
 *
 * L'ordine degli elementi è arbitrario.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Calcola l'unione di due insiemi set1 e set2, denotato set1 ∪ set2, che contiene tutti gli…
 *
 * elementi presenti in set1 o in set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Calcola la media degli intervalli.
 *
 * - Se l'intervallo è delimitato a destra e a sinistra, restituisce (intervalMin(i) +
 * intervalMax(i)) / 2. - Se l'intervallo è delimitato solo a sinistra, restituisce +∞. - Se
 * l'intervallo è limitato solo a destra, restituisce -∞. - Se l'intervallo non è delimitato
 * o è vuoto, restituisce NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Combina due intervalli interval1 e interval2.
 *
 * Equivale a union se la loro intersezione è non vuota, altrimenti include anche l'insieme
 * intermedio.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Calcola l'intersezione di due intervalli interval1 e interval2, contenente gli elementi comuni a entrambi.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Restituisce se l'intervallo interval è delimitato a sinistra e a destra oppure no.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief (No `func_intervalIsClosed` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Restituisce se l'interval è vuoto o meno.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Restituisce se l'intervallo interval è limitato a sinistra o meno.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief (No `func_intervalIsLeftClosed` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Restituisce se l'intervallo interval è delimitato a destra o meno.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief (No `func_intervalIsRightClosed` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Restituisce il limite superiore dell'intervallo interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Restituisce il limite inferiore dell'intervallo interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Restituisce la dimensione dell'intervallo interval.
 *
 * - Se l'intervallo è delimitato, restituisce max - min. - Se l'intervallo non è delimitato,
 * restituisce +∞. - Se l'intervallo è vuoto, restituisce 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Restituisce un elenco contenente gli elementi dell'intervallo interval con una distanza step tra ciascuno di essi.
 *
 * Se l'intervallo è negativo, prende gli elementi in ordine inverso.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (opzionale)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
