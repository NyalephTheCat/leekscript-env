// === weapon ===

/**
 * @brief Determina se la tua entità può sparare all'entità con id entità con l'arma arma.
 *
 * @category weapon
 * @cost 45 ops
 *
 * @param[in] weapon (opzionale) L'arma da testare. L'impostazione predefinita è l'arma attualmente equipaggiata.
 * @param[in] entity L'id dell'entità su cui vuoi attivare.
 * @return canUse true se la tua entità può attivarsi, false in caso contrario.
 */
function canUseWeapon(integer|real weapon, integer|real entity) => boolean;

/**
 * @brief Determina se la tua entità può sparare alla cellula cell con l'arma arma.
 *
 * @category weapon
 * @cost 45 ops
 *
 * @param[in] weapon (opzionale) L'arma da testare. L'impostazione predefinita è l'arma attualmente equipaggiata.
 * @param[in] cell Il numero della cella che vuoi sparare.
 * @return canUse true se la tua entità può attivarsi, false in caso contrario.
 */
function canUseWeaponOnCell(integer|real weapon, integer|real cell) => boolean;

