// --- Functions ---

// === math ===

/**
 * @brief Restituisce il valore assoluto del numero number.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Il numero di cui verrà calcolato il valore assoluto.
 * @return result Il valore assoluto del numero.
 */
function abs(integer|real number) => integer;

/**
 * @brief Calcola l'arcoseno di argomento, nell'intervallo [0, @ref PI].
 *
 * @category math
 * @cost 12 ops
 *
 * @param[in] argument Numero di cui verrà calcolato l'arcoseno.
 * @return result L'arcocoseno dell'argomento.
 */
function acos(integer|real argument) => real;

/**
 * @brief Calcola l'arcoseno di argomento, nell'intervallo [0, @ref PI].
 *
 * @category math
 * @cost 12 ops
 *
 * @param[in] argument Numero di cui verrà calcolato l'arcoseno.
 * @return result L'arcoseno dell'argomento.
 */
function asin(integer|real argument) => real;

/**
 * @brief Calcola l'arcotangente di argomento, nell'intervallo [0, @ref PI].
 *
 * @category math
 * @cost 25 ops
 *
 * @param[in] argument Numero di cui verrà calcolato l'arcotangente.
 * @return result L'arcotangente dell'argomento.
 */
function atan(integer|real argument) => real;

/**
 * @brief Converte le coordinate cartesiane (x, y) in coordinate polari (r, theta).
 *
 * Questa funzione restituisce l'angolo theta tra -@ref PI e @ref PI utilizzando i segni degli
 * argomenti.
 *
 * @category math
 * @cost 35 ops
 *
 * @param[in] y Coordinata y.
 * @param[in] x Coordinata x.
 * @return result L'angolo theta in coordinate polari del punto (x, y).
 */
function atan2(integer|real y, integer|real x) => real;

/**
 * @brief Restituisce una stringa di caratteri contenente il numero x in formato binario.
 *
 * @category math
 * @cost 10 ops
 *
 * @param[in] x
 * @return string
 */
function binString(integer x) => string;

/**
 * @brief Restituisce il numero di bit a 1 nel numero x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return bits
 */
function bitCount(integer x) => integer;

/**
 * @brief Inverte tutti i bit del numero x da sinistra a destra.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return reversed
 */
function bitReverse(integer x) => integer;

/**
 * @brief Converte i bit di un numero intero in un numero in virgola mobile.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return real
 */
function bitsToReal(integer x) => real;

/**
 * @brief Inverte i byte (8 bit) di un numero x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return reversed
 */
function byteReverse(integer x) => integer;

/**
 * @brief Calcola la radice cubica di numero
 *
 * @category math
 * @cost 62 ops
 *
 * @param[in] number Numero di cui vogliamo calcolare la radice cubica.
 * @return result Radice cubica di numero.
 */
function cbrt(integer|real number) => real;

/**
 * @brief Restituisce l'arrotondamento di numero.
 *
 * Puoi trovare l'arrotondamento per difetto con @ref floor e l'arrotondamento con @ref round.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Numero per il quale vogliamo trovare l'arrotondamento superiore.
 * @return result Arrotonda per eccesso il numero.
 */
function ceil(integer|real number) => integer;

/**
 * @brief Calcola il coseno dell'angolo.
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle Numero di cui verrà calcolato il coseno (in radianti).
 * @return cosine Il coseno dell'angolo, nell'intervallo [-1, 1].
 */
function cos(integer|real angle) => real;

/**
 * @brief Eleva il numero di Eulero @ref E alla potenza di numero.
 *
 * @category math
 * @cost 40 ops
 *
 * @param[in] number L'esponente a cui sarà elevato @ref E.
 * @return result @ref E** numero.
 */
function exp(integer|real number) => real;

/**
 * @brief Calcola l'arrotondamento per difetto di numero.
 *
 * Puoi trovare l'arrotondamento per eccesso con @ref ceil e l'arrotondamento con @ref round.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Numero di cui vogliamo trovare l'arrotondamento per difetto.
 * @return result Arrotondato per difetto a numero.
 */
function floor(integer|real number) => integer;

/**
 * @brief Restituisce una stringa di caratteri contenente il numero x in formato esadecimale.
 *
 * @category math
 * @cost 10 ops
 *
 * @param[in] x
 * @return string
 */
function hexString(integer x) => string;

/**
 * @brief Restituisce l'ipotenusa del triangolo rettangolo di lati x e y.
 *
 * Equivalente a sqrt(x**2 + y**2).
 *
 * @category math
 * @cost 187 ops
 *
 * @param[in] x Il valore x.
 * @param[in] y Il valore y.
 * @return hypotenuse sqrt(x**2 + y**2).
 */
function hypot(integer|real x, integer|real y) => real;

/**
 * @brief Restituisce vero se il numero x è finito, falso in caso contrario.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return finite
 */
function isFinite(real x) => boolean;

/**
 * @brief Restituisce true se il numero x è infinito, false in caso contrario.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return infinite
 */
function isInfinite(real x) => boolean;

/**
 * @brief Restituisce *true* se il numero x è un valore NaN (Not a Number) nella sua…
 *
 * rappresentazione float, *false* in caso contrario.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return nan
 */
function isNaN(real x) => boolean;

/**
 * @brief Restituisce *vero* se i numeri x e y sono permutazioni nella loro rappresentazione decimale, *falso* in caso contrario.
 *
 * @category math
 * @cost 50 ops
 *
 * @param[in] x
 * @param[in] y
 * @return permutation
 */
function isPermutation(integer x, integer y) => boolean;

/**
 * @brief Restituisce il numero di bit a 0 all'inizio del numero x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return zeros
 */
function leadingZeros(integer x) => integer;

/**
 * @brief Calcola il logaritmo naturale del numero number.
 *
 * @category math
 * @cost 39 ops
 *
 * @param[in] number Un numero compreso nell'intervallo ]0; +∞[.
 * @return log Il logaritmo naturale del numero.
 */
function log(integer|real number) => real;

/**
 * @brief Calcola il logaritmo in base 10 del numero number.
 *
 * @category math
 * @cost 23 ops
 *
 * @param[in] number Un numero compreso nell'intervallo ]0; +∞[.
 * @return log10 Il logaritmo in base 10 del numero.
 */
function log10(integer|real number) => real;

/**
 * @brief Calcola il logaritmo in base 2 del numero number.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] number Un numero compreso nell'intervallo ]0; +∞[.
 * @return log2 Il logaritmo in base 2 del numero.
 */
function log2(integer|real number) => real;

/**
 * @brief Restituisce il valore maggiore tra i due numeri a e b.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] a Un numero.
 * @param[in] b Un numero.
 * @return max Il numero maggiore tra a e b.
 */
function max(integer|real a, integer|real b) => integer|real;

/**
 * @brief Restituisce il valore più piccolo tra i due numeri a e b.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] a Un numero.
 * @param[in] b Un numero.
 * @return min Il numero più piccolo tra a e b.
 */
function min(integer|real a, integer|real b) => integer|real;

/**
 * @brief Converte un valore in un numero.
 *
 * Se il valore è una stringa, la funzione numerica proverà a convertirlo in un numero, se il
 * valore è già un numero, la funzione restituisce il numero e, per qualsiasi altro tipo,
 * restituisce null.
 *
 * @category math
 * @cost 20 ops
 *
 * @param[in] value Il valore da convertire in un numero.
 * @return number Il numero convertito.
 */
function number(any value) => real;

/**
 * @brief Eleva il numero di base alla potenza dell'esponente.
 *
 * @category math
 * @cost 140 ops
 *
 * @param[in] base La base.
 * @param[in] exp L'espositore.
 * @return result base elevata alla potenza esponente.
 */
function pow(integer|real base, integer|real exp) => real;

/**
 * @brief Restituisce un numero casuale reale, compreso tra 0 (incluso) e 1 (escluso).
 *
 * @category math
 * @cost 30 ops
 *
 * @return number Un numero casuale nell'intervallo [0; 1[.
 */
function rand() => real;

/**
 * @brief Restituisce un numero casuale reale, compreso tra a (incluso) e b (escluso).
 *
 * @deprecated Questa funzione è deprecata. È sostituito da @ref randReal.
 * @sa randReal
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a Limite inferiore.
 * @param[in] b Limite superiore.
 * @return number Un numero casuale nell'intervallo [a; B[.
 */
function randFloat(integer|real a, integer|real b) => integer;

/**
 * @brief Restituisce un numero intero casuale compreso tra a (incluso) e b (escluso).
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a Limite inferiore.
 * @param[in] b Limite superiore.
 * @return number Un numero intero casuale nell'intervallo [a; B[.
 */
function randInt(integer|real a, integer|real b) => integer;

/**
 * @brief Restituisce un numero casuale reale, compreso tra a (incluso) e b (escluso).
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] a
 * @param[in] b
 * @return number
 */
function randReal(real a, real b) => real;

/**
 * @brief Restituisce i bit grezzi del numero x in un numero intero.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return bits
 */
function realBits(real x) => integer;

/**
 * @brief Restituisce un nuovo numero con i bit di x spostati di s da sinistra (reimposta i bit da destra).
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @param[in] s
 * @return rotated
 */
function rotateLeft(integer x, integer s) => integer;

/**
 * @brief Restituisce un nuovo numero con i bit di x spostati di s a destra (reimposta i bit a sinistra).
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @param[in] s
 * @return rotated
 */
function rotateRight(integer x, integer s) => integer;

/**
 * @brief Restituisce l'arrotondamento di numero.
 *
 * Puoi trovare l'arrotondamento per difetto con @ref floor e l'arrotondamento per eccesso con
 * @ref ceil.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Numero di cui vogliamo trovare l'arrotondamento.
 * @return number Arrotondato per numero.
 */
function round(integer|real number) => integer;

/**
 * @brief Determina il segno del numero number.
 *
 * @category math
 * @cost 2 ops
 *
 * @param[in] number Il numero di cui verrà determinato il segno.
 * @return sign 1 se il numero è positivo, 0 se il numero è zero e -1 se il numero è negativo.
 */
function signum(integer|real number) => integer;

/**
 * @brief Calcola il seno dell'angolo angle passato come parametro
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle L'angolo di cui verrà calcolato il seno
 * @return sine Restituisce il seno dell'angolo angle
 */
function sin(integer|real angle) => real;

/**
 * @brief Calcola la radice quadrata del numero number.
 *
 * @category math
 * @cost 8 ops
 *
 * @param[in] number Numero di cui verrà calcolata la radice.
 * @return root Radice quadrata di numero.
 */
function sqrt(integer|real number) => real;

/**
 * @brief Calcola la tangente dell'angolo angle (in radianti).
 *
 * @category math
 * @cost 30 ops
 *
 * @param[in] angle Angolo in radianti.
 * @return tangent Tangente dell'angolo.
 */
function tan(integer|real angle) => real;

/**
 * @brief Converte l'angolo radianti in gradi.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] radians Valore in radianti
 * @return degrees Angolo in gradi.
 */
function toDegrees(integer|real radians) => real;

/**
 * @brief Converte l'angolo gradi in radianti.
 *
 * @category math
 * @cost 31 ops
 *
 * @param[in] degrees Valore in gradi
 * @return radians Angolo in radianti.
 */
function toRadians(integer|real degrees) => real;

/**
 * @brief Restituisce il numero di bit a 0 alla fine del numero x.
 *
 * @category math
 * @cost 1 op
 *
 * @param[in] x
 * @return zeros
 */
function trailingZeros(integer x) => integer;

// === string ===

/**
 * @brief Restituisce il carattere della stringa stringa che si trova nella posizione posizione.
 *
 * Il primo carattere della stringa è nella posizione 0.
 *
 * @category string
 * @cost 8 ops
 *
 * @param[in] string Stringa da cui vogliamo recuperare un carattere.
 * @param[in] position Posizione del carattere da trovare.
 * @return char stringa contenente il carattere ricercato o una stringa vuota se la posizione non è
 *     valida.
 */
function charAt(string string, integer|real position) => string;

/**
 * @brief Restituisce il punto di codice unicode (32 bit, numero intero) situato nella posizione…
 *
 * indice (o 0 per impostazione predefinita) nella stringa stringa.
 * *Esempio*: codePointAt('hi', 1) // 97 (carattere 'a')
 *
 * @category string
 * @cost 5 ops
 *
 * @param[in] string
 * @param[in] index (opzionale)
 * @return codePoint
 */
function codePointAt(string string, integer index) => integer;
function codePointAt(string string) => integer;

/**
 * @brief Determina se una stringa search si trova all'interno di una stringa string.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Stringa in cui verrà eseguita la ricerca.
 * @param[in] search Stringa da cercare.
 * @return contains true se search è in string, false in caso contrario.
 */
function contains(string string, string search) => boolean;

/**
 * @brief Determina se una stringa termina con una stringa suffisso.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Stringa in cui verrà eseguita la ricerca
 * @param[in] suffix Suffisso per cercare
 * @return endsWith vero se stringa termina con suffisso
 */
function endsWith(string string, string suffix) => boolean;

/**
 * @brief Determina la posizione della prima occorrenza della stringa search nella stringa string, a…
 *
 * partire dalla posizione start.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string La stringa in cui verrà eseguita la ricerca.
 * @param[in] search La stringa da cercare.
 * @param[in] start (opzionale) La posizione iniziale della ricerca.
 * @return index La posizione della prima occorrenza di search in string da start, -1 se la stringa non
 *     è stata trovata.
 */
function indexOf(string string, string search, integer|real start) => integer;
function indexOf(string string, string search) => integer;

/**
 * @brief Restituisce la lunghezza di stringa.
 *
 * @category string
 * @cost 15 ops
 *
 * @param[in] string La stringa di cui verrà restituita la lunghezza.
 * @return length La lunghezza di stringa.
 */
function length(string string) => integer;

/**
 * @brief Sostituisce tutte le occorrenze di search con replace nella stringa string.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Stringa in cui vengono effettuate le sostituzioni.
 * @param[in] search Sottostringa da sostituire.
 * @param[in] replace Corda di ricambio.
 * @return string La stringa del risultato, con sostituzioni.
 */
function replace(string string, string search, string replace) => string;

/**
 * @brief Divide la stringa stringa in sottostringhe delimitate da delimitatore.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Catena di taglio.
 * @param[in] delimiter Stringa che delimita il passaggio da un elemento all'altro.
 * @param[in] limit (opzionale) Numero massimo di elementi dell'array.
 * @return parts Matrice contenente le sottostringhe trovate.
 */
function split(string string, string delimiter, integer|real limit) => Array<string>;
function split(string string, string delimiter) => Array<string>;

/**
 * @brief Controlla se stringa inizia con prefisso.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Stringa di ricerca.
 * @param[in] prefix Prefisso cercato.
 * @return startsWith Vero se la stringa inizia con prefisso.
 */
function startsWith(string string, string prefix) => boolean;

/**
 * @brief Converte un valore in una stringa.
 *
 * Se il valore è già una stringa, viene restituito.
 * Se il valore è il numero x, viene restituito "x".
 * Se il valore è un array, viene restituita una stringa nel formato "[key1: value1, key2:
 * value2, ...]".
 * Se il valore è un booleano, "true" e "false" vengono restituiti rispettivamente per true e
 * false.
 * Se il valore è null, viene restituito "null".
 *
 * @category string
 * @cost 8 ops
 *
 * @param[in] value Il valore da convertire in una stringa di caratteri.
 * @return string La stringa convertita.
 */
function string(any value) => string;

/**
 * @brief Restituisce la sottostringa della stringa stringa a partire dal carattere all'indice inizio e di dimensione lunghezza.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Catena di taglio.
 * @param[in] start Indice dei caratteri iniziali.
 * @param[in] length (opzionale) Lunghezza della sottostringa.
 * @return string Sottostringa.
 */
function substring(string string, integer|real start, integer|real length) => string;
function substring(string string, integer|real start) => string;

/**
 * @brief Converte i caratteri maiuscoli in stringa in minuscoli.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Stringa da trasformare
 * @return string Stringa minuscola
 */
function toLower(string string) => string;

/**
 * @brief Converte i caratteri minuscoli in stringa in maiuscoli.
 *
 * @category string
 * @cost O(n)
 *
 * @param[in] string Stringa da trasformare.
 * @return string Stringa maiuscola.
 */
function toUpper(string string) => string;

// === array ===

/**
 * @brief Questa funzione è disponibile da LeekScript 4 e versioni successive.
 *
 * Divide l'elenco array in sottoelenchi di dimensioni massime chunkSize e restituisce
 * l'elenco di questi sottoelenchi. L'ultimo sottoelenco può contenere meno di chunkSize
 * elementi.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] chunkSize (opzionale)
 * @return chunks
 */
function arrayChunk(Array array, integer chunkSize) => Array<Array>;
function arrayChunk(Array array) => Array<Array>;

/**
 * @brief Svuota l'elenco array di tutti i suoi elementi.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array
 */
function arrayClear(Array array) => void;

/**
 * @brief Aggiungi i due array uno dopo l'altro.
 *
 * Le chiavi di testo vengono mantenute e tutte le chiavi numeriche vengono reindicizzate.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array1 Primo tavolo.
 * @param[in] array2 Secondo tavolo.
 * @return newArray Somma dei due array.
 */
function arrayConcat(Array array1, Array array2) => Array;

/**
 * @brief Restituisce "true" se il predicato callback applicato a ciascun elemento nell'elenco restituisce "true".
 *
 * *Esempi*: arrayEvery([1, 2, 3, 4, 5], x => x > 0) // vero arrayEvery([1, 2, 3, 4, 5], x =>
 * x % 2 == 0) // falso
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] callback
 * @return every
 */
function arrayEvery(Array array, Function callback) => boolean;

/**
 * @brief Restituisce un nuovo array contenente tutte le coppie chiave/valore dell'array di origine per il quale la funzione di callback ha restituito true.
 *
 * Se la funzione di callback accetta un parametro, verrà inviato il valore dell'array di
 * origine, se accetta due parametri, verranno inviati la chiave e il valore.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tavola originale.
 * @param[in] callback Funzione chiamata per ogni elemento.
 * @return newArray Nuovo tavolo.
 */
function arrayFilter(Array array, Function callback) => Array;

/**
 * @brief Restituisce un nuovo array contenente tutti gli elementi dell'array di origine.
 *
 * Tutti gli elementi contenuti in un sottoarray vengono estratti nel nuovo array.L'argomento
 * depth determina la profondità massima del sottoarray da estrarre.
 * var array = [1, 2, [[3, 4], 5], [6]];
 * debug(arrayFlatten(array, 1)); // [1,2,[3,4],5,6]
 *
 * @category array
 * @cost ∞
 *
 * @param[in] array Tavola originale.
 * @param[in] depth (opzionale) Profondità massima.
 * @return newArray Nuovo tavolo.
 */
function arrayFlatten(Array array, integer|real depth) => Array;
function arrayFlatten(Array array) => Array;

/**
 * @brief Ridurre l'array array [v1, v2, ..., vn] da sinistra partendo dal valore v0 e applicando la funzione f.
 *
 * Equivale :
 * f(f(f(v0, v1), v2), ...)
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tavola originale.
 * @param[in] f Funzione da applicare.
 * @param[in] v0 Valore iniziale.
 * @return result Tavolo ridotto.
 */
function arrayFoldLeft(Array array, Function f, any v0) => any;

/**
 * @brief Ridurre l'array array [v1, v2, ..., vn] da destra partendo dal valore v0 e applicando la funzione f.
 *
 * Equivale :
 * f(v1, f(v2, ..., f(vn, v0)))
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tavola originale.
 * @param[in] f Funzione da applicare.
 * @param[in] v0 Valore iniziale.
 * @return result Tavolo ridotto.
 */
function arrayFoldRight(Array array, Function f, any v0) => any;

/**
 * @brief Restituisce una tabella associando ad ogni elemento univoco della lista array la sua quantità (elemento => quantità).
 *
 * *Esempio* : ``leekscript var lista = [1, 1, 2, 2, 2, 2, 3, 4, 4] var frequenze =
 * arrayFrequencies(lista) debug(frequenze) // [1:2, 2:4, 3:1, 4:2] ``
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @return frequencies
 */
function arrayFrequencies(Array array) => Map<any, Integer>;

/**
 * @brief Restituisce l'elemento dell'elenco array alla posizione index.
 *
 * Se l'indice non è nell'elenco, restituire defaultValue.
 *
 * @category array
 * @cost 1 op
 *
 * @param[in] array
 * @param[in] index
 * @param[in] defaultValue (opzionale)
 * @return element
 */
function arrayGet(Array array, integer index, any defaultValue) => any;
function arrayGet(Array array, integer index) => any;

/**
 * @brief Chiama la funzione di callback per ogni elemento dell'array.
 *
 * Se la funzione di callback accetta un parametro, verrà inviato il valore dell'array di
 * origine, se accetta due parametri, verranno inviati la chiave e il valore.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tavola originale.
 * @param[in] callback Funzione chiamata per ogni elemento.
 */
function arrayIter(Array array, Function callback) => void;

/**
 * @brief Restituisce un nuovo array contenente per ogni chiave dell'array di origine, il valore restituito dalla funzione di callback.
 *
 * Se la funzione di callback accetta un parametro, verrà inviato il valore dell'array di
 * origine, se accetta due parametri, verranno inviati la chiave e il valore.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tavola originale.
 * @param[in] callback Funzione chiamata per ogni elemento.
 * @return newArray Nuovo tavolo.
 */
function arrayMap(Array array, Function callback) => Array;

/**
 * @brief Restituisce l'elemento di valore massimo dell'array array.
 *
 * Per maggiori informazioni sul valore massimo di un array vedi @ref sort.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array in cui verrà ricercato il valore massimo.
 * @return element Articolo di valore massimo.
 */
function arrayMax(Array array) => any;

/**
 * @brief Restituisce l'elemento di valore minimo dell'array array.
 *
 * Per maggiori informazioni sul valore minimo di un array vedi @ref sort.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array in cui verrà ricercato il valore minimo.
 * @return element Articolo di valore minimo.
 */
function arrayMin(Array array) => any;

/**
 * @brief Restituisce un nuovo array contenente due liste, nella prima ci sono tutte le coppie chiave/valore per le quali la funzione di callback ha restituito true, nella seconda ci sono tutte le altre.
 *
 * Se la funzione di callback accetta un parametro, verrà inviato il valore dell'array di
 * origine, se accetta due parametri, verranno inviati la chiave e il valore.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tavola originale.
 * @param[in] callback Funzione chiamata per ogni elemento.
 * @return newArray Nuovo tavolo.
 */
function arrayPartition(Array array, Function callback) => Array<Array>;

/**
 * @brief Restituisce un elenco di elementi count casuali dall'elenco array, senza duplicati.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] count
 * @return random
 */
function arrayRandom(Array array, integer count) => Array;

/**
 * @brief Rimuove tutti gli elementi uguali a elemento nell'elenco array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] element
 */
function arrayRemoveAll(Array array, any element) => void;

/**
 * @brief Restituisce un sottoelenco di array contenente tutti gli elementi dalla posizione inizio alla posizione fine (esclusa).
 *
 * Se viene passato il parametro di incremento stride, la funzione seleziona un solo elemento
 * ogni stride.
 * *Esempio*: nuovo elenco contenente elementi dalla posizione 10 alla 20 (escluso). ``
 * arraySlice(lista, 10, 20) ``
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] start
 * @param[in] end (opzionale)
 * @param[in] stride (opzionale)
 * @return slice
 */
function arraySlice(Array array, any start, any end, integer stride) => Array;
function arraySlice(Array array, any start, any end) => Array;
function arraySlice(Array array, any start) => Array;

/**
 * @brief Restituisce true se il predicato callback applicato ad almeno uno degli elementi della lista restituisce true
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @param[in] callback
 * @return some
 */
function arraySome(Array array, Function callback) => boolean;

/**
 * @brief Ordina la matrice in base all'ordine definito dalla funzione di callback.
 *
 * Gli elementi vengono confrontati a due a due, la funzione di callback deve restituire i
 * valori -1, 0 o 1 a seconda che il primo valore sia prima, allo stesso livello o dopo il
 * secondo valore. Se la funzione di callback prende 2 parametri vengono inviati i due
 * valori, se ne prende 4 vengono inviate le coppie chiave/valore.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Tavola originale
 * @param[in] callback (opzionale) Funzione di ordinamento.
 * @return sortedArray L'array ordinato
 */
function arraySort(Array array, Function callback) => Array;
function arraySort(Array array) => Array;

/**
 * @brief (No `func_arrayToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array
 * @return set
 */
function arrayToSet(Array array) => Set;

/**
 * @brief Restituisce un elenco contenente tutti gli elementi dell'elenco array eliminando i duplicati.
 *
 * @category array
 * @cost O(n²)
 *
 * @param[in] array
 * @return unique
 */
function arrayUnique(Array array) => Array;

/**
 * @brief Ordina l'array array preservando l'associazione chiave:valore secondo l'ordine order.
 *
 * @deprecated Questa funzione è deprecata.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Matrice da ordinare.
 * @param[in] order (opzionale) L'ordinamento: @ref SORT_ASC o @ref SORT_DESC.
 */
function assocSort(Array array, integer|real order) => void;
function assocSort(Array array) => void;

/**
 * @brief Calcola la media degli elementi contenuti nell'array array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array di cui vogliamo calcolare la media.
 * @return averageValue Valore medio.
 */
function average(Array<integer|real> array) => real;

/**
 * @brief Conta il numero di elementi nell'array array.
 *
 * @category array
 * @cost 1 op
 *
 * @param[in] array Array di cui verrà conteggiato il numero di elementi.
 * @return numberOfElements Numero di elementi dell'array.
 */
function count(Array array) => integer;

/**
 * @brief Ridimensiona l'array array a size e riempie tutte le sue caselle con value.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array La tabella da completare.
 * @param[in] value Il valore per ogni quadrato nell'array.
 * @param[in] size (opzionale) Il numero di scatole. Per impostazione predefinita, la dimensione dell'array corrente.
 */
function fill(Array array, any value, integer|real size) => void;
function fill(Array array, any value) => void;

/**
 * @brief Determina se l'elemento element si trova nell'array array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array La tabella di ricerca.
 * @param[in] element L'elemento da cercare.
 * @return inArray true se l'elemento è nell'array, false altrimenti.
 */
function inArray(Array array, any element) => boolean;

/**
 * @brief Inserisce un elemento element nell'array alla posizione position.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array La matrice in cui verrà inserito l'elemento.
 * @param[in] element L'elemento da inserire.
 * @param[in] position La posizione dell'inserimento.
 */
function insert(Array array, any element, integer|real position) => void;

/**
 * @brief Determina se l'array array è vuoto.
 *
 * Equivalente a count(array) == 0.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array La matrice da testare.
 * @return empty true se l'array è vuoto, false in caso contrario.
 */
function isEmpty(Array array) => boolean;

/**
 * @brief Unisce più elementi in una stringa, separandoli con un delimitatore glue.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Un array di elementi da unire.
 * @param[in] glue Il delimitatore dell'elemento.
 * @return string La stringa risultante dell'unione.
 */
function join(Array array, string glue) => string;

/**
 * @brief Ordina l'array per chiavi in ordine.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Matrice da ordinare.
 * @param[in] order (opzionale) L'ordinamento: @ref SORT_ASC o @ref SORT_DESC.
 */
function keySort(Array array, integer|real order) => void;
function keySort(Array array) => void;

/**
 * @brief Rimuove l'ultima cella dall'array array e restituisce l'elemento corrispondente.
 *
 * @category array
 * @cost 5 ops
 *
 * @param[in] array L'array la cui ultima casella verrà eliminata.
 * @return element L'oggetto che era nella vecchia ultima scatola.
 */
function pop(Array array) => any;

/**
 * @brief Aggiunge l'elemento element alla fine dell'array.
 *
 * @category array
 * @cost 2 ops
 *
 * @param[in] array L'array in cui vogliamo aggiungere l'elemento.
 * @param[in] element L'elemento da aggiungere.
 */
function push(Array array, any element) => void;

/**
 * @brief Accoda tutti gli elementi dell'array elements alla fine dell'array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array L'array in cui vogliamo aggiungere gli elementi.
 * @param[in] elements Elementi da aggiungere.
 */
function pushAll(Array array, Array elements) => void;

/**
 * @brief Rimuove un elemento dall'array array nella posizione position e restituisce l'elemento eliminato.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array da cui vogliamo eliminare un elemento.
 * @param[in] position Posizione dell'elemento da eliminare.
 * @return element L'elemento rimosso dalla matrice.
 */
function remove(Array array, integer|real position) => any;

/**
 * @brief Elimina la prima occorrenza di un elemento nell'array.
 *
 * Se l'elemento non viene trovato, l'array non viene modificato.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Array da cui vogliamo eliminare un elemento.
 * @param[in] element Elemento da trovare e quindi eliminare.
 */
function removeElement(Array array, any element) => void;

/**
 * @brief Elimina un elemento dall'array array associato alla chiave key.
 *
 * @category array
 * @cost 5 ops
 *
 * @param[in] array Array da cui vogliamo eliminare un elemento.
 * @param[in] key La chiave associata all'elemento da eliminare.
 */
function removeKey(Array array, any key) => void;

/**
 * @brief Inverte l'array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tavolo da invertire.
 */
function reverse(Array array) => void;

/**
 * @brief Trova l'elemento element nell'array array, a partire dalla posizione start.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array La tabella di ricerca.
 * @param[in] element L'elemento da cercare.
 * @param[in] start (opzionale) La posizione dell'inizio della ricerca.
 * @return pos La posizione della prima occorrenza dell'elemento element nell'array, a partire da
 *     start, null se l'elemento non è stato trovato.
 */
function search(Array array, any element, integer|real start) => integer;
function search(Array array, any element) => integer;

/**
 * @brief Rimuove la prima cella dall'array e restituisce l'elemento corrispondente.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array La matrice la cui prima cella verrà eliminata.
 * @return element L'elemento che era nella vecchia prima cella.
 */
function shift(Array array) => any;

/**
 * @brief Mescola una scacchiera in modo casuale.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Il tabellone casuale.
 */
function shuffle(Array array) => void;

/**
 * @brief Ordina l'array in ordine crescente o decrescente.
 *
 * L'ordine crescente predefinito è:
 * Tutti booleani (prima falso poi vero); Tutti i numeri (ordinati dal più piccolo al più
 * grande); Tutti i canali (in ordine alfabetico); Tutti gli elementi nulli.
 *
 * @category array
 * @cost O(nlog(n))
 *
 * @param[in] array Matrice da ordinare.
 * @param[in] order (opzionale) @ref SORT_ASC per ordinare l'array in ordine crescente o @ref SORT_DESC per ordinarlo in
 *     ordine decrescente.
 */
function sort(Array array, integer|real order) => void;
function sort(Array array) => void;

/**
 * @brief Restituisce un sottoarray di array che inizia alla posizione start e termina alla posizione end.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tabella delle fonti.
 * @param[in] start Indice di partenza.
 * @param[in] end Fine indice.
 * @return array Sottoarray.
 */
function subArray(Array array, integer|real start, integer|real end) => Array;

/**
 * @brief Restituisce la somma di tutti gli elementi numerici nell'array array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Tabella per sommare.
 * @return sum Somma degli elementi dell'array.
 */
function sum(Array<integer|real> array) => real;

/**
 * @brief Aggiunge l'elemento element all'inizio dell'array.
 *
 * @category array
 * @cost O(n)
 *
 * @param[in] array Matrice in cui verrà aggiunto l'elemento.
 * @param[in] element Articolo da aggiungere.
 */
function unshift(Array array, any element) => void;

// === map ===

/**
 * @brief Restituisce la media di tutti i valori nella tabella map.
 *
 * Se la tabella è vuota, restituisce "0.0".
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return average
 */
function mapAverage(Map map) => real;

/**
 * @brief Svuota la tabella map di tutti i suoi elementi.
 *
 * @category map
 * @cost 1 op
 *
 * @param[in] map
 */
function mapClear(Map map) => void;

/**
 * @brief Restituisce true se la tabella map contiene il valore value, false in caso contrario.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] value
 * @return contains
 */
function mapContains(Map map, any value) => boolean;

/**
 * @brief Restituisce true se la tabella map contiene la chiave key, false in caso contrario.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map
 * @param[in] key
 * @return contains
 */
function mapContainsKey(Map map, any key) => boolean;

/**
 * @brief Restituisce true se il predicato callback applicato a ciascun elemento della tabella map…
 *
 * restituisce true, false in caso contrario.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return every
 */
function mapEvery(Map map, Function callback) => boolean;

/**
 * @brief Sostituisce tutti i valori nella tabella map con il valore value.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] value
 */
function mapFill(Map map, any value) => void;

/**
 * @brief Restituisce una nuova tabella contenente tutti i valori della tabella di origine map per…
 *
 * la quale il predicato callback applicato ha restituito *true*.
 * La funzione callback accetta gli argomenti *(valore, chiave, tabella)* in questo ordine.
 * *Esempio* : ``leekscript var map = [1: '1', 2: '2', 3: '3'] var result = mapFilter(map,
 * function(value, key, map) { return key % 2 == 1 }) // [1: '1', 3: '3'] ``
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return filtered
 */
function mapFilter(Map map, Function callback) => Map;

/**
 * @brief Riduce la tabella map partendo dal valore v e applicando la funzione f per ogni elemento.
 *
 * L'ordine degli elementi è indeterminato.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] f
 * @param[in] v
 * @return result
 */
function mapFold(Map map, Function f, any v) => any;

/**
 * @brief Restituisce il valore della tabella map associata alla chiave key o default se la chiave non esiste nella tabella.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map
 * @param[in] key
 * @param[in] default (opzionale)
 * @return element
 */
function mapGet(Map map, any key, any default) => any;
function mapGet(Map map, any key) => any;

/**
 * @brief Questa funzione è disponibile da LeekScript 4 e versioni successive.
 *
 * Restituisce true se la tabella è vuota, false se ne contiene almeno una (chiave, valore).
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map
 * @return isEmpty
 */
function mapIsEmpty(Map map) => boolean;

/**
 * @brief Applica la funzione callback su tutti i valori della tabella map.
 *
 * La funzione callback prende gli argomenti: *value*, *key*, *table* in questo ordine.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 */
function mapIter(Map map, Function callback) => void;

/**
 * @brief Restituisce un elenco contenente tutte le chiavi della tabella map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return keys
 */
function mapKeys(Map map) => Array;

/**
 * @brief Restituisce una nuova tabella contenente i valori restituiti dalla funzione callback…
 *
 * applicata a ogni elemento della tabella map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return newMap
 */
function mapMap(Map map, Function callback) => Map;

/**
 * @brief Restituisce il valore massimo della tabella map.
 *
 * Se la tabella è vuota, restituisce null.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return max
 */
function mapMax(Map map) => real;

/**
 * @brief Restituisce una tabella contenente tutti i valori delle tabelle map1 e map2.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map1
 * @param[in] map2
 * @return merged
 */
function mapMerge(Map map1, Map map2) => Map;

/**
 * @brief Restituisce il valore minimo della tabella map.
 *
 * Se la tabella è vuota, restituisce null.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return min
 */
function mapMin(Map map) => real;

/**
 * @brief Aggiunge o sostituisce il valore associato alla chiave key con il valore value nella tabella map.
 *
 * @category map
 * @cost 3 ops
 *
 * @param[in] map
 * @param[in] key
 * @param[in] value
 * @return value
 */
function mapPut(Map map, any key, any value) => any;

/**
 * @brief Aggiunge o sostituisce tutti i valori dalla tabella elements alla tabella map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] elements
 */
function mapPutAll(Map map, Map elements) => void;

/**
 * @brief Elimina la key dalla tabella map.
 *
 * @category map
 * @cost 2 ops
 *
 * @param[in] map
 * @param[in] key
 * @return element
 */
function mapRemove(Map map, any key) => any;

/**
 * @brief Rimuove tutti i valori uguali a value nella tabella map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] value
 */
function mapRemoveAll(Map map, any value) => void;

/**
 * @brief Sostituisce il valore associato alla chiave key con il valore value nella tabella map solo…
 *
 * se un valore è già associato a key.
 *
 * @category map
 * @cost 3 ops
 *
 * @param[in] map
 * @param[in] key
 * @param[in] value
 * @return value
 */
function mapReplace(Map map, any key, any value) => any;

/**
 * @brief Sostituisce tutti i valori nella tabella map1 con i valori della tabella map2 solo se il…
 *
 * valore è già associato a una chiave.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map1
 * @param[in] map2
 */
function mapReplaceAll(Map map1, Map map2) => void;

/**
 * @brief Restituisce la chiave associata a un value nella tabella map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] value
 * @return key
 */
function mapSearch(Map map, any value) => real;

/**
 * @brief Restituisce il numero di voci nella tabella map.
 *
 * @category map
 * @cost 1 op
 *
 * @param[in] map
 * @return size
 */
function mapSize(Map map) => integer;

/**
 * @brief Restituisce true se il predicato callback applicato ad almeno un elemento della tabella…
 *
 * map restituisce true, false in caso contrario.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @param[in] callback
 * @return some
 */
function mapSome(Map map, Function callback) => boolean;

/**
 * @brief Restituisce la somma di tutti i valori nella tabella map.
 *
 * Se la tabella è vuota, restituisce 0.0.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return sum
 */
function mapSum(Map map) => real;

/**
 * @brief Restituisce un elenco contenente tutti i valori della tabella map.
 *
 * @category map
 * @cost O(n)
 *
 * @param[in] map
 * @return values
 */
function mapValues(Map map) => Array;

