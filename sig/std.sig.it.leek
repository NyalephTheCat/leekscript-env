 * @return turn Il turno di combattimento in cui è apparsa l'entità.
 */
function getBirthTurn(integer|real entity) => integer;
function getBirthTurn() => integer;

/**
 * @brief (No `func_getBulbType` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (opzionale)
 * @return bulbType
 */
function getBulbType(integer|real entity) => integer;
function getBulbType() => integer;

/**
 * @brief Restituisce la cella in cui si trova l'entità con id entity.
 *
 * Usa getCell() senza parametri per recuperare la tua cella.
 *
 * @category leek
 * @cost 5 ops
 *
 * @param[in] entity (opzionale) L'id dell'entità la cui cella verrà restituita.
 * @return cell Il numero di cella in cui si trova l'entità.
 */
function getCell(integer|real entity) => integer;
function getCell() => integer;

/**
 * @brief Restituisce i punti elenco dell'entità con id entity.
 *
 * @category leek
 * @cost 40 ops
 *
 * @param[in] entity (opzionale) L'id dell'entità di cui verranno restituiti i punti elenco.
 * @return chips Un array contenente gli ID dei punti elenco dell'entità entity.
 */
function getChips(integer|real entity) => Array<integer>;
function getChips() => Array<integer>;

/**
 * @brief Restituisce il numero di core dell'entità con id entity.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (opzionale) L'entità di cui verrà restituito il numero di core.
 * @return cores Il numero di core dell'entità entità.
 */
function getCores(integer|real entity) => integer;
function getCores() => integer;

/**
