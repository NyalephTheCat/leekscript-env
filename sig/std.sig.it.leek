/**
 * @brief Determina se un'entità è attiva.
 *
 * Equivalente a getLife(entità) > 0.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity L'id dell'entità da testare.
 * @return alive true se entità è viva, false se morta.
 */
function isAlive(integer|real entity) => boolean;

/**
 * @brief Determina se entità è il tuo alleato.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity L'id dell'entità da testare.
 * @return isAlly vero se l'entità è un tuo alleato o te stesso, falso se è un nemico.
 */
function isAlly(integer|real entity) => boolean;

/**
 * @brief Determina se entità è morta.
 *
 * Equivalente a getLife(entità) == 0.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity L'id dell'entità da testare.
 * @return dead true se entità è morta, false se viva.
 */
function isDead(integer|real entity) => boolean;

/**
 * @brief Determina se entità è il tuo nemico.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity L'id dell'entità da testare.
 * @return isEnemy vero se l'entità è un nemico, falso se è un alleato o te stesso.
 */
function isEnemy(integer|real entity) => boolean;

/**
 * @brief Restituisce se l'entità entity è statica o meno.
 *
 * Un'entità statica non può spostarsi o essere spostata.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (opzionale) L'id dell'entità da testare.
 * @return static true se entity è statico, false in caso contrario.
 */
function isStatic(integer|real entity) => boolean;
function isStatic() => boolean;

/**
 * @brief Restituisce se entità è un'invocazione o meno.
 *
 * @category leek
