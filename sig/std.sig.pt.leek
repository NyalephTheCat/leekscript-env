 */
function getEnemies() => Array<integer>;

/**
 * @brief Retorna o número de inimigos na luta.
 *
 * @category fight
 * @cost 25 ops
 *
 * @return numEnemies O número de inimigos.
 */
function getEnemiesCount() => integer;

/**
 * @brief Calcula a soma dos pontos de vida de todas as entidades inimigas.
 *
 * @category fight
 * @cost 50 ops
 *
 * @return life A soma dos pontos de vida do time inimigo.
 */
function getEnemiesLife() => integer;

/**
 * @brief Retorna o id da torre inimiga ou -1 se não existir.
 *
 * @category fight
 * @cost 15 ops
 *
 * @return enemyTurret A ID da torre inimiga.
 */
function getEnemyTurret() => integer;

/**
 * @brief Determina o aliado mais distante de sua entidade, como o corvo voa.
 *
 * @category fight
 * @cost 31 ops
 *
 * @return farthestAlly O id da entidade amiga mais distante.
 */
function getFarthestAlly() => integer;

/**
 * @brief Determina o inimigo mais distante de sua entidade, como o corvo voa.
 *
 * @category fight
 * @cost 31 ops
 *
 * @return farthestEnemy O id da entidade inimiga mais distante.
 */
function getFarthestEnemy() => integer;

/**
 * @brief (No `func_getFightBoss` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category fight
 * @cost 10 ops
 *
 * @return boss
 */
function getFightBoss() => integer;

/**
 * @brief Retorna o contexto da luta atual.
 *
 * @category fight
 * @cost 10 ops
 *
 * @return context Dependendo do contexto da batalha: Batalha de Teste (@ref FIGHT_CONTEXT_TEST), Batalha de
 *     Arena (@ref FIGHT_CONTEXT_GARDEN), Batalha de Torneio (@ref FIGHT_CONTEXT_TOURNAMENT), Batalha
 *     de Desafio (@ref FIGHT_CONTEXT_CHALLENGE), Batalha Real (@ref FIGHT_CONTEXT_BATTLE_ROYALE)
 */
function getFightContext() => integer;

/**
 * @brief Retorna o ID da luta atual.
 *
 * @category fight
 * @cost 5 ops
 *
 * @return id O id da luta atual.
 */
function getFightID() => integer;

/**
 * @brief Retorna o tipo de combate atual.
 *
 * @category fight
 * @cost 10 ops
 *
 * @return fightType Dependendo do tipo de luta: luta solo (@ref FIGHT_TYPE_SOLO), luta de fazendeiro
 *     (@ref FIGHT_TYPE_FARMER), luta de equipe (@ref FIGHT_TYPE_TEAM), Battle Royale
 *     (@ref FIGHT_TYPE_BATTLE_ROYALE)
 */
function getFightType() => integer;

/**
 * @brief Retorna a entidade amiga mais próxima da sua entidade.
 *
 * @category fight
 * @cost 25 ops
 *
 * @return nearestAlly O id da entidade amiga mais próxima.
 */
function getNearestAlly() => integer;

/**
 * @brief Retorna a entidade aliada mais próxima da entidade fornecida como parâmetro.
 *
 * @category fight
 * @cost 35 ops
 *
 * @param[in] entity O id da entidade cujo aliado mais próximo queremos saber.
 * @return ally O id da entidade amiga mais próxima.
 */
function getNearestAllyTo(integer|real entity) => integer;

/**
 * @brief Retorna a entidade aliada mais próxima da célula fornecida como parâmetro.
 *
 * @category fight
 * @cost 35 ops
 *
