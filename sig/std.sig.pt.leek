 */
function getCellsToUseChipOnCell(integer|real chip, integer|real cell, Array<integer> ignoredCells) => Array<integer>;
function getCellsToUseChipOnCell(integer|real chip, integer|real cell) => Array<integer>;

/**
 * @brief Retorna a lista de células a partir das quais sua entidade poderá usar a arma weapon na entidade entity.
 *
