 * @param[in] mp (opcional) O número máximo de MP a ser usado. Por padrão, sem limite.
 * @return mp O número de pontos de movimento usados.
 */
function moveTowardLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveTowardLine(integer|real cell1, integer|real cell2) => integer;

// === utils ===

/**
 * @brief Limpa todas as marcações feitas por mark() e markText() no campo.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Copia o valor passado como parâmetro nos níveis nível e retorna a cópia.
 *
 * No caso de uma matriz, por exemplo, um clone(array, 1) copiará a matriz, mas não seus
 * elementos, um clone(array, 2) copiará a matriz e todos os elementos.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value O valor para clonar
 * @param[in] level (opcional) O número de níveis para clonar
 * @return copy O valor clonado
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Registra uma mensagem de objeto no log pessoal, disponível no relatório ao final da luta.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object A mensagem a ser gravada.
 */
function debug(any object) => void;

/**
 * @brief Registra uma mensagem de objeto no log pessoal, disponível no relatório ao final da luta, da cor cor.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object A mensagem a ser gravada.
 * @param[in] color A cor da mensagem. Você pode usar a função @ref getColor.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Registra uma mensagem de erro de objeto no log pessoal, disponível no relatório ao final da luta.
 *
 * As mensagens de erro aparecem em vermelho no relatório de luta.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object A mensagem de erro a ser registrada.
 */
function debugE(any object) => void;

/**
 * @brief Registra uma mensagem de alerta de objeto no log pessoal, disponível no relatório ao final da luta.
 *
 * Mensagens de advertência aparecem em laranja no relatório de combate.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object A mensagem de aviso a ser gravada.
 */
function debugW(any object) => void;

/**
 * @brief Exclui o registro associado à chave chave, se existir.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key A chave de registro a ser excluída.
 */
function deleteRegister(string key) => void;

/**
 * @brief Retorna a data da luta, no formato dd/MM/aaaa.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date A data da luta.
 */
function getDate() => string;

/**
 * @brief Retorna o número de instruções que sua entidade executou durante o turno atual.
 *
 * @deprecated Esta função está obsoleta. É substituído por @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions O número de instruções que sua entidade executou durante o turno atual.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Retorna o limite de RAM utilizável do seu AI.
 *
 * A RAM é consumida pela criação de listas, tabelas e objetos.
 * O limite atual é de 100 megabytes ou 12.500.000 itens de lista.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Retorna o número de operações consumidas por sua entidade desde o início de seu turno.
 *
 * Este número deve permanecer menor que @ref OPERATIONS_LIMIT para que a entidade não falhe.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Número de operações consumidas por sua entidade desde o início de seu turno.
 */
function getOperations() => integer;

/**
 * @brief Retorna o valor armazenado no registro da entidade associada à chave key ou nulo se o registro não existir.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key A chave de registro cujo valor será retornado.
 * @return value O valor armazenado no registro chave.
 */
function getRegister(string key) => string;

/**
 * @brief Retorna o conjunto de registros de entidade como uma matriz associativa [chave de registro:valor de registro].
 *
 * Exemplo: debug(getRegisters());
 * // Mostra por exemplo:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers A matriz associativa correspondente a todos os registradores da entidade.
 */
function getRegisters() => Array<string>;

/**
 * @brief Retorna o tempo de batalha, no formato HH:mm:ss.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time A hora da luta.
 */
function getTime() => string;

/**
 * @brief Retorna o timestamp da luta, igual ao número de segundos desde 1º de janeiro de 1970.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp O timestamp da luta.
 */
function getTimestamp() => integer;

/**
 * @brief Retorna a quantidade de RAM usada atualmente pelo seu AI.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Inclua a IA chamada ai na IA atual.
 *
 * Atenção, a função include deve ser chamada somente no bloco principal, e seu parâmetro
 * deve ser uma string escrita diretamente
 * no código. Para obter mais informações, consulte a seção no tutorial:
 * http://leekwars.com/help/tutorial#includes .
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai O nome da IA a incluir.
 */
function include(string ai) => void;

/**
 * @brief Decodifica string json para objeto LeekScript (número, string, array...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json A string JSON a ser decodificada.
 * @return object O objeto LeekScript decodificado.
 */
function jsonDecode(string json) => any;

/**
 * @brief Codifica o objeto objeto em uma string JSON.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object O objeto a ser codificado em JSON.
 * @return json A string codificada em JSON.
 */
function jsonEncode(string object) => string;

/**
 * @brief Marca uma ou mais células da cor indicada no parâmetro no terreno para o número de voltas indicado no parâmetro.
 *
 * Esta marcação só é visível ao criador da entidade.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells A célula ou matriz de várias células para marcar
 * @param[in] color (opcional) Cor de marcação
 * @param[in] duration (opcional) Duração da marcação
 * @return success Retorna verdadeiro se tudo correu bem
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Escreve um texto em uma ou mais células da cor indicada em parâmetro no chão para o número de voltas indicado em parâmetro.
 *
 * Esses textos são visíveis apenas para o criador da entidade.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells A célula ou matriz de várias células para gravar
 * @param[in] text (opcional) O texto a escrever (máximo 10 caracteres)
 * @param[in] color (opcional) Cor do texto
 * @param[in] duration (opcional) Duração do texto
 * @return success Retorna verdadeiro se tudo correu bem
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Pausa a luta, apenas para o criador da entidade que está usando a função.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Armazena o valor no registro chave.
 *
 * A chave e o valor são strings que devem conter respectivamente 100 e 5000 caracteres no
 * máximo. Um alho-poró pode ter no máximo 100 registros, armazenar em um novo registro não
 * funcionará se todos os registros
 * já estão ocupados.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key A chave do registro onde armazenar o valor.
 * @param[in] value O valor a ser armazenado.
 * @return success true se a operação foi bem-sucedida, false caso contrário.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Mostra aos jogadores uma célula da cor cor no campo por 1 turno.
 *
 * O uso desse recurso custa 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell A célula para mostrar
 * @param[in] color (opcional) Cor de marcação
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Retorna o tipo do valor value, dentre os tipos: @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN,…
 *
 * @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value O valor cujo tipo será retornado.
 * @return type O tipo de valor.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Retorna o id da entidade que criou a mensagem mensagem.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message A mensagem cujo autor será retornado.
 * @return entity O id da entidade que cria a mensagem mensagem.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Retorna o array de parâmetros de mensagem message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message A mensagem cujos parâmetros serão retornados.
 * @return params Os parâmetros da mensagem mensagem.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Retorna o tipo de mensagem mensagem.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message A mensagem cujo tipo será retornado (entre @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK, etc.).
 * @return type O tipo de mensagem mensagem.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Retorna a matriz de mensagens da entidade entity.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (opcional) A entidade cujas mensagens serão retornadas.
 * @return messages A tabela de suas mensagens. Uma mensagem é representada na forma de um array do
 *     formulário: [autor, tipo, parâmetros] Os diferentes tipos de mensagens são
 *     representados pelas constantes: @ref MESSAGE_HEAL: solicitação de atendimento;
 *     @ref MESSAGE_ATTACK: pedido de ataque; @ref MESSAGE_BUFF_FORCE: forçar solicitação de reforço;
 *     ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Envie uma mensagem para toda a sua equipe.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type O tipo de mensagem a ser enviada (consulte as constantes MESSAGE_*).
 * @param[in] params Os parâmetros da mensagem, que podem ser qualquer valor.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Envia uma mensagem para a entidade com id entidade.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity O id da entidade para a qual a mensagem será enviada.
 * @param[in] type O tipo de mensagem a ser enviada (consulte as constantes MESSAGE_*).
 * @param[in] params Os parâmetros da mensagem, que podem ser qualquer valor.
 * @return sent true se o envio foi bem-sucedido, false se ocorreu um erro.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Retorna a quantidade de azul na cor color, entre 0 e 255.
 *
 * Por exemplo, getBlue(@ref COLOR_BLUE) = 255 e getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color A cor cuja taxa azul será retornada.
 * @return blue A taxa de azul na cor color
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Retorna o número inteiro correspondente à cor (vermelho, verde, azul) fornecida como parâmetro.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Valor vermelho entre 0 e 255.
 * @param[in] green Valor verde entre 0 e 255.
 * @param[in] blue Valor azul entre 0 e 255.
 * @return color int correspondente à cor fornecida como parâmetro.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Retorna a quantidade de verde na cor cor, entre 0 e 255.
 *
 * Por exemplo, getGreen(@ref COLOR_GREEN) = 255 e getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color A cor cuja taxa verde será retornada.
 * @return green A taxa de verde na cor color
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Retorna a quantidade de vermelho na cor color, entre 0 e 255.
 *
 * Por exemplo, getRed(@ref COLOR_RED) = 255 e getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color A cor cuja taxa vermelha será retornada.
 * @return red A taxa de vermelho na cor color
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Limpa o conjunto.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Procura um elemento element no conjunto set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Devolve a diferença entre os conjuntos set1 e set2, ou seja, todos os elementos do set1 que não estão no set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Calcula a disjunção exclusiva de dois conjuntos conjunto1 e conjunto2, notado conjunto1 ⊕…
 *
 * conjunto2, que são os elementos presentes em conjunto1 ou conjunto2, mas não em ambos ao
 * mesmo tempo.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Calcula a intersecção de dois conjuntos conjunto1 e conjunto2, notado conjunto1 ∩…
 *
 * conjunto2, que são os elementos comuns dos dois conjuntos.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Retorna se um conjunto está vazio ou não.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Determina se um conjunto set1 é um subconjunto de set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Insere um elemento element no conjunto set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Remove um elemento element do conjunto set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Devolve o tamanho do conjunto set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Devolve uma lista contendo todos os elementos do conjunto set.
 *
 * A ordem dos elementos é arbitrária.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Calcula a união de dois conjuntos set1 e set2, denotado set1 ∪ set2, que contém todos os…
 *
 * elementos presentes em set1 ou em set2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Calcula a média do intervalo.
 *
 * - Se o intervalo for limitado à esquerda e à direita, retorna (intervalMin(i) +
 * intervalMax(i)) / 2. - Se o intervalo for limitado apenas à esquerda, retorna +∞. - Se o
 * intervalo for limitado apenas à direita, retorna -∞. - Se o intervalo não for limitado ou
 * for vazio, retorna NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Combina dois intervalos intervalo1 e intervalo2.
 *
 * Equivalente a união se a sua intersecção não for vazia, caso contrário inclui também o
 * conjunto entre eles.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Calcula a intersecção de dois intervalos intervalo1 e intervalo2, contendo os elementos comuns a ambos.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Devolve se o intervalo intervalo é limitado à esquerda e à direita ou não.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Retorna se o intervalo intervalo é fechado à esquerda e à direita ou não.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Retorna se o intervalo está vazio ou não.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Devolve se o intervalo intervalo é limitado à esquerda ou não.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Devolve se o intervalo está ou não fechado à esquerda.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Devolve se o intervalo intervalo é limitado à direita ou não.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Retorna se o intervalo intervalo é fechado à direita ou não.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Devolve o limite superior do intervalo intervalo.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Devolve o limite inferior do intervalo intervalo.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Retorna o tamanho do intervalo intervalo.
 *
 * - Se o intervalo for limitado, retorna max - min. - Se o intervalo não for limitado,
 * retorna +∞. - Se o intervalo for vazio, retorna 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Retorna uma lista contendo os elementos do intervalo intervalo com um passo entre cada um.
 *
 * Se o intervalo for negativo, pega nos elementos pela ordem inversa.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (opcional)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
