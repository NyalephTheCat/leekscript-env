 * @return mp O número de pontos de movimento usados.
 */
function moveTowardCells(Array<integer> cells, integer|real mp) => integer;
function moveTowardCells(Array<integer> cells) => integer;

/**
 * @brief Aproxima sua entidade de um conjunto de entidades, usando o máximo de mp pontos de movimento.
