 */
function getWeaponTargets(integer|real weapon, integer|real cell) => Array<integer>;

/**
 * @brief Verifica a linha de visão entre a célula inicial e a célula final, ignorando as entidades ignoredEntities.
 *
 * @category fight
 * @cost 31 ops
 *
 * @param[in] start Célula inicial.
 * @param[in] end Célula Alvo.
 * @param[in] entityToIgnore (opcional) Uma entidade ou lista de entidades a serem ignoradas.
 * @return los Retorna true se a linha de visão estiver limpa.
 */
function lineOfSight(integer|real start, integer|real end, integer|real entityToIgnore) => boolean;
function lineOfSight(integer|real start, integer|real end) => boolean;

/**
 * @brief Afasta sua entidade de outra entidade, usando o máximo de mp pontos de movimento.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entity A entidade da qual sua entidade deve se afastar.
 * @param[in] mp (opcional) O número máximo de MP a ser usado. Por padrão, sem limite.
 * @return mp O número de pontos de movimento usados.
 */
function moveAwayFrom(integer|real entity, integer|real mp) => integer;
function moveAwayFrom(integer|real entity) => integer;

/**
 * @brief Move sua entidade para uma célula de distância, usando até mp pontos de movimento.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell A célula da qual sua entidade deve se afastar.
