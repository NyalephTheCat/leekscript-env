 */
function getChipTargets(integer|real chip, integer|real cell) => Array<integer>;

/**
 * @brief Retorna entidades amigas mortas.
 *
 * @category fight
 * @cost 100 ops
 *
 * @return deadAllies A tabela de entidades mortas aliadas.
 */
function getDeadAllies() => Array<integer>;

/**
 * @brief Retorna entidades inimigas mortas.
 *
 * @category fight
 * @cost 100 ops
 *
 * @return deadEnemies A tabela de entidades inimigas mortas.
 */
function getDeadEnemies() => Array<integer>;

/**
 * @brief Retorna o número de inimigos que morreram em combate.
 *
 * @category fight
 * @cost 25 ops
 *
 * @return numDeadEnemies O número de inimigos mortos.
 */
function getDeadEnemiesCount() => integer;

/**
 * @brief Retorna as entidades inimigas (vivas ou mortas) para o combate.
 *
 * @category fight
 * @cost 100 ops
 *
