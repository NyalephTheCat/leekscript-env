 * @return ally O id da entidade amiga mais próxima.
 */
function getNearestAllyToCell(integer|real cell) => integer;

/**
 * @brief Retorna a entidade inimiga mais próxima da sua entidade.
 *
 * @category fight
 * @cost 25 ops
 *
 * @return nearestEnemy O id da entidade inimiga mais próxima.
 */
function getNearestEnemy() => integer;

/**
 * @brief Retorna a entidade inimiga mais próxima da entidade fornecida como parâmetro.
 *
 * @category fight
 * @cost 35 ops
 *
 * @param[in] entity O id da entidade cujo inimigo mais próximo queremos conhecer.
 * @return enemy O id da entidade inimiga mais próxima.
 */
function getNearestEnemyTo(integer|real entity) => integer;

/**
 * @brief Retorna a entidade inimiga mais próxima da célula fornecida como parâmetro.
 *
 * @category fight
 * @cost 35 ops
 *
 * @param[in] cell O id da célula cujo inimigo mais próximo queremos conhecer.
 * @return enemy O id da entidade inimiga mais próxima.
 */
function getNearestEnemyToCell(integer|real cell) => integer;

/**
 * @brief Retorna o id da entidade que jogará após o jogador atual.
