 * @return cells Lista de células a partir das quais a arma pode ser usada.
 */
function getCellsToUseWeapon(integer|real weapon, integer|real entity, Array<integer> ignoredCells) => Array<integer>;
function getCellsToUseWeapon(integer|real weapon, integer|real entity) => Array<integer>;

/**
 * @brief Retorna a lista de células a partir das quais sua entidade poderá usar a arma weapon em uma célula cell.
 *
 * @category fight
 * @cost 25834 ops
 *
 * @param[in] weapon (opcional) A arma para testar. O padrão é sua arma atualmente equipada.
 * @param[in] cell A célula alvo.
 * @param[in] ignoredCells (opcional) Matriz de células a serem ignoradas. Por padrão, uma matriz vazia.
 * @return cell Lista de células a partir das quais a arma pode ser usada.
 */
function getCellsToUseWeaponOnCell(integer|real weapon, integer|real cell, Array<integer> ignoredCells) => Array<integer>;
function getCellsToUseWeaponOnCell(integer|real weapon, integer|real cell) => Array<integer>;

/**
 * @brief Retorna as entidades que serão afetadas se o chip chip for usado na célula cell.
