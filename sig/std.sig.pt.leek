function moveAwayFromEntities(Array<integer> entities) => integer;

/**
 * @brief Move sua entidade para longe de um conjunto de entidades, usando o máximo de mp pontos de movimento.
 *
 * @deprecated Esta função está obsoleta. É substituído por @ref moveAwayFromEntities.
 * @sa moveAwayFromEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities A matriz que contém os IDs das entidades das quais sua entidade deve se afastar.
 * @param[in] mp (opcional) O número máximo de MP a ser usado. Por padrão, sem limite.
 * @return mp O número de pontos de movimento usados.
 */
function moveAwayFromLeeks(Array<integer|real> entities, integer|real mp) => integer;
function moveAwayFromLeeks(Array<integer|real> entities) => integer;

