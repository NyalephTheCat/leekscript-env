 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Retorna o conteúdo de uma célula com id célula.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell O id da célula cujo conteúdo será retornado.
 * @return content O conteúdo da célula célula: @ref CELL_EMPTY para uma célula vazia, @ref CELL_ENTITY para uma
 *     entidade, @ref CELL_OBSTACLE para um obstáculo.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Retorna a distância entre duas células célula1 e célula2.
 *
 * A distância devolvida é expressa em número de células, e não tem em conta os vários
 * obstáculos entre as duas células.
 * Para obter a distância em linha reta, consulte @ref getDistance e para obter a distância do
 * caminho entre as duas células evitando obstáculos, consulte @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 O id da célula inicial.
 * @param[in] cell2 O id da célula de chegada.
 * @return distance A distância entre as duas células célula1 e célula2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Retorna o id da célula na posição (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x A posição x da célula.
 * @param[in] y A posição y da célula.
 * @return cell O id da célula na posição (x, y), nulo se a célula não existir.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Determina a posição em X da célula célula.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell A célula cuja posição em X será determinada.
 * @return x A posição X da célula.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Determina a posição Y da célula célula.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell A célula cuja posição em Y será determinada.
 * @return y A posição Y da célula.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Calcula a distância em voo de corvo entre duas células célula1 e célula2.
 *
 * Para obter a distância em número de células, consulte @ref getCellDistance, e para obter o
 * comprimento do caminho entre as duas células desviando dos vários obstáculos, consulte
 * @ref getPathLength.
 *
 * @deprecated Esta função está obsoleta. É substituído por @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 A célula inicial.
 * @param[in] cell2 A célula de chegada.
 * @return distance A distância em que o corvo voa entre as duas células.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Retorna a entidade que está na célula célula.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell A célula cuja entidade queremos recuperar.
 * @return entity O id da entidade na célula ou -1 se a célula não tiver nenhuma entidade.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Retorna a entidade que está na célula célula.
 *
 * @deprecated Esta função está obsoleta. É substituído por @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell A célula cuja entidade queremos recuperar.
 * @return entity O id da entidade na célula ou -1 se a célula não tiver nenhuma entidade.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Retorna o tipo de terreno em que ocorre a luta (fábrica, deserto, floresta etc.), dentre…
 *
 * as constantes @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_FOREST, @ref MAP_GLACIER e
 * @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType O tipo de terreno.
 */
function getMapType() => integer;

/**
 * @brief Retorna a lista de espaços de obstáculos no terreno.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles A matriz que contém os IDs das células de obstáculo.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Retorna o caminho evitando obstáculos entre duas células cell1 e cell2, caso exista, ignorando as células contidas no array ignoredCells.
 *
 * Se um jogador estiver em uma célula ignorada, o caminho pode passar por cima dele.
 * A célula inicial célula1 nunca faz parte do caminho resultante. A célula célula2 faz parte
 * do caminho resultante se e somente se estiver vazia ou for ignorada por ignoredCells.
 * Se não existir nenhum caminho entre as duas células, getPath retornará null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start A célula inicial.
 * @param[in] end A célula de chegada.
 * @param[in] ignoredCells (opcional) A matriz de células a serem ignoradas.
 * @return path A matriz que contém as células que compõem o caminho entre as duas células.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Retorna o comprimento do caminho entre duas células célula1 e célula2, evitando obstáculos, ignorando as células contidas no array ignoredCells.
 *
 * Esta função é equivalente a count(getPath(cell1, cell2, ignoredCells)).
 * Se um jogador estiver em uma célula ignorada, o caminho pode passar por cima dele.
 * A célula inicial célula1 nunca é contada no resultado. A célula célula2 é contada no
 * resultado se e somente se estiver vazia ou for ignorada por ignoredCells.
 * Se não existir nenhum caminho entre as duas células, getPathLength retornará nulo.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 A célula inicial.
 * @param[in] cell2 A célula de chegada.
 * @param[in] ignoredCells (opcional) A matriz de células a serem ignoradas.
 * @return length O comprimento do caminho entre célula1 e célula2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Determina se uma célula está vazia.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell A célula a ser testada.
 * @return empty true se a célula estiver vazia, false caso contrário.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Determina se o conteúdo da célula célula é uma entidade.
