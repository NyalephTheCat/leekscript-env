 * @return result Os valores de retorno de useChip são: @ref USE_CRITICAL, em acerto crítico; @ref USE_SUCCESS,
 *     se bem-sucedido; @ref USE_FAILED, em caso de falha; @ref USE_INVALID_TARGET, se o destino não
 *     existir; @ref USE_NOT_ENOUGH_TP, se sua entidade não tiver TP suficiente;
 *     @ref USE_INVALID_COOLDOWN, se o chip ainda não puder ser usado; @ref USE_INVALID_POSITION, se
 *     o alcance for ruim ou a linha de visão não estiver clara
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

