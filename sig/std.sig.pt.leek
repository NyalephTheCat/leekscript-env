function getCellToUseWeaponOnCell(integer|real weapon, integer|real cell, Array<integer> ignoredCells) => integer;
function getCellToUseWeaponOnCell(integer|real weapon, integer|real cell) => integer;

/**
 * @brief Retorna a lista de células a partir das quais sua entidade poderá usar o chip chip na entidade entity.
