 * @param[in] entity (opcjonalny) Identyfikator jednostki, której typ zostanie zwrócony.
 * @return type Typ jednostki podmiotu:@ref ENTITY_LEEK, jeśli jest to por.; @ref ENTITY_BULB, jeśli jest to
 *     „cebula”.
 */
function getType(integer|real entity) => integer;
function getType() => integer;

/**
 * @brief Zwraca aktualnie wyposażoną broń podmiot.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (opcjonalny) Identyfikator podmiotu, którego aktualna broń zostanie zwrócona.
 * @return weapon Identyfikator aktualnie wyposażonej broni w jednostce, null, jeśli jednostka nie ma
 *     wyposażonej broni lub jednostka nie istnieje.
 */
function getWeapon(integer|real entity) => integer;
function getWeapon() => integer;

/**
 * @brief Zwraca broń podmiotu o identyfikatorze entity.
 *
 * @category leek
 * @cost 50 ops
 *
 * @param[in] entity (opcjonalny) Identyfikator podmiotu, którego broń zostanie zwrócona.
 * @return weapon Tablica zawierająca identyfikatory broni entity.
 */
function getWeapons(integer|real entity) => Array<integer>;
function getWeapons() => Array<integer>;

/**
 * @brief Zwraca mądrość podmiotu o id entity.
 *
 * Użyj getWisdom() bez parametrów, aby odzyskać swoją mądrość.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (opcjonalny) Identyfikator podmiotu, którego mądrość zostanie zwrócona.
 * @return wisdom Mądrość identyfikatora jednostki entity.
 */
function getWisdom(integer|real entity) => integer;
function getWisdom() => integer;

/**
 * @brief Określa, czy podmiot żyje.
 *
 * Odpowiednik getLife(entity) > 0.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity Identyfikator jednostki do przetestowania.
 * @return alive prawda, jeśli podmiot żyje, fałsz, jeśli nie żyje.
 */
function isAlive(integer|real entity) => boolean;

/**
 * @brief Określa, czy podmiot jest twoim sojusznikiem.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity Identyfikator jednostki do przetestowania.
 * @return isAlly prawda, jeśli podmiot jest twoim sojusznikiem lub tobą, fałsz, jeśli jest wrogiem.
 */
function isAlly(integer|real entity) => boolean;

/**
 * @brief Określa, czy podmiot nie żyje.
 *
 * Odpowiednik getLife(entity) == 0.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity Identyfikator jednostki do przetestowania.
 * @return dead prawda, jeśli podmiot nie żyje, fałsz, jeśli żyje.
 */
function isDead(integer|real entity) => boolean;

/**
 * @brief Określa, czy podmiot jest twoim wrogiem.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity Identyfikator jednostki do przetestowania.
 * @return isEnemy prawda, jeśli podmiot jest wrogiem, fałsz, jeśli jest to sojusznik lub ty.
 */
function isEnemy(integer|real entity) => boolean;

/**
 * @brief Zwraca informację, czy obiekt jest statyczny, czy nie.
 *
 * Obiekt statyczny nie może się poruszać ani być przenoszony.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] entity (opcjonalny) Identyfikator jednostki do przetestowania.
 * @return static prawda, jeśli obiekt jest statyczny, fałsz w przeciwnym razie.
 */
function isStatic(integer|real entity) => boolean;
function isStatic() => boolean;

/**
 * @brief Zwraca czy encja jest wywołaniem czy nie.
 *
 * @category leek
 * @cost 10 ops
 *
 * @param[in] entity (opcjonalny) Identyfikator jednostki do przetestowania.
 * @return summon true, jeśli encja jest wywołaniem, false w przeciwnym razie.
 */
function isSummon(integer|real entity) => boolean;
function isSummon() => boolean;

/**
 * @brief Zwraca tablicę say() poprzednich jednostek w postaci [identyfikator_obiektu, komunikat].
 *
 * @category leek
 * @cost 78 ops
 *
 * @return messages Tablica poprzednich say().
 */
function listen() => Array;

/**
 * @brief Spraw, by Twoja jednostka przemówiła.
 *
 * @category leek
 * @cost 30 ops
 *
 * @param[in] message Wiadomość, którą twoja jednostka ogłosi na arenie.
 */
function say(string message) => void;

/**
 * @brief Wyposaż swój byt w broń.
 *
 * @category leek
 * @cost 15 ops
 *
 * @param[in] weapon Identyfikator broni do wyposażenia.
 */
function setWeapon(integer|real weapon) => void;

