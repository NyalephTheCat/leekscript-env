 *     wyzwaniem (@ref FIGHT_CONTEXT_CHALLENGE), Battle Royale (@ref FIGHT_CONTEXT_BATTLE_ROYALE)
 */
function getFightContext() => integer;

/**
 * @brief Zwraca bieżący identyfikator walki.
 *
 * @category fight
 * @cost 5 ops
 *
 * @return id Identyfikator bieżącej walki.
 */
function getFightID() => integer;

/**
 * @brief Zwraca bieżący typ walki.
 *
 * @category fight
 * @cost 10 ops
 *
 * @return fightType W zależności od rodzaju walki: walka solo (@ref FIGHT_TYPE_SOLO), walka farmera
 *     (@ref FIGHT_TYPE_FARMER), walka drużynowa (@ref FIGHT_TYPE_TEAM), Battle Royale
 *     (@ref FIGHT_TYPE_BATTLE_ROYALE)
 */
function getFightType() => integer;

/**
 * @brief Zwraca najbliższą przyjazną istotę twojej jednostce.
 *
 * @category fight
 * @cost 25 ops
 *
 * @return nearestAlly Identyfikator najbliższej przyjaznej jednostki.
 */
function getNearestAlly() => integer;

/**
 * @brief Zwraca najbliższą jednostkę pokrewną jednostce podanej jako parametr.
 *
 * @category fight
 * @cost 35 ops
 *
 * @param[in] entity Identyfikator podmiotu, którego najbliższego sojusznika chcemy poznać.
 * @return ally Identyfikator najbliższej przyjaznej jednostki.
 */
function getNearestAllyTo(integer|real entity) => integer;

/**
 * @brief Zwraca najbliższą sprzymierzoną jednostkę do komórki podanej jako parametr.
 *
 * @category fight
 * @cost 35 ops
 *
 * @param[in] cell Identyfikator komórki, której najbliższego sojusznika chcemy poznać.
 * @return ally Identyfikator najbliższej przyjaznej jednostki.
 */
function getNearestAllyToCell(integer|real cell) => integer;

/**
 * @brief Zwraca najbliższy wrogi byt do twojego bytu.
 *
 * @category fight
 * @cost 25 ops
 *
 * @return nearestEnemy Identyfikator najbliższego wrogiego podmiotu.
 */
function getNearestEnemy() => integer;

/**
 * @brief Zwraca najbliższą wrogą jednostkę jednostce podanej jako parametr.
 *
 * @category fight
 * @cost 35 ops
 *
 * @param[in] entity Identyfikator podmiotu, którego najbliższego wroga chcemy poznać.
 * @return enemy Identyfikator najbliższego wrogiego podmiotu.
 */
function getNearestEnemyTo(integer|real entity) => integer;

/**
 * @brief Zwraca najbliższą wrogą jednostkę do komórki podanej jako parametr.
 *
 * @category fight
 * @cost 35 ops
 *
 * @param[in] cell Identyfikator komórki, której najbliższego wroga chcemy poznać.
 * @return enemy Identyfikator najbliższego wrogiego podmiotu.
 */
function getNearestEnemyToCell(integer|real cell) => integer;

/**
 * @brief Zwraca identyfikator podmiotu, który będzie grał po bieżącym graczu.
 *
 * @category fight
 * @cost 20 ops
 *
 * @param[in] entity (opcjonalny)
 * @return player Następny gracz.
 */
function getNextPlayer(integer|real entity) => integer;
function getNextPlayer() => integer;

/**
 * @brief Zwraca identyfikator podmiotu, który grał przed bieżącym graczem.
 *
 * @category fight
 * @cost 20 ops
 *
 * @param[in] entity (opcjonalny)
 * @return player Poprzedni gracz.
 */
function getPreviousPlayer(integer|real entity) => integer;
function getPreviousPlayer() => integer;

/**
 * @brief Zwraca bieżącą turę walki.
 *
 * Maksymalna liczba tur to @ref MAX_TURNS.
 *
 * @category fight
 * @cost 15 ops
 *
 * @return turn Obecna tura walki.
 */
function getTurn() => integer;

/**
 * @brief Zwraca elementy, na które wpłynie to, jeśli broń broń zostanie użyta na komórce cell.
 *
 * @category fight
 * @cost 40 ops
 *
 * @param[in] weapon (opcjonalny) Broń do przetestowania.
 * @param[in] cell Komórka docelowa.
 * @return targets Tablica zawierająca identyfikatory wszystkich jednostek, których to dotyczy.
 */
function getWeaponTargets(integer|real weapon, integer|real cell) => Array<integer>;

/**
 * @brief Sprawdza linię wzroku między komórką początkową a komórką końcową, ignorując ignorowane elementy.
 *
 * @category fight
 * @cost 31 ops
 *
 * @param[in] start Komórka startowa.
 * @param[in] end Komórka docelowa.
 * @param[in] entityToIgnore (opcjonalny) Jednostka lub lista jednostek do zignorowania.
 * @return los Zwraca true, jeśli linia wzroku jest wolna.
 */
function lineOfSight(integer|real start, integer|real end, integer|real entityToIgnore) => boolean;
function lineOfSight(integer|real start, integer|real end) => boolean;

/**
 * @brief Odsuwa twój obiekt od innego obiektu, zużywając maksymalną liczbę mp punktów ruchu.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entity Podmiot, z którego Twój podmiot powinien się wycofać.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveAwayFrom(integer|real entity, integer|real mp) => integer;
function moveAwayFrom(integer|real entity) => integer;

/**
 * @brief Przesuwa twoją istotę o jedną komórkę komórkę dalej, zużywając maksymalnie mp punktów ruchu.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell Komórka, z której Twoja jednostka powinna się oddalić.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveAwayFromCell(integer|real cell, integer|real mp) => integer;
function moveAwayFromCell(integer|real cell) => integer;

/**
 * @brief Odsuwa twoją jednostkę od zestawu komórek komórek, używając maksymalnej liczby mp punktów ruchu.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cells Tablica zawierająca komórki, z których Twoja jednostka powinna się oddalić.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveAwayFromCells(Array<integer|real> cells, integer|real mp) => integer;
function moveAwayFromCells(Array<integer|real> cells) => integer;

/**
 * @brief Odsuwa twój obiekt od zestawu obiektów, wykorzystując maksymalną liczbę mp punktów ruchu.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities Tablica zawierająca identyfikatory podmiotów, od których podmiot powinien się odsunąć.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveAwayFromEntities(Array<integer> entities, integer|real mp) => integer;
function moveAwayFromEntities(Array<integer> entities) => integer;

/**
 * @brief Odsuwa twój obiekt od zestawu obiektów, wykorzystując maksymalną liczbę mp punktów ruchu.
 *
 * @deprecated Ta funkcja jest przestarzała. Zastępuje go @ref moveAwayFromEntities.
 * @sa moveAwayFromEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities Tablica zawierająca identyfikatory podmiotów, od których podmiot powinien się odsunąć.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveAwayFromLeeks(Array<integer|real> entities, integer|real mp) => integer;
function moveAwayFromLeeks(Array<integer|real> entities) => integer;

/**
 * @brief Odsuwa obiekt od linii zdefiniowanej przez dwie komórki cell1 i cell2, używając maksymalnie mp punktów ruchu.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 Komórka 1.
 * @param[in] cell2 Komórka 2.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveAwayFromLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveAwayFromLine(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Zbliża twój obiekt do innego obiektu, wykorzystując maksymalną liczbę mp punktów ruchu.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entity Jednostka, do której Twoja jednostka powinna się zwrócić.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveToward(integer|real entity, integer|real mp) => integer;
function moveToward(integer|real entity) => integer;

/**
 * @brief Przesuwa twoją jednostkę o jedną komórkę komórkę bliżej, używając maksymalnej liczby mp punktów ruchu.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell Komórka, do której powinien zbliżać się Twój obiekt.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveTowardCell(integer|real cell, integer|real mp) => integer;
function moveTowardCell(integer|real cell) => integer;

/**
 * @brief Przesuwa twoją jednostkę bliżej zestawu komórek komórek, używając maksymalnej liczby punktów ruchu mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cells Tablica zawierająca komórki, do których jednostka powinna się zbliżyć.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveTowardCells(Array<integer> cells, integer|real mp) => integer;
function moveTowardCells(Array<integer> cells) => integer;

/**
 * @brief Zbliża twój obiekt do zbioru obiektów, używając maksymalnej liczby mp punktów ruchu.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] entities Tablica zawierająca identyfikatory podmiotów, do których podmiot powinien się zbliżać.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveTowardEntities(Array<integer> entities, integer|real mp) => integer;
function moveTowardEntities(Array<integer> entities) => integer;

/**
 * @brief Zbliża twój obiekt do zbioru obiektów, używając maksymalnej liczby mp punktów ruchu.
 *
 * @deprecated Ta funkcja jest przestarzała. Zastępuje go @ref moveTowardEntities.
 * @sa moveTowardEntities
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] leeks Tablica zawierająca identyfikatory podmiotów, do których podmiot powinien się zbliżać.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveTowardLeeks(Array<integer> leeks, integer|real mp) => integer;
function moveTowardLeeks(Array<integer> leeks) => integer;

/**
 * @brief Zbliża obiekt do linii wyznaczonej przez dwie komórki cell1 i cell2, wykorzystując maksymalną liczbę punktów ruchu mp.
 *
 * @category fight
 * @cost 500 ops
 *
 * @param[in] cell1 Komórka 1.
 * @param[in] cell2 Komórka 2.
 * @param[in] mp (opcjonalny) Maksymalna liczba MP do wykorzystania. Domyślnie bez limitu.
 * @return mp Liczba wykorzystanych punktów ruchu.
 */
function moveTowardLine(integer|real cell1, integer|real cell2, integer|real mp) => integer;
function moveTowardLine(integer|real cell1, integer|real cell2) => integer;

// === utils ===

/**
 * @brief Usuwa wszystkie oznaczenia wykonane przez mark() i markText() w polu.
 *
 * @category utils
 * @cost 15 ops
 */
function clearMarks() => void;

/**
 * @brief Kopiuje wartość przekazaną jako parametr na poziomach poziom i zwraca kopię.
 *
 * Na przykład w przypadku tablicy klon(tablica, 1) skopiuje tablicę, ale nie jej elementy,
 * klon(tablica, 2) skopiuje tablicę, jak również wszystkie elementy.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] value Wartość do sklonowania
 * @param[in] level (opcjonalny) Liczba poziomów do sklonowania
 * @return copy Sklonowana wartość
 */
function clone(any value, integer|real level) => any;
function clone(any value) => any;

/**
 * @brief Zapisuje wiadomość obiektową w osobistym dzienniku, dostępną w raporcie po zakończeniu walki.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Wiadomość do nagrania.
 */
function debug(any object) => void;

/**
 * @brief Zapisuje wiadomość obiektową w osobistym dzienniku, dostępną w raporcie po zakończeniu walki, w kolorze kolor.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Wiadomość do nagrania.
 * @param[in] color Kolor wiadomości. Możesz użyć funkcji @ref getColor.
 */
function debugC(any object, integer|real color) => void;

/**
 * @brief Zapisuje komunikat o błędzie obiektu w osobistym dzienniku, dostępnym w raporcie po zakończeniu walki.
 *
 * Komunikaty o błędach pojawiają się w raporcie walki na czerwono.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Komunikat o błędzie do zarejestrowania.
 */
function debugE(any object) => void;

/**
 * @brief Zapisuje wiadomość ostrzegawczą o obiekcie w osobistym dzienniku, dostępną w raporcie po zakończeniu walki.
 *
 * Komunikaty ostrzegawcze pojawiają się w raporcie bojowym na pomarańczowo.
 *
 * @category utils
 * @cost 100 ops
 *
 * @param[in] object Komunikat ostrzegawczy do zapisania.
 */
function debugW(any object) => void;

/**
 * @brief Usuwa rejestr powiązany z kluczem kluczem, jeśli istnieje.
 *
 * @category utils
 * @cost 16 ops
 *
 * @param[in] key Klucz rejestru do usunięcia.
 */
function deleteRegister(string key) => void;

/**
 * @brief Zwraca datę walki w formacie dd/MM/rrrr.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return date Data walki.
 */
function getDate() => string;

/**
 * @brief Zwraca liczbę instrukcji, które Twoja jednostka wykonała w bieżącej turze.
 *
 * @deprecated Ta funkcja jest przestarzała. Zastępuje go @ref getOperations.
 * @sa getOperations
 *
 * @category utils
 * @cost 15 ops
 *
 * @return instructions Liczba instrukcji, które Twoja jednostka wykonała w bieżącej turze.
 */
function getInstructionsCount() => integer;

/**
 * @brief (No `func_getMaxOperations` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations
 */
function getMaxOperations() => integer;

/**
 * @brief Zwraca użyteczny limit pamięci RAM twojej sztucznej inteligencji.
 *
 * Pamięć RAM jest zużywana na tworzenie list, tabel i obiektów.
 * Bieżący limit wynosi 100 megabajtów lub 12 500 000 elementów listy.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getMaxRAM() => integer;

/**
 * @brief Zwraca liczbę operacji wykorzystanych przez twoją jednostkę od początku jej tury.
 *
 * Ta liczba musi być mniejsza niż @ref OPERATIONS_LIMIT, aby jednostka nie uległa awarii.
 *
 * @category utils
 * @cost 1 op
 *
 * @return operations Liczba operacji wykorzystanych przez twoją jednostkę od początku jej tury.
 */
function getOperations() => integer;

/**
 * @brief Zwraca wartość przechowywaną w rejestrze jednostek powiązanym z kluczem klucz lub null, jeśli rejestr nie istnieje.
 *
 * @category utils
 * @cost 15 ops
 *
 * @param[in] key Klucz rejestru, którego wartość zostanie zwrócona.
 * @return value Wartość przechowywana w rejestrze kluczy.
 */
function getRegister(string key) => string;

/**
 * @brief Zwraca zestaw rejestrów jednostek jako tablicę asocjacyjną [klucz rejestru:wartość rejestru].
 *
 * Przykład: debug(getRegisters());
 * // Wyświetla na przykład:
 * // ['reg1': '314323', 'reg2': 'test_string']
 *
 * @category utils
 * @cost 25 ops
 *
 * @return registers Tablica asocjacyjna odpowiadająca wszystkim rejestrom jednostki.
 */
function getRegisters() => Array<string>;

/**
 * @brief Zwraca czas bitwy w formacie HH:mm:ss.
 *
 * @category utils
 * @cost 50 ops
 *
 * @return time Czas walki.
 */
function getTime() => string;

/**
 * @brief Zwraca znacznik czasu walki równy liczbie sekund od 1 stycznia 1970 r.
 *
 * @category utils
 * @cost 5 ops
 *
 * @return timestamp Znacznik czasu walki.
 */
function getTimestamp() => integer;

/**
 * @brief Zwraca ilość pamięci RAM aktualnie używanej przez twoją sztuczną inteligencję.
 *
 * @category utils
 * @cost 1 op
 *
 * @return ram
 */
function getUsedRAM() => integer;

/**
 * @brief Dołącz sztuczną inteligencję o nazwie ai do bieżącej sztucznej inteligencji.
 *
 * Uwaga, funkcja include musi być wywołana tylko w bloku głównym, a jej parametr musi być
 * napisem zapisanym bezpośrednio
 * w kodzie. Aby uzyskać więcej informacji, zobacz sekcję samouczka:
 * http://leekwars.com/help/tutorial#includes .
 *
 * @category utils
 * @cost 1 op
 *
 * @param[in] ai Nazwa sztucznej inteligencji do uwzględnienia.
 */
function include(string ai) => void;

/**
 * @brief Dekoduje łańcuch json do obiektu LeekScript (liczba, łańcuch, tablica...).
 *
 * @category utils
 * @cost O(n)
 *
 * @param[in] json Ciąg JSON do zdekodowania.
 * @return object Zdekodowany obiekt LeekScript.
 */
function jsonDecode(string json) => any;

/**
 * @brief Koduje obiekt object w łańcuch JSON.
 *
 * @category utils
 * @cost ∞
 *
 * @param[in] object Obiekt do zakodowania w formacie JSON.
 * @return json Ciąg zakodowany w formacie JSON.
 */
function jsonEncode(string object) => string;

/**
 * @brief Zaznacza jedną lub więcej komórek koloru wskazanego w parametrze na ziemi przez liczbę obrotów wskazaną w parametrze.
 *
 * To oznaczenie jest widoczne tylko dla hodowcy jednostki.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Komórka lub tablica wielu komórek do oznaczenia
 * @param[in] color (opcjonalny) Kolor oznaczenia
 * @param[in] duration (opcjonalny) Czas trwania znakowania
 * @return success Zwraca true, jeśli wszystko poszło dobrze
 */
function mark(any cells, integer|real color, integer|real duration) => boolean;
function mark(any cells, integer|real color) => boolean;
function mark(any cells) => boolean;

/**
 * @brief Zapisuje tekst na jednej lub kilku komórkach koloru wskazanego w parametrze na ziemi przez liczbę zwojów wskazaną w parametrze.
 *
 * Te teksty są widoczne tylko dla hodowcy jednostki.
 *
 * @category utils
 * @cost 164 ops
 *
 * @param[in] cells Komórka lub tablica wielu komórek do zapisu
 * @param[in] text (opcjonalny) Tekst do wpisania (maksymalnie 10 znaków)
 * @param[in] color (opcjonalny) Kolor tekstu
 * @param[in] duration (opcjonalny) Czas trwania tekstu
 * @return success Zwraca true, jeśli wszystko poszło dobrze
 */
function markText(any cells, string text, integer|real color, integer|real duration) => boolean;
function markText(any cells, string text, integer|real color) => boolean;
function markText(any cells, string text) => boolean;
function markText(any cells) => boolean;

/**
 * @brief Wstrzymuje walkę, tylko dla hodowcy podmiotu korzystającego z funkcji.
 *
 * @category utils
 * @cost 30 ops
 */
function pause() => void;

/**
 * @brief Przechowuje wartość w rejestrze kluczy.
 *
 * Klucz i wartość to ciągi znaków, które muszą zawierać maksymalnie odpowiednio 100 i 5000
 * znaków. Por może mieć maksymalnie 100 rejestrów, zapisanie w nowym rejestrze nie będzie
 * działać, jeśli wszystkie rejestry
 * są już zajęci.
 *
 * @category utils
 * @cost 50 ops
 *
 * @param[in] key Klucz rejestru, w którym ma być przechowywana wartość.
 * @param[in] value Wartość do przechowywania.
 * @return success true, jeśli operacja się powiodła, false w przeciwnym razie.
 */
function setRegister(string key, string value) => boolean;

/**
 * @brief Pokazuje graczom komórkę koloru kolor na polu przez 1 turę.
 *
 * Korzystanie z tej funkcji kosztuje 1PT.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] cell Komórka do pokazania
 * @param[in] color (opcjonalny) Kolor oznaczenia
 */
function show(integer|real cell, integer|real color) => void;
function show(integer|real cell) => void;

/**
 * @brief Zwraca typ wartości wartość spośród typów: @ref TYPE_NULL, @ref TYPE_NUMBER, @ref TYPE_BOOLEAN,…
 *
 * @ref TYPE_STRING, @ref TYPE_ARRAY, @ref TYPE_FUNCTION.
 *
 * @category utils
 * @cost 8 ops
 *
 * @param[in] value Wartość, której typ zostanie zwrócony.
 * @return type Typ wartości.
 */
function typeOf(any value) => integer;

// === network ===

/**
 * @brief Zwraca identyfikator podmiotu będącego autorem wiadomości message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Wiadomość, której autor zostanie zwrócony.
 * @return entity Identyfikator podmiotu tworzącego wiadomość message.
 */
function getMessageAuthor(Array message) => integer;

/**
 * @brief Zwraca tablicę parametrów komunikatu message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Wiadomość, której parametry zostaną zwrócone.
 * @return params Parametry wiadomości message.
 */
function getMessageParams(Array message) => any;

/**
 * @brief Zwraca typ wiadomości message.
 *
 * @category network
 * @cost 5 ops
 *
 * @param[in] message Wiadomość, której typ zostanie zwrócony (między @ref MESSAGE_HEAL, @ref MESSAGE_ATTACK itp.).
 * @return type Typ wiadomości wiadomość.
 */
function getMessageType(Array message) => integer;

/**
 * @brief Zwraca tablicę komunikatów encji entity.
 *
 * @category network
 * @cost O(n)
 *
 * @param[in] entity (opcjonalny) Jednostka, której komunikaty zostaną zwrócone.
 * @return messages Tabela Twoich wiadomości. Wiadomość jest reprezentowana w formie a tablica postaci:
 *     [autor, typ, parametry] Różne typy komunikatów są reprezentowane przez stałe:
 *     @ref MESSAGE_HEAL: prośba o opiekę; @ref MESSAGE_ATTACK: prośba o atak; @ref MESSAGE_BUFF_FORCE:
 *     wymuś żądanie przyspieszenia; ...
 */
function getMessages(integer|real entity) => Array<Array>;
function getMessages() => Array<Array>;

/**
 * @brief Wyślij wiadomość do całego zespołu.
 *
 * @category network
 * @cost 40 ops
 *
 * @param[in] type Typ wiadomości do wysłania (zobacz stałe MESSAGE_*).
 * @param[in] params Parametry komunikatu, które mogą mieć dowolną wartość.
 */
function sendAll(integer|real type, any params) => void;

/**
 * @brief Wysyła wiadomość do podmiotu o identyfikatorze entity.
 *
 * @category network
 * @cost 15 ops
 *
 * @param[in] entity Identyfikator podmiotu, do którego zostanie wysłana wiadomość.
 * @param[in] type Typ wiadomości do wysłania (zobacz stałe MESSAGE_*).
 * @param[in] params Parametry komunikatu, które mogą mieć dowolną wartość.
 * @return sent true, jeśli wysłanie się powiodło, false, jeśli wystąpił błąd.
 */
function sendTo(integer|real entity, integer|real type, any params) => boolean;

// === color ===

/**
 * @brief Zwraca ilość koloru niebieskiego w kolorze kolor z przedziału od 0 do 255.
 *
 * Na przykład getBlue(@ref COLOR_BLUE) = 255 i getBlue(@ref COLOR_GREEN) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Kolor, którego niebieska stawka zostanie zwrócona.
 * @return blue Stopień nasycenia koloru niebieskiego w kolorze color
 */
function getBlue(integer|real color) => integer;

/**
 * @brief Zwraca liczbę całkowitą odpowiadającą kolorowi (czerwony, zielony, niebieski) podanym jako parametry.
 *
 * @category color
 * @cost 15 ops
 *
 * @param[in] red Czerwona wartość między 0 a 255.
 * @param[in] green Zielona wartość od 0 do 255.
 * @param[in] blue Niebieska wartość między 0 a 255.
 * @return color int odpowiadający kolorowi podanemu jako parametr.
 */
function getColor(integer|real red, integer|real green, integer|real blue) => integer;

/**
 * @brief Zwraca ilość koloru zielonego w kolorze kolor z przedziału od 0 do 255.
 *
 * Na przykład getGreen(@ref COLOR_GREEN) = 255 i getGreen(@ref COLOR_RED) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Kolor, którego zielona stawka zostanie zwrócona.
 * @return green Szybkość koloru zielonego w kolorze color
 */
function getGreen(integer|real color) => integer;

/**
 * @brief Zwraca ilość czerwieni w kolorze kolor z przedziału od 0 do 255.
 *
 * Na przykład getRed(@ref COLOR_RED) = 255 i getRed(@ref COLOR_BLUE) = 0.
 *
 * @category color
 * @cost 10 ops
 *
 * @param[in] color Kolor, którego czerwona stawka zostanie zwrócona.
 * @return red Współczynnik czerwieni w kolorze
 */
function getRed(integer|real color) => integer;

// === set ===

/**
 * @brief Czyści set.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return set
 */
function setClear(Set set) => Set;

/**
 * @brief Wyszukuje element element w zbiorze set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return contains
 */
function setContains(Set set, any element) => boolean;

/**
 * @brief Zwraca różnicę między zbiorami zestaw1 i zestaw2, tj.
 *
 * wszystkie elementy zestaw1, które nie znajdują się w zestaw2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return difference
 */
function setDifference(Set set1, Set set2) => Set;

/**
 * @brief Oblicza wyłączną dysjunkcję dwóch zbiorów zestaw1 i zestaw2, z notacją zestaw1 ⊕zestaw2,…
 *
 * które są elementami obecnymi w zestaw1 lub zestaw2, ale nie w obu jednocześnie.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return disjunction
 */
function setDisjunction(Set set1, Set set2) => Set;

/**
 * @brief Oblicza przecięcie dwóch zbiorów zestaw1 i zestaw2, z notacją zestaw1 ∩zestaw2, które są…
 *
 * wspólnymi elementami tych dwóch zbiorów.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return intersection
 */
function setIntersection(Set set1, Set set2) => Set;

/**
 * @brief Zwraca, czy zestaw jest pusty, czy nie.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @return empty
 */
function setIsEmpty(Set set) => boolean;

/**
 * @brief Określa, czy zbiór zestaw1 jest podzbiorem zestaw2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return subset
 */
function setIsSubsetOf(Set set1, Set set2) => boolean;

/**
 * @brief Wstawia element element do zbioru set.
 *
 * @category set
 * @cost 3 ops
 *
 * @param[in] set
 * @param[in] element
 * @return added
 */
function setPut(Set set, any element) => boolean;

/**
 * @brief Usuwa element element ze zbioru set.
 *
 * @category set
 * @cost 2 ops
 *
 * @param[in] set
 * @param[in] element
 * @return existed
 */
function setRemove(Set set, any element) => boolean;

/**
 * @brief Zwraca rozmiar zestawu.
 *
 * @category set
 * @cost 1 op
 *
 * @param[in] set
 * @return size
 */
function setSize(Set set) => integer;

/**
 * @brief Zwraca listę zawierającą wszystkie elementy zbioru set.
 *
 * Kolejność elementów jest dowolna.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set
 * @return array
 */
function setToArray(Set set) => Array;

/**
 * @brief Oblicza unię dwóch zbiorów zestaw1 i zestaw2, oznaczoną jako zestaw1 ∪zestaw2, która…
 *
 * zawiera wszystkie elementy obecne w zestaw1 lub w zestaw2.
 *
 * @category set
 * @cost O(n)
 *
 * @param[in] set1
 * @param[in] set2
 * @return union
 */
function setUnion(Set set1, Set set2) => Set;

// === interval ===

/**
 * @brief Oblicza średnią interwałową.
 *
 * - Jeśli przedział jest ograniczony z lewej i prawej strony, zwraca (intervalMin(i) +
 * intervalMax(i)) / 2. - Jeśli przedział jest ograniczony tylko z lewej strony, zwraca +∞. -
 * Jeśli przedział jest ograniczony tylko z prawej strony, zwraca -∞. - Jeśli przedział jest
 * nieograniczony lub pusty, zwraca NaN.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval
 * @return average
 */
function intervalAverage(Interval interval) => real;

/**
 * @brief Łączy dwa interwały interval1 i interval2.
 *
 * Równoważne z union, jeśli ich przecięcie jest niepuste, w przeciwnym razie obejmuje
 * również zbiór pomiędzy nimi.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return combination
 */
function intervalCombine(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Oblicza przecięcie dwóch przedziałów interval1 i interval2, zawierające elementy wspólne dla obu.
 *
 * @category interval
 * @cost 3 ops
 *
 * @param[in] interval1
 * @param[in] interval2
 * @return intersection
 */
function intervalIntersection(Interval interval1, Interval interval2) => Interval;

/**
 * @brief Zwraca, czy przedział interval jest ograniczony z lewej i prawej strony, czy nie.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsBounded(Interval interval) => boolean;

/**
 * @brief Zwraca, czy interwał interval jest zamknięty z lewej i prawej strony, czy nie.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsClosed(Interval interval) => boolean;

/**
 * @brief Zwraca, czy interval jest pusty.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return empty
 */
function intervalIsEmpty(Interval interval) => boolean;

/**
 * @brief Zwraca, czy interwał interval jest lewostronnie ograniczony, czy nie.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsLeftBounded(Interval interval) => boolean;

/**
 * @brief Zwraca, czy interval jest zamknięty po lewej stronie.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsLeftClosed(Interval interval) => boolean;

/**
 * @brief Zwraca, czy przedział interval jest prawostronnie ograniczony, czy nie.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return bounded
 */
function intervalIsRightBounded(Interval interval) => boolean;

/**
 * @brief Zwraca, czy interwał interval jest zamknięty z prawej strony, czy nie.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return closed
 */
function intervalIsRightClosed(Interval interval) => boolean;

/**
 * @brief Zwraca górną granicę przedziału interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return max
 */
function intervalMax(Interval interval) => integer|real;

/**
 * @brief Zwraca dolną granicę przedziału interval.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return min
 */
function intervalMin(Interval interval) => integer|real;

/**
 * @brief Zwraca rozmiar przedziału interval.
 *
 * - Jeśli przedział jest ograniczony, zwraca max - min. - Jeśli przedział nie jest
 * ograniczony, zwraca +∞. - Jeśli przedział jest pusty, zwraca 0.
 *
 * @category interval
 * @cost 1 op
 *
 * @param[in] interval
 * @return size
 */
function intervalSize(Interval interval) => integer|real;

/**
 * @brief Zwraca listę zawierającą elementy przedziału interval wraz z odległością step między każdym z nich.
 *
 * Jeśli interwał jest ujemny, pobiera elementy w odwrotnej kolejności.
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @param[in] step (opcjonalny)
 * @return array
 */
function intervalToArray(Interval interval, integer|real step) => Array;
function intervalToArray(Interval interval) => Array;

/**
 * @brief (No `func_intervalToSet` in doc lang — add an entry to match the client Documentation tab.)
 *
 * @category interval
 * @cost O(n)
 *
 * @param[in] interval
 * @return set
 */
function intervalToSet(Interval interval) => Set;
