/**
 * @brief Wywołuje jednostkę określoną przez chip chip w komórce cell mającej dla IA funkcję ai.
 *
 * @category chip
 * @cost 1750 ops
 *
 * @param[in] chip Chip używany do przywoływania. Chip musi być chipem typu summon i musi być wyposażony
 *     w jednostkę korzystającą z funkcji summon.
 * @param[in] cell Powinna pojawić się komórka lub wezwanie.
 * @param[in] ai Inwokacja AI, jako funkcja.
 * @param[in] name (opcjonalny)
 * @return return Funkcja summon daje taki sam zwrot jak funkcja @ref useChip.
 */
function summon(integer|real chip, integer|real cell, Function ai, string name) => integer;
function summon(integer|real chip, integer|real cell, Function ai) => integer;

/**
 * @brief Użyj chipa chip na elemencie entity.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip do wykorzystania.
 * @param[in] entity (opcjonalny) Jednostka docelowa.
 * @return result Wartości zwracane przez useChip to: @ref USE_CRITICAL, przy trafieniu krytycznym;
 *     @ref USE_SUCCESS, jeśli się powiedzie; @ref USE_FAILED, w przypadku awarii;
 *     @ref USE_INVALID_TARGET, jeśli cel nie istnieje; @ref USE_NOT_ENOUGH_TP, jeśli Twoja jednostka
 *     nie ma wystarczającej liczby TP; @ref USE_INVALID_COOLDOWN, jeśli chip nie nadaje się
 *     jeszcze do użytku; @ref USE_INVALID_POSITION, jeśli zasięg jest zły lub linia wzroku nie
 *     jest wyraźna
 */
function useChip(integer|real chip, integer|real entity) => integer;
function useChip(integer|real chip) => integer;

/**
 * @brief Użyj chipa chip na komórce cell.
 *
 * @category chip
 * @cost 3000 ops
 *
 * @param[in] chip Chip do wykorzystania.
 * @param[in] cell Komórka docelowa.
 * @return result Wartość większa niż 0, jeśli atak został rozpoczęty.
 */
function useChipOnCell(integer|real chip, integer|real cell) => integer;

// === field ===

/**
 * @brief Zwraca zawartość komórki o identyfikatorze cell.
 *
 * @category field
 * @cost 6 ops
 *
 * @param[in] cell Identyfikator komórki, której zawartość zostanie zwrócona.
 * @return content Zawartość komórki cell: @ref CELL_EMPTY dla pustej komórki, @ref CELL_ENTITY dla jednostki,
 *     @ref CELL_OBSTACLE dla przeszkody.
 */
function getCellContent(integer|real cell) => integer;

/**
 * @brief Zwraca odległość między dwiema komórkami cell1 i cell2.
 *
 * Zwrócona odległość jest wyrażona w liczbie komórek i nie uwzględnia różnych przeszkód
 * między dwiema komórkami.
 * Aby uzyskać odległość w linii prostej, zobacz @ref getDistance i aby uzyskać odległość ścieżki
 * między dwiema komórkami unikając przeszkód, zobacz @ref getPathLength.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Identyfikator komórki początkowej.
 * @param[in] cell2 Identyfikator komórki przybycia.
 * @return distance Odległość między dwiema komórkami cell1 i cell2.
 */
function getCellDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Zwraca identyfikator komórki na pozycji (x, y).
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] x Pozycja x komórki.
 * @param[in] y Pozycja y komórki.
 * @return cell Identyfikator komórki na pozycji (x, y), null, jeśli komórka nie istnieje.
 */
function getCellFromXY(integer|real x, integer|real y) => integer;

/**
 * @brief Określa pozycję w X komórki cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Komórka, której pozycja w X zostanie określona.
 * @return x Pozycja X komórki.
 */
function getCellX(integer|real cell) => integer;

/**
 * @brief Określa pozycję Y komórki cell.
 *
 * @category field
 * @cost 5 ops
 *
 * @param[in] cell Komórka, której pozycja w Y zostanie określona.
 * @return y Pozycja Y komórki.
 */
function getCellY(integer|real cell) => integer;

/**
 * @brief Oblicza odległość w linii prostej między dwiema komórkami cell1 i cell2.
 *
 * Aby uzyskać odległość wyrażoną w liczbie komórek, zobacz @ref getCellDistance, a aby uzyskać
 * długość ścieżki między dwiema komórkami omijającymi różne przeszkody, zobacz
 * @ref getPathLength.
 *
 * @deprecated Ta funkcja jest przestarzała. Zastępuje go @ref getCellDistance.
 * @sa getCellDistance
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Komórka startowa.
 * @param[in] cell2 Cela przybycia.
 * @return distance Odległość w linii prostej między dwiema komórkami.
 */
function getDistance(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Zwraca jednostkę znajdującą się w komórce cell.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Komórka, której obiekt chcemy pobrać.
 * @return entity Identyfikator jednostki w komórce lub -1, jeśli komórka nie ma jednostki.
 */
function getEntityOnCell(integer|real cell) => integer;

/**
 * @brief Zwraca jednostkę znajdującą się w komórce cell.
 *
 * @deprecated Ta funkcja jest przestarzała. Zastępuje go @ref getEntityOnCell.
 * @sa getEntityOnCell
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell Komórka, której obiekt chcemy pobrać.
 * @return entity Identyfikator jednostki w komórce lub -1, jeśli komórka nie ma jednostki.
 */
function getLeekOnCell(integer|real cell) => integer;

/**
 * @brief Zwraca rodzaj terenu, na którym toczy się walka (fabryka, pustynia, las itp.), wśród…
 *
 * stałych @ref MAP_NEXUS, @ref MAP_FACTORY, @ref MAP_DESERT, @ref MAP_LAS, @ref MAP_GLACIER i @ref MAP_BEACH.
 *
 * @category field
 * @cost 5 ops
 *
 * @return mapType Rodzaj terenu.
 */
function getMapType() => integer;

/**
 * @brief Zwraca listę pól przeszkód w terenie.
 *
 * @category field
 * @cost 85 ops
 *
 * @return obstacles Tablica zawierająca identyfikatory komórek przeszkód.
 */
function getObstacles() => Array<integer>;

/**
 * @brief Zwraca ścieżkę omijającą przeszkody między dwiema komórkami cell1 i cell2, jeśli istnieje, ignorując komórki zawarte w tablicy ignoredCells.
 *
 * Jeśli gracz znajduje się w ignorowanej komórce, ścieżka może go ominąć.
 * Komórka początkowa cell1 nigdy nie jest częścią ścieżki wynikowej. Komórka cell2 jest
 * częścią ścieżki wynikowej wtedy i tylko wtedy, gdy jest pusta lub ignorowana przez
 * ignoredCells.
 * Jeśli między dwiema komórkami nie ma ścieżki, getPath zwraca wartość null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] start Komórka startowa.
 * @param[in] end Cela przybycia.
 * @param[in] ignoredCells (opcjonalny) Tablica komórek do zignorowania.
 * @return path Tablica zawierająca komórki tworzące ścieżkę między dwiema komórkami.
 */
function getPath(integer|real start, integer|real end, Array<integer> ignoredCells) => Array<integer>;
function getPath(integer|real start, integer|real end) => Array<integer>;

/**
 * @brief Zwraca długość ścieżki między dwiema komórkami cell1 i cell2, omijając przeszkody, ignorując komórki zawarte w tablicy ignoredCells.
 *
 * Ta funkcja jest równoważna funkcji count(getPath(cell1, cell2, ignoredCells)).
 * Jeśli gracz znajduje się w ignorowanej komórce, ścieżka może go ominąć.
 * Komórka początkowa cell1 nigdy nie jest wliczana do wyniku. Komórka cell2 jest liczona w
 * wyniku wtedy i tylko wtedy, gdy jest pusta lub ignorowana przez ignoredCells.
 * Jeśli między dwiema komórkami nie ma ścieżki, getPathLength zwraca wartość null.
 *
 * @category field
 * @cost O(n²)
 *
 * @param[in] cell1 Komórka startowa.
 * @param[in] cell2 Cela przybycia.
 * @param[in] ignoredCells (opcjonalny) Tablica komórek do zignorowania.
 * @return length Długość ścieżki między komórką1 a komórką2.
 */
function getPathLength(integer|real cell1, integer|real cell2, Array<integer> ignoredCells) => integer;
function getPathLength(integer|real cell1, integer|real cell2) => integer;

/**
 * @brief Określa, czy komórka jest pusta.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Komórka do przetestowania.
 * @return empty true, jeśli komórka jest pusta, false w przeciwnym razie.
 */
function isEmptyCell(integer|real cell) => boolean;

/**
 * @brief Określa, czy zawartość komórki cell jest jednostką.
 *
 * @category field
 * @cost 1 op
 *
 * @param[in] cell Komórka do przetestowania.
 * @return isEntity true, jeśli komórka zawiera jednostkę, false w przeciwnym razie.
 */
function isEntity(integer|real cell) => boolean;

/**
 * @brief Określa, czy zawartość komórki cell jest jednostką.
 *
 * @deprecated Ta funkcja jest przestarzała. Zastępuje go @ref isEntity.
 * @sa isEntity
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Komórka do przetestowania.
 * @return isLeek true, jeśli komórka zawiera jednostkę, false w przeciwnym razie.
 */
function isLeek(integer|real cell) => boolean;

/**
 * @brief Określa, czy zawartość komórki cell jest przeszkodą.
 *
 * @category field
 * @cost 10 ops
 *
 * @param[in] cell Komórka do przetestowania.
 * @return isObstacle true, jeśli komórka zawiera przeszkodę, false w przeciwnym razie.
 */
function isObstacle(integer|real cell) => boolean;

/**
 * @brief Określa, czy dwie komórki cell1 i cell2 znajdują się w tej samej linii.
 *
 * @category field
 * @cost 15 ops
 *
 * @param[in] cell1 Pierwsza komórka.
 * @param[in] cell2 Druga komórka.
 * @return sameLine prawda, jeśli dwie komórki znajdują się w tej samej linii, fałsz w przeciwnym razie.
 */
function isOnSameLine(integer|real cell1, integer|real cell2) => boolean;

